<style>
  html,body,#root{height:100%}
  body{background:#fbf7f3;color:#2b2a27;font-family:Inter,system-ui,sans-serif}
  .font-display{font-family:'DM Serif Display',Georgia,serif}
  /* ── Dark mode palette ── automatically inverts surfaces & text */
  html.dark body { background:#171513; color:#e7e4df; }
  html.dark .bg-white { background-color:#23201d !important; }
  html.dark .bg-stone-50 { background-color:#1d1b18 !important; }
  html.dark .bg-stone-100 { background-color:#2a2724 !important; }
  html.dark .bg-stone-200 { background-color:#34302c !important; }
  html.dark .bg-brand-50 { background-color:#3a2419 !important; }
  html.dark .bg-brand-50\/40, html.dark .bg-brand-50\/30 { background-color:#2c1d15 !important; }
  html.dark .from-brand-50, html.dark .from-brand-100 { --tw-gradient-from:#3a2419 var(--tw-gradient-from-position); }
  html.dark .to-white, html.dark .via-white { --tw-gradient-to:#23201d var(--tw-gradient-to-position); }
  html.dark .border-stone-100, html.dark .border-stone-200, html.dark .border-stone-300 { border-color:#3a3631 !important; }
  html.dark .text-stone-500 { color:#a8a29e !important; }
  html.dark .text-stone-600 { color:#c4bfb7 !important; }
  html.dark .text-stone-700, html.dark .text-stone-800, html.dark .text-stone-900 { color:#e7e4df !important; }
  html.dark .text-stone-400 { color:#8a8580 !important; }
  html.dark .text-stone-300 { color:#5e5a55 !important; }
  html.dark input, html.dark textarea, html.dark select { background:#1d1b18 !important; color:#e7e4df !important; border-color:#3a3631 !important; }
  html.dark .shadow-lg, html.dark .shadow-2xl, html.dark .shadow { box-shadow:0 4px 20px rgba(0,0,0,0.4) !important; }
  /* Amber/red/leaf badge backgrounds keep their hue but get a darker base */
  html.dark .bg-amber-50, html.dark .bg-amber-50\/30, html.dark .bg-amber-50\/50 { background-color:#3a2810 !important; }
  html.dark .bg-red-50,   html.dark .bg-red-50\/50   { background-color:#3a1818 !important; }
  html.dark .bg-leaf-500\/5, html.dark .bg-leaf-500\/10 { background-color:#1b2c14 !important; }
  html.dark .bg-leaf-100 { background-color:#1f3819 !important; color:#9bcd7a !important; }
  /* "Have" / "low" tiny pills */
  html.dark .bg-blue-100 { background-color:#13284a !important; color:#9bb6e1 !important; }
  html.dark .bg-red-100  { background-color:#3a1818 !important; color:#f0a0a0 !important; }
  ::-webkit-scrollbar{width:10px;height:10px}
  ::-webkit-scrollbar-thumb{background:#e8dfd5;border-radius:6px}
  ::-webkit-scrollbar-thumb:hover{background:#d4c6b5}
  .fade-in{animation:fade .25s ease-out}
  @keyframes fade{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}
  .shimmer{background:linear-gradient(90deg,#f4ebe1 0%,#faf4ec 50%,#f4ebe1 100%);background-size:200% 100%;animation:shim 1.2s linear infinite}
  @keyframes shim{to{background-position:-200% 0}}
  .card-hover{transition:transform .15s ease, box-shadow .15s ease}
  .card-hover:hover{transform:translateY(-2px);box-shadow:0 10px 24px -12px rgba(60,40,20,.18)}
  details>summary{list-style:none;cursor:pointer}
  details>summary::-webkit-details-marker{display:none}
  input[type=range]{accent-color:#c96b4a}
  .stepdone{text-decoration:line-through;color:#9a8f84}
  .map-container { height: 320px; width: 100%; border-radius: 12px; }
  .leaflet-container { font-family: Inter, sans-serif; }
  .scan-overlay { position:absolute; inset:0; pointer-events:none; border:2px solid #c96b4a; border-radius:12px; box-shadow: 0 0 0 9999px rgba(0,0,0,0.4) inset; }
  .scan-overlay::before { content:''; position:absolute; top:50%; left:10%; right:10%; height:2px; background:linear-gradient(90deg,transparent,#c96b4a,transparent); animation: scanline 2s infinite; }
  @keyframes scanline { 0%,100%{top:30%} 50%{top:70%} }

  /* ── Mobile / iPhone enhancements ─────────────────────────────────── */
  /* Instant tap response — no 300ms delay on iOS */
  button,[role="button"]{touch-action:manipulation;-webkit-tap-highlight-color:transparent}
  /* Prevent iOS Safari from auto-zooming on input focus (needs font-size ≥ 16px) */
  input:not([type=range]):not([type=checkbox]):not([type=radio]),
  select,textarea{font-size:max(16px,0.875rem)!important}
  /* iPhone home-indicator safe area for the fixed bottom nav */
  .ka-bottom-nav{padding-bottom:env(safe-area-inset-bottom,0px)}
  /* Main content clears the bottom nav + home indicator */
  .ka-content{padding-bottom:max(6rem,calc(5rem + env(safe-area-inset-bottom,0px)))}
  /* Smooth momentum scrolling on iOS */
  .overflow-y-auto,main{-webkit-overflow-scrolling:touch}
  /* Hide scrollbar on horizontal chip strips (Pantry tabs, etc.) */
  .ka-no-scrollbar{scrollbar-width:none;-ms-overflow-style:none}
  .ka-no-scrollbar::-webkit-scrollbar{display:none;width:0;height:0}
  /* Slightly higher-contrast muted text (raise stone-400 → effective 500) */
  .text-stone-400.ka-readable, .ka-readable .text-stone-400 { color:#78716c !important; }
  /* Visible keyboard focus ring everywhere — was inconsistent */
  button:focus-visible, a:focus-visible, [role="button"]:focus-visible,
  input:focus-visible, select:focus-visible, textarea:focus-visible {
    outline:2px solid #c96b4a; outline-offset:2px; border-radius:6px;
  }
  /* ── Print stylesheet: shopping list only ─────────────────────────── */
  @media print {
    body { background:#fff !important; color:#000 !important; font-size:12pt; }
    /* Hide chrome: sidebar, bottom nav, headers, buttons, status bars */
    aside, .ka-bottom-nav, header.header, .ka-content > div > h1, .status-banner,
    button, .refresh-btn, .add-row, .toast, [class*="bg-brand-50"], [class*="from-brand-100"] { display:none !important; }
    /* Print only the elements marked .ka-print */
    body > div { background:#fff !important; }
    main { padding:0 !important; max-width:100% !important; }
    .ka-print-only { display:block !important; }
    .ka-print-hide { display:none !important; }
    /* Make all cards plain */
    [class*="rounded"] { border-radius:0 !important; box-shadow:none !important; border:0.5pt solid #999 !important; }
    /* List items: one per line, no truncation */
    .ka-print-item { page-break-inside:avoid; padding:6pt 0; border-bottom:0.5pt solid #ddd; }
  }
  /* Bigger default minimum tap target on mobile */
  @media (max-width: 768px){
    button,[role="button"],a[href]{min-height:44px}
    /* Don't force min-height on tiny inline buttons (close icons, etc.) that already set their own size */
    button[aria-label="close"],button[aria-label="decrease quantity"],button[aria-label="increase quantity"],button[aria-label="more options"]{min-height:initial}
  }
  /* Prevent body scroll when a bottom sheet is open is implicit via inset-0 overlays */
</style>
</head>
