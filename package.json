<script src="https://cdn.tailwindcss.com"></script>
<script>
tailwind.config = {
  darkMode: 'class',
  theme: {
    extend: {
      colors: {
        brand: {
          50:'#fbf5f1',100:'#f4e4da',200:'#e8c4ad',300:'#dba07e',
          400:'#cf8058',500:'#c96b4a',600:'#b45538',700:'#94432e',
          800:'#753726',900:'#5c2d20'
        },
        leaf: { 500:'#5A8F3D',600:'#4a7832', 700:'#3c6328' }
      },
      fontFamily: {
        display: ['"DM Serif Display"','Georgia','serif'],
        sans: ['Inter','system-ui','sans-serif']
      }
    }
  }
}
// ── Theme bootstrapper ── reads kitchenAgent:v2:theme (system|light|dark)
// and applies <html class="dark"> before paint to avoid a flash.
(function applyTheme(){
  try {
    const pref = localStorage.getItem('kitchenAgent:v2:theme') || 'system';
    const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
    const isDark = pref === 'dark' || (pref === 'system' && prefersDark);
    document.documentElement.classList.toggle('dark', isDark);
  } catch {}
})();
</script>
