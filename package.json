<script type="text/babel" data-type="module">
const { useState, useEffect, useMemo, useRef, useReducer, useCallback, createContext, useContext } = React;

/* =====================================================================
   STORAGE
   ===================================================================== */
const NS = 'kitchenAgent:v2:';
const store = {
  get(k, fb){ try { const v = localStorage.getItem(NS+k); return v==null?fb:JSON.parse(v); } catch(e){ return fb; } },
  set(k, v){ try { localStorage.setItem(NS+k, JSON.stringify(v)); } catch(e){} },
  del(k){ localStorage.removeItem(NS+k); },
  clearAll(){ Object.keys(localStorage).filter(k=>k.startsWith(NS)).forEach(k=>localStorage.removeItem(k)); }
};

/* =====================================================================
   CLOUD SYNC (Airtable, via /.netlify/functions/airtable)
   =====================================================================
   Strategy:
     - localStorage is the working cache (fast UI, offline-tolerant).
     - Airtable is the source of truth; pulled on boot, written on change.
     - Each user has their own data scoped by userId.
     - If the function call fails (no env vars, offline, etc.) we fall back
       to localStorage-only behavior — the app still works.

   Airtable schema:
     Users         : userId, name, fingerprint, createdAt
     Pantry        : userId, itemId, name, ingredient_id, qty, unit,
                     expires_at, added_at, photo (attachment), updatedAt
     Plan          : userId, planJson (long text)            -- single row per user
     Profile       : userId, profileJson (long text)         -- single row per user
     CookedMarks   : userId, marksJson (long text)           -- single row per user
     Orders        : userId, orderId, json (long text), createdAt
     CustomRecipes : userId, recipeId, name, json (long text), updatedAt
   ===================================================================== */
const Cloud = (() => {
  const ENDPOINT = '/.netlify/functions/airtable';
  let _enabled = null;            // null = unknown, true/false after first call
  let _pushTimers = {};           // debounce timers per key

  // Per-key Airtable record IDs (so updates don't create duplicates).
  // Persisted to localStorage so we don't have to re-fetch the whole table to find them.
  const recordIds = {
    get(key){ return store.get('cloud:rid:'+key, null); },
    set(key, id){ store.set('cloud:rid:'+key, id); },
    getMap(table){ return store.get('cloud:ridmap:'+table, {}); },   // {itemId: airtableId}
    setMap(table, map){ store.set('cloud:ridmap:'+table, map); },
  };

  async function call(action, body){
    const res = await fetch(ENDPOINT, {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ action, ...body }),
    });
    const data = await res.json().catch(()=>({error:'Bad JSON from airtable function'}));
    if (!res.ok) throw new Error(data.error || `airtable fn ${res.status}`);
    return data;
  }

  function getUserId(){ return store.get('userId', null); }
  function getUserName(){ return store.get('userName', ''); }
  function setUser(id, name){
    store.set('userId', id);
    store.set('userName', name || '');
  }

  function newUserId(){
    // Stable random ID; not a real fingerprint, just a per-user namespace.
    return 'u_' + (crypto.randomUUID ? crypto.randomUUID().split('-')[0] : Math.random().toString(36).slice(2,10));
  }

  // Singleton blob keys → stored as one JSON-string row in their own table.
  const BLOB_TABLES = {
    plan:        { table: 'Plan',        field: 'planJson' },
    profile:     { table: 'Profile',     field: 'profileJson' },
    cookedMarks: { table: 'CookedMarks', field: 'marksJson' },
  };

  // Array-of-items keys → one Airtable row per item, identified by itemId field.
  const ARRAY_TABLES = {
    pantry:        { table: 'Pantry',        idField: 'itemId' },
    orders:        { table: 'Orders',        idField: 'orderId' },
    customRecipes: { table: 'CustomRecipes', idField: 'recipeId' },
  };

  // ---------- BOOT ----------
  async function init(){
    try {
      // Probe: a no-op listUsers call confirms env vars are set.
      await call('listUsers', {});
      _enabled = true;
    } catch (err) {
      console.warn('[Cloud] disabled:', err.message);
      _enabled = false;
      return false;
    }
    return true;
  }

  function isEnabled(){ return _enabled === true; }

  // ---------- USER IDENTITY ----------
  async function ensureUser(name){
    if (!isEnabled()) return null;
    let id = getUserId();
    if (!id) { id = newUserId(); }
    const fingerprint = (navigator.userAgent || '').slice(0, 200);
    const { user } = await call('ensureUser', { userId: id, name, fingerprint });
    setUser(id, name);
    return user;
  }

  async function listUsers(){
    if (!isEnabled()) return [];
    const { users } = await call('listUsers', {});
    return users.map(u => ({ id: u.fields.userId, name: u.fields.name || 'Unnamed' }));
  }

  // ---------- PULL (cloud → localStorage) ----------
  async function pullAll(){
    if (!isEnabled()) return;
    const userId = getUserId();
    if (!userId) return;

    // Singleton blobs
    for (const [key, { table, field }] of Object.entries(BLOB_TABLES)) {
      try {
        const { records } = await call('listForUser', { table, userId });
        if (records.length) {
          const rec = records[0];
          recordIds.set(key, rec.id);
          const raw = rec.fields[field];
          if (raw) {
            try { store.set(key, JSON.parse(raw)); } catch {}
          }
        }
      } catch (e) {
        console.warn(`[Cloud] pull ${key} failed:`, e.message);
      }
    }

    // Array-of-items tables
    for (const [key, { table, idField }] of Object.entries(ARRAY_TABLES)) {
      try {
        const { records } = await call('listForUser', { table, userId });
        const map = {};
        const items = records.map(r => {
          const f = r.fields;
          map[f[idField]] = r.id;
          if (table === 'Pantry') {
            return {
              id: f.itemId,
              ingredient_id: f.ingredient_id || '',
              name: f.name || '',
              qty: Number(f.qty || 0),
              unit: f.unit || '',
              expires_at: f.expires_at || null,
              added_at: f.added_at || new Date().toISOString(),
              photo: (f.photo && f.photo[0]) ? f.photo[0].url : null,
            };
          }
          // Orders / CustomRecipes: stored as JSON in `json` field
          if (f.json) {
            try { return JSON.parse(f.json); } catch { return null; }
          }
          return null;
        }).filter(Boolean);
        recordIds.setMap(table, map);
        if (items.length || store.get(key, null) === null) {
          store.set(key, items);
        }
      } catch (e) {
        console.warn(`[Cloud] pull ${key} failed:`, e.message);
      }
    }
  }

  // ---------- PUSH (localStorage → cloud), debounced ----------
  function pushKey(key, value){
    if (!isEnabled()) return;
    const userId = getUserId();
    if (!userId) return;
    clearTimeout(_pushTimers[key]);
    _pushTimers[key] = setTimeout(() => doPush(key, value, userId).catch(e =>
      console.warn(`[Cloud] push ${key} failed:`, e.message)
    ), 800);
  }

  async function doPush(key, value, userId){
    if (BLOB_TABLES[key]) {
      const { table, field } = BLOB_TABLES[key];
      const rid = recordIds.get(key);
      const fields = { userId, [field]: JSON.stringify(value || {}) };
      const record = rid ? { id: rid, fields } : { fields };
      const { records } = await call('upsert', { table, records: [record] });
      if (records[0]) recordIds.set(key, records[0].id);
      return;
    }
    if (ARRAY_TABLES[key]) {
      const { table, idField } = ARRAY_TABLES[key];
      const map = recordIds.getMap(table);
      const items = Array.isArray(value) ? value : [];
      const liveIds = new Set();

      // Build records to upsert
      const records = items.map(item => {
        const itemId = item.id || item.orderId || item.recipeId;
        if (!itemId) return null;
        liveIds.add(itemId);
        const rid = map[itemId];
        let fields;
        if (table === 'Pantry') {
          fields = {
            userId,
            itemId,
            ingredient_id: item.ingredient_id || '',
            name: item.name || '',
            qty: Number(item.qty || 0),
            unit: item.unit || '',
            expires_at: item.expires_at || null,
            added_at: item.added_at || new Date().toISOString(),
            updatedAt: new Date().toISOString(),
          };
        } else if (table === 'Orders') {
          fields = {
            userId, orderId: itemId,
            json: JSON.stringify(item),
            createdAt: item.createdAt || new Date().toISOString(),
          };
        } else { // CustomRecipes
          fields = {
            userId, recipeId: itemId,
            name: item.name || '',
            json: JSON.stringify(item),
            updatedAt: new Date().toISOString(),
          };
        }
        return rid ? { id: rid, fields } : { fields };
      }).filter(Boolean);

      if (records.length) {
        const { records: out } = await call('upsert', { table, records });
        out.forEach(r => { map[r.fields[idField]] = r.id; });
      }

      // Delete records that disappeared from the array
      const idsToDelete = [];
      for (const [itemId, rid] of Object.entries(map)) {
        if (!liveIds.has(itemId)) {
          idsToDelete.push(rid);
          delete map[itemId];
        }
      }
      if (idsToDelete.length) {
        await call('delete', { table, ids: idsToDelete });
      }
      recordIds.setMap(table, map);
    }
    // Other keys (view, shoppingExtras, etc.) intentionally not synced — local-only.
  }

  return {
    init, isEnabled, ensureUser, listUsers, pullAll, pushKey,
    getUserId, getUserName, setUser, newUserId,
  };
})();

// Expose on window for debugging + manual user switching from devtools.
// Usage in console:  window.signOut()  → reload to pick a different user.
window.Cloud = Cloud;
window.signOut = function(){
  store.del('userId');
  store.del('userName');
  // Also wipe per-user record-id maps so the next user pulls fresh
  Object.keys(localStorage).filter(k => k.startsWith(NS+'cloud:')).forEach(k => localStorage.removeItem(k));
  location.reload();
};

/* =====================================================================
   ADAPTERS — real store integrations + external APIs
   ===================================================================== */

// --- Instacart Developer Platform (recipe URL generator) ---
// Without API keys: we generate an Instacart *search* URL using ingredient names.
// With API keys (user pastes into settings): we hit /idp/v1/products/recipe to get a
// proper recipe landing page that persists to Instacart's database.
const Instacart = {
  getKey(){ return store.get('api:instacart',''); },
  setKey(k){ store.set('api:instacart',k); },
  // Fallback: build a search URL that adds ingredients to an Instacart search
  fallbackSearchUrl(ingredients, retailer_key='aldi'){
    const q = ingredients.map(i => i.name).join(' ');
    return `https://www.instacart.com/store/${retailer_key}/search/${encodeURIComponent(q)}`;
  },
  // Production: call API to create a "recipe" shopping list. Returns a products_link_url.
  async createRecipeLink({ title, ingredients, retailer_key='aldi', partner_linkback_url }){
    const key = this.getKey();
    if (!key) {
      return { ok:false, url: this.fallbackSearchUrl(ingredients, retailer_key), fallback:true, reason:'no-api-key' };
    }
    try {
      const res = await fetch('https://connect.instacart.com/idp/v1/products/recipe', {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${key}`, 'Content-Type':'application/json' },
        body: JSON.stringify({
          title, author:'Kitchen Agent', servings: 4,
          ingredients: ingredients.map(i => ({
            name: i.name, display_text: i.display || i.name,
            measurements: i.qty ? [{ quantity: i.qty, unit: i.unit || 'each' }] : [],
          })),
          landing_page_configuration: { partner_linkback_url: partner_linkback_url || window.location.href },
        })
      });
      if (!res.ok) throw new Error(`Instacart API ${res.status}`);
      const data = await res.json();
      return { ok:true, url: data.products_link_url, fallback:false };
    } catch (e) {
      console.warn('Instacart API failed, using fallback:', e.message);
      return { ok:false, url: this.fallbackSearchUrl(ingredients, retailer_key), fallback:true, reason:e.message };
    }
  },
  // Store locator: just direct-link to retailer storefront (works without API)
  storefrontUrl(retailer_key, zip){
    const q = zip ? `?zip_code=${encodeURIComponent(zip)}` : '';
    return `https://www.instacart.com/store/${retailer_key}/storefront${q}`;
  }
};

// --- Walmart Deep-Link ---
// The Walmart cart pre-fill URL format is not officially documented; we use
// the known /cart/add-to-cart?items=SKU1|qty,SKU2|qty pattern observed on walmart.com.
// Without SKUs we fall back to a search URL (works reliably).
const Walmart = {
  getKey(){ return store.get('api:walmart',''); },
  setKey(k){ store.set('api:walmart',k); },
  // Deep link for a cart. items: [{sku, qty}]
  cartUrl(items){
    if (!items || items.length===0) return 'https://www.walmart.com/grocery';
    // If any item has an SKU, use add-to-cart path; otherwise search
    const withSku = items.filter(i => i.sku);
    if (withSku.length > 0) {
      const param = withSku.map(i => `${i.sku}|${i.qty||1}`).join(',');
      return `https://www.walmart.com/cart/add-to-cart?items=${encodeURIComponent(param)}`;
    }
    const q = items.map(i => i.name).join(' ');
    return `https://www.walmart.com/search?q=${encodeURIComponent(q)}&cat_id=976759`;
  },
  storeLocatorUrl(zip){
    return `https://www.walmart.com/store/finder?location=${encodeURIComponent(zip||'')}`;
  }
};

// --- Open Food Facts ---
// Free API, 100 req/min. We cache responses aggressively.
const OpenFoodFacts = {
  UA: 'KitchenAgent/1.0 (prototype)',
  CACHE_KEY: 'off:cache',
  cache(){ return store.get(this.CACHE_KEY, {}); },
  setCache(c){ store.set(this.CACHE_KEY, c); },
  async lookup(barcode){
    barcode = String(barcode).replace(/\D/g,'');
    if (!barcode) return null;
    const c = this.cache();
    if (c[barcode] && c[barcode]._ts && Date.now()-c[barcode]._ts < 1000*60*60*24*30) {
      return c[barcode];
    }
    try {
      const res = await fetch(`https://world.openfoodfacts.org/api/v2/product/${barcode}.json`, {
        headers: { 'User-Agent': this.UA }
      });
      if (!res.ok) throw new Error(`OFF ${res.status}`);
      const data = await res.json();
      if (data.status !== 1 || !data.product) {
        const miss = { _ts: Date.now(), found:false, barcode };
        c[barcode] = miss; this.setCache(c);
        return miss;
      }
      const p = data.product;
      const result = {
        _ts: Date.now(),
        found: true,
        barcode,
        name: p.product_name_en || p.product_name || 'Unknown product',
        brand: p.brands || '',
        qty: p.quantity || '',
        category: (p.categories_tags && p.categories_tags[0]) || '',
        nutrition_grade: p.nutrition_grades || null,
        image_url: p.image_front_url || p.image_url || null,
      };
      c[barcode] = result; this.setCache(c);
      return result;
    } catch (e) {
      console.warn('OFF lookup failed:', e.message);
      return { found:false, error: e.message, barcode };
    }
  }
};

// v10: Learned barcode map — every successful scan (OFF hit or manual fallback) is cached here so re-scans are instant.
const BarcodeMap = {
  KEY: 'kitchenAgent:v2:barcodeMap',
  get(barcode) {
    try {
      const m = JSON.parse(localStorage.getItem(this.KEY) || '{}');
      return m[String(barcode)] || null;
    } catch { return null; }
  },
  set(barcode, item) {
    try {
      const m = JSON.parse(localStorage.getItem(this.KEY) || '{}');
      m[String(barcode)] = { ...item, last_seen: Date.now() };
      localStorage.setItem(this.KEY, JSON.stringify(m));
    } catch {}
  },
  // Used by smart suggestions: list barcodes by category
  forCategory(cat) {
    try {
      const m = JSON.parse(localStorage.getItem(this.KEY) || '{}');
      return Object.entries(m).filter(([_,v]) => v.category === cat).map(([k,v]) => ({ barcode: k, ...v }));
    } catch { return []; }
  }
};


// --- Tesseract.js OCR wrapper ---
// Real receipt scanning via WASM in the browser.
const OCR = {
  _worker: null,
  async getWorker(onProgress){
    if (this._worker) return this._worker;
    this._worker = await Tesseract.createWorker('eng', 1, {
      logger: m => onProgress && onProgress(m)
    });
    return this._worker;
  },
  async recognize(imageSource, onProgress){
    const worker = await this.getWorker(onProgress);
    const { data } = await worker.recognize(imageSource);
    return data;
  }
};

// --- Claude Vision (Anthropic) ---
// Identifies grocery items from photos directly — works on bottles, produce, blurry
// shots, foreign-language labels, anywhere OCR fails. Falls back to OCR if no key set.
//   API key is stored in localStorage under kitchenAgent:v2:anthropicKey
//   Privacy: the request goes browser → api.anthropic.com directly. No middleman.
const Claude = {
  KEY: 'kitchenAgent:v2:anthropicKey',
  MODEL: 'claude-sonnet-4-5-20250929', // current vision-capable Sonnet
  ENDPOINT: 'https://api.anthropic.com/v1/messages',
  getKey(){ try { return localStorage.getItem(this.KEY) || ''; } catch { return ''; } },
  setKey(k){ try { k ? localStorage.setItem(this.KEY, k.trim()) : localStorage.removeItem(this.KEY); } catch {} },
  isEnabled(){ return !!this.getKey(); },

  // Convert a File/Blob/dataURL to a {media_type, data} pair Anthropic's API wants.
  async fileToImageBlock(file){
    const blob = file instanceof Blob ? file : await (await fetch(file)).blob();
    // Resize huge images down to ~1600px so we don't waste tokens / hit payload limits.
    const resized = await this._resize(blob, 1600);
    const dataUrl = await new Promise((res, rej) => {
      const r = new FileReader();
      r.onload = () => res(r.result);
      r.onerror = rej;
      r.readAsDataURL(resized);
    });
    const [meta, b64] = dataUrl.split(',');
    const media_type = (meta.match(/data:(image\/[a-z+]+)/i) || [])[1] || 'image/jpeg';
    return { type:'image', source:{ type:'base64', media_type, data: b64 } };
  },

  async _resize(blob, maxSide){
    try {
      const bitmap = await createImageBitmap(blob);
      const ratio = Math.min(1, maxSide / Math.max(bitmap.width, bitmap.height));
      if (ratio === 1 && blob.size < 800*1024) return blob; // already small
      const w = Math.round(bitmap.width * ratio), h = Math.round(bitmap.height * ratio);
      const canvas = document.createElement('canvas');
      canvas.width = w; canvas.height = h;
      canvas.getContext('2d').drawImage(bitmap, 0, 0, w, h);
      return await new Promise(res => canvas.toBlob(b => res(b || blob), 'image/jpeg', 0.85));
    } catch { return blob; }
  },

  // Low-level message call. Throws on HTTP error with a helpful message.
  async _call({ system, user_text, images = [], max_tokens = 600 }){
    const key = this.getKey();
    if (!key) throw new Error('No Anthropic API key set. Add one in Settings → API connections.');
    const content = [];
    for (const img of images) content.push(img);
    if (user_text) content.push({ type:'text', text: user_text });
    const body = {
      model: this.MODEL,
      max_tokens,
      system,
      messages: [{ role:'user', content }],
    };
    const res = await fetch(this.ENDPOINT, {
      method:'POST',
      headers:{
        'content-type':'application/json',
        'x-api-key': key,
        'anthropic-version':'2023-06-01',
        'anthropic-dangerous-direct-browser-access':'true',
      },
      body: JSON.stringify(body),
    });
    const json = await res.json().catch(()=>({}));
    if (!res.ok) {
      const msg = json?.error?.message || `Claude API ${res.status}`;
      throw new Error(msg);
    }
    const text = (json.content || []).filter(c => c.type==='text').map(c => c.text).join('\n').trim();
    return { text, raw: json };
  },

  // Identify ONE grocery / household item from a photo. Returns:
  //   { name, brand, category, quantity_text, is_food, confidence, unit, default_expiry_days, notes }
  async identifyItem(file, { canonicalIngredients = [] } = {}){
    const img = await this.fileToImageBlock(file);
    // Give Claude the list of canonical ingredient names so it can match exactly.
    const canon = canonicalIngredients.slice(0, 250).map(i => i.name).join(', ');
    const system =
      'You identify grocery, pantry, fridge, and household items from photos. ' +
      'Respond ONLY with valid JSON — no markdown fences, no prose.';
    const user_text =
      'Identify the single product in this photo.\n\n' +
      'Return JSON exactly matching this schema:\n' +
      '{"name": "short product name (e.g. \\"Whole Milk\\", \\"Bananas\\", \\"Toilet Paper\\")", ' +
      '"brand": "brand name or empty string", ' +
      '"category": "produce | meat | dairy | grain | spice | condiment | canned | frozen | beverage | snack | bakery | household | other", ' +
      '"is_food": true|false, ' +
      '"quantity_text": "size on package or empty (e.g. \\"12 oz\\", \\"1 gallon\\")", ' +
      '"unit": "best unit to track in pantry: each | lb | oz | gallon | bottle | pack | box | can", ' +
      '"default_expiry_days": number (typical shelf life — 7 for produce, 14 for dairy, 365 for canned, etc.), ' +
      '"confidence": "high | medium | low", ' +
      '"notes": "optional 1-line note if helpful (e.g. \\"likely organic\\")"}\n\n' +
      (canon ? 'If the item matches one of these canonical ingredient names exactly, use that exact name: ' + canon + '\n\n' : '') +
      'If you cannot tell what the item is, set confidence to "low" and best-guess the name.';
    const { text } = await this._call({ system, user_text, images:[img], max_tokens: 400 });
    // Tolerant JSON parse — strip code fences if Claude adds them.
    const cleaned = text.replace(/^```(?:json)?\s*/i,'').replace(/\s*```$/,'').trim();
    let parsed;
    try { parsed = JSON.parse(cleaned); }
    catch { parsed = { name:'', brand:'', category:'other', is_food:true, quantity_text:'', unit:'each', default_expiry_days:14, confidence:'low', notes:'Could not parse response: '+cleaned.slice(0,80) }; }
    return parsed;
  },

  // Identify MULTIPLE items in one photo (e.g. groceries laid out on a counter).
  async identifyItems(file, { canonicalIngredients = [] } = {}){
    const img = await this.fileToImageBlock(file);
    const canon = canonicalIngredients.slice(0, 250).map(i => i.name).join(', ');
    const system = 'You identify grocery items from photos. Respond ONLY with valid JSON.';
    const user_text =
      'List every distinct grocery / household item visible in this photo. Each row should be one product, not one piece.\n\n' +
      'Return JSON: { "items": [ { ...same shape as single-item... } ] }\n\n' +
      (canon ? 'Prefer these canonical names when they match: ' + canon : '');
    const { text } = await this._call({ system, user_text, images:[img], max_tokens: 1200 });
    const cleaned = text.replace(/^```(?:json)?\s*/i,'').replace(/\s*```$/,'').trim();
    try { const parsed = JSON.parse(cleaned); return parsed.items || []; }
    catch { return []; }
  },

  // ── Parse a recipe from URL / pasted text / photo ──────────────────────
  // Returns a structured recipe in the shape this app uses internally.
  // `input` is { url?, text?, file? } — exactly one should be set.
  async parseRecipe({ url, text, file } = {}){
    let userBlock;
    const images = [];
    if (file) {
      images.push(await this.fileToImageBlock(file));
      userBlock = 'Extract the full recipe shown in this image. If multiple recipes are visible, pick the most prominent one.';
    } else if (url) {
      // Note: we send Claude the URL itself + ask it to use its training knowledge.
      // For pages it doesn't know, the user can paste text instead. This avoids CORS-blocked fetches.
      userBlock = `Extract the recipe at this URL (use the canonical published version): ${url}`;
    } else if (text) {
      userBlock = `Extract the recipe from this text:\n\n---\n${text.slice(0, 8000)}\n---`;
    } else {
      throw new Error('Provide url, text, or file to parseRecipe');
    }
    const system =
      'You convert recipes from any format into clean structured JSON. Respond ONLY with valid JSON — no code fences.';
    const schema =
      '{\n' +
      '  "name": "Recipe title",\n' +
      '  "source": "Where it came from (cookbook name, blog name, or \\"Custom\\")",\n' +
      '  "servings": number,\n' +
      '  "prep_min": number,\n' +
      '  "cook_min": number,\n' +
      '  "ingredients": ["1 cup flour", "2 tbsp olive oil", "..."],\n' +
      '  "steps": ["Preheat oven to 400°F.", "Combine dry ingredients...", "..."],\n' +
      '  "tags": ["quick", "vegetarian", "one-pan", "..."],\n' +
      '  "meal_types": ["breakfast"|"lunch"|"dinner"|"snack"],\n' +
      '  "macros": { "calories": number, "protein": number, "carbs": number, "fat": number },\n' +
      '  "notes": "1-line description or chef tip"\n' +
      '}';
    const { text: out } = await this._call({
      system,
      user_text: userBlock + '\n\nReturn JSON exactly matching this schema (omit fields you can\'t determine):\n' + schema,
      images,
      max_tokens: 2500,
    });
    const cleaned = out.replace(/^```(?:json)?\s*/i,'').replace(/\s*```$/,'').trim();
    let parsed;
    try { parsed = JSON.parse(cleaned); }
    catch (e) { throw new Error('Could not parse recipe — try pasting the text directly. Raw: ' + cleaned.slice(0,160)); }
    // Defaults so the rest of the app doesn't break on missing fields
    parsed.id = 'custom_' + (parsed.name || 'recipe').toLowerCase().replace(/[^\w]+/g,'_').slice(0,40) + '_' + Date.now().toString(36);
    parsed.source = parsed.source || 'Custom';
    parsed.servings = parsed.servings || 2;
    parsed.prep_min = parsed.prep_min || 0;
    parsed.cook_min = parsed.cook_min || 0;
    parsed.ingredients = parsed.ingredients || [];
    parsed.steps = parsed.steps || [];
    parsed.tags = parsed.tags || ['custom'];
    parsed.meal_types = parsed.meal_types || ['dinner'];
    parsed.canonical_ingredients = []; // user can map later; ok empty
    parsed._custom = true;
    parsed._imported_at = new Date().toISOString();
    return parsed;
  },

  // ── Parse a natural-language pantry update into structured deltas ──────
  // Examples user might say:
  //   "I just used two eggs and half a gallon of milk"
  //   "Add a dozen tomatoes to the fridge"
  //   "Used up all the rice"
  // Returns: { actions: [{ name, delta, unit?, location? }] }
  // delta is negative for usage, positive for additions.
  async parsePantryUpdate(text, { pantryItems = [], canonicalIngredients = [] } = {}){
    const pantryHint = pantryItems.slice(0, 30).map(p => `${p.name} (${p.qty} ${p.unit||''} in ${p.location||'pantry'})`).join(', ');
    const canonHint = canonicalIngredients.slice(0, 150).map(i => i.name).join(', ');
    const system =
      'You convert spoken kitchen updates into JSON deltas for a pantry tracker. Respond ONLY with valid JSON.';
    const user_text =
      'Parse this utterance into structured pantry actions:\n\n' +
      '"' + text + '"\n\n' +
      'Return JSON: { "actions": [{ "name": "<item name>", "delta": <number, negative if used, positive if added>, "unit": "<unit if mentioned>", "location": "pantry"|"fridge"|"freezer"|"non_food" (optional) }] }\n\n' +
      (pantryHint ? 'CURRENT PANTRY (match exact names where possible): ' + pantryHint + '\n\n' : '') +
      (canonHint ? 'CANONICAL NAMES: ' + canonHint + '\n\n' : '') +
      'For "used up all", set delta to a large negative number like -999. For "a dozen", use 12. For "half", use 0.5. ' +
      'If no quantity is given but the item is used, assume delta -1; if added, +1.';
    const { text: out } = await this._call({ system, user_text, max_tokens: 600 });
    const cleaned = out.replace(/^```(?:json)?\s*/i,'').replace(/\s*```$/,'').trim();
    try { return JSON.parse(cleaned); } catch { return { actions: [] }; }
  },

  // ── Refresh wholesale grocery prices for an ingredient list ────────────
  // Returns: { results: [{ ingredient_id, store_id, pack_size, pack_unit, pack_price, uses_per_pack, sale_pack_price? }] }
  async refreshPrices({ ingredients = [], stores = [], region = '' } = {}){
    if (!ingredients.length || !stores.length) return { results: [] };
    // Trim payload — Claude doesn't need full ingredient objects.
    const ingList = ingredients.slice(0, 200).map(i => ({ id: i.id, name: i.name, unit: i.default_unit }));
    const storeList = stores.map(s => ({ id: s.id, chain: s.chain }));
    const system =
      'You are a US grocery-price researcher. Return realistic 2026 retail pack prices for the user\'s region, ' +
      'using your training knowledge of each chain\'s typical pricing. Respond ONLY with valid JSON — no markdown.';
    const user_text =
      `Region: ${region || 'United States, average pricing'}\n\n` +
      `STORES: ${JSON.stringify(storeList)}\n\n` +
      `INGREDIENTS: ${JSON.stringify(ingList)}\n\n` +
      `For each (ingredient, store) pair, return the realistic SHOPPING PACK price the user would actually pay at checkout — ` +
      `not a per-tablespoon estimate. For example sesame oil is sold as an 8 fl oz bottle for ~$5-7, not $1.\n\n` +
      `Return JSON: { "results": [ { "ingredient_id":"...", "store_id":"...", ` +
      `"pack_size": <number>, "pack_unit": "oz|lb|gal|each|pack|bottle|box|can", ` +
      `"pack_price": <number>, "uses_per_pack": <int — how many typical recipe uses one pack covers>, ` +
      `"sale_pack_price": <number or null> } ] }\n\n` +
      `Be conservative — only include pairs where you have a real estimate. Skip pairs you can't confidently price.`;
    const { text } = await this._call({ system, user_text, max_tokens: 6000 });
    const cleaned = text.replace(/^```(?:json)?\s*/i,'').replace(/\s*```$/,'').trim();
    try { return JSON.parse(cleaned); } catch { return { results: [] }; }
  },

  // ── Suggest recipes given current pantry + cooking history ─────────────
  async suggestRecipes({ pantryItems = [], recentlyCooked = [], dietary = [], n = 3 } = {}){
    const pantry = pantryItems.slice(0, 80).map(p => `${p.name} (${p.qty} ${p.unit||''})`).join(', ');
    const recent = recentlyCooked.slice(0, 8).join(', ');
    const system =
      'You suggest practical home recipes based on what someone has on hand. Respond ONLY with valid JSON.';
    const user_text =
      `Suggest ${n} recipes I could cook tonight using mostly what I already have. ` +
      'Prefer recipes that use ingredients about to expire. Avoid anything I cooked in the last week.\n\n' +
      'PANTRY: ' + pantry + '\n' +
      (recent ? 'RECENTLY COOKED (avoid): ' + recent + '\n' : '') +
      (dietary?.length ? 'DIETARY RESTRICTIONS (strict): ' + dietary.join(', ') + '\n' : '') +
      '\nReturn JSON: { "suggestions": [ { "name": "...", "why": "1 sentence pitch using their pantry", ' +
      '"missing_items": ["..."], "prep_min": <int>, "cook_min": <int>, "servings": <int>, ' +
      '"steps": ["...","..."], "ingredients": ["..."] } ] }';
    const { text } = await this._call({ system, user_text, max_tokens: 2500 });
    const cleaned = text.replace(/^```(?:json)?\s*/i,'').replace(/\s*```$/,'').trim();
    try { return JSON.parse(cleaned).suggestions || []; } catch { return []; }
  },
};

// ─── Notifications (browser-side) ───────────────────────────────────────
// Registers a service worker (sw.js next to index.html) and fires local
// notifications for expiring pantry items + leftovers eat-by. Apple Web Push
// is no-op unless the app is installed as a PWA on iOS 16.4+; Android Chrome
// + desktop browsers work out of the box.
const Notifs = {
  ENABLED_KEY: 'kitchenAgent:v2:notifsEnabled',
  LASTFIRED_KEY: 'kitchenAgent:v2:notifsLastFired',

  supported(){ return 'Notification' in window && 'serviceWorker' in navigator; },
  permission(){ return this.supported() ? Notification.permission : 'unsupported'; },
  enabled(){ try { return localStorage.getItem(this.ENABLED_KEY) === '1' && this.permission() === 'granted'; } catch { return false; } },

  async registerSW(){
    if (!('serviceWorker' in navigator)) return null;
    try {
      // Use a relative URL so it works on any deploy path.
      const reg = await navigator.serviceWorker.register('sw.js');
      return reg;
    } catch (e) {
      console.warn('SW register failed:', e.message);
      return null;
    }
  },

  async requestEnable(){
    if (!this.supported()) return { ok:false, reason:'unsupported' };
    let perm = Notification.permission;
    if (perm === 'default') perm = await Notification.requestPermission();
    if (perm !== 'granted') {
      try { localStorage.setItem(this.ENABLED_KEY, '0'); } catch {}
      return { ok:false, reason: perm };
    }
    await this.registerSW();
    try { localStorage.setItem(this.ENABLED_KEY, '1'); } catch {}
    return { ok:true };
  },
  disable(){ try { localStorage.setItem(this.ENABLED_KEY, '0'); } catch {} },

  // Show one notification. Tagged so we don't double-fire today's reminder.
  async show({ title, body, tag, url }){
    if (!this.enabled()) return false;
    try {
      const reg = await navigator.serviceWorker.getRegistration();
      if (reg && reg.showNotification) {
        await reg.showNotification(title, { body, tag, data:{ url:url||'/' }, badge:'/icon.png', icon:'/icon.png' });
      } else {
        new Notification(title, { body, tag });
      }
      return true;
    } catch (e) { console.warn('Notify failed:', e.message); return false; }
  },

  // Scan pantry + leftovers, fire one consolidated notification per day per category.
  // Call this on app boot — duplicate calls in the same day are deduped by the date-key tag.
  async checkAndFire(state){
    if (!this.enabled()) return 0;
    let last = {};
    try { last = JSON.parse(localStorage.getItem(this.LASTFIRED_KEY) || '{}'); } catch {}
    const todayKey = new Date().toISOString().slice(0,10);

    let fired = 0;
    const day = 86400000;
    const now = Date.now();

    // Expiring food (≤2 days)
    const expiring = (state.pantry || []).filter(p => {
      if (!p || (p.location||'pantry') === 'non_food') return false;
      const diff = (new Date(p.expires_at).getTime() - now) / day;
      return diff >= 0 && diff <= 2;
    });
    if (expiring.length && last['exp:'+todayKey] !== expiring.length) {
      const names = expiring.slice(0,3).map(p => p.name).join(', ');
      const extra = expiring.length > 3 ? ` +${expiring.length-3} more` : '';
      if (await this.show({
        title: `${expiring.length} item${expiring.length===1?'':'s'} expiring soon`,
        body: names + extra,
        tag: 'ka-exp-'+todayKey,
        url: '/?view=reminders',
      })) { last['exp:'+todayKey] = expiring.length; fired++; }
    }

    // Leftovers within eat-by tomorrow
    const expLeft = (state.leftovers || []).filter(l => {
      if (l.status !== 'fresh') return false;
      const diff = (new Date(l.eat_by).getTime() - now) / day;
      return diff >= 0 && diff <= 1;
    });
    if (expLeft.length && last['lo:'+todayKey] !== expLeft.length) {
      if (await this.show({
        title: `Eat your leftovers today`,
        body: expLeft.slice(0,3).map(l => l.name).join(', '),
        tag: 'ka-lo-'+todayKey,
        url: '/?view=leftovers',
      })) { last['lo:'+todayKey] = expLeft.length; fired++; }
    }

    try { localStorage.setItem(this.LASTFIRED_KEY, JSON.stringify(last)); } catch {}
    return fired;
  },
};
// Always try to register the SW on load (silent if permission isn't granted).
if (typeof window !== 'undefined' && 'serviceWorker' in navigator) {
  window.addEventListener('load', () => Notifs.registerSW());
}

// ─── Storage health ─────────────────────────────────────────────────────
// localStorage has a ~5-10MB cap per origin. Cook photos & barcode cache
// can fill it up. These helpers measure usage and prune safely.
const StorageHealth = {
  usageBytes(){
    let total = 0;
    try {
      for (let i = 0; i < localStorage.length; i++) {
        const k = localStorage.key(i);
        const v = localStorage.getItem(k) || '';
        total += k.length + v.length;
      }
    } catch {}
    return total * 2; // UTF-16 → bytes
  },
  ourBytes(){
    let total = 0;
    try {
      for (let i = 0; i < localStorage.length; i++) {
        const k = localStorage.key(i);
        if (!k || !k.startsWith('kitchenAgent:')) continue;
        const v = localStorage.getItem(k) || '';
        total += k.length + v.length;
      }
    } catch {}
    return total * 2;
  },
  estimatedCapBytes(){ return 5 * 1024 * 1024; }, // 5MB conservative
  usagePercent(){
    const cap = this.estimatedCapBytes();
    return Math.min(100, Math.round(this.usageBytes() / cap * 100));
  },
  // Drop cook-history photos older than `days` days.
  pruneCookPhotos(days = 90){
    let removed = 0;
    try {
      const hist = JSON.parse(localStorage.getItem('kitchenAgent:v2:cookHistory') || '[]');
      const cutoff = Date.now() - days * 86400000;
      const cleaned = hist.map(h => {
        if (h.photo_data_url && new Date(h.date).getTime() < cutoff) {
          removed++;
          const { photo_data_url, ...rest } = h;
          return rest;
        }
        return h;
      });
      localStorage.setItem('kitchenAgent:v2:cookHistory', JSON.stringify(cleaned));
    } catch {}
    return removed;
  },
  // Drop Open Food Facts cache (it's just barcode lookups — cheap to refetch).
  clearBarcodeCache(){
    try { localStorage.removeItem('kitchenAgent:v2:off:cache'); return true; } catch { return false; }
  },
  // Auto-run on boot when we're close to cap.
  autoPruneIfNeeded(){
    if (this.usagePercent() >= 80) {
      const removed = this.pruneCookPhotos(60);
      this.clearBarcodeCache();
      return { ran: true, removed };
    }
    return { ran: false, removed: 0 };
  },
};

// ─── Pricing module ─────────────────────────────────────────────────────
// Layer of pack-aware price overrides that sits on top of the bundled
// estimates in __KA_DATA.prices. Three sources fill this in over time:
//   1. claude_refresh     — Settings → "Refresh prices with Claude"
//   2. receipt_learned    — extracted from receipt OCR after a shop
//   3. user_corrected     — tap-to-edit in the shopping list
//
// Shape on disk (localStorage 'priceOverrides'):
//   { [ingredient_id]: { [store_id]: {
//       pack_size, pack_unit, pack_price, uses_per_pack,
//       sale_pack_price, as_of, source
//   }}}
const Pricing = {
  KEY: 'kitchenAgent:v2:priceOverrides',
  _cache: null,

  _read(){
    if (this._cache) return this._cache;
    try { this._cache = JSON.parse(localStorage.getItem(this.KEY) || '{}'); }
    catch { this._cache = {}; }
    return this._cache;
  },
  _write(){
    try { localStorage.setItem(this.KEY, JSON.stringify(this._cache || {})); } catch {}
  },

  // Lookup a pack-price override for an ingredient at a store.
  get(ingredient_id, store_id){
    const all = this._read();
    return (all[ingredient_id] && all[ingredient_id][store_id]) || null;
  },

  // Lookup all per-store overrides for an ingredient.
  getAll(ingredient_id){
    return this._read()[ingredient_id] || {};
  },

  // Save one override. `source` is one of 'claude_refresh'|'receipt_learned'|'user_corrected'.
  set(ingredient_id, store_id, data, source = 'user_corrected'){
    const all = this._read();
    if (!all[ingredient_id]) all[ingredient_id] = {};
    all[ingredient_id][store_id] = {
      pack_size:       Number(data.pack_size)     || 1,
      pack_unit:       String(data.pack_unit||'each'),
      pack_price:      Number(data.pack_price)    || 0,
      uses_per_pack:   Math.max(1, Number(data.uses_per_pack) || 1),
      sale_pack_price: data.sale_pack_price != null ? Number(data.sale_pack_price) : null,
      as_of:           new Date().toISOString().slice(0,10),
      source,
    };
    this._write();
  },

  // Bulk save from a Claude refresh.
  setMany(results, source = 'claude_refresh'){
    if (!Array.isArray(results)) return 0;
    let n = 0;
    for (const r of results) {
      if (!r || !r.ingredient_id || !r.store_id) continue;
      if (!(Number(r.pack_price) > 0)) continue;
      this.set(r.ingredient_id, r.store_id, r, source);
      n++;
    }
    return n;
  },

  // Delete an override.
  clear(ingredient_id, store_id){
    const all = this._read();
    if (all[ingredient_id]) {
      delete all[ingredient_id][store_id];
      if (!Object.keys(all[ingredient_id]).length) delete all[ingredient_id];
      this._write();
    }
  },

  // Wipe everything (debug / reset).
  clearAll(){
    this._cache = {};
    try { localStorage.removeItem(this.KEY); } catch {}
  },

  // Resolve the EFFECTIVE pack record for (ingredient, store):
  //   1. Override (if any) — pack-aware, has uses_per_pack
  //   2. Bundled per-use estimate from __KA_DATA.prices — wrapped to look pack-aware (pack_size=1, uses_per_pack=1)
  //   3. null
  effectivePack(ingredient_id, store_id, basePrices, fallbackUnit = 'each'){
    const ov = this.get(ingredient_id, store_id);
    if (ov) return { ...ov, _override: true };
    const base = basePrices?.[ingredient_id]?.[store_id];
    if (!base) return null;
    return {
      pack_size: 1,
      pack_unit: fallbackUnit,
      pack_price: (base.sale_price ?? base.price) || 0,
      uses_per_pack: 1,
      sale_pack_price: base.sale_price ?? null,
      as_of: base.as_of || '',
      source: 'bundle_estimate',
      _override: false,
    };
  },

  // Given a recipe-quantity (number of "uses") and an effective pack record,
  // return how many packs to buy + the total cost.
  packsToBuy(qty, pack){
    if (!pack) return { packs: 0, total: 0, leftover_uses: 0 };
    const uses = Math.max(1, pack.uses_per_pack || 1);
    const packs = Math.max(1, Math.ceil(qty / uses));
    const price = (pack.sale_pack_price != null ? pack.sale_pack_price : pack.pack_price) || 0;
    return {
      packs,
      total: packs * price,
      leftover_uses: packs * uses - qty,
    };
  },
};

// --- Routing (OSRM + Nominatim) ---
// All client-side, free. Rate-limited (1 req/sec) — cache aggressively.
const Routing = {
  CACHE_KEY: 'routing:cache',
  cache(){ return store.get(this.CACHE_KEY, {}); },
  setCache(c){ store.set(this.CACHE_KEY, c); },
  async geocode(address){
    if (!address) return null;
    const c = this.cache();
    const key = 'g:'+address.toLowerCase().trim();
    if (c[key] && Date.now()-c[key]._ts < 1000*60*60*24*7) return c[key];
    // Nominatim usage policy: custom User-Agent, 1 req/sec. We include email in UA.
    try {
      await new Promise(r => setTimeout(r, 1100)); // rate limit courtesy
      const res = await fetch(`https://nominatim.openstreetmap.org/search?format=json&limit=1&q=${encodeURIComponent(address)}`);
      if (!res.ok) throw new Error(`Nominatim ${res.status}`);
      const arr = await res.json();
      if (!arr.length) return null;
      const result = { _ts: Date.now(), lat: parseFloat(arr[0].lat), lng: parseFloat(arr[0].lon), display: arr[0].display_name };
      c[key] = result; this.setCache(c);
      return result;
    } catch (e) {
      console.warn('Geocode failed:', e.message);
      return null;
    }
  },
  async route(waypoints){
    // waypoints: [{lat,lng}, ...]
    if (waypoints.length < 2) return null;
    const c = this.cache();
    const key = 'r:' + waypoints.map(w => `${w.lat.toFixed(4)},${w.lng.toFixed(4)}`).join(';');
    if (c[key] && Date.now()-c[key]._ts < 1000*60*60*24) return c[key];
    const coords = waypoints.map(w => `${w.lng},${w.lat}`).join(';');
    try {
      const res = await fetch(`https://router.project-osrm.org/route/v1/driving/${coords}?overview=full&geometries=geojson`);
      if (!res.ok) throw new Error(`OSRM ${res.status}`);
      const data = await res.json();
      if (!data.routes || !data.routes[0]) return null;
      const r = data.routes[0];
      const result = {
        _ts: Date.now(),
        distance_m: r.distance,
        duration_s: r.duration,
        geometry: r.geometry,
      };
      c[key] = result; this.setCache(c);
      return result;
    } catch (e) {
      console.warn('OSRM route failed:', e.message);
      return null;
    }
  },
  /** Score stores by detour cost (in minutes added vs direct work→home). */
  async scoreStores(home, work, stores){
    const homeGeo = await this.geocode(home);
    const workGeo = await this.geocode(work);
    if (!homeGeo || !workGeo) return null;
    const direct = await this.route([workGeo, homeGeo]);
    if (!direct) return null;
    const results = [];
    for (const s of stores) {
      if (!s._geo) continue;
      const viaStore = await this.route([workGeo, s._geo, homeGeo]);
      if (!viaStore) continue;
      const detour_min = (viaStore.duration_s - direct.duration_s) / 60;
      results.push({ store: s, detour_min, direct, viaStore, homeGeo, workGeo });
    }
    return results.sort((a,b) => a.detour_min - b.detour_min);
  }
};

/* =====================================================================
   DATA LOADER — fetches all JSON data files on boot
   ===================================================================== */
async function loadData(){
  const d = window.__KA_DATA;
  if (!d) throw new Error('Embedded data missing');
  // Merge user-added custom recipes (from prior imports / Claude plans) so
  // they appear alongside built-ins everywhere — library, plan, cook mode.
  let custom = [];
  try { custom = JSON.parse(localStorage.getItem('kitchenAgent:v2:customRecipes') || '[]') || []; } catch {}
  const recipes = [...(d.recipes || []), ...custom];
  return { recipes, ingredients: d.ingredients, prices: d.prices, stores: d.stores, matchers: d.matchers };
}

