<!-- Boot — runs LAST so all Babel blocks have registered components -->
<script>
(function(){
  async function loadData(){
  const d = window.__KA_DATA;
  if (!d) throw new Error('Embedded data missing');
  // Merge user-added custom recipes (from prior imports / Claude plans) so
  // they appear alongside built-ins everywhere — library, plan, cook mode.
  let custom = [];
  try { custom = JSON.parse(localStorage.getItem('kitchenAgent:v2:customRecipes') || '[]') || []; } catch {}
  const recipes = [...(d.recipes || []), ...custom];
  return { recipes, ingredients: d.ingredients, prices: d.prices, stores: d.stores, matchers: d.matchers };
}
  const REQUIRED = ['App','Dashboard','MealPlan','RecipeLibrary','RecipeDetail','CookMode',
    'ShoppingList','SchedulePickup','Pantry','ScanItem','ScanReceipt','Orders','Settings',
    'Leftovers','CookHistory','Reminders','ReminderBanner'];
  let waits = 0;
  function mount(){
    waits++;
    if (!window.__KA || REQUIRED.some(k => !window.__KA[k])) {
      if (waits > 200) { // give up after ~10s so user can at least see errors
        const missing = REQUIRED.filter(k => !window.__KA?.[k]);
        console.warn('Kitchen Agent: missing components after 10s:', missing);
      } else {
        return setTimeout(mount, 50);
      }
    }
    // Auto-prune at boot if localStorage is filling up — keep the app reliable.
    try {
      const res = window.__KA?.StorageHealth?.autoPruneIfNeeded?.();
      if (res?.ran) console.log('[KA] Auto-pruned storage:', res);
    } catch {}
    loadData().then(data => {
      ReactDOM.createRoot(document.getElementById('root')).render(
        React.createElement(window.__KA.App, { data })
      );
    }).catch(e => {
      document.getElementById('root').innerHTML =
        `<div style="padding:40px;max-width:560px;margin:0 auto;text-align:center;color:#b45538">
          <h2 style="font-size:24px;margin-bottom:12px">Couldn't load data</h2>
          <p>Make sure you're running a local web server:</p>
          <pre style="background:#f4ebe1;padding:12px;border-radius:8px;text-align:left;margin-top:12px">cd Kitchen_Agent/prototype
python3 -m http.server 8080</pre>
          <p style="opacity:.7;font-size:13px;margin-top:12px">${e.message}</p>
        </div>`;
    });
  }
  // Give Babel 50ms to start processing blocks
  setTimeout(mount, 100);
})();
</script>


<!-- ═══════════════════════════════════════════════════════════════════
     SESSION MANAGER  — Export / Import / Multi-Session support
     Works on top of the existing kitchenAgent:v2: localStorage keys
     ═══════════════════════════════════════════════════════════════════ -->
<script>
(function() {
  const NS = 'kitchenAgent:v2:';
  const SESSION_INDEX = 'ka_sessions_index';

  // ── helpers ──────────────────────────────────────────────────────────
  function getAllKAKeys() {
    return Object.keys(localStorage).filter(k => k.startsWith(NS));
  }

  function captureSnapshot() {
    const snap = {};
    getAllKAKeys().forEach(k => {
      try { snap[k] = JSON.parse(localStorage.getItem(k)); } catch(e) { snap[k] = localStorage.getItem(k); }
    });
    return snap;
  }

  function restoreSnapshot(snap) {
    // Only restore KA keys — never touch unrelated storage
    getAllKAKeys().forEach(k => localStorage.removeItem(k));
    Object.entries(snap).forEach(([k, v]) => {
      try { localStorage.setItem(k, typeof v === 'string' ? v : JSON.stringify(v)); } catch(e) {}
    });
  }

  function getSessionIndex() {
    try { return JSON.parse(localStorage.getItem(SESSION_INDEX)) || {}; } catch(e) { return {}; }
  }

  function saveSessionIndex(idx) {
    localStorage.setItem(SESSION_INDEX, JSON.stringify(idx));
  }

  // ── auto-save current session every 60s ──────────────────────────────
  setInterval(() => {
    try {
      const idx = getSessionIndex();
      idx.__autosave = { snap: captureSnapshot(), ts: Date.now() };
      saveSessionIndex(idx);
    } catch(e) {}
  }, 60000);

  // ── Export as JSON file ───────────────────────────────────────────────
  window.KA_exportSession = function(name) {
    const snap = captureSnapshot();
    const blob = new Blob([JSON.stringify({ name: name || 'Kitchen Agent Session', ts: Date.now(), data: snap }, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `kitchen-session-${new Date().toISOString().slice(0,10)}.json`;
    a.click();
    URL.revokeObjectURL(url);
  };

  // ── Import from JSON file ─────────────────────────────────────────────
  window.KA_importSession = function() {
    const input = document.createElement('input');
    input.type = 'file';
    input.accept = '.json';
    input.onchange = (e) => {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = (ev) => {
        try {
          const parsed = JSON.parse(ev.target.result);
          const snap = parsed.data || parsed; // handle both formats
          restoreSnapshot(snap);
          showToast('✅ Session imported! Reloading…');
          setTimeout(() => location.reload(), 1200);
        } catch(err) {
          showToast('❌ Invalid session file');
        }
      };
      reader.readAsText(file);
    };
    input.click();
  };

  // ── Save named session ────────────────────────────────────────────────
  window.KA_saveNamedSession = function(name) {
    if (!name) return;
    const idx = getSessionIndex();
    idx[name] = { snap: captureSnapshot(), ts: Date.now() };
    saveSessionIndex(idx);
    showToast(`✅ Saved as "${name}"`);
    renderSessionPanel();
  };

  // ── Load named session ────────────────────────────────────────────────
  window.KA_loadNamedSession = function(name) {
    const idx = getSessionIndex();
    if (!idx[name]) return;
    restoreSnapshot(idx[name].snap);
    showToast(`✅ Loaded "${name}" — reloading…`);
    setTimeout(() => location.reload(), 1200);
  };

  // ── Delete named session ──────────────────────────────────────────────
  window.KA_deleteNamedSession = function(name) {
    const idx = getSessionIndex();
    delete idx[name];
    saveSessionIndex(idx);
    showToast(`🗑 Deleted "${name}"`);
    renderSessionPanel();
  };

  // ── Clear current session (fresh start) ──────────────────────────────
  window.KA_clearSession = function() {
    if (!confirm('Clear all current data and start fresh?')) return;
    getAllKAKeys().forEach(k => localStorage.removeItem(k));
    showToast('🧹 Session cleared — reloading…');
    setTimeout(() => location.reload(), 1200);
  };

  // ── Toast notification ────────────────────────────────────────────────
  function showToast(msg) {
    const t = document.getElementById('ka-session-toast');
    if (!t) return;
    t.textContent = msg;
    t.classList.remove('opacity-0', 'translate-y-2');
    t.classList.add('opacity-100', 'translate-y-0');
    setTimeout(() => {
      t.classList.add('opacity-0', 'translate-y-2');
      t.classList.remove('opacity-100', 'translate-y-0');
    }, 3000);
  }

  // ── Session panel rendering ───────────────────────────────────────────
  function renderSessionPanel() {
    const panel = document.getElementById('ka-session-panel-list');
    if (!panel) return;
    const idx = getSessionIndex();
    const sessions = Object.entries(idx).filter(([k]) => k !== '__autosave');
    if (sessions.length === 0) {
      panel.innerHTML = '<p class="text-xs text-stone-400 text-center py-4">No saved sessions yet</p>';
      return;
    }
    panel.innerHTML = sessions.map(([name, data]) => {
      const d = new Date(data.ts).toLocaleDateString('en-US', { month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' });
      return `<div class="flex items-center gap-2 py-2 border-b border-stone-100 last:border-0">
        <div class="flex-1 min-w-0">
          <div class="font-medium text-stone-800 text-sm truncate">${name}</div>
          <div class="text-xs text-stone-400">${d}</div>
        </div>
        <button onclick="KA_loadNamedSession('${name.replace(/'/g,"\\'")}');toggleSessionDrawer()" class="text-xs px-2 py-1 bg-brand-100 text-brand-700 rounded-lg font-medium hover:bg-brand-200 touch-manipulation">Load</button>
        <button onclick="KA_deleteNamedSession('${name.replace(/'/g,"\\'")}');renderSessionPanel()" class="text-xs px-2 py-1 bg-red-50 text-red-600 rounded-lg font-medium hover:bg-red-100 touch-manipulation">✕</button>
      </div>`;
    }).join('');
  }

  // ── Toggle drawer ─────────────────────────────────────────────────────
  window.toggleSessionDrawer = function() {
    const drawer = document.getElementById('ka-session-drawer');
    if (!drawer) return;
    const isOpen = !drawer.classList.contains('translate-x-full');
    if (isOpen) {
      drawer.classList.add('translate-x-full');
      drawer.setAttribute('aria-hidden', 'true');
    } else {
      renderSessionPanel();
      drawer.classList.remove('translate-x-full');
      drawer.setAttribute('aria-hidden', 'false');
    }
  };

  // ── Inject UI after page load ─────────────────────────────────────────
  function injectUI() {
    // Toast
    const toast = document.createElement('div');
    toast.id = 'ka-session-toast';
    toast.className = 'fixed bottom-24 left-1/2 -translate-x-1/2 z-[9999] bg-stone-800 text-white text-sm px-4 py-2 rounded-full shadow-lg opacity-0 translate-y-2 transition-all duration-300 pointer-events-none whitespace-nowrap';
    document.body.appendChild(toast);

    // FAB trigger button (top-right corner)
    const fab = document.createElement('button');
    fab.id = 'ka-session-fab';
    fab.setAttribute('aria-label', 'Sessions');
    fab.onclick = () => toggleSessionDrawer();
    fab.style.cssText = 'position:fixed;top:env(safe-area-inset-top,12px);right:12px;z-index:998;background:#c96b4a;color:white;border:none;border-radius:50%;width:40px;height:40px;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(0,0,0,.2);cursor:pointer;touch-action:manipulation;-webkit-tap-highlight-color:transparent;font-size:18px;';
    fab.innerHTML = '💾';
    document.body.appendChild(fab);

    // Slide-over drawer
    const drawer = document.createElement('div');
    drawer.id = 'ka-session-drawer';
    drawer.setAttribute('role', 'dialog');
    drawer.setAttribute('aria-label', 'Session Manager');
    drawer.setAttribute('aria-hidden', 'true');
    drawer.className = 'fixed inset-y-0 right-0 z-[999] w-80 max-w-[90vw] bg-white shadow-2xl transform translate-x-full transition-transform duration-300 flex flex-col';
    drawer.innerHTML = `
      <div class="flex items-center justify-between px-5 py-4 border-b border-stone-100">
        <h2 class="font-semibold text-stone-800">💾 Sessions</h2>
        <button onclick="toggleSessionDrawer()" aria-label="Close" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-stone-100 text-stone-500 text-lg touch-manipulation">✕</button>
      </div>
      <div class="flex-1 overflow-y-auto px-5 py-4 space-y-4">

        <!-- Save current -->
        <div>
          <p class="text-xs font-semibold text-stone-500 uppercase tracking-wider mb-2">Save Current Session</p>
          <div class="flex gap-2">
            <input id="ka-session-name-input" type="text" placeholder="Session name…" class="flex-1 text-sm border border-stone-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-400" />
            <button onclick="KA_saveNamedSession(document.getElementById('ka-session-name-input').value);document.getElementById('ka-session-name-input').value=''" class="px-3 py-2 bg-brand-500 text-white text-sm rounded-lg font-medium hover:bg-brand-600 touch-manipulation">Save</button>
          </div>
        </div>

        <!-- Export / Import -->
        <div class="grid grid-cols-2 gap-2">
          <button onclick="KA_exportSession()" class="py-2.5 text-sm bg-stone-100 text-stone-700 rounded-xl font-medium hover:bg-stone-200 touch-manipulation">⬇ Export JSON</button>
          <button onclick="KA_importSession()" class="py-2.5 text-sm bg-stone-100 text-stone-700 rounded-xl font-medium hover:bg-stone-200 touch-manipulation">⬆ Import JSON</button>
        </div>

        <!-- Saved sessions list -->
        <div>
          <p class="text-xs font-semibold text-stone-500 uppercase tracking-wider mb-2">Saved Sessions</p>
          <div id="ka-session-panel-list"></div>
        </div>

        <!-- Danger zone -->
        <div class="pt-2 border-t border-stone-100">
          <button onclick="KA_clearSession()" class="w-full py-2.5 text-sm bg-red-50 text-red-600 rounded-xl font-medium hover:bg-red-100 touch-manipulation">🗑 Clear All Data</button>
          <p class="text-xs text-stone-400 text-center mt-2">Your data is stored only in this browser</p>
        </div>
      </div>
    `;
    document.body.appendChild(drawer);

    // Close drawer on backdrop tap
    document.addEventListener('click', (e) => {
      const drawer = document.getElementById('ka-session-drawer');
      const fab = document.getElementById('ka-session-fab');
      if (drawer && !drawer.classList.contains('translate-x-full') &&
          !drawer.contains(e.target) && e.target !== fab) {
        toggleSessionDrawer();
      }
    });
  }

  // Wait for DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', injectUI);
  } else {
    setTimeout(injectUI, 500); // let React render first
  }
})();
</script>


<!-- ===== CLAUDE API INTEGRATION ===== -->
<script>
(function(){
'use strict';

/* ------------------------------------------------------------------ */
/*  1. Core helper — window.KA_claude                                  */
/* ------------------------------------------------------------------ */
/* v14: recipe step overrides — keyed by recipe id, stored in localStorage */
window.KA_getCleanedSteps = function(recipe) {
  if (!recipe) return null;
  try {
    const map = JSON.parse(localStorage.getItem('kitchenAgent:v2:recipeStepOverrides') || '{}');
    const entry = map[recipe.id];
    return entry && Array.isArray(entry.steps) ? entry.steps : null;
  } catch { return null; }
};
window.KA_saveCleanedSteps = function(recipeId, steps) {
  try {
    const map = JSON.parse(localStorage.getItem('kitchenAgent:v2:recipeStepOverrides') || '{}');
    map[recipeId] = { steps, cleaned_at: Date.now() };
    localStorage.setItem('kitchenAgent:v2:recipeStepOverrides', JSON.stringify(map));
    return true;
  } catch (e) { console.warn('saveCleanedSteps failed:', e); return false; }
};
window.KA_clearCleanedSteps = function() {
  try { localStorage.removeItem('kitchenAgent:v2:recipeStepOverrides'); return true; }
  catch { return false; }
};
/* Helper: returns the cleaned-up steps if any, otherwise the original recipe.steps */
window.KA_stepsFor = function(recipe) {
  if (!recipe) return [];
  const cleaned = window.KA_getCleanedSteps(recipe);
  if (cleaned && cleaned.length) return cleaned;
  return recipe.steps || [];
};

/* v14: Cleanup one recipe's steps via Claude (Sonnet) */
window.KA_cleanupRecipeSteps = async function(recipe) {
  if (!recipe) throw new Error('No recipe');
  const original = (recipe.steps || []).join('\n---\n');
  if (!original.trim()) return [];
  const prompt = `You are cleaning up a recipe's step-by-step instructions that got mangled during import. The current text below may contain run-on sentences, non-instructional headers (like "BEST WAYS TO SERVE"), serving suggestions, pairings, or garbled OCR fragments embedded inline.

Return clean, sequential, properly-numbered steps that someone would actually follow while cooking. Drop the non-instructional content.

RECIPE NAME: ${recipe.name || 'Unknown'}
${recipe.servings ? 'SERVINGS: ' + recipe.servings : ''}
${recipe.prep_min ? 'PREP TIME: ' + recipe.prep_min + ' min' : ''}
${recipe.cook_min ? 'COOK TIME: ' + recipe.cook_min + ' min' : ''}

CURRENT (POSSIBLY MESSY) STEPS:
${original}

RULES:
- Split into 4-12 logical numbered steps (most recipes land in this range).
- Each step is a single action; keep it under 200 characters.
- Use imperative voice ("Heat oil in a skillet", not "You should heat the oil...").
- Preserve all real cooking actions, quantities, times, and temperatures.
- DROP serving suggestions, side-dish recommendations, "best ways to serve" headers, sauce-pairing blocks, garbled fragments (e.g. random characters or OCR junk).
- If the original was already clean, return its steps as-is in the same order.

Respond with ONLY a JSON object — no markdown fences:
{"steps": ["step 1...", "step 2...", "..."]}`;

  const raw = await window.KA_claude({
    task: 'recipe-step-cleanup',
    messages: [{ role: 'user', content: prompt }],
  });
  const m = raw.match(/\{[\s\S]*\}/);
  if (!m) throw new Error('No JSON in Claude response');
  const parsed = JSON.parse(m[0]);
  if (!parsed.steps || !Array.isArray(parsed.steps) || !parsed.steps.length) {
    throw new Error('Claude returned no usable steps');
  }
  return parsed.steps;
};

/* v11: real-time price lookup via /.netlify/functions/prices */
window.KA_priceLookup = async function(ingredient, opts = {}) {
  try {
    const res = await fetch('/.netlify/functions/prices', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ingredient, stores: opts.stores || ['kroger','walmart','serpapi'], locationId: opts.locationId, zip: opts.zip }),
    });
    if (!res.ok) return null;
    return await res.json();
  } catch (e) { return null; }
};

window.KA_claude = async function({ task, messages, imageBase64, mimeType, model } = {}) {
  const res = await fetch('/.netlify/functions/claude', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ task, messages, imageBase64, mimeType, model }),
  });
  if (!res.ok) {
    const txt = await res.text();
    throw new Error('Claude API error: ' + txt);
  }
  return (await res.json()).content;
};

/* ------------------------------------------------------------------ */
/*  2. Confidence-check modal for Instacart                            */
/* ------------------------------------------------------------------ */

// Inject modal container once
const MODAL_ID = 'ka-instacart-modal';
function getModal() {
  let el = document.getElementById(MODAL_ID);
  if (!el) {
    el = document.createElement('div');
    el.id = MODAL_ID;
    el.style.cssText = 'display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.45);overflow-y:auto;';
    document.body.appendChild(el);
  }
  return el;
}

// Show confidence review popup, returns final items list
window.KA_instacartConfidence = async function(items) {
  if (!items || items.length === 0) return items;

  const modal = getModal();

  // Ask Claude to score each item and suggest alternatives for low-confidence ones
  let scored = [];
  try {
    const prompt = `You are a grocery matching expert. Given this shopping list, rate each item 0-100 for how confidently a generic search engine would find the right product (100 = very common item like "chicken breast", 50 = somewhat ambiguous, 0 = very unclear). For any item scoring below 85, suggest 2 specific alternative search terms that are clearer.

Items: ${items.map((i, idx) => `${idx+1}. ${i.display || i.name}`).join('\n')}

Respond ONLY with valid JSON array, no markdown. Format:
[{"idx":0,"score":95,"name":"original name","alternatives":[]},{"idx":1,"score":72,"name":"original name","alternatives":["alt 1","alt 2"]}]`;

    const raw = await window.KA_claude({
      task: 'confidence',
      messages: [{ role: 'user', content: prompt }]
    });

    // Extract JSON from response
    const jsonMatch = raw.match(/\[[\s\S]*\]/);
    if (jsonMatch) scored = JSON.parse(jsonMatch[0]);
  } catch (e) {
    console.warn('KA: confidence scoring failed, opening Instacart directly', e.message);
    return items; // fail open
  }

  const flagged = scored.filter(s => s.score < 85);
  if (flagged.length === 0) return items; // all confident, proceed

  // Build modal UI
  return new Promise((resolve) => {
    const selectedAlts = {}; // idx → chosen name (undefined = keep original)

    const render = () => {
      modal.style.display = 'block';
      modal.innerHTML = `
        <div style="max-width:560px;margin:40px auto 80px;background:#fbf7f3;border-radius:20px;padding:24px;box-shadow:0 20px 60px rgba(0,0,0,0.2);">
          <h2 style="font-family:Georgia,serif;font-size:1.5rem;color:#3d2b1f;margin:0 0 4px;">Instacart Review</h2>
          <p style="font-size:0.85rem;color:#78716c;margin:0 0 20px;">${flagged.length} item${flagged.length>1?'s':''} may not match well — pick alternatives or keep originals.</p>

          <div style="display:flex;flex-direction:column;gap:14px;">
            ${flagged.map(item => `
              <div style="background:#fff;border-radius:14px;padding:16px;border:1.5px solid #e7e5e4;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
                  <strong style="color:#3d2b1f;font-size:0.95rem;">${item.name}</strong>
                  <span style="font-size:0.75rem;padding:3px 9px;border-radius:99px;background:${item.score < 60 ? '#fef2f2' : '#fefce8'};color:${item.score < 60 ? '#b91c1c' : '#a16207'};">${item.score}% match</span>
                </div>
                <div style="display:flex;flex-direction:column;gap:7px;">
                  <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:0.88rem;color:#44403c;">
                    <input type="radio" name="alt_${item.idx}" value="__original__" ${!selectedAlts[item.idx]?'checked':''} style="accent-color:#c96b4a;"/>
                    Keep: <em>${item.name}</em>
                  </label>
                  ${(item.alternatives||[]).map((alt, ai) => `
                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:0.88rem;color:#44403c;">
                      <input type="radio" name="alt_${item.idx}" value="${alt.replace(/"/g,'&quot;')}" ${selectedAlts[item.idx]===alt?'checked':''} style="accent-color:#c96b4a;"/>
                      ${alt}
                    </label>
                  `).join('')}
                </div>
              </div>
            `).join('')}
          </div>

          <div style="display:flex;gap:10px;margin-top:24px;">
            <button id="ka-inst-cancel" style="flex:1;padding:13px;border:1.5px solid #d6d3d1;border-radius:12px;background:transparent;color:#78716c;font-size:0.9rem;cursor:pointer;">Cancel</button>
            <button id="ka-inst-confirm" style="flex:2;padding:13px;border:none;border-radius:12px;background:#c96b4a;color:#fff;font-size:0.9rem;font-weight:600;cursor:pointer;">Add to Instacart →</button>
          </div>
        </div>`;

      // Wire up radio buttons
      modal.querySelectorAll('input[type=radio]').forEach(radio => {
        radio.addEventListener('change', (e) => {
          const parts = e.target.name.split('_');
          const idx = parseInt(parts[1]);
          selectedAlts[idx] = e.target.value === '__original__' ? undefined : e.target.value;
        });
      });

      document.getElementById('ka-inst-cancel').onclick = () => {
        modal.style.display = 'none';
        resolve(null); // cancelled
      };

      document.getElementById('ka-inst-confirm').onclick = () => {
        modal.style.display = 'none';
        // Build final items, swapping flagged items that got an alternative
        const finalItems = items.map((item, i) => {
          const scoreEntry = flagged.find(f => f.idx === i);
          if (scoreEntry && selectedAlts[i]) {
            return { ...item, name: selectedAlts[i], display: selectedAlts[i] };
          }
          return item;
        });
        resolve(finalItems);
      };
    };

    render();
  });
};

/* ------------------------------------------------------------------ */
/*  3. Patch Instacart.createRecipeLink to run confidence check first  */
/* ------------------------------------------------------------------ */
function patchInstacart() {
  const KA = window.__KA;
  if (!KA || !KA.Instacart) return false;
  const orig = KA.Instacart.createRecipeLink.bind(KA.Instacart);
  KA.Instacart.createRecipeLink = async function(opts) {
    try {
      const finalIngredients = await window.KA_instacartConfidence(opts.ingredients);
      if (finalIngredients === null) throw new Error('Cancelled by user');
      return orig({ ...opts, ingredients: finalIngredients });
    } catch (e) {
      if (e.message === 'Cancelled by user') throw e;
      console.warn('KA: confidence patch failed, using original', e.message);
      return orig(opts);
    }
  };
  return true;
}

/* ------------------------------------------------------------------ */
/*  4. Patch OCR.recognize to enhance with Claude vision               */
/* ------------------------------------------------------------------ */
function patchOCR() {
  const KA = window.__KA;
  if (!KA || !KA.OCR) return false;
  const origRecognize = KA.OCR.recognize.bind(KA.OCR);

  KA.OCR.recognizeWithClaude = async function(file, onProgress) {
    // First run Tesseract as before
    onProgress && onProgress({ status: 'recognizing text', progress: 0 });
    const tesseractResult = await origRecognize(file, onProgress).catch(() => ({ text: '' }));

    // Also run Claude vision in parallel for richer extraction
    try {
      const base64 = await new Promise((res, rej) => {
        const reader = new FileReader();
        reader.onload = e => res(e.target.result.split(',')[1]);
        reader.onerror = rej;
        reader.readAsDataURL(file);
      });
      const mimeType = file.type || 'image/jpeg';

      const claudeText = await window.KA_claude({
        task: 'vision',
        imageBase64: base64,
        mimeType,
        messages: [{
          role: 'user',
          content: 'Identify all food items, brands, quantities, and any barcodes visible in this image. Return a JSON object: {"items":[{"name":"...","brand":"...","quantity":"...","unit":"...","barcode":"..."}],"raw_text":"..."}'
        }]
      });

      // Try to parse Claude's structured response
      const jsonMatch = claudeText.match(/\{[\s\S]*\}/);
      if (jsonMatch) {
        const parsed = JSON.parse(jsonMatch[0]);
        const combined = parsed.raw_text
          ? (tesseractResult.text || '') + '\n' + parsed.raw_text
          : tesseractResult.text;
        return { text: combined, claudeItems: parsed.items || [], source: 'claude+tesseract' };
      }
    } catch (e) {
      console.warn('KA: Claude vision fallback failed', e.message);
    }

    return { ...tesseractResult, source: 'tesseract' };
  };

  // Override recognize to use Claude-enhanced version
  KA.OCR.recognize = KA.OCR.recognizeWithClaude;
  return true;
}

/* ------------------------------------------------------------------ */
/*  5. Claude-powered meal plan generation (budget-aware)              */
/* ------------------------------------------------------------------ */

// In-memory cache of the most recent Claude plan so the modal can
// regenerate / swap individual meals against the same context.
window.__KA_LAST_CLAUDE_PLAN = null;

function readState_() {
  const out = {};
  ['plan','pantry','profile','shoppingExtras'].forEach(k => {
    try { out[k] = JSON.parse(localStorage.getItem('kitchenAgent:v2:' + k) || 'null'); } catch{}
  });
  return out;
}

function pantryIsEmpty_(pantry) {
  // < 8 real items counts as "essentially empty" → trigger 2-week
  // staple-stocking mode. The default seed adds ~20 items so a freshly seeded
  // pantry will NOT trigger this path.
  const real = (pantry || []).filter(p => p && p.qty > 0);
  return real.length < 8;
}

function buildBudgetPrompt_({ budget, pantryEmpty, dietary, slots, pantryItems, proteinPicks, mealPrep, restrictions, equipment, pickyNotes, householdMembers, perMealMax, weeklyTimeMax, staples, expiringSoon, lowStock, favorites }) {
  const minBudget = (budget * 0.90).toFixed(2);
  const maxBudget = (budget * 1.10).toFixed(2);

  const intro = pantryEmpty
    ? `You are a professional meal planner who is extremely careful about grocery budgets.

THE USER HAS AN ESSENTIALLY EMPTY PANTRY, so you must build a TWO-WEEK plan (14 days) with a TOTAL grocery budget of $${(budget*2).toFixed(2)} (which is 2 x their normal $${budget}/week).

Why two weeks: the first shop must include shelf-stable PANTRY STAPLES that will carry into future weeks (oils, vinegars, spices, rice, pasta, canned goods, condiments, baking basics). Choose staples deliberately so they are reused across MANY of the 14 recipes. The second week's incremental cost should therefore be much lower than the first.`
    : `You are a professional meal planner who is extremely careful about grocery budgets.

Build a 7-day meal plan whose TOTAL grocery cost (everything the user must buy this week, NOT counting items already in their pantry) lands inside $${minBudget} - $${maxBudget} (the user's $${budget} weekly budget +/- 10%).`;

  const planLength = pantryEmpty ? 14 : 7;
  const totalCap   = pantryEmpty ? (budget*2*1.10).toFixed(2) : maxBudget;
  const totalFloor = pantryEmpty ? (budget*2*0.90).toFixed(2) : minBudget;

  return `${intro}

NON-NEGOTIABLE BUDGET RULES (no exceptions):
- estimated_total_cost MUST be between $${totalFloor} and $${totalCap}.
- For every recipe, sum its ingredients_to_buy item costs => recipe.estimated_cost.
- Do NOT include items already in the pantry in any cost calc.
- If a recipe is too expensive, replace it with a cheaper one BEFORE returning.
- Use realistic 2025 US grocery prices (Walmart / Aldi tier). Examples: chicken breast $3.50/lb, ground beef 80/20 $5/lb, eggs (dozen) $3.50, milk (gallon) $4, onion $0.80 ea, bell pepper $1.20 ea, rice (1 lb) $1.20, pasta (1 lb) $1.50, olive oil (16 oz) $7, soy sauce $3.

USER'S "ANYTHING SPECIFIC THIS WEEK" REQUEST (verbatim — honor this strictly): ${dietary}
MEAL SLOTS PER DAY: ${slots}
PROTEIN PREFERENCES: ${proteinPicks || 'any'}

ITEMS ALREADY IN PANTRY (use these as much as possible — every item below is FREE for the user, $0 cost):
  ${pantryItems || '(empty — must buy everything from scratch)'}
${staples ? `STAPLES (reused across many recipes — favor these): ${staples}` : ''}
${expiringSoon ? `EXPIRING SOON (use within 5 days, prioritize these in early-week meals): ${expiringSoon}` : ''}
${lowStock ? `LOW-STOCK (running out — only count on small amounts): ${lowStock}` : ''}

MEAL-PREP LUNCH: ${mealPrep ? 'Yes — pick ONE lunch recipe and repeat it' : 'No'}

HARD DIETARY RESTRICTIONS (NEVER violate — these are blockers, not preferences):
  ${restrictions || '(none)'}
KITCHEN EQUIPMENT AVAILABLE (only suggest recipes that can be made with these):
  ${equipment}
HOUSEHOLD MEMBERS &amp; THEIR ALLERGIES/DISLIKES (respect every single one — allergies are blockers):
  ${householdMembers || '(only the primary user)'}
${pickyNotes ? `ADDITIONAL PICKY-EATER NOTES (treat as soft constraints): ${pickyNotes}` : ''}
${perMealMax ? `MAX TIME PER MEAL: ${perMealMax} min (prep + cook combined). Never exceed.` : ''}
${weeklyTimeMax ? `MAX WEEKLY COOK TIME: ${weeklyTimeMax} min total across all 7 days.` : ''}
${favorites ? `USER'S TOP-RATED RECIPES (lean toward these or similar styles): ${favorites}` : ''}

PLANNING RULES (in priority order):
0. ABSOLUTE: never include any recipe that violates a hard dietary restriction or any household member's allergy. Filter these out BEFORE considering anything else.
1. Honor the user's "anything specific this week" text VERBATIM. If they wrote "spicy thai" or "chicken twice", that is a hard requirement — work it into the plan.
2. Use the pantry list above AGGRESSIVELY. A recipe that uses 4 pantry items beats one that uses 1, even if the latter is more exciting. Whenever a recipe uses a pantry item, list its id under "uses_pantry". Items marked EXPIRING SOON should be used in days 1-3 of the plan.
3. Account for leftovers. If a dinner makes 4 servings and the household = 2, REUSE it as the next day's lunch — and set that lunch's "leftover_from" to "day N dinner" exactly. Aim to populate at least 2-3 leftover lunches across the week.
4. Vary cuisines across days (no back-to-back repeats) but do NOT vary at the cost of pantry use.
5. Practical weeknight cook times (30-45 min); weekend can be longer.
5b. COOKWARE REUSE: when multiple meals are cooked on the same day, prefer recipes that share pans/equipment. Example: dinner is "skillet chicken" + side is "skillet vegetables" → both use the 12-inch skillet, so user only washes one pan. Consider this only after the budget, pantry, and dietary rules are satisfied.
6. Use SPECIFIC recipe names (e.g. "Garlic Soy Chicken Thighs", not "chicken dish").
7. If pantry is empty, lean HARD on staples that get reused: one $7 olive oil powers 6+ recipes; one $3 soy sauce powers 4+; one $1.50 pasta powers 2+. Reuse > variety when stocking.

Respond with ONLY a JSON object - no markdown fences, no commentary. Schema:

{
  "weeks": ${planLength === 14 ? 2 : 1},
  "is_pantry_stocking": ${pantryEmpty},
  "budget_per_week": ${budget},
  "estimated_total_cost": <number>,
  "estimated_first_week_cost": <number>,
  "estimated_second_week_cost": ${pantryEmpty ? '<number>' : 'null'},
  "days": [
    {
      "date_label": "Monday (Week 1)",
      "day_index": 0,
      "breakfast": {
        "name": "...",
        "servings": 2,
        "estimated_cost": <number>,
        "uses_pantry": ["staple ids"],
        "ingredients_to_buy": [{"item":"...","qty":"...","cost":<number>}],
        "notes": "..."
      },
      "lunch":   { "name":"...","servings":2,"estimated_cost":<number>,"uses_pantry":[],"ingredients_to_buy":[],"leftover_from":"day N dinner (optional)","notes":"","equipment_used":["e.g. 'small saucepan'","'microwave'"] },
      "dinner":  { "name":"...","servings":4,"estimated_cost":<number>,"uses_pantry":[],"ingredients_to_buy":[],"notes":"","equipment_used":["e.g. '12-inch skillet'","'sheet pan'"] }
    }
    /* repeat for ${planLength} days total */
  ],
  "pantry_staples_to_buy": [
    {"item":"olive oil (16 oz)","cost":7.00,"powers_recipes":["Recipe A","Recipe B"]}
  ],
  "shopping_highlights": ["3 fresh items worth buying this week"],
  "prep_tip": "One short meal-prep tip"
}

Return JSON only. estimated_total_cost is the sum of every meal's estimated_cost across all ${planLength} days PLUS any pantry_staples_to_buy costs that aren't already itemized in a meal.`;
}

/* v15: chunked meal plan generation.
   - Phase A (skeleton, Haiku, ~2-3s): one tiny call returns 7 day themes + one-line meal names per slot.
   - Phase B (details, Sonnet, parallel, ~3-5s each): each day gets its own call returning full JSON
     (costs, ingredients_to_buy, uses_pantry, leftover_from, equipment_used).
   - Every individual Netlify call stays well under 10s. Total wall ≈ 5-8s on a fast connection.
   - The modal shows progress as days arrive ("✓ Monday · ⏳ Tuesday · …").
*/
window.KA_claudeMealPlan = async function() {
  const KA = window.__KA;
  if (!KA) return;
  const state = readState_();

  const profile = state.profile || {};
  const budget = Math.min(300, Math.max(50, parseInt(profile.weekly_budget) || 150));
  const pantryEmpty = pantryIsEmpty_(state.pantry);
  const foodPantry = (state.pantry || []).filter(p => p && p.qty > 0 && (p.location||'pantry') !== 'non_food');
  const pantryItems = foodPantry.map(p => p.name || p.ingredient_id).slice(0, 30).join(', ');
  const staples = foodPantry.filter(p => p.is_staple).map(p => p.name).slice(0, 10).join(', ');
  const expiringSoon = foodPantry.filter(p => {
    const days = (new Date(p.expires_at) - Date.now()) / 86400000;
    return days >= 0 && days <= 5;
  }).map(p => p.name).slice(0, 8).join(', ');
  const dietary = (profile.preferences_text || '').slice(0, 200) || 'no specific notes';
  const restrictions = (profile.dietary_restrictions || []).join(', ');
  const equipment = (profile.equipment || ['oven','stovetop','microwave']).join(', ');
  const slots = (profile.meal_slots || ['breakfast','lunch','dinner']);
  const slotList = slots.join(', ');
  const proteinPicks = (profile.protein_picks || []).join(', ');
  const mealPrep = !!profile.meal_prep_lunch;
  const pickyNotes = (profile.picky_eater_notes || '').slice(0, 200);
  const householdMembers = (profile.household_members || []).map(m =>
    `${m.name}${m.allergies?.length ? ' (allergic: ' + m.allergies.join(', ') + ')' : ''}${m.dislikes?.length ? ' (dislikes: ' + m.dislikes.join(', ') + ')' : ''}`
  ).join('; ');
  const perMealMax = profile.per_meal_time_max || 0;
  const planLength = pantryEmpty ? 14 : 7;
  const targetBudget = pantryEmpty ? budget * 2 : budget;
  const dailyBudget = (targetBudget / planLength).toFixed(2);

  const constraintsBlock = [
    `BUDGET: $${dailyBudget}/day target (total ${planLength}-day budget $${targetBudget.toFixed(2)} ±10%).`,
    restrictions ? `HARD RESTRICTIONS (never violate): ${restrictions}.` : null,
    householdMembers ? `HOUSEHOLD: ${householdMembers}.` : null,
    `EQUIPMENT available: ${equipment}.`,
    perMealMax ? `MAX per-meal time: ${perMealMax} min.` : null,
    pickyNotes ? `Picky notes: ${pickyNotes}.` : null,
    proteinPicks ? `Protein preferences: ${proteinPicks}.` : null,
    dietary && dietary !== 'no specific notes' ? `Special this week: ${dietary}.` : null,
    pantryItems ? `Pantry (already have — use, $0 cost): ${pantryItems}.` : null,
    expiringSoon ? `Expiring in ≤5 days (prioritize early in week): ${expiringSoon}.` : null,
  ].filter(Boolean).join(' ');

  const statusEl = document.getElementById('ka-claude-plan-status');
  const setStatus = (msg) => { if (statusEl) statusEl.textContent = msg; };

  // -- Phase A: skeleton (Haiku, tiny output) --
  setStatus(`⏳ Sketching ${planLength}-day plan…`);
  const skeletonPrompt = `Build a ${planLength}-day meal plan skeleton. ${constraintsBlock}

For each day, return:
- date_label ("Monday", "Tuesday", etc.)
- cuisine_theme (e.g. "Italian", "Mexican", "Sheet pan")
- one-line meal NAMES per slot (${slotList}). Each name 4-7 words, specific (e.g. "Garlic Soy Chicken Thighs"), no recipe details.

RULES:
- Vary cuisines across days (no back-to-back repeats).
- Account for leftovers: at least 2 lunches should reuse a previous dinner. Tag those with leftover_from.
${mealPrep ? (
    profile.meal_prep_lunch_2
      ? `- MEAL-PREP MODE (TWO LANES): pick TWO different lunch recipes. Recipe A repeats for ${profile.meal_prep_lunch_count || 4} days; Recipe B repeats for ${profile.meal_prep_lunch_count_2 || 3} days. Remaining days use dinner leftovers.`
      : `- MEAL-PREP MODE: pick ONE lunch recipe and repeat for ${profile.meal_prep_lunch_count || 4} servings; remaining days use leftovers.`
  ) : ''}

Respond with ONLY JSON, no markdown:
{
  "days": [
    {"day_index": 0, "date_label": "Monday", "cuisine_theme": "...", "breakfast": "...", "lunch": "...", "dinner": "...", "snack": "...", "leftover_from": null}
    ${planLength === 14 ? ',// repeat through Sunday week 2' : ''}
  ]
}`;

  let skeleton;
  try {
    const rawSkeleton = await window.KA_claude({
      task: 'meal-plan-skeleton',
      messages: [{ role: 'user', content: skeletonPrompt }],
    });
    const m = rawSkeleton.match(/\{[\s\S]*\}/);
    if (!m) throw new Error('Skeleton: no JSON in response');
    skeleton = JSON.parse(m[0]);
    if (!skeleton.days || !Array.isArray(skeleton.days) || !skeleton.days.length) {
      throw new Error('Skeleton: empty days array');
    }
  } catch (e) {
    setStatus('');
    alert('Skeleton phase failed: ' + e.message + '. Try again — usually a transient timeout.');
    console.error(e);
    return;
  }

  // -- Phase B: per-day details, parallel --
  const days = skeleton.days.slice(0, planLength);
  const progress = { done: 0, total: days.length, errors: 0 };
  setStatus(`⏳ Got ${days.length}-day skeleton. Filling in details (parallel)…`);

  const detailPrompt = (day) => `You are filling in details for one day of a meal plan. The skeleton picked these meal names — keep them as-is.

DAY: ${day.date_label} (${day.cuisine_theme})
${slots.map(slot => day[slot] ? `${slot.toUpperCase()}: ${day[slot]}` : '').filter(Boolean).join('\n')}
${day.leftover_from ? 'LEFTOVER_FROM: ' + day.leftover_from : ''}

CONSTRAINTS: ${constraintsBlock}

For each meal, return:
- name (same as skeleton)
- servings (number)
- estimated_cost (USD)
- uses_pantry: array of pantry items used (free)
- ingredients_to_buy: [{item, qty, cost}]
- equipment_used: array of equipment ("12-inch skillet", "sheet pan", etc.)
- notes: 1 sentence prep tip
- leftover_from (if this slot uses leftovers, copy from skeleton; else null)

Use realistic 2025 Walmart/Aldi pricing (chicken breast $3.50/lb, eggs $3.50/dozen, rice $1.20/lb, etc.). Pantry items have $0 cost.

Respond with ONLY JSON:
{
  "day_index": ${day.day_index},
  "date_label": "${day.date_label}",
  ${slots.map(slot => day[slot] ? `"${slot}": {"name":"...","servings":2,"estimated_cost":0,"uses_pantry":[],"ingredients_to_buy":[],"equipment_used":[],"notes":"","leftover_from":null}` : '').filter(Boolean).join(',\n  ')}
}`;

  const detailPromises = days.map((day, idx) => (async () => {
    try {
      const raw = await window.KA_claude({
        task: 'meal-plan-day',
        messages: [{ role: 'user', content: detailPrompt(day) }],
      });
      const m = raw.match(/\{[\s\S]*\}/);
      if (!m) throw new Error('day ' + idx + ': no JSON');
      const detail = JSON.parse(m[0]);
      progress.done++;
      setStatus(`⏳ Filled ${progress.done}/${progress.total} days…`);
      return detail;
    } catch (e) {
      progress.errors++;
      progress.done++;
      console.warn('Day detail failed for', day.date_label, e.message);
      // Fallback: synthesize a barebones detail so the plan still renders
      const synth = { day_index: day.day_index, date_label: day.date_label };
      slots.forEach(slot => {
        if (day[slot]) synth[slot] = { name: day[slot], servings: 2, estimated_cost: 0, uses_pantry: [], ingredients_to_buy: [], equipment_used: [], notes: '(detail unavailable — retry)', leftover_from: day.leftover_from || null };
      });
      return synth;
    }
  })());

  const detailedDays = await Promise.all(detailPromises);

  // -- Phase C: assemble final plan object --
  const plan = {
    weeks: planLength === 14 ? 2 : 1,
    is_pantry_stocking: pantryEmpty,
    budget_per_week: budget,
    days: detailedDays,
    estimated_total_cost: detailedDays.reduce((sum, d) => {
      return sum + slots.reduce((s, slot) => s + (d[slot]?.estimated_cost || 0), 0);
    }, 0),
    shopping_highlights: [],
    pantry_staples_to_buy: [],
    prep_tip: pantryEmpty ? 'Empty pantry: invest in staples this week — olive oil, salt, pepper, rice, pasta, garlic.' : null,
    _budget: budget,
    _pantryEmpty: pantryEmpty,
    _dateAnchor: new Date().toISOString().slice(0,10),
    _generationErrors: progress.errors,
  };

  setStatus('');
  if (progress.errors > 0) {
    KA?.notify?.(`Plan generated with ${progress.errors} day${progress.errors===1?'':'s'} fallback — open the modal and tap Swap on incomplete meals.`, 'info');
  }
  window.__KA_LAST_CLAUDE_PLAN = plan;
  showMealPlanResult(plan);
  return plan;
};

/* ------------------------------------------------------------------ */
/*  Helpers used by the modal                                          */
/* ------------------------------------------------------------------ */
function planTotalCost_(plan) {
  let total = 0;
  (plan.days || []).forEach(day => {
    ['breakfast','lunch','dinner','snack'].forEach(s => {
      if (day[s] && typeof day[s].estimated_cost === 'number') total += day[s].estimated_cost;
    });
  });
  (plan.pantry_staples_to_buy || []).forEach(p => {
    if (typeof p.cost === 'number') total += p.cost;
  });
  return total;
}

function recipeFromClaudeMeal_(meal, slot) {
  // Convert one Claude meal into a custom recipe stored via KA_addRecipe.
  const id = 'claude-' + Date.now() + '-' + Math.random().toString(36).slice(2,8);
  const ingredients = [];
  (meal.ingredients_to_buy || []).forEach(ing => {
    ingredients.push({ name: ing.item, qty: ing.qty || '', notes: 'buy ($' + (Number(ing.cost)||0).toFixed(2) + ')' });
  });
  (meal.uses_pantry || []).forEach(p => {
    ingredients.push({ name: typeof p === 'string' ? p : (p.item || p.name), qty: '', notes: 'from pantry' });
  });
  return {
    id,
    name: meal.name,
    source: 'Claude',
    servings: meal.servings || 2,
    prep_min: 10, cook_min: 25,
    tags: ['ai', slot],
    meal_types: [slot],
    cuisine: meal.cuisine || '',
    ingredients,
    canonical_ingredients: [],
    steps: meal.notes ? [meal.notes] : ['Generated by Claude — adjust to taste.'],
    notes: meal.notes || '',
    estimated_cost: meal.estimated_cost || 0,
    leftover_from: meal.leftover_from || null,
    equipment_used: meal.equipment_used || [],
    image: null,
  };
}

window.KA_applyClaudePlan = function(plan) {
  // Add each suggested meal as a custom recipe and write the weekly plan.
  if (!plan || !plan.days) return false;
  try {
    const start = new Date(plan._dateAnchor || new Date().toISOString().slice(0,10));
    start.setHours(0,0,0,0);

    const existing = JSON.parse(localStorage.getItem('kitchenAgent:v2:plan') || '{}');
    const newPlan = { ...existing };

    plan.days.forEach((day, idx) => {
      const d = new Date(start);
      d.setDate(d.getDate() + (typeof day.day_index === 'number' ? day.day_index : idx));
      const key = d.toISOString().slice(0,10);
      const slotMap = { ...(newPlan[key] || {}) };
      ['breakfast','lunch','dinner','snack'].forEach(slot => {
        const meal = day[slot];
        if (!meal || !meal.name) return;
        const customs = JSON.parse(localStorage.getItem('kitchenAgent:v2:customRecipes') || '[]');
        let existingRec = customs.find(r => r.name === meal.name && (r.meal_types||[]).includes(slot));
        if (!existingRec) {
          existingRec = recipeFromClaudeMeal_(meal, slot);
          if (typeof window.KA_addRecipe === 'function') window.KA_addRecipe(existingRec);
        }
        slotMap[slot] = existingRec.id;
      });
      newPlan[key] = slotMap;
    });

    localStorage.setItem('kitchenAgent:v2:plan', JSON.stringify(newPlan));
    window.dispatchEvent(new Event('kitchenagent:reload'));
    return true;
  } catch (e) {
    console.error('[KA] applyClaudePlan failed', e);
    alert('Could not add meals to plan: ' + e.message);
    return false;
  }
};

window.KA_swapClaudeMeal = async function(dayIdx, slot, modalRefresh) {
  const plan = window.__KA_LAST_CLAUDE_PLAN;
  if (!plan) return;
  const currentDay = plan.days[dayIdx];
  const currentMeal = currentDay && currentDay[slot];
  if (!currentMeal) return;

  const usedNames = [];
  plan.days.forEach(d => ['breakfast','lunch','dinner','snack'].forEach(s => {
    if (d[s] && d[s].name) usedNames.push(d[s].name);
  }));

  const target = (plan._budget || 150) * (plan._pantryEmpty ? 2 : 1);
  const remainingBudget = target - planTotalCost_(plan) + (currentMeal.estimated_cost || 0);
  const dietary = (JSON.parse(localStorage.getItem('kitchenAgent:v2:profile')||'{}').preferences_text) || 'no specific restrictions';

  const swapPrompt = `Suggest ONE alternative ${slot} recipe to replace "${currentMeal.name}" on ${currentDay.date_label}.

CONSTRAINTS:
- Must NOT be any of: ${usedNames.join(', ')}.
- estimated_cost must be <= $${Math.max(2, remainingBudget).toFixed(2)} (this keeps the total grocery bill within +/-10% of $${plan._budget}).
- Use realistic 2025 US grocery prices. Don't include items already in the pantry in cost.
- Dietary preference: ${dietary}.

Respond with ONLY a JSON object:
{"name":"...","servings":<number>,"estimated_cost":<number>,"uses_pantry":[],"ingredients_to_buy":[{"item":"...","qty":"...","cost":<number>}],"notes":"..."}`;

  try {
    const raw = await window.KA_claude({
      task: 'recipe-swap',
      messages: [{ role: 'user', content: swapPrompt }]
    });
    const m = raw.match(/\{[\s\S]*\}/);
    if (!m) throw new Error('No JSON in swap response');
    const newMeal = JSON.parse(m[0]);
    plan.days[dayIdx][slot] = newMeal;
    if (typeof modalRefresh === 'function') modalRefresh();
  } catch (e) {
    alert('Swap failed: ' + e.message);
  }
};

function showMealPlanResult(plan) {
  // Remove any existing modal so re-renders during swap don't stack.
  document.querySelectorAll('.ka-claude-plan-modal').forEach(el => el.remove());

  const slotEmoji = { breakfast: '🌅', lunch: '☀️', dinner: '🌙', snack: '🍎' };
  const budget = plan._budget || 150;
  const pantryEmpty = !!plan._pantryEmpty;
  const target = pantryEmpty ? budget * 2 : budget;
  const total = planTotalCost_(plan);
  const pct = Math.min(140, Math.round((total / target) * 100));
  const inBudget = total <= target * 1.10 + 0.01 && total >= target * 0.90 - 0.01;
  const barColor = inBudget ? '#16a34a' : (total > target ? '#dc2626' : '#d97706');

  const modal = document.createElement('div');
  modal.className = 'ka-claude-plan-modal';
  modal.style.cssText = 'position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.5);overflow-y:auto;';

  const refresh = () => showMealPlanResult(plan);

  const days = plan.days || [];

  modal.innerHTML = `
    <div style="max-width:720px;margin:32px auto 80px;background:#fbf7f3;border-radius:20px;padding:24px;box-shadow:0 20px 60px rgba(0,0,0,0.25);">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-bottom:16px;">
        <div style="flex:1;min-width:0;">
          <h2 style="font-family:Georgia,serif;font-size:1.55rem;color:#3d2b1f;margin:0;">✨ Claude's Meal Plan</h2>
          <p style="color:#78716c;font-size:0.83rem;margin:4px 0 0;">
            ${pantryEmpty
              ? '<strong style="color:#c96b4a">2-week pantry-stocking plan</strong> — empty pantry detected, so we doubled the budget and chose recipes that share staples.'
              : 'Generated with Claude Opus — optimized for budget, leftovers &amp; variety.'}
          </p>
        </div>
        <button class="ka-mp-close" style="width:34px;height:34px;border-radius:50%;border:1.5px solid #d6d3d1;background:#fff;font-size:1.05rem;cursor:pointer;flex-shrink:0;">✕</button>
      </div>

      <!-- Budget bar -->
      <div style="background:#fff;border-radius:14px;padding:14px 16px;border:1px solid #e7e5e4;margin-bottom:14px;">
        <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px;">
          <div style="font-size:0.78rem;color:#78716c;text-transform:uppercase;letter-spacing:0.05em;font-weight:600;">
            Estimated total ${pantryEmpty ? '(2 weeks)' : '(week)'}
          </div>
          <div style="font-family:Georgia,serif;font-size:1.25rem;color:${barColor};font-weight:700;">
            $${total.toFixed(2)} <span style="font-size:0.8rem;color:#a8a29e;font-weight:400;">/ $${target.toFixed(2)}</span>
          </div>
        </div>
        <div style="height:8px;background:#f5f5f4;border-radius:99px;overflow:hidden;">
          <div style="height:100%;width:${Math.min(100,pct)}%;background:${barColor};border-radius:99px;transition:width 0.4s;"></div>
        </div>
        <div style="display:flex;justify-content:space-between;font-size:0.72rem;color:#a8a29e;margin-top:4px;">
          <span>$${(target*0.90).toFixed(2)} (-10%)</span>
          <span style="color:${inBudget?'#16a34a':'#dc2626'};font-weight:600;">${inBudget ? '✓ within ±10% of budget' : '⚠ outside ±10% range'}</span>
          <span>$${(target*1.10).toFixed(2)} (+10%)</span>
        </div>
      </div>

      <!-- Primary action: add to plan -->
      <div style="display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;">
        <button class="ka-mp-add" style="flex:1;min-width:200px;padding:13px 18px;background:linear-gradient(135deg,#16a34a,#15803d);color:#fff;border:none;border-radius:12px;font-size:0.95rem;font-weight:600;cursor:pointer;box-shadow:0 4px 12px rgba(22,163,74,0.3);">
          ➕ Add ${days.length === 14 ? 'all 14 days' : 'all 7 days'} to my plan
        </button>
        <button class="ka-mp-regen" style="padding:13px 16px;background:#fff;color:#3d2b1f;border:1.5px solid #e7e5e4;border-radius:12px;font-size:0.88rem;font-weight:600;cursor:pointer;">
          🔄 New plan
        </button>
      </div>

      ${plan.pantry_staples_to_buy?.length ? `
        <div style="background:#fef3c7;border-radius:14px;padding:14px;margin-bottom:14px;border:1px solid #fde68a;">
          <div style="font-weight:700;color:#92400e;font-size:0.85rem;margin-bottom:8px;">🥫 Pantry staples to buy (reused across many recipes)</div>
          <ul style="margin:0;padding-left:18px;font-size:0.85rem;color:#3d2b1f;">
            ${plan.pantry_staples_to_buy.map(p => `
              <li style="margin-bottom:4px;">
                <strong>${p.item}</strong> · $${(Number(p.cost)||0).toFixed(2)}
                ${p.powers_recipes?.length ? `<span style="color:#78716c;font-size:0.8rem;"> — used in: ${p.powers_recipes.join(', ')}</span>` : ''}
              </li>
            `).join('')}
          </ul>
        </div>
      ` : ''}

      <!-- Days list -->
      <div style="display:flex;flex-direction:column;gap:12px;">
        ${days.map((day, dIdx) => `
          <div style="background:#fff;border-radius:14px;padding:14px;border:1px solid #e7e5e4;">
            <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px;">
              <div style="font-weight:700;color:#c96b4a;font-size:0.85rem;text-transform:uppercase;letter-spacing:0.05em;">${day.date_label}</div>
            </div>
            <div style="display:flex;flex-direction:column;gap:8px;">
              ${['breakfast','lunch','dinner','snack'].filter(s => day[s]).map(slot => {
                const meal = day[slot];
                return `
                  <div style="display:flex;gap:10px;align-items:flex-start;padding:8px;border-radius:10px;background:#fafaf9;">
                    <span style="font-size:1.1rem;width:24px;flex-shrink:0;line-height:1;">${slotEmoji[slot]||'🍽️'}</span>
                    <div style="flex:1;min-width:0;">
                      <div style="display:flex;justify-content:space-between;gap:8px;align-items:baseline;flex-wrap:wrap;">
                        <span style="font-size:0.92rem;color:#3d2b1f;font-weight:600;">${meal.name}</span>
                        <span style="font-size:0.78rem;color:#78716c;font-weight:600;white-space:nowrap;">$${(Number(meal.estimated_cost)||0).toFixed(2)}</span>
                      </div>
                      ${meal.leftover_from ? `<div style="font-size:0.74rem;color:#a8a29e;font-style:italic;">↻ leftovers from ${meal.leftover_from}</div>` : ''}
                      ${meal.equipment_used?.length ? `<div style="font-size:0.72rem;color:#78716c;margin-top:2px;">🍳 ${meal.equipment_used.join(' · ')}</div>` : ''}
                      ${meal.notes ? `<div style="font-size:0.78rem;color:#78716c;margin-top:2px;">${meal.notes}</div>` : ''}
                      <button class="ka-mp-swap" data-day="${dIdx}" data-slot="${slot}" style="margin-top:6px;font-size:0.74rem;color:#c96b4a;background:transparent;border:1px solid #f5e6e0;padding:3px 9px;border-radius:99px;cursor:pointer;font-weight:600;">↔ Swap</button>
                    </div>
                  </div>
                `;
              }).join('')}
            </div>
            ${(() => {
              // v10: cookware-sharing callout per day
              const allEq = ['breakfast','lunch','dinner','snack']
                .filter(s => day[s]?.equipment_used?.length)
                .flatMap(s => day[s].equipment_used);
              const counts = {};
              allEq.forEach(e => { const k = String(e).toLowerCase().trim(); counts[k] = (counts[k]||0)+1; });
              const reused = Object.entries(counts).filter(([_,n]) => n >= 2);
              if (!reused.length) return '';
              return `<div style="margin-top:8px;padding:6px 10px;background:#ecfdf5;border-radius:8px;border:1px solid #a7f3d0;font-size:0.74rem;color:#065f46;">
                ♻️ <strong>Pan reuse:</strong> ${reused.map(([k,n]) => `${k} (used ${n}×)`).join(', ')}
              </div>`;
            })()}
          </div>
        `).join('')}
      </div>

      ${plan.shopping_highlights?.length ? `
        <div style="background:#f0f4ff;border-radius:14px;padding:14px;margin-top:14px;">
          <div style="font-weight:600;color:#3451c7;font-size:0.85rem;margin-bottom:6px;">🛒 Buy fresh this week</div>
          <ul style="margin:0;padding-left:18px;font-size:0.86rem;color:#3d2b1f;">
            ${plan.shopping_highlights.map(h => `<li>${h}</li>`).join('')}
          </ul>
        </div>
      ` : ''}

      ${plan.prep_tip ? `
        <div style="background:#f0fdf4;border-radius:14px;padding:14px;margin-top:10px;font-size:0.86rem;color:#166534;">
          💡 ${plan.prep_tip}
        </div>
      ` : ''}

      <p style="font-size:0.74rem;color:#a8a29e;margin-top:16px;text-align:center;">
        Costs are AI estimates based on Walmart/Aldi pricing. Actual receipts may vary ±15%.
        Items already in your pantry are excluded from these totals.
      </p>
    </div>`;

  document.body.appendChild(modal);

  modal.querySelector('.ka-mp-close').onclick = () => modal.remove();
  modal.onclick = (e) => { if (e.target === modal) modal.remove(); };

  modal.querySelector('.ka-mp-add').onclick = () => {
    const ok = window.KA_applyClaudePlan(plan);
    if (ok) {
      modal.remove();
      const toast = document.createElement('div');
      toast.textContent = `✓ Added ${days.length} day${days.length===1?'':'s'} of meals to your plan`;
      toast.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:10000;background:#16a34a;color:#fff;padding:12px 20px;border-radius:99px;font-weight:600;font-size:0.9rem;box-shadow:0 6px 20px rgba(22,163,74,0.4);';
      document.body.appendChild(toast);
      setTimeout(() => toast.remove(), 3500);
    }
  };

  modal.querySelector('.ka-mp-regen').onclick = async () => {
    modal.remove();
    await window.KA_claudeMealPlan();
  };

  modal.querySelectorAll('.ka-mp-swap').forEach(btn => {
    btn.onclick = async () => {
      const dayIdx = parseInt(btn.getAttribute('data-day'));
      const slot = btn.getAttribute('data-slot');
      btn.textContent = '⏳ swapping…';
      btn.disabled = true;
      await window.KA_swapClaudeMeal(dayIdx, slot, refresh);
    };
  });
}

/* ------------------------------------------------------------------ */
/*  6. (Disabled) "✨ Claude Plan" button — primary planner button     */
/*  in the React component now triggers Claude by default. We keep    */
/*  this stub so legacy boot logic doesn't crash.                     */
/* ------------------------------------------------------------------ */
function injectClaudePlanButton() {
  // Intentionally a no-op. See MealPlan component's "Plan my week with Claude" button.
  return;
  // eslint-disable-next-line
  function legacyInjectClaudePlanButton_() {
  // Look for the meal plan heading and inject button next to it
  const observer = new MutationObserver(() => {
    // Find h1 with text "Meal plan" or "Meal Plan"
    const h1s = document.querySelectorAll('h1');
    for (const h1 of h1s) {
      if (/meal.plan/i.test(h1.textContent) && !h1.parentElement.querySelector('#ka-claude-plan-btn')) {
        const wrapper = h1.closest('div');
        if (!wrapper) continue;

        // Inject status span and button
        const statusSpan = document.createElement('span');
        statusSpan.id = 'ka-claude-plan-status';
        statusSpan.style.cssText = 'font-size:0.8rem;color:#c96b4a;';

        const btn = document.createElement('button');
        btn.id = 'ka-claude-plan-btn';
        btn.innerHTML = '✨ Claude Plan';
        btn.title = 'Generate an AI-optimized 7-day meal plan with Claude Opus';
        btn.style.cssText = [
          'display:inline-flex',
          'align-items:center',
          'gap:5px',
          'padding:7px 14px',
          'background:linear-gradient(135deg,#c96b4a,#d97706)',
          'color:#fff',
          'border:none',
          'border-radius:99px',
          'font-size:0.82rem',
          'font-weight:600',
          'cursor:pointer',
          'box-shadow:0 2px 8px rgba(201,107,74,0.35)',
          'white-space:nowrap',
        ].join(';');

        btn.onclick = async () => {
          btn.disabled = true;
          btn.textContent = '⏳ Planning…';
          try {
            await window.KA_claudeMealPlan();
          } finally {
            btn.disabled = false;
            btn.innerHTML = '✨ Claude Plan';
          }
        };

        // Insert after h1
        const row = document.createElement('div');
        row.style.cssText = 'display:flex;align-items:center;gap:10px;margin-top:10px;flex-wrap:wrap;';
        row.appendChild(btn);
        row.appendChild(statusSpan);
        h1.parentElement.appendChild(row);
        break;
      }
    }
  });

  observer.observe(document.body, { childList: true, subtree: true });
}

}

/* ------------------------------------------------------------------ */
/*  Boot — wait for __KA to be ready then patch                       */
/* ------------------------------------------------------------------ */
function boot() {
  let attempts = 0;
  const interval = setInterval(() => {
    if (window.__KA) {
      clearInterval(interval);
      patchInstacart();
      patchOCR();
      injectClaudePlanButton();
      console.log('[KA Claude] Integration ready — Sonnet for recipes/vision/shopping, Opus for meal plans');
    } else if (++attempts > 100) {
      clearInterval(interval);
      console.warn('[KA Claude] __KA not found after 10s, patches skipped');
    }
  }, 100);
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', boot);
} else {
  boot();
}

})();
</script>
<!-- =============== REMINDERS + NOTIFICATIONS (v10) =============== -->
<script type="text/babel" data-type="module">
const { useState, useEffect, useMemo } = React;
const K = window.__KA;
const { Icon, Card, Section, Button, Badge, Chip, Input, useApp } = K;

// --- Engine: derive a list of pending reminders from current state ---
function computeReminders(state) {
  const out = [];
  const now = Date.now();
  const day = 86400000;

  // 1. Expiring food (≤3 days, not non-food)
  (state.pantry || []).forEach(p => {
    if (!p || (p.location||'pantry') === 'non_food') return;
    const t = new Date(p.expires_at).getTime();
    const diff = (t - now) / day;
    if (diff >= 0 && diff <= 3) {
      out.push({
        id: 'exp-' + p.id,
        category: 'expiring',
        priority: 70 - diff * 10,
        title: 'Use up ' + p.name,
        body: 'Expires in ' + Math.max(0, Math.round(diff)) + 'd · ' + p.qty + ' ' + (p.unit||''),
        url: '/?view=pantry',
      });
    } else if (diff < 0) {
      out.push({
        id: 'expd-' + p.id,
        category: 'expired',
        priority: 80,
        title: p.name + ' is expired',
        body: 'Expired ' + Math.abs(Math.round(diff)) + 'd ago — toss or extend',
        url: '/?view=pantry',
      });
    }
  });

  // 2. Low-stock restock alerts (food + non-food)
  (state.pantry || []).forEach(p => {
    if (!p || typeof p.restock_threshold !== 'number') return;
    if (p.qty <= p.restock_threshold) {
      out.push({
        id: 'restock-' + p.id,
        category: 'restock',
        priority: 60,
        title: 'Restock ' + p.name,
        body: 'You have ' + p.qty + ' ' + (p.unit||'') + ' left (threshold ' + p.restock_threshold + ')',
        url: '/?view=' + ((p.location||'pantry') === 'non_food' ? 'pantry' : 'shop'),
      });
    }
  });

  // 3. Defrost / thaw — freezer items in tomorrow's plan
  const tomorrow = new Date(); tomorrow.setHours(0,0,0,0); tomorrow.setDate(tomorrow.getDate() + 1);
  const tomorrowKey = tomorrow.toISOString().slice(0,10);
  const tomorrowSlots = (state.plan || {})[tomorrowKey] || {};
  const tomorrowRecipeIds = new Set(Object.values(tomorrowSlots).filter(Boolean));
  if (window.__KA_DATA && tomorrowRecipeIds.size) {
    const recipesById = {};
    window.__KA_DATA.recipes.forEach(r => { recipesById[r.id] = r; });
    const frozenItems = (state.pantry || []).filter(p => (p.location||'pantry') === 'freezer' && p.qty > 0);
    tomorrowRecipeIds.forEach(rid => {
      const r = recipesById[rid]; if (!r) return;
      const need = new Set(r.canonical_ingredients || []);
      frozenItems.forEach(p => {
        if (need.has(p.ingredient_id)) {
          out.push({
            id: 'thaw-' + tomorrowKey + '-' + p.id,
            category: 'thaw',
            priority: 95,
            title: 'Take ' + p.name + ' out tonight',
            body: "Tomorrow's plan needs it for " + r.name + '. Move to fridge to thaw overnight.',
            url: '/?view=plan',
          });
        }
      });
    });
  }

  // 4. Fresh leftovers eat-by reminders (≤1 day)
  (state.leftovers || []).forEach(l => {
    if (l.status !== 'fresh') return;
    const diff = (new Date(l.eat_by).getTime() - now) / day;
    if (diff >= 0 && diff <= 1) {
      out.push({
        id: 'lo-' + l.id,
        category: 'leftover',
        priority: 65,
        title: 'Eat ' + l.name,
        body: l.servings + ' serving' + (l.servings===1?'':'s') + ' left — eat by ' + new Date(l.eat_by).toLocaleDateString(),
        url: '/?view=leftovers',
      });
    }
  });

  // 5. Predicted restocks (smart usage) — for non-food items the user buys regularly
  const predictions = predictRestocks(state.purchaseHistory || []);
  predictions.forEach(p => {
    out.push({
      id: 'predict-' + p.name.toLowerCase().replace(/[^\w]+/g,'_'),
      category: 'predict',
      priority: 50,
      title: 'You usually buy ' + p.name + ' soon',
      body: 'Last bought ' + p.daysAgo + 'd ago, typically every ' + Math.round(p.cadenceDays) + 'd',
      url: '/?view=pantry',
    });
  });

  // Highest priority first
  out.sort((a,b) => (b.priority||0) - (a.priority||0));
  return out;
}

// Smart restock prediction — looks at purchaseHistory, computes inter-purchase intervals
function predictRestocks(history) {
  const byName = {};
  history.forEach(h => {
    (h.items || []).forEach(it => {
      const key = (it.name || '').toLowerCase();
      if (!byName[key]) byName[key] = [];
      byName[key].push(new Date(h.date).getTime());
    });
  });
  const out = [];
  const now = Date.now();
  const day = 86400000;
  Object.entries(byName).forEach(([name, dates]) => {
    if (dates.length < 2) return;
    dates.sort((a,b) => a-b);
    const gaps = [];
    for (let i = 1; i < dates.length; i++) gaps.push(dates[i] - dates[i-1]);
    const avgGap = gaps.reduce((a,b) => a+b, 0) / gaps.length;
    const lastBought = dates[dates.length-1];
    const daysAgo = Math.round((now - lastBought) / day);
    const cadenceDays = avgGap / day;
    // Suggest if we're within ±20% of the next predicted restock
    if (daysAgo >= cadenceDays * 0.85) {
      out.push({ name: name.replace(/\b\w/g, c => c.toUpperCase()), daysAgo, cadenceDays });
    }
  });
  return out.slice(0, 4);
}

K.computeReminders = computeReminders;
K.predictRestocks = predictRestocks;

// --- In-app reminder banner that lives at the top of every page ---
function ReminderBanner() {
  const { state } = useApp();
  const reminders = useMemo(() => computeReminders(state), [state]);
  const [dismissed, setDismissed] = useState(() => {
    try { return JSON.parse(localStorage.getItem('kitchenAgent:v2:reminderDismissals') || '{}'); } catch { return {}; }
  });
  const persistDismiss = (next) => {
    setDismissed(next);
    try { localStorage.setItem('kitchenAgent:v2:reminderDismissals', JSON.stringify(next)); } catch {}
  };
  const visible = reminders.filter(r => {
    const d = dismissed[r.id];
    return !d || (Date.now() - d) > 24*3600*1000;
  });
  if (!visible.length) return null;
  const top = visible[0];

  const bg = {
    thaw: 'bg-blue-50 border-blue-200 text-blue-900',
    expiring: 'bg-amber-50 border-amber-200 text-amber-900',
    expired: 'bg-red-50 border-red-200 text-red-900',
    restock: 'bg-orange-50 border-orange-200 text-orange-900',
    leftover: 'bg-leaf-50 border-leaf-200 text-leaf-900',
    predict: 'bg-stone-50 border-stone-200 text-stone-800',
  }[top.category] || 'bg-stone-50';

  return (
    <div className={'mx-3 md:mx-8 mt-3 rounded-xl border px-3 py-2 flex items-center gap-2 fade-in ' + bg}>
      <span className="text-base">
        {top.category === 'thaw' ? '🧊' : top.category === 'expiring' ? '⚠️' : top.category === 'expired' ? '❌' : top.category === 'restock' ? '🔄' : top.category === 'leftover' ? '🥡' : '📊'}
      </span>
      <div className="flex-1 min-w-0">
        <div className="text-sm font-medium truncate">{top.title}</div>
        <div className="text-[11px] opacity-80 truncate">{top.body}</div>
      </div>
      {visible.length > 1 && <span className="text-[10px] opacity-70">+{visible.length-1}</span>}
      <button onClick={() => persistDismiss({...dismissed, [top.id]: Date.now()})}
        className="text-current opacity-50 hover:opacity-100 px-1" title="Dismiss for 24h">✕</button>
    </div>
  );
}

K.ReminderBanner = ReminderBanner;

// --- Reminders page ---
function Reminders(){
  const { state, go } = useApp();
  const reminders = useMemo(() => computeReminders(state), [state]);
  const grouped = useMemo(() => {
    const g = {};
    reminders.forEach(r => { (g[r.category] = g[r.category] || []).push(r); });
    return g;
  }, [reminders]);

  const [pushStatus, setPushStatus] = useState(null);
  useEffect(() => {
    if (typeof Notification === 'undefined') { setPushStatus({ supported: false }); return; }
    setPushStatus({ supported: true, permission: Notification.permission });
  }, []);

  const enableNotifications = async () => {
    if (typeof Notification === 'undefined') return;
    const perm = await Notification.requestPermission();
    setPushStatus(s => ({ ...s, permission: perm }));
    if (perm !== 'granted') return;
    // Register service worker + try to subscribe to push (works only if backend has VAPID)
    try {
      const reg = await navigator.serviceWorker.register('/sw.js');
      const probe = await fetch('/.netlify/functions/push', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({}) });
      const probeData = await probe.json().catch(() => ({}));
      if (!probeData.configured || !probeData.publicKey) {
        setPushStatus(s => ({ ...s, configured: false, message: 'Browser notifications enabled. Real push requires VAPID env vars.' }));
        // Fire a test in-tab notification
        new Notification('Kitchen Agent', { body: 'Notifications enabled — reminders will appear here while the app is open.' });
        return;
      }
      const sub = await reg.pushManager.subscribe({
        userVisibleOnly: true,
        applicationServerKey: urlB64ToUint8Array(probeData.publicKey),
      });
      try { localStorage.setItem('kitchenAgent:v2:pushSubscription', JSON.stringify(sub)); } catch {}
      setPushStatus(s => ({ ...s, configured: true, message: 'Real push enabled. Reminders will fire even when the app is closed.' }));
    } catch (e) {
      setPushStatus(s => ({ ...s, message: 'Could not enable: ' + e.message }));
    }
  };

  return (
    <div className="space-y-5 fade-in">
      <div>
        <h1 className="font-display text-3xl md:text-4xl">Reminders</h1>
        <p className="text-sm text-stone-600 mt-1">{reminders.length} pending · derived from your pantry, plan, and history</p>
      </div>

      {/* Notification opt-in */}
      <Card>
        <div className="flex items-start gap-3">
          <div className="text-3xl">🔔</div>
          <div className="flex-1">
            <div className="font-medium">Browser &amp; push notifications</div>
            {!pushStatus?.supported && <div className="text-xs text-stone-500 mt-1">Your browser doesn&apos;t support web notifications.</div>}
            {pushStatus?.supported && pushStatus.permission !== 'granted' && (
              <div className="text-xs text-stone-500 mt-1">
                Enable to receive reminders even when the app tab isn&apos;t focused. Real push (when the app is closed) requires VAPID keys in Netlify env vars.
              </div>
            )}
            {pushStatus?.permission === 'granted' && (
              <div className="text-xs text-leaf-700 mt-1">
                ✓ Browser notifications enabled.{pushStatus.configured ? ' Real push wired.' : ' Real push waits on VAPID env vars.'}
              </div>
            )}
            {pushStatus?.message && <div className="text-[11px] text-stone-500 mt-1">{pushStatus.message}</div>}
            {pushStatus?.supported && pushStatus.permission !== 'granted' && (
              <Button onClick={enableNotifications} className="mt-3"><Icon name="alert" cls="w-4 h-4"/>Enable notifications</Button>
            )}
          </div>
        </div>
      </Card>

      {!reminders.length && (
        <Card><div className="text-center py-8"><div className="text-5xl mb-2">✨</div><div className="font-medium">All clear!</div><div className="text-sm text-stone-500 mt-1">Nothing expiring, nothing low-stock, nothing to thaw.</div></div></Card>
      )}

      {Object.entries(grouped).map(([cat, items]) => (
        <Section key={cat} title={catLabel(cat) + ' (' + items.length + ')'}>
          <Card>
            {items.map(r => (
              <div key={r.id} className="flex items-start gap-3 py-2 border-b border-stone-100 last:border-0">
                <div className="text-lg w-8 text-center">{catIcon(cat)}</div>
                <div className="flex-1 min-w-0">
                  <div className="font-medium text-sm">{r.title}</div>
                  <div className="text-xs text-stone-500">{r.body}</div>
                </div>
                <button onClick={() => {
                  const v = (r.url || '').split('view=')[1] || 'dashboard';
                  go(v);
                }} className="text-xs text-brand-600 hover:underline">open →</button>
              </div>
            ))}
          </Card>
        </Section>
      ))}
    </div>
  );

  function catLabel(c) {
    return ({ thaw: 'Thaw tonight', expiring: 'Expiring soon', expired: 'Expired', restock: 'Restock', leftover: 'Leftovers', predict: 'Smart predictions' })[c] || c;
  }
  function catIcon(c) {
    return ({ thaw: '🧊', expiring: '⚠️', expired: '❌', restock: '🔄', leftover: '🥡', predict: '📊' })[c] || '•';
  }
}

K.Reminders = Reminders;

// helper for VAPID base64-url decoding
function urlB64ToUint8Array(b64) {
  const padding = '='.repeat((4 - b64.length % 4) % 4);
  const base64 = (b64 + padding).replace(/\-/g, '+').replace(/_/g, '/');
  const raw = atob(base64);
  const out = new Uint8Array(raw.length);
  for (let i = 0; i < raw.length; ++i) out[i] = raw.charCodeAt(i);
  return out;
}
</script>

<!-- =============== LEFTOVERS + COOK HISTORY (v9) =============== -->
<script type="text/babel" data-type="module">
const { useState, useMemo } = React;
const K = window.__KA;
const { Icon, Card, Section, Button, Badge, Chip, Input, useApp } = K;

function Leftovers(){
  const { state, setKey, go, notify, data } = useApp();
  const leftovers = state.leftovers || [];

  const fresh = leftovers.filter(l => l.status === 'fresh' && new Date(l.eat_by) > Date.now());
  const expired = leftovers.filter(l => l.status === 'fresh' && new Date(l.eat_by) <= Date.now());
  const past = leftovers.filter(l => l.status !== 'fresh');

  const setStatus = (id, status) => {
    setKey('leftovers', leftovers.map(l => l.id === id ? {...l, status} : l));
  };
  const remove = (id) => setKey('leftovers', leftovers.filter(l => l.id !== id));

  const renderItem = (l) => {
    const days = Math.round((new Date(l.eat_by) - Date.now()) / 86400000);
    const daysLabel = days >= 0 ? `eat in ${days}d` : `expired ${Math.abs(days)}d ago`;
    return (
      <div key={l.id} className="flex items-center gap-3 py-3 border-b border-stone-100 last:border-0">
        <div className="text-2xl w-10 text-center">🥡</div>
        <div className="flex-1 min-w-0">
          <div className="font-medium truncate">{l.name}</div>
          <div className="text-xs text-stone-500">{l.servings} serving{l.servings===1?'':'s'} · {daysLabel} · cooked {new Date(l.created_at).toLocaleDateString()}</div>
        </div>
        <Badge tone={days < 0 ? 'red' : days <= 1 ? 'warn' : 'leaf'}>{days >= 0 ? `${days}d` : 'expired'}</Badge>
        {l.status === 'fresh' && (
          <div className="flex gap-1">
            <button onClick={() => setStatus(l.id, 'eaten')}
              title="Mark as eaten"
              className="px-2 py-1 text-xs rounded border border-leaf-500 text-leaf-700 hover:bg-leaf-50">
              ✓ ate it
            </button>
            <button onClick={() => setStatus(l.id, 'tossed')}
              title="Threw it out (logged for waste analytics)"
              className="px-2 py-1 text-xs rounded border border-stone-300 text-stone-600 hover:bg-stone-50">
              tossed
            </button>
          </div>
        )}
        <button onClick={() => remove(l.id)} className="text-stone-400 hover:text-red-500 ml-2">
          <Icon name="trash" cls="w-3.5 h-3.5"/>
        </button>
      </div>
    );
  };

  return (
    <div className="space-y-5 fade-in">
      <div>
        <h1 className="font-display text-3xl md:text-4xl">Leftovers</h1>
        <p className="text-sm text-stone-600 mt-1">{fresh.length} fresh · {expired.length} expired · {past.length} logged</p>
      </div>

      {leftovers.length === 0 && (
        <Card>
          <div className="text-center py-8">
            <div className="text-5xl mb-2">🥡</div>
            <div className="font-medium">No leftovers tracked yet.</div>
            <div className="text-sm text-stone-500 mt-1">When you finish a cook session, you can save leftover servings with an eat-by date.</div>
          </div>
        </Card>
      )}

      {fresh.length > 0 && (
        <Section title="In the fridge">
          <Card>{fresh.map(renderItem)}</Card>
        </Section>
      )}

      {expired.length > 0 && (
        <Section title="Expired (please toss or extend)">
          <Card className="bg-red-50/40 border-red-200">{expired.map(renderItem)}</Card>
        </Section>
      )}

      {past.length > 0 && (
        <Section title="History">
          <Card className="bg-stone-50">{past.slice(-20).reverse().map(renderItem)}</Card>
        </Section>
      )}
    </div>
  );
}
K.Leftovers = Leftovers;

function CookHistory(){
  const { state, go } = useApp();
  const history = (state.cookHistory||[]).slice().sort((a,b) => new Date(b.date) - new Date(a.date));

  const totalCost = history.reduce((a,h) => a + (h.est_cost||0), 0);
  const avgPlate = history.length ? (history.reduce((a,h) => {
    const ratio = h.servings_made && h.est_cost ? h.est_cost / h.servings_made : 0;
    return a + ratio;
  }, 0) / Math.max(1, history.filter(h => h.servings_made && h.est_cost).length)) : 0;
  const avgRating = (() => {
    const rs = history.map(h => h.rating).filter(Boolean);
    return rs.length ? (rs.reduce((a,b)=>a+b,0)/rs.length).toFixed(1) : null;
  })();

  return (
    <div className="space-y-5 fade-in">
      <div>
        <h1 className="font-display text-3xl md:text-4xl">Cook history</h1>
        <p className="text-sm text-stone-600 mt-1">{history.length} meals cooked · ${totalCost.toFixed(2)} total spend</p>
      </div>

      {history.length === 0 ? (
        <Card><div className="text-center py-8"><div className="text-5xl mb-2">📚</div><div className="font-medium">No meals cooked yet.</div></div></Card>
      ) : (
        <>
          <div className="grid grid-cols-2 md:grid-cols-3 gap-3">
            <Card><div className="text-xs uppercase text-stone-500">Meals cooked</div><div className="font-display text-2xl mt-1">{history.length}</div></Card>
            <Card><div className="text-xs uppercase text-stone-500">Avg plate cost</div><div className="font-display text-2xl mt-1">${avgPlate.toFixed(2)}</div></Card>
            {avgRating && <Card><div className="text-xs uppercase text-stone-500">Avg rating</div><div className="font-display text-2xl mt-1 text-amber-600">{avgRating}★</div></Card>}
          </div>
          <Card>
            <div className="space-y-1">
              {history.map(h => (
                <div key={h.id} className="flex items-center gap-3 py-2 border-b border-stone-100 last:border-0">
                  {h.photo_data_url ? (
                    <img src={h.photo_data_url} className="w-12 h-12 rounded-lg object-cover" alt=""/>
                  ) : <div className="w-12 h-12 rounded-lg bg-brand-50 flex items-center justify-center text-2xl">🍽️</div>}
                  <div className="flex-1 min-w-0">
                    <div className="font-medium truncate">{h.recipe_name}</div>
                    <div className="text-xs text-stone-500">{new Date(h.date).toLocaleDateString()} · {h.servings_made} servings · ${(h.est_cost||0).toFixed(2)}{h.leftovers_kept ? ` · ${h.leftovers_kept} leftover` : ''}</div>
                  </div>
                  {h.rating > 0 && (
                    <div className="text-amber-600 text-sm font-medium">
                      {'★'.repeat(h.rating)}<span className="text-stone-300">{'★'.repeat(5-h.rating)}</span>
                    </div>
                  )}
                  <button onClick={()=>go('recipe', h.recipe_id)} className="text-xs text-brand-600 hover:underline">view recipe</button>
                </div>
              ))}
            </div>
          </Card>
        </>
      )}
    </div>
  );
}
K.CookHistory = CookHistory;
</script>

