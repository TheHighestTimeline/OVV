                "what can I cook," realistic prices, and smart substitutions.
              </div>
              <button onClick={() => go('settings')} className="mt-3 inline-flex items-center gap-2 px-4 py-2 bg-white text-brand-700 rounded-lg text-sm font-medium hover:bg-brand-50 min-h-[40px]">
                Add API key →
              </button>
            </div>
          </div>
        </div>
      )}

      <div>
        <div className="text-sm text-stone-500">{greet}, {state.profile.name.split(' ')[0]}</div>
        <h1 className="font-display text-3xl md:text-4xl">Let's figure out dinner.</h1>
      </div>

      {/* Tonight card */}
      <Card className="bg-gradient-to-br from-brand-50 to-white">
        <div className="flex items-start gap-4 flex-wrap">
          <div className="flex-1 min-w-[260px]">
            <div className="text-xs uppercase tracking-wider text-brand-700 font-semibold">Tonight</div>
            {tonight ? (
              <>
                <h3 className="font-display text-2xl mt-1">{tonight.name}</h3>
                <div className="text-sm text-stone-600 mt-1">{tonight.source}</div>
                <div className="flex gap-2 flex-wrap mt-3">
                  <Badge tone="brand"><Icon name="clock" cls="w-3 h-3"/>{(tonight.prep_min||0)+(tonight.cook_min||0)} min</Badge>
                  <Badge tone="leaf"><Icon name="flame" cls="w-3 h-3"/>{tonight.macros?.calories || '—'} cal</Badge>
                  {tonight.tags?.slice(0,2).map(t => <Badge key={t} tone="stone">{t}</Badge>)}
                </div>
                <div className="flex gap-2 mt-4 flex-wrap">
                  <Button onClick={()=>go('cook', tonight.id)}><Icon name="play" cls="w-4 h-4"/>Start cooking</Button>
                  {todayAll.length >= 2 && (
                    <Button variant="leaf" onClick={()=>go('cooksession', todayAll.map(x => x.recipe.id).join(','))}>
                      🍳 Cook all {todayAll.length} together
                    </Button>
                  )}
                  <Button variant="outline" onClick={()=>go('recipe', tonight.id)}>View recipe</Button>
                </div>
              </>
            ) : (
              <>
                <h3 className="font-display text-2xl mt-1">Nothing planned</h3>
                <div className="text-sm text-stone-600 mt-1">Pick a meal or auto-plan the week.</div>
                <div className="flex gap-2 mt-4">
                  <Button onClick={()=>go('plan')}><Icon name="calendar" cls="w-4 h-4"/>Plan the week</Button>
                  <Button variant="outline" onClick={()=>go('recipes')}>Browse recipes</Button>
                </div>
              </>
            )}
          </div>
          <div className="hidden sm:block text-7xl">🍽️</div>
        </div>
      </Card>

      {/* v9: Action widgets — surface things needing attention */}
      {(() => {
        const expSoon = state.pantry
          .filter(p => p && (p.location||'pantry') !== 'non_food')
          .filter(p => {
            const d = (new Date(p.expires_at) - Date.now()) / 86400000;
            return d >= 0 && d <= 5;
          })
          .sort((a,b) => new Date(a.expires_at) - new Date(b.expires_at))
          .slice(0, 6);
        const lowStock = state.pantry.filter(p => typeof p.restock_threshold === 'number' && p.qty <= p.restock_threshold);
        const freshLeftovers = (state.leftovers||[]).filter(l => l.status === 'fresh' && new Date(l.eat_by) > Date.now());
        return (expSoon.length || lowStock.length || freshLeftovers.length) ? (
          <div className="grid grid-cols-1 md:grid-cols-3 gap-3">
            {expSoon.length > 0 && (
              <Card className="bg-amber-50/60 border-amber-200 cursor-pointer" onClick={()=>go('pantry')}>
                <div className="text-xs uppercase tracking-wider text-amber-700 font-semibold mb-1">Expiring soon</div>
                <div className="font-display text-xl text-amber-900">{expSoon.length}</div>
                <div className="text-xs text-stone-700 mt-1 line-clamp-2">
                  {expSoon.slice(0,3).map(p => p.name).join(', ')}{expSoon.length > 3 ? `, +${expSoon.length-3} more` : ''}
                </div>
                <div className="text-[11px] text-amber-700 mt-2">Tap to use up →</div>
              </Card>
            )}
            {lowStock.length > 0 && (
              <Card className="bg-red-50/60 border-red-200 cursor-pointer" onClick={()=>go('pantry')}>
                <div className="text-xs uppercase tracking-wider text-red-700 font-semibold mb-1">Restock alerts</div>
                <div className="font-display text-xl text-red-900">{lowStock.length}</div>
                <div className="text-xs text-stone-700 mt-1 line-clamp-2">
                  {lowStock.slice(0,3).map(p => p.name).join(', ')}{lowStock.length > 3 ? `, +${lowStock.length-3} more` : ''}
                </div>
                <div className="text-[11px] text-red-700 mt-2">Below threshold →</div>
              </Card>
            )}
            {freshLeftovers.length > 0 && (
              <Card className="bg-leaf-500/10 border-leaf-500/30 cursor-pointer" onClick={()=>go('leftovers')}>
                <div className="text-xs uppercase tracking-wider text-leaf-700 font-semibold mb-1">Fresh leftovers</div>
                <div className="font-display text-xl text-leaf-700">{freshLeftovers.length}</div>
                <div className="text-xs text-stone-700 mt-1 line-clamp-2">
                  {freshLeftovers.slice(0,2).map(l => `${l.servings} of ${l.name}`).join('; ')}
                </div>
                <div className="text-[11px] text-leaf-700 mt-2">Eat before next cook →</div>
              </Card>
            )}
          </div>
        ) : null;
      })()}

      {/* v9: Cost analytics — rolling spend per meal cooked */}
      {(() => {
        const history = (state.cookHistory||[]).slice(-30);
        if (!history.length) return null;
        const costs = history.map(h => h.est_cost || 0).filter(c => c > 0);
        if (!costs.length) return null;
        const avg = costs.reduce((a,b)=>a+b,0) / costs.length;
        const totalCooked = history.length;
        const avgRating = (() => {
          const rs = history.map(h => h.rating).filter(Boolean);
          return rs.length ? (rs.reduce((a,b)=>a+b,0) / rs.length).toFixed(1) : null;
        })();
        const totalSpend = history.reduce((a,h) => a + (h.est_cost || 0), 0);
        return (
          <Card>
            <div className="flex items-center justify-between flex-wrap gap-2">
              <div>
                <div className="text-xs uppercase tracking-wider text-stone-500 font-semibold">Cost analytics (last 30 cooked)</div>
                <div className="text-2xl font-display mt-1">${avg.toFixed(2)}<span className="text-base text-stone-500"> avg per meal</span></div>
              </div>
              <div className="flex gap-4 text-xs text-stone-600">
                <div><div className="text-stone-400 uppercase">Cooked</div><div className="font-display text-base text-stone-700">{totalCooked}</div></div>
                <div><div className="text-stone-400 uppercase">Total spend</div><div className="font-display text-base text-stone-700">${totalSpend.toFixed(0)}</div></div>
                {avgRating && <div><div className="text-stone-400 uppercase">Avg rating</div><div className="font-display text-base text-amber-700">{avgRating}★</div></div>}
              </div>
            </div>
          </Card>
        );
      })()}

      {/* Quick stats */}
      <div className="grid grid-cols-2 md:grid-cols-4 gap-3">
        <StatCard icon="book2" label="Recipes" value={recipes.length} onClick={()=>go('recipes')}/>
        <StatCard icon="pantry" label="Pantry" value={pantrySize} sub={expiringSoon.length ? `${expiringSoon.length} expiring` : 'all fresh'} subTone={expiringSoon.length?'warn':'leaf'} onClick={()=>go('pantry')}/>
        <StatCard icon="cart" label="Shop" value={`${Object.values(state.plan).reduce((a,s)=>a+Object.keys(s||{}).length,0)}`} sub="meals planned" onClick={()=>go('shop')}/>
        <StatCard icon="pkg" label="Orders" value={activeOrders.length} sub={activeOrders.length?'active':'none'} onClick={()=>go('orders')}/>
      </div>

      {/* Upcoming */}
      {upcoming.length > 0 && (
        <Section title="Coming up">
          <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {upcoming.slice(0,6).map(({date, recipe}) => (
              <Card key={dateKey(date)} className="card-hover cursor-pointer" onClick={()=>go('recipe', recipe.id)}>
                <div className="text-xs text-stone-500">{dayShort(date)}</div>
                <div className="font-medium mt-1 line-clamp-2">{recipe.name}</div>
                <div className="text-xs text-stone-500 mt-1">{(recipe.prep_min||0)+(recipe.cook_min||0)} min · {recipe.source}</div>
              </Card>
            ))}
          </div>
        </Section>
      )}

      {/* Expiring soon */}
      {expiringSoon.length > 0 && (
        <Section title="Use it up">
          <Card className="border-amber-200 bg-amber-50/50">
            <div className="flex items-start gap-3">
              <Icon name="alert" cls="w-5 h-5 text-amber-600 shrink-0 mt-0.5"/>
              <div className="flex-1">
                <div className="text-sm font-medium">{expiringSoon.length} {expiringSoon.length===1?'item expires':'items expire'} in the next 3 days</div>
                <div className="text-sm text-stone-600 mt-1">{expiringSoon.map(p=>p.name).join(', ')}</div>
                <Button variant="ghost" className="mt-2 text-amber-700" onClick={()=>go('pantry')}>Review pantry →</Button>
              </div>
            </div>
          </Card>
        </Section>
      )}

      {/* Today's meals rail */}
      {todayAll.length > 0 && (
        <Section title="Today's meals">
          <div className="grid grid-cols-2 md:grid-cols-4 gap-3">
            {todayAll.map(({slot, recipe}) => (
              <Card key={slot} className="card-hover cursor-pointer" onClick={()=>go('recipe', recipe.id)}>
                <div className="flex items-center gap-2 text-xs text-stone-500 uppercase tracking-wide">
                  <span className="text-base">{({breakfast:'🌅',lunch:'🥗',dinner:'🍽️',snack:'🍎'})[slot]}</span>{slot}
                </div>
                <div className="font-medium mt-1 line-clamp-2">{recipe.name}</div>
                <div className="text-xs text-stone-500 mt-1">{(recipe.prep_min||0)+(recipe.cook_min||0)} min</div>
              </Card>
            ))}
          </div>
        </Section>
      )}

      <Section title="Quick actions">
        <div className="grid grid-cols-2 md:grid-cols-4 gap-3">
          <QuickAction icon="scan"    label="Scan barcode" onClick={()=>go('scanItem')}/>
          <QuickAction icon="receipt" label="Scan receipt" onClick={()=>go('scanReceipt')}/>
          <QuickAction icon="spark"   label="Auto-plan week" onClick={()=>go('plan')}/>
          <QuickAction icon="cart"    label="Shop & save"  onClick={()=>go('shop')}/>
        </div>
      </Section>
    </div>
  );
}

function StatCard({icon,label,value,sub,subTone='stone',onClick}){
  return (
    <button onClick={onClick} className="text-left bg-white border border-stone-200 rounded-xl p-4 card-hover">
      <div className="flex items-center gap-2 text-stone-500 text-xs"><Icon name={icon} cls="w-4 h-4"/>{label}</div>
      <div className="font-display text-2xl mt-1">{value}</div>
      {sub && <div className={'text-xs mt-0.5 '+(subTone==='warn'?'text-amber-700':subTone==='leaf'?'text-leaf-700':'text-stone-500')}>{sub}</div>}
    </button>
  );
}
function QuickAction({icon,label,onClick}){
  return (
    <button onClick={onClick} className="bg-white border border-stone-200 rounded-xl p-4 card-hover text-left">
      <div className="w-9 h-9 rounded-lg bg-brand-50 text-brand-600 flex items-center justify-center mb-2"><Icon name={icon}/></div>
      <div className="text-sm font-medium">{label}</div>
    </button>
  );
}

window.__KA.Dashboard = Dashboard;
</script>

<!-- =============== MEAL PLAN =============== -->
<script type="text/babel" data-type="module">
const { useState, useEffect, useMemo, useRef, useCallback } = React;
const K = window.__KA;
const { Icon, Card, Section, Button, Badge, Chip, Input, useApp, fmt$, dateKey, dayLabel, dayShort, days, pantryMatchScore, autoPlan, Claude, MEAL_SLOTS, MEAL_SLOT_EMOJI, MEAL_SLOT_LABEL } = K;

const PROTEIN_OPTIONS = [
  { id:'chicken',    label:'Chicken',    emoji:'🍗' },
  { id:'beef',       label:'Beef',       emoji:'🥩' },
  { id:'seafood',    label:'Seafood',    emoji:'🐟' },
  { id:'pork',       label:'Pork',       emoji:'🥓' },
  { id:'turkey',     label:'Turkey',     emoji:'🦃' },
  { id:'vegetarian', label:'Vegetarian', emoji:'🥦' },
];

function MealPlan(){
  const { state, setKey, go, data, notify } = useApp();
  const { recipes } = data;
  const recipesById = useMemo(()=>Object.fromEntries(recipes.map(r=>[r.id,r])),[recipes]);
  const [week] = useState(() => days(7));
  const [picker, setPicker] = useState(null); // { date, slot }
  const [q, setQ] = useState('');
  const [filterTag, setFilterTag] = useState(null);
  const [mealPrepInfo, setMealPrepInfo] = useState(null);
  const [previewRecipe, setPreviewRecipe] = useState(null);  // v16: open popup instead of navigating

  // Which slots to plan (user can hide snacks if they don't want them)
  const slots = state.profile.meal_slots || MEAL_SLOTS;

  const allTags = useMemo(() => {
    const s = new Set();
    recipes.forEach(r => (r.tags||[]).forEach(t => s.add(t)));
    return ['all', ...Array.from(s)];
  }, [recipes]);

  const filtered = useMemo(() => {
    let list = recipes;
    if (picker?.slot) list = list.filter(r => (r.meal_types||['dinner','lunch']).includes(picker.slot));
    if (q) list = list.filter(r => r.name.toLowerCase().includes(q.toLowerCase()));
    if (filterTag && filterTag !== 'all') list = list.filter(r => (r.tags||[]).includes(filterTag));
    return list.map(r => ({ r, score: pantryMatchScore(r, state.pantry) }))
      .sort((a,b) => b.score - a.score).map(x => x.r);
  }, [recipes, q, filterTag, state.pantry, picker]);

  const setProfileField = (key, val) => setKey('profile', { ...state.profile, [key]: val });
  const toggleProtein = (pid) => {
    const cur = state.profile.protein_picks || [];
    setProfileField('protein_picks', cur.includes(pid) ? cur.filter(x=>x!==pid) : [...cur, pid]);
  };
  const toggleSlot = (slot) => {
    const cur = state.profile.meal_slots || MEAL_SLOTS;
    setProfileField('meal_slots', cur.includes(slot) ? cur.filter(x=>x!==slot) : [...cur, slot]);
  };

  // Collect all recipe ids currently used in plan → exclude on regen
  const currentlyPlannedIds = useMemo(() => {
    const ids = new Set();
    Object.values(state.plan || {}).forEach(day => {
      Object.values(day || {}).forEach(rid => { if (rid) ids.add(rid); });
    });
    return Array.from(ids);
  }, [state.plan]);

  const [aiPlanning, setAiPlanning] = useState(false);
  const autoPlanClick = async () => {
    // DEFAULT: Claude. It respects the budget slider, pantry, and verbatim prefs text,
    // and shows a preview modal so the user can swap meals before committing.
    if (typeof window.KA_claudeMealPlan !== 'function') {
      notify('Claude planner not loaded — falling back to local algorithm.', 'info');
      autoPlanLocalClick();
      return;
    }
    setAiPlanning(true);
    try { await window.KA_claudeMealPlan(); }
    catch (e) { notify('Claude plan failed: ' + e.message, 'error'); }
    finally { setAiPlanning(false); }
  };
  // Legacy local autoplan — exposed as a smaller fallback button.
  const autoPlanLocalClick = () => {
    const { plan: newPlan, meta } = autoPlan(recipes, state.pantry, state.profile, week[0], 7, {
      slots,
      proteinFilter: state.profile.protein_picks,
      preferencesText: state.profile.preferences_text,
      mealPrepLunch: state.profile.meal_prep_lunch,
      mealPrepCount: state.profile.meal_prep_lunch_count,
      excludeIds: [],
    });
    const merged = { ...state.plan, ...newPlan };
    setKey('plan', merged);
    setMealPrepInfo(meta.mealPrep);
    notify(`Planned ${Object.keys(newPlan).length} days · ${meta.picks.length} meals${meta.mealPrep ? ` · meal-prep lunch x${meta.mealPrep.count}` : ''}`, 'success');
  };

  // "Clear & regenerate" — clears THIS week then replans avoiding the week we just cleared
  const clearAndRegen = () => {
    const excludeIds = currentlyPlannedIds;    // don't repeat last week's picks
    const p = { ...state.plan };
    week.forEach(d => delete p[dateKey(d)]);   // clear
    const { plan: newPlan, meta } = autoPlan(recipes, state.pantry, state.profile, week[0], 7, {
      slots,
      proteinFilter: state.profile.protein_picks,
      preferencesText: state.profile.preferences_text,
      mealPrepLunch: state.profile.meal_prep_lunch,
      mealPrepCount: state.profile.meal_prep_lunch_count,
      excludeIds,
    });
    setKey('plan', { ...p, ...newPlan });
    setMealPrepInfo(meta.mealPrep);
    notify(`Regenerated with ${excludeIds.length} previous picks excluded`, 'success');
  };

  const clearWeek = () => {
    const p = { ...state.plan };
    week.forEach(d => delete p[dateKey(d)]);
    setKey('plan', p);
    setMealPrepInfo(null);
  };
  const clearDay = (d) => {
    const key = dateKey(d);
    if (!state.plan[key]) return;
    const p = { ...state.plan };
    delete p[key];
    setKey('plan', p);
    notify(`Cleared ${dayLabel(d)} ${d.getDate()}`, 'success');
  };

  const assign = (date, slot, recipeId) => {
    const key = dateKey(date);
    const day = state.plan[key] || {};
    setKey('plan', { ...state.plan, [key]: { ...day, [slot]: recipeId } });
    setPicker(null);
  };
  const unassign = (date, slot) => {
    const key = dateKey(date);
    const day = { ...(state.plan[key] || {}) };
    delete day[slot];
    const p = { ...state.plan };
    if (Object.keys(day).length === 0) delete p[key];
    else p[key] = day;
    setKey('plan', p);
  };

  const planCount = useMemo(() => {
    let n = 0;
    week.forEach(d => { n += Object.keys(state.plan[dateKey(d)] || {}).length; });
    return n;
  }, [state.plan, week]);

  // v16: total estimated cost for the week (sums each planned recipe's estimated_cost)
  const weekTotalCost = useMemo(() => {
    let total = 0;
    week.forEach(d => {
      const slotMap = state.plan[dateKey(d)] || {};
      Object.values(slotMap).forEach(rid => {
        const r = recipesById[rid];
        if (r && !r.leftover_from && typeof r.estimated_cost === 'number') total += r.estimated_cost;
      });
    });
    return total;
  }, [state.plan, week, recipesById]);

  // v16: "Add all to shopping list" — aggregates every ingredients_to_buy line from every planned Claude recipe
  const addAllToShopping = () => {
    const extras = [...state.shoppingExtras];
    let added = 0;
    week.forEach(d => {
      const slotMap = state.plan[dateKey(d)] || {};
      Object.values(slotMap).forEach(rid => {
        const r = recipesById[rid];
        if (!r) return;
        (r.ingredients || []).forEach(line => {
          if (typeof line !== 'object') return;
          const notes = line.notes || '';
          if (/from pantry/i.test(notes)) return; // skip pantry items
          const fakeId = 'claude_ing_' + (line.name || '').toLowerCase().replace(/[^\w]+/g,'_');
          if (!extras.find(e => e.ingredient_id === fakeId)) {
            const m = notes.match(/\$([0-9.]+)/);
            extras.push({
              id: crypto.randomUUID(),
              ingredient_id: fakeId,
              name: line.name,
              qty: 1,
              source_recipe: r.id,
              est_cost: m ? parseFloat(m[1]) : 0,
            });
            added++;
          }
        });
      });
    });
    setKey('shoppingExtras', extras);
    notify(`Added ${added} unique items to your shopping list. Open Shop tab to order.`, 'success');
  };

  return (
    <div className="space-y-6 fade-in">
      <div>
        <h1 className="font-display text-3xl md:text-4xl">Meal plan</h1>
        <p className="text-sm text-stone-600 mt-1">
          {planCount} meals planned this week · {slots.length} slots/day
          {weekTotalCost > 0 && (
            <span> · <strong className="text-brand-700">est. ${weekTotalCost.toFixed(2)}</strong> total</span>
          )}
        </p>
      </div>

      {/* Quick plan — one-tap, uses saved defaults. Loud & obvious so users
          don't get lost in the customization panel before they've tried it. */}
      {planCount === 0 && (
        <Card className="bg-gradient-to-br from-brand-50 to-leaf-500/10 border-brand-200">
          <div className="flex items-start gap-3">
            <div className="text-3xl">✨</div>
            <div className="flex-1">
              <div className="font-display text-lg">Quick plan</div>
              <div className="text-sm text-stone-600 mt-0.5">
                Claude builds a 7-day plan using your saved preferences, budget, and pantry. One tap.
              </div>
              <Button variant="leaf" onClick={autoPlanClick} disabled={aiPlanning || !Claude.isEnabled()} className="mt-3">
                <Icon name="spark" cls="w-4 h-4"/>{aiPlanning ? 'Planning…' : 'Plan my week'}
              </Button>
              {!Claude.isEnabled() && (
                <div className="text-xs text-amber-700 mt-2">Needs an Anthropic key — <button onClick={()=>go('settings')} className="underline">add it in Settings</button>.</div>
              )}
            </div>
          </div>
        </Card>
      )}

      <div className="flex gap-2 flex-wrap">
        {planCount > 0 && (
          <Button variant="leaf" onClick={autoPlanClick} disabled={aiPlanning}>
            <Icon name="spark" cls="w-4 h-4"/>{aiPlanning ? 'Planning…' : '✨ Replan'}
          </Button>
        )}
        {planCount > 0 && (
          <Button variant="outline" onClick={addAllToShopping}>
            <Icon name="cart" cls="w-4 h-4"/>Add all to shopping list
          </Button>
        )}
        {planCount > 0 && <Button variant="outline" onClick={clearWeek}>Clear week</Button>}
        <Button variant="ghost" onClick={autoPlanLocalClick} title="Fallback: local heuristic (offline, no AI)">
          Quick local plan
        </Button>
      </div>

      {planCount > 0 && weekTotalCost > 0 && (
        <Card className="bg-leaf-500/5 border-leaf-500/30">
          <div className="flex items-start gap-3 flex-wrap">
            <span className="text-2xl">🛒</span>
            <div className="flex-1 min-w-[200px] text-sm">
              <strong>Ready to order?</strong> Tap <strong>Add all to shopping list</strong> above, then open the{' '}
              <button onClick={()=>go('shop')} className="text-brand-600 underline font-medium">Shop tab</button>
              {' '}to send your cart to Walmart pickup or Instacart delivery.
            </div>
          </div>
        </Card>
      )}

      {/* Preferences panel */}
      <Card>
        <div className="space-y-4">
          <div>
            <div className="text-sm font-medium mb-2">What proteins do you want?</div>
            <div className="flex flex-wrap gap-2">
              {PROTEIN_OPTIONS.map(p => (
                <Chip key={p.id} active={(state.profile.protein_picks||[]).includes(p.id)} onClick={()=>toggleProtein(p.id)}>
                  <span className="mr-1">{p.emoji}</span>{p.label}
                </Chip>
              ))}
            </div>
            <p className="text-xs text-stone-500 mt-2">Pick any combo. Recipes matching get a boost; others still appear if they score highly on pantry + variety.</p>
          </div>

          <div>
            <div className="text-sm font-medium mb-1">Anything specific this week?</div>
            <textarea
              value={state.profile.preferences_text || ''}
              onChange={e => setProfileField('preferences_text', e.target.value)}
              placeholder="e.g. spicy, pasta, Asian flavors, quick weeknight dinners, low-carb"
              className="w-full px-3 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:outline-none text-sm"
              rows={2}
            />
            <p className="text-xs text-stone-500 mt-1">Free-form. Keywords match against recipe names, cuisines, and ingredients.</p>
          </div>

          {/* Weekly budget slider — Claude plan stays within ±10% */}
          <div>
            <div className="flex items-baseline justify-between mb-2">
              <div className="text-sm font-medium">Weekly grocery budget</div>
              <div className="text-base font-display text-brand-600">${state.profile.weekly_budget || 150}<span className="text-xs text-stone-500 font-sans"> / week</span></div>
            </div>
            <input
              type="range" min={50} max={300} step={5}
              value={state.profile.weekly_budget || 150}
              onChange={e => setProfileField('weekly_budget', parseInt(e.target.value) || 150)}
              className="w-full accent-brand-500"
              style={{
                background: `linear-gradient(to right, #c96b4a 0%, #c96b4a ${(((state.profile.weekly_budget||150)-50)/250)*100}%, #e7e5e4 ${(((state.profile.weekly_budget||150)-50)/250)*100}%, #e7e5e4 100%)`,
                height: '6px', borderRadius: '999px', appearance: 'none', cursor: 'pointer'
              }}
            />
            <div className="flex justify-between text-[11px] text-stone-500 mt-1">
              <span>$50</span><span>$100</span><span>$150</span><span>$200</span><span>$250</span><span>$300</span>
            </div>
            <p className="text-xs text-stone-500 mt-2">
              Claude Plan keeps every meal &amp; ingredient list within <strong>±10%</strong> of this budget. If your pantry is empty, it will suggest a 2-week plan with staple-stocking instead (no exceptions).
            </p>
          </div>

          <div className="flex flex-wrap gap-6">
            <div>
              <div className="text-sm font-medium mb-2">Which meals to plan</div>
              <div className="flex flex-wrap gap-2">
                {MEAL_SLOTS.map(s => (
                  <Chip key={s} active={slots.includes(s)} onClick={()=>toggleSlot(s)}>
                    <span className="mr-1">{MEAL_SLOT_EMOJI[s]}</span>{MEAL_SLOT_LABEL[s]}
                  </Chip>
                ))}
              </div>
            </div>
            <div>
              <div className="text-sm font-medium mb-2">Lunch meal-prep mode</div>
              <label className="flex items-center gap-2 text-sm">
                <input type="checkbox" className="w-4 h-4 accent-brand-500"
                  checked={!!state.profile.meal_prep_lunch}
                  onChange={e => setProfileField('meal_prep_lunch', e.target.checked)}
                />
                <span className="px-1.5 py-0.5 rounded-full bg-brand-50 text-brand-700 text-[10px] font-semibold mr-1">A</span>
                Pick <strong className="mx-1">one</strong> recipe ×{' '}
                <input type="number" min={1} max={14}
                  className="w-14 px-2 py-1 border border-stone-300 rounded text-sm"
                  value={state.profile.meal_prep_lunch_count || 4}
                  onChange={e => setProfileField('meal_prep_lunch_count', Math.max(1, parseInt(e.target.value)||4))}
                />
                servings
              </label>
              {state.profile.meal_prep_lunch && !state.profile.meal_prep_lunch_2 && (
                <button onClick={() => setProfileField('meal_prep_lunch_2', true)}
                  className="text-xs text-brand-600 hover:underline mt-2 ml-6">
                  + add second batch
                </button>
              )}
              {state.profile.meal_prep_lunch && state.profile.meal_prep_lunch_2 && (
                <label className="flex items-center gap-2 text-sm mt-2">
                  <input type="checkbox" className="w-4 h-4 accent-brand-500"
                    checked={!!state.profile.meal_prep_lunch_2}
                    onChange={e => setProfileField('meal_prep_lunch_2', e.target.checked)}
                  />
                  <span className="px-1.5 py-0.5 rounded-full bg-leaf-100 text-leaf-700 text-[10px] font-semibold mr-1">B</span>
                  Plus another recipe ×{' '}
                  <input type="number" min={1} max={14}
                    className="w-14 px-2 py-1 border border-stone-300 rounded text-sm"
                    value={state.profile.meal_prep_lunch_count_2 || 3}
                    onChange={e => setProfileField('meal_prep_lunch_count_2', Math.max(1, parseInt(e.target.value)||3))}
                  />
                  servings
                  <button onClick={()=>{ setProfileField('meal_prep_lunch_2', false); }}
                    className="ml-2 text-xs text-stone-400 hover:text-red-600">remove</button>
                </label>
              )}
              <p className="text-[11px] text-stone-500 mt-1">
                Two lanes? Claude will pick TWO lunch recipes and split the week between them. Qtys auto-scale.
              </p>
            </div>
          </div>
        </div>
      </Card>

      {mealPrepInfo && (
        <Card className="bg-leaf-500/5 border-leaf-500/30">
          <div className="flex items-start gap-3">
            <Icon name="check" cls="w-5 h-5 text-leaf-600 shrink-0 mt-0.5"/>
            <div className="text-sm">
              <strong>Meal-prep lunch:</strong> {mealPrepInfo.name}{' '}
              — prepping {mealPrepInfo.count} servings ({mealPrepInfo.multiplier}× ingredients in shopping list)
            </div>
          </div>
        </Card>
      )}

      {/* 7 columns × slots rows */}
      <Card>
        <div className="overflow-x-auto">
          <div className="min-w-[980px]">
            {/* Header row */}
            <div className="grid gap-2 pb-2 border-b border-stone-200" style={{gridTemplateColumns: '96px repeat(7, minmax(0, 1fr))'}}>
              <div></div>
              {week.map(d => {
                const isToday = dateKey(d) === dateKey(new Date());
                const planned = !!state.plan[dateKey(d)];
                return (
                  <div key={dateKey(d)} className="text-center relative">
                    <div className={'text-xs uppercase tracking-wide '+(isToday?'text-brand-600 font-semibold':'text-stone-500')}>{dayLabel(d)}</div>
                    <div className="text-lg font-display">{d.getDate()}</div>
                    {planned && (
                      <button
                        onClick={() => { if (confirm(`Clear all meals on ${dayLabel(d)} ${d.getDate()}?`)) clearDay(d); }}
                        title="Clear this day"
                        className="text-[10px] mt-1 text-stone-400 hover:text-red-600">
                        clear day
                      </button>
                    )}
                  </div>
                );
              })}
            </div>

            {/* Slot rows */}
            {slots.map(slot => (
              <div key={slot} className="grid gap-2 py-2 border-b border-stone-100" style={{gridTemplateColumns: '96px repeat(7, minmax(0, 1fr))'}}>
                <div className="flex items-center gap-2 pr-2 text-xs text-stone-600">
                  <span className="text-base">{MEAL_SLOT_EMOJI[slot]}</span>
                  <span className="font-medium">{MEAL_SLOT_LABEL[slot]}</span>
                </div>
                {week.map(d => {
                  const key = dateKey(d);
                  const rid = state.plan[key]?.[slot];
                  const recipe = rid ? recipesById[rid] : null;
                  const isToday = dateKey(d) === dateKey(new Date());
                  return (
                    <div key={key+slot} className={'rounded-lg p-2 min-h-[84px] border '+(isToday?'border-brand-200':'border-stone-200')}>
                      {recipe ? (
                        <div className="h-full flex flex-col">
                          <button className="text-left flex-1" onClick={()=>setPreviewRecipe(recipe)}>
                            {recipe.leftover_from && (
                              <div className="inline-block mb-1 px-1.5 py-0.5 rounded-full bg-amber-100 text-amber-800 text-[9px] font-semibold uppercase tracking-wide">
                                ↻ Leftovers
                              </div>
                            )}
                            <div className="text-xs font-medium line-clamp-3 leading-snug">{recipe.name}</div>
                            <div className="text-[10px] text-stone-500 mt-1 flex flex-wrap items-center gap-x-1.5">
                              {recipe.leftover_from
                                ? <span className="text-amber-700">from {recipe.leftover_from}</span>
                                : <span>{(recipe.prep_min||0)+(recipe.cook_min||0)}min</span>}
                              {typeof recipe.estimated_cost === 'number' && recipe.estimated_cost > 0 && (
                                <span className="text-stone-700 font-medium">· ${recipe.estimated_cost.toFixed(2)}</span>
                              )}
                            </div>
                          </button>
                          <div className="flex gap-1 mt-1">
                            <button onClick={()=>setPicker({date:d,slot})} className="text-[10px] text-brand-600 hover:underline">swap</button>
                            <span className="text-stone-300 text-[10px]">·</span>
                            <button onClick={()=>unassign(d,slot)} className="text-[10px] text-stone-500 hover:text-red-600">remove</button>
                          </div>
                        </div>
                      ) : (
                        <button onClick={()=>setPicker({date:d,slot})} className="w-full h-full border-2 border-dashed border-stone-200 rounded flex items-center justify-center text-xs text-stone-400 hover:border-brand-500 hover:text-brand-500 transition">
                          <Icon name="plus" cls="w-3 h-3 mr-0.5"/>add
                        </button>
                      )}
                    </div>
                  );
                })}
              </div>
            ))}
          </div>
        </div>
      </Card>

      {/* Recipe picker modal */}
      {picker && (
        <div className="fixed inset-0 bg-black/40 z-30 flex items-center justify-center p-4" onClick={()=>setPicker(null)}>
          <div className="bg-white rounded-xl max-w-2xl w-full max-h-[80vh] flex flex-col" onClick={e=>e.stopPropagation()}>
            <div className="p-4 border-b border-stone-200">
              <div className="flex items-center justify-between mb-2">
                <h3 className="font-display text-lg">
                  {MEAL_SLOT_EMOJI[picker.slot]} Pick a {MEAL_SLOT_LABEL[picker.slot].toLowerCase()} for {dayLabel(picker.date)} {picker.date.getDate()}
                </h3>
                <button onClick={()=>setPicker(null)}><Icon name="x" cls="w-5 h-5 text-stone-500"/></button>
              </div>
              <Input placeholder="Search recipes..." value={q} onChange={e=>setQ(e.target.value)} autoFocus/>
              <div className="flex flex-wrap gap-2 mt-2">
                {allTags.slice(0,8).map(t => <Chip key={t} active={filterTag===t} onClick={()=>setFilterTag(filterTag===t?null:t)}>{t}</Chip>)}
              </div>
              <div className="text-xs text-stone-500 mt-2">{filtered.length} {picker.slot} recipes available</div>
            </div>
            <div className="flex-1 overflow-y-auto p-3 space-y-2">
              {filtered.slice(0,50).map(r => (
                <button key={r.id} onClick={()=>assign(picker.date, picker.slot, r.id)} className="w-full text-left p-3 rounded-lg hover:bg-stone-50 border border-stone-100 flex items-center gap-3">
                  <div className="w-10 h-10 rounded bg-brand-50 text-brand-600 flex items-center justify-center">🍽️</div>
                  <div className="flex-1 min-w-0">
                    <div className="font-medium truncate">{r.name}</div>
                    <div className="text-xs text-stone-500">{(r.prep_min||0)+(r.cook_min||0)} min · {r.servings} servings · {(r.tags||[]).join(', ')}</div>
                  </div>
                  <Badge tone="leaf">{Math.round(pantryMatchScore(r, state.pantry)*100)}% in pantry</Badge>
                </button>
              ))}
              {filtered.length === 0 && (
                <div className="p-8 text-center text-sm text-stone-500">No {picker.slot} recipes match. Try clearing filters.</div>
              )}
            </div>
          </div>
        </div>
      )}

      {previewRecipe && window.__KA.RecipePreviewModal && (
        <window.__KA.RecipePreviewModal recipe={previewRecipe} onClose={()=>setPreviewRecipe(null)}/>
      )}

      <Section title="How auto-plan works">
        <Card className="bg-brand-50/40">
          <div className="flex items-start gap-3">
            <Icon name="info" cls="w-5 h-5 text-brand-600 shrink-0 mt-0.5"/>
            <div className="text-sm">
              Scoring formula: <strong>pantry match × 3</strong> + cuisine variety + protein-filter boost + preferences-keyword boost − prep-time penalty (&gt;60min) − recent-cooldown. Top-5 by score enter a weighted random pick so no two runs give identical plans. <strong>Clear &amp; regenerate</strong> explicitly excludes the {currentlyPlannedIds.length} recipes from your current week.
            </div>
          </div>
        </Card>
      </Section>
    </div>
  );
}

K.MealPlan = MealPlan;
</script>

<!-- =============== RECIPE LIBRARY + DETAIL =============== -->
<script type="text/babel" data-type="module">
const { useState, useEffect, useMemo, useRef } = React;
const K = window.__KA;
const { Icon, Card, Section, Button, Badge, Chip, Input, HintBubble, useApp, pantryMatchScore, Claude } = K;

/* ─────────────────────────────────────────────────────────────────────────
   ADD RECIPE — URL / paste / photo, parsed by Claude into structured data.
   ───────────────────────────────────────────────────────────────────────── */
function AddRecipeSheet({ onClose, onAdded }){
  const { notify } = useApp();
  const [mode, setMode] = useState('url'); // 'url' | 'text' | 'photo'
  const [url, setUrl] = useState('');
  const [text, setText] = useState('');
  const [file, setFile] = useState(null);
  const [filePreview, setFilePreview] = useState(null);
  const [busy, setBusy] = useState(false);
  const [parsed, setParsed] = useState(null); // structured recipe after Claude returns
  const fileRef = React.useRef(null);

  const hasKey = Claude.isEnabled();

  const handleFile = (e) => {
    const f = e.target.files?.[0];
    if (!f) return;
    setFile(f);
    setFilePreview(URL.createObjectURL(f));
  };

  const parse = async () => {
    if (!hasKey) { notify('Add an Anthropic API key in Settings first', 'error'); return; }
    setBusy(true); setParsed(null);
    try {
      const r = await Claude.parseRecipe(
        mode === 'url'  ? { url: url.trim() } :
        mode === 'text' ? { text } :
                          { file }
      );
      setParsed(r);
    } catch (e) {
      notify('Recipe parse failed: ' + e.message, 'error');
    } finally {
      setBusy(false);
    }
  };

  const save = () => {
    if (!parsed) return;
    // Persist to localStorage list of custom recipes
    let customs = [];
    try { customs = JSON.parse(localStorage.getItem('kitchenAgent:v2:customRecipes') || '[]'); } catch {}
    customs.push(parsed);
    localStorage.setItem('kitchenAgent:v2:customRecipes', JSON.stringify(customs));
    if (window.KA_addRecipe) window.KA_addRecipe(parsed);
    notify(`Added "${parsed.name}" to your library`, 'success');
    onAdded && onAdded(parsed);
    onClose();
  };

  // ────── edit-before-save: minimal inline editing ──────
  const updateField = (k, v) => setParsed(p => ({...p, [k]: v}));
  const updateStep = (i, v) => setParsed(p => ({...p, steps: p.steps.map((s, idx)=> idx===i ? v : s)}));
  const updateIng  = (i, v) => setParsed(p => ({...p, ingredients: p.ingredients.map((s, idx)=> idx===i ? v : s)}));
  const addStep = () => setParsed(p => ({...p, steps: [...(p.steps||[]), '']}));
  const addIng  = () => setParsed(p => ({...p, ingredients: [...(p.ingredients||[]), '']}));
  const rmStep = (i) => setParsed(p => ({...p, steps: p.steps.filter((_,idx)=>idx!==i)}));
  const rmIng  = (i) => setParsed(p => ({...p, ingredients: p.ingredients.filter((_,idx)=>idx!==i)}));

  return (
    <div className="fixed inset-0 bg-black/50 z-40 flex md:items-center md:justify-center md:p-4 items-end justify-stretch" onClick={onClose}>
      <div className="bg-white w-full md:max-w-xl md:rounded-2xl rounded-t-2xl max-h-[92vh] md:max-h-[88vh] flex flex-col shadow-2xl fade-in"
        style={{paddingBottom:'env(safe-area-inset-bottom)'}}
        onClick={e=>e.stopPropagation()}>
        <div className="md:hidden w-12 h-1.5 rounded-full bg-stone-300 mx-auto my-2.5"/>
        <div className="px-4 pt-2 pb-3 border-b border-stone-200 flex items-center justify-between">
          <h3 className="font-display text-xl">Add a recipe</h3>
          <button onClick={onClose} aria-label="close" className="w-10 h-10 rounded-full text-stone-500 hover:bg-stone-100 flex items-center justify-center">
            <Icon name="x" cls="w-5 h-5"/>
          </button>
        </div>

        {!hasKey && (
          <div className="px-4 py-3 bg-amber-50 text-amber-800 text-sm border-b border-amber-200">
            Add an Anthropic API key in Settings to enable recipe import.
          </div>
        )}

        {!parsed ? (
          <>
            <div className="px-4 pt-3">
              <div className="grid grid-cols-3 gap-1.5 p-1 bg-stone-100 rounded-xl">
                {[['url','🔗 URL'],['text','📝 Paste'],['photo','📷 Photo']].map(([id,label]) => (
                  <button key={id} onClick={()=>setMode(id)}
                    className={'px-3 py-2.5 rounded-lg text-sm font-medium min-h-[44px] transition '+(mode===id?'bg-white text-brand-700 shadow-sm':'text-stone-600')}>
                    {label}
                  </button>
                ))}
              </div>
            </div>
            <div className="flex-1 overflow-y-auto px-4 pt-3 pb-4 space-y-3">
              {mode === 'url' && (
                <div className="space-y-2">
                  <label className="text-xs text-stone-500 uppercase tracking-wide">Recipe URL</label>
                  <Input value={url} onChange={e=>setUrl(e.target.value)}
                    placeholder="https://cooking.nytimes.com/recipes/..."
                    inputMode="url" autoComplete="off"/>
                  <p className="text-xs text-stone-500">
                    Claude tries to recall the recipe from its training. For brand-new posts, use Paste instead.
                  </p>
                </div>
              )}
              {mode === 'text' && (
                <div className="space-y-2">
                  <label className="text-xs text-stone-500 uppercase tracking-wide">Paste the recipe text</label>
                  <textarea value={text} onChange={e=>setText(e.target.value)} rows={10}
                    placeholder="Paste ingredients + steps from anywhere — blog, email, Notes app, screenshot OCR — Claude will structure it."
                    className="w-full px-3 py-3 border border-stone-300 rounded-lg text-base"
                    style={{minHeight:'180px'}}/>
                </div>
              )}
              {mode === 'photo' && (
                <div className="space-y-3">
                  <input type="file" accept="image/*" capture="environment" ref={fileRef} onChange={handleFile} className="hidden"/>
                  {!filePreview ? (
                    <Button onClick={()=>fileRef.current?.click()} className="w-full justify-center min-h-[56px]">
                      <Icon name="camera" cls="w-5 h-5"/>Photo of cookbook page or screen
                    </Button>
                  ) : (
                    <div className="flex gap-3">
                      <img src={filePreview} className="w-32 h-32 object-contain rounded-lg bg-stone-50 border border-stone-200 shrink-0" alt="recipe"/>
                      <div className="flex-1">
                        <div className="text-sm text-stone-600">Looks good?</div>
                        <button onClick={()=>{ setFile(null); setFilePreview(null); fileRef.current?.click(); }} className="text-xs text-brand-600 underline mt-1">Choose different photo</button>
                      </div>
                    </div>
                  )}
                </div>
              )}
            </div>
            <div className="border-t border-stone-200 px-4 py-3 bg-white">
              <Button onClick={parse} disabled={busy || !hasKey || (mode==='url' && !url.trim()) || (mode==='text' && !text.trim()) || (mode==='photo' && !file)}
                className="w-full justify-center min-h-[48px]">
                {busy ? (<><Icon name="refresh" cls="w-4 h-4 animate-spin"/>Asking Claude…</>) : 'Parse with Claude'}
              </Button>
            </div>
          </>
        ) : (
          // Edit-before-save screen
          <>
            <div className="flex-1 overflow-y-auto px-4 pt-3 pb-4 space-y-4">
              <div>
                <label className="text-xs text-stone-500 uppercase tracking-wide">Recipe name</label>
                <Input value={parsed.name||''} onChange={e=>updateField('name', e.target.value)} className="mt-1 text-base"/>
              </div>
              <div className="grid grid-cols-3 gap-2">
                <div>
                  <label className="text-xs text-stone-500">Servings</label>
                  <Input type="number" value={parsed.servings||1} min="1" inputMode="numeric" onChange={e=>updateField('servings', Number(e.target.value)||1)} className="mt-1"/>
                </div>
                <div>
                  <label className="text-xs text-stone-500">Prep min</label>
                  <Input type="number" value={parsed.prep_min||0} min="0" inputMode="numeric" onChange={e=>updateField('prep_min', Number(e.target.value)||0)} className="mt-1"/>
                </div>
                <div>
                  <label className="text-xs text-stone-500">Cook min</label>
                  <Input type="number" value={parsed.cook_min||0} min="0" inputMode="numeric" onChange={e=>updateField('cook_min', Number(e.target.value)||0)} className="mt-1"/>
                </div>
              </div>
              <div>
                <div className="flex items-center justify-between mb-1">
                  <label className="text-xs text-stone-500 uppercase tracking-wide">Ingredients ({parsed.ingredients?.length||0})</label>
                  <button onClick={addIng} className="text-xs text-brand-600 hover:underline">+ add</button>
                </div>
                <div className="space-y-1.5">
                  {(parsed.ingredients||[]).map((line, i) => (
                    <div key={i} className="flex gap-1.5">
                      <Input value={line} onChange={e=>updateIng(i, e.target.value)} className="flex-1"/>
                      <button onClick={()=>rmIng(i)} className="w-10 h-10 text-stone-400 hover:text-red-500 rounded-lg"><Icon name="x" cls="w-4 h-4 mx-auto"/></button>
                    </div>
                  ))}
                </div>
              </div>
              <div>
                <div className="flex items-center justify-between mb-1">
                  <label className="text-xs text-stone-500 uppercase tracking-wide">Steps ({parsed.steps?.length||0})</label>
                  <button onClick={addStep} className="text-xs text-brand-600 hover:underline">+ add</button>
                </div>
                <div className="space-y-1.5">
                  {(parsed.steps||[]).map((step, i) => (
                    <div key={i} className="flex gap-1.5 items-start">
                      <div className="w-7 h-7 mt-1 shrink-0 rounded-full bg-brand-500 text-white text-xs font-medium flex items-center justify-center">{i+1}</div>
                      <textarea value={step} onChange={e=>updateStep(i, e.target.value)} rows={2}
                        className="flex-1 px-3 py-2 border border-stone-300 rounded-lg text-sm" style={{minHeight:'56px'}}/>
                      <button onClick={()=>rmStep(i)} className="w-10 h-10 mt-1 text-stone-400 hover:text-red-500 rounded-lg shrink-0"><Icon name="x" cls="w-4 h-4 mx-auto"/></button>
                    </div>
                  ))}
                </div>
              </div>
            </div>
            <div className="border-t border-stone-200 px-4 py-3 bg-white flex gap-2">
              <Button variant="outline" onClick={()=>setParsed(null)} className="flex-1 justify-center">Start over</Button>
              <Button onClick={save} className="flex-1 justify-center">Save recipe</Button>
            </div>
          </>
        )}
      </div>
    </div>
  );
}

/* ─────────────────────────────────────────────────────────────────────────
   WHAT CAN I COOK? — Claude suggests 3 recipes from current pantry.
   ───────────────────────────────────────────────────────────────────────── */
function WhatToCookSheet({ onClose }){
  const { state, data, go, notify, setKey } = useApp();
  const [busy, setBusy] = useState(true);
  const [suggestions, setSuggestions] = useState([]);
  const [err, setErr] = useState('');

  useEffect(() => {
    let cancelled = false;
    (async () => {
      try {
        const recent = (state.cookHistory||[]).slice(-10).map(h => h.recipe_name).filter(Boolean);
        const res = await Claude.suggestRecipes({
          pantryItems: state.pantry,
          recentlyCooked: recent,
          dietary: state.profile?.dietary_restrictions || [],
          n: 3,
        });
        if (!cancelled) setSuggestions(res);
      } catch (e) {
        if (!cancelled) setErr(e.message);
      } finally {
        if (!cancelled) setBusy(false);
      }
    })();
    return () => { cancelled = true; };
  }, []);

  const saveAndOpen = (sug) => {
    const recipe = {
      id: 'sugg_' + Date.now().toString(36),
      name: sug.name, source: 'Claude suggestion',
      servings: sug.servings || 2,
      prep_min: sug.prep_min || 0, cook_min: sug.cook_min || 0,
      ingredients: sug.ingredients || [], steps: sug.steps || [],
      tags: ['suggested'], meal_types: ['dinner'],
      canonical_ingredients: [], _custom: true, _imported_at: new Date().toISOString(),
    };
    let customs = [];
    try { customs = JSON.parse(localStorage.getItem('kitchenAgent:v2:customRecipes') || '[]'); } catch {}
    customs.push(recipe);
    localStorage.setItem('kitchenAgent:v2:customRecipes', JSON.stringify(customs));
    if (window.KA_addRecipe) window.KA_addRecipe(recipe);
    onClose();
    setTimeout(() => go('recipe', recipe.id), 50);
  };

  return (
    <div className="fixed inset-0 bg-black/50 z-40 flex md:items-center md:justify-center md:p-4 items-end justify-stretch" onClick={onClose}>
      <div className="bg-white w-full md:max-w-lg md:rounded-2xl rounded-t-2xl max-h-[92vh] md:max-h-[85vh] flex flex-col shadow-2xl fade-in"
        style={{paddingBottom:'env(safe-area-inset-bottom)'}} onClick={e=>e.stopPropagation()}>
        <div className="md:hidden w-12 h-1.5 rounded-full bg-stone-300 mx-auto my-2.5"/>
        <div className="px-4 pt-2 pb-3 border-b border-stone-200 flex items-center justify-between">
          <h3 className="font-display text-xl">What can I cook?</h3>
          <button onClick={onClose} aria-label="close" className="w-10 h-10 rounded-full text-stone-500 hover:bg-stone-100 flex items-center justify-center">
            <Icon name="x" cls="w-5 h-5"/>
          </button>
        </div>
        <div className="flex-1 overflow-y-auto p-4 space-y-3">
          {busy && <div className="text-center text-stone-500 py-8"><Icon name="refresh" cls="w-6 h-6 mx-auto animate-spin text-brand-500 mb-2"/>Claude is checking your pantry…</div>}
          {err && <div className="text-sm text-red-600 bg-red-50 p-3 rounded-lg">Suggestion failed: {err}</div>}
          {!busy && !err && suggestions.length === 0 && (
            <div className="text-center text-stone-500 py-8">No suggestions came back. Try again later or add more items to your pantry.</div>
          )}
          {suggestions.map((sug, i) => (
            <Card key={i} className="card-hover cursor-pointer" onClick={()=>saveAndOpen(sug)}>
              <div className="font-display text-lg">{sug.name}</div>
              <div className="text-sm text-stone-600 mt-1">{sug.why}</div>
              <div className="flex flex-wrap gap-2 mt-2">
                {(sug.prep_min || sug.cook_min) && <Badge tone="brand">{(sug.prep_min||0)+(sug.cook_min||0)} min</Badge>}
                {sug.servings && <Badge tone="stone">{sug.servings} servings</Badge>}
                {sug.missing_items?.length > 0 && <Badge tone="warn">{sug.missing_items.length} to buy</Badge>}
              </div>
              {sug.missing_items?.length > 0 && (
                <div className="text-xs text-stone-500 mt-1.5">Missing: {sug.missing_items.slice(0,4).join(', ')}{sug.missing_items.length>4?'…':''}</div>
              )}
            </Card>
          ))}
        </div>
      </div>
    </div>
  );
}

function RecipeLibrary(){
  const { data, go, state } = useApp();
  const { recipes } = data;
  const [q, setQ] = useState('');
  const [tag, setTag] = useState('all');
  const [source, setSource] = useState('all');
  const [sort, setSort] = useState('pantry');
  const [previewRecipe, setPreviewRecipe] = useState(null);
  const [ingredientQuery, setIngredientQuery] = useState('');
  const [pantryOnlyMode, setPantryOnlyMode] = useState(false);
  const [maxTime, setMaxTime] = useState(0); // 0 = no limit
  const [showAddRecipe, setShowAddRecipe] = useState(false);
  const [showWhatToCook, setShowWhatToCook] = useState(false);
  const [showFavOnly, setShowFavOnly] = useState(false);
  const favs = useMemo(() => {
    try { return new Set(JSON.parse(localStorage.getItem('kitchenAgent:v2:favorites') || '[]')); }
    catch { return new Set(); }
  }, [recipes.length, showFavOnly]);

  const sources = useMemo(()=>{
    const s = new Set(); recipes.forEach(r=>s.add(r.source));
    return ['all', ...Array.from(s)];
  }, [recipes]);
  const tags = useMemo(()=>{
    const s = new Set(); recipes.forEach(r=>(r.tags||[]).forEach(t=>s.add(t)));
    return ['all', ...Array.from(s)];
  }, [recipes]);

  const filtered = useMemo(()=>{
    let list = recipes;
    if (q) list = list.filter(r => r.name.toLowerCase().includes(q.toLowerCase()));
    if (tag !== 'all') list = list.filter(r => (r.tags||[]).includes(tag));
    if (source !== 'all') list = list.filter(r => r.source === source);
    if (ingredientQuery) {
      const qIng = ingredientQuery.toLowerCase().trim();
      list = list.filter(r => {
        // match canonical ingredients OR verbatim ingredient lines
        const inCanonical = (r.canonical_ingredients||[]).some(cid => {
          const ing = data.ingredients.find(i => i.id === cid);
          return (ing?.name || cid).toLowerCase().includes(qIng);
        });
        const inLines = (r.ingredients||[]).some(line => {
          const t = typeof line === 'string' ? line : (line.name || '');
          return t.toLowerCase().includes(qIng);
        });
        return inCanonical || inLines;
      });
    }
    if (maxTime > 0) {
      list = list.filter(r => ((r.prep_min||0) + (r.cook_min||0)) <= maxTime);
    }
    if (pantryOnlyMode) {
      // Only recipes where pantry covers >=80% of canonical ingredients (close to "no shopping needed")
      list = list.filter(r => {
        const score = pantryMatchScore(r, state.pantry);
        return score >= 0.8;
      });
    }
    if (showFavOnly) list = list.filter(r => favs.has(r.id));
    const withScore = list.map(r => ({ r, p: pantryMatchScore(r, state.pantry) }));
    if (sort === 'pantry') withScore.sort((a,b)=>b.p-a.p);
    else if (sort === 'quick') withScore.sort((a,b)=>((a.r.prep_min||0)+(a.r.cook_min||0)) - ((b.r.prep_min||0)+(b.r.cook_min||0)));
    else if (sort === 'calories') withScore.sort((a,b)=>(a.r.macros?.calories||999) - (b.r.macros?.calories||999));
    else if (sort === 'protein') withScore.sort((a,b)=>(b.r.macros?.protein||0) - (a.r.macros?.protein||0));
    return withScore.map(x => x.r);
  }, [recipes, q, tag, source, sort, state.pantry, ingredientQuery, pantryOnlyMode, maxTime, data.ingredients, showFavOnly, favs]);

  return (
    <div className="space-y-5 fade-in">
      <div>
        <h1 className="font-display text-3xl">Recipes</h1>
        <div className="text-sm text-stone-500 mt-1">{recipes.length} recipes in your library</div>
      </div>

      {/* Top action row — works as 2-up on mobile, inline on desktop */}
      <div className="grid grid-cols-2 md:flex md:justify-start gap-2">
        <Button onClick={()=>setShowWhatToCook(true)} className="justify-center" disabled={!Claude.isEnabled()} title={Claude.isEnabled() ? 'Suggest a meal' : 'Needs Anthropic key in Settings'}>
          <Icon name="flame" cls="w-4 h-4"/>What can I cook?
        </Button>
        <Button variant="outline" onClick={()=>setShowAddRecipe(true)} className="justify-center">
          <Icon name="plus" cls="w-4 h-4"/>Add recipe
        </Button>
      </div>
      {Claude.isEnabled() && (
        <HintBubble id="recipes-import" placement="top" className="max-w-xs">
          ✨ <strong>Add recipe</strong> imports from any URL, pasted text, or a photo of a cookbook page.
        </HintBubble>
      )}

      <div className="space-y-3">
        <div className="flex gap-2 items-center">
          <div className="flex-1 relative">
            <Icon name="search" cls="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-stone-400"/>
            <Input placeholder="Search recipes..." value={q} onChange={e=>setQ(e.target.value)} className="pl-9"/>
          </div>
          <select className="px-3 py-2 border border-stone-300 rounded-lg text-sm bg-white" value={sort} onChange={e=>setSort(e.target.value)}>
            <option value="pantry">Best match</option>
            <option value="quick">Quickest</option>
            <option value="calories">Fewest calories</option>
            <option value="protein">Most protein</option>
          </select>
        </div>
        <div className="flex gap-2 items-center">
          <div className="flex-1 relative">
            <Icon name="filter" cls="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-stone-400"/>
            <Input placeholder="Search by ingredient (e.g. eggplant)" value={ingredientQuery} onChange={e=>setIngredientQuery(e.target.value)} className="pl-9"/>
          </div>
        </div>

        <div className="flex flex-wrap gap-2 items-center">
          <Chip active={showFavOnly} onClick={()=>setShowFavOnly(!showFavOnly)}>♥ Favorites</Chip>
          <Chip active={pantryOnlyMode} onClick={()=>setPantryOnlyMode(!pantryOnlyMode)}>🍽️ From pantry</Chip>
          <span className="text-xs text-stone-500 ml-2">Max time:</span>
          {[0,15,30,45,60].map(m => (
            <Chip key={m} active={maxTime===m} onClick={()=>setMaxTime(m)}>{m===0 ? 'any' : m+' min'}</Chip>
          ))}
        </div>

        <div className="flex gap-2 flex-wrap">
          {tags.slice(0,10).map(t => <Chip key={t} active={tag===t} onClick={()=>setTag(t)}>{t}</Chip>)}
        </div>
        <div className="flex gap-2 flex-wrap text-xs">
          {sources.map(s => <button key={s} onClick={()=>setSource(s)} className={'px-2.5 py-1 rounded-full border '+(source===s?'bg-stone-800 text-white border-stone-800':'bg-white text-stone-500 border-stone-300')}>{s}</button>)}
        </div>
      </div>

      <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {filtered.slice(0, 60).map(r => <RecipeCard key={r.id} recipe={r} onSelect={setPreviewRecipe}/>)}
      </div>
      {filtered.length > 60 && <div className="text-center text-sm text-stone-500">Showing first 60 of {filtered.length}. Refine filters to see more.</div>}
      {filtered.length === 0 && <div className="text-center text-stone-500 py-8">No recipes match.</div>}

      {previewRecipe && <RecipePreviewModal recipe={previewRecipe} onClose={()=>setPreviewRecipe(null)}/>}
      {showAddRecipe && <AddRecipeSheet onClose={()=>setShowAddRecipe(false)} onAdded={()=>{ /* loadData re-runs on next mount */ }}/>}
      {showWhatToCook && <WhatToCookSheet onClose={()=>setShowWhatToCook(false)}/>}
    </div>
  );
}

function RecipeCard({recipe, onSelect}){
  const { go, state } = useApp();
  const match = Math.round(pantryMatchScore(recipe, state.pantry)*100);
  const cookedCount = (state.cookHistory||[]).filter(h => h.recipe_id === recipe.id).length;
  const handleClick = () => { if (onSelect) onSelect(recipe); else go('recipe', recipe.id); };
  return (
    <Card className="card-hover cursor-pointer relative" onClick={handleClick}>
      <div className="absolute top-2 right-2 z-10" onClick={e=>e.stopPropagation()}>
        <FavoriteHeart id={recipe.id} size="w-5 h-5"/>
      </div>
      <div className="flex items-center justify-center h-28 bg-gradient-to-br from-brand-100 to-brand-50 rounded-lg text-5xl mb-3">
        {recipe.tags?.includes('asian') ? '🍜' : recipe.tags?.includes('mexican') ? '🌮' : recipe.tags?.includes('italian') ? '🍝' : recipe.tags?.includes('mediterranean') ? '🥙' : recipe.tags?.includes('indian') ? '🍛' : '🍽️'}
      </div>
      <div className="font-medium line-clamp-2 mb-1 pr-8">{recipe.name}</div>
      <div className="text-xs text-stone-500">{recipe.source}</div>
      <div className="flex items-center gap-2 mt-2 flex-wrap">
        <Badge tone="brand">{(recipe.prep_min||0)+(recipe.cook_min||0)} min</Badge>
        {recipe.macros?.calories && <Badge tone="stone">{recipe.macros.calories} cal</Badge>}
        {match>0 && <Badge tone={match>60?'leaf':'stone'}>{match}% pantry</Badge>}
        {cookedCount > 0 && <Badge tone="leaf">cooked {cookedCount}×</Badge>}
      </div>
    </Card>
  );
}

// ─── Tiny shared helpers for favorites + per-recipe notes ─────────────
const RecipeMeta = {
  FAV_KEY:  'kitchenAgent:v2:favorites',
  NOTE_KEY: 'kitchenAgent:v2:recipeNotes',
  isFav(id){
    try { return JSON.parse(localStorage.getItem(this.FAV_KEY) || '[]').includes(id); }
    catch { return false; }
  },
  toggleFav(id){
    let list = [];
    try { list = JSON.parse(localStorage.getItem(this.FAV_KEY) || '[]'); } catch {}
    const i = list.indexOf(id);
    if (i >= 0) list.splice(i,1); else list.push(id);
    localStorage.setItem(this.FAV_KEY, JSON.stringify(list));
    return i < 0; // returns new fav-state
  },
  getNote(id){
    try { return JSON.parse(localStorage.getItem(this.NOTE_KEY) || '{}')[id] || ''; }
    catch { return ''; }
  },
  setNote(id, text){
    let obj = {};
    try { obj = JSON.parse(localStorage.getItem(this.NOTE_KEY) || '{}'); } catch {}
    if (text && text.trim()) obj[id] = text;
    else delete obj[id];
    localStorage.setItem(this.NOTE_KEY, JSON.stringify(obj));
  },
};

function FavoriteHeart({id, size='w-6 h-6'}){
  const [on, setOn] = React.useState(() => RecipeMeta.isFav(id));
  const toggle = (e) => { e.stopPropagation(); setOn(RecipeMeta.toggleFav(id)); };
  return (
    <button onClick={toggle} aria-label={on?'unfavorite':'favorite'} title={on?'Remove from favorites':'Save to favorites'}
      className={'w-11 h-11 rounded-full flex items-center justify-center transition '+
        (on ? 'text-red-500 hover:bg-red-50' : 'text-stone-400 hover:bg-stone-100 hover:text-red-400')}>
      <svg viewBox="0 0 24 24" className={size} fill={on?'currentColor':'none'} stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
        <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
      </svg>
    </button>
  );
}

function RecipeDetail({id}){
  const { data, state, setKey, go, notify } = useApp();
  const recipe = data.recipes.find(r => r.id === id);
  if (!recipe) return <div className="text-stone-500">Recipe not found. <button onClick={()=>go('recipes')} className="text-brand-600 underline">Back to library</button></div>;
  const match = Math.round(pantryMatchScore(recipe, state.pantry)*100);
  const pantryById = Object.fromEntries(state.pantry.map(p => [p.ingredient_id, p]));

  // ── Cooked stats from cookHistory + notes ──
  const cookedEntries = (state.cookHistory || []).filter(h => h.recipe_id === id);
  const cookedCount = cookedEntries.length;
  const lastCooked = cookedEntries.length ? new Date(Math.max(...cookedEntries.map(h => new Date(h.date)))) : null;
  const daysSinceCook = lastCooked ? Math.floor((Date.now() - lastCooked.getTime()) / 86400000) : null;
  const avgRating = cookedEntries.length
    ? Math.round(cookedEntries.reduce((s,h)=>s+(h.rating||0),0) / cookedEntries.length * 10) / 10
    : 0;
  const [note, setNoteState] = React.useState(() => RecipeMeta.getNote(id));
  const saveNote = (v) => { setNoteState(v); RecipeMeta.setNote(id, v); };
  const canonicalIngredients = (recipe.canonical_ingredients||[]).map(cid => {
    const ing = data.ingredients.find(i => i.id === cid);
    return { id: cid, name: ing?.name || cid, inPantry: !!pantryById[cid] };
  });
  const missingIngredients = canonicalIngredients.filter(c => !c.inPantry);

  const addMissingToShopping = () => {
    const extras = [...state.shoppingExtras];
    missingIngredients.forEach(m => {
      if (!extras.find(e => e.ingredient_id === m.id)) {
        extras.push({ id: crypto.randomUUID(), ingredient_id: m.id, qty: 1, source_recipe: recipe.id });
      }
    });
    setKey('shoppingExtras', extras);
    notify(`Added ${missingIngredients.length} items to your shopping list`, 'success');
  };

  const scheduleForToday = () => {
    const key = require_dateKey(new Date());
    const day = state.plan[key] || {};
    const slot = (recipe.meal_types||['dinner'])[0] || 'dinner';
    setKey('plan', { ...state.plan, [key]: { ...day, [slot]: recipe.id } });
    notify(`Scheduled for ${slot} today`, 'success');
  };
  function require_dateKey(d){ return d.toISOString().slice(0,10); }

  return (
    <div className="space-y-6 fade-in max-w-3xl">
      <button onClick={()=>go('recipes')} className="text-sm text-stone-500 hover:text-brand-600 flex items-center gap-1"><Icon name="chevleft" cls="w-4 h-4"/>Back to recipes</button>
      <div>
        <div className="flex items-start justify-between gap-3">
          <div className="min-w-0">
            <div className="text-xs uppercase tracking-wider text-brand-700 font-semibold">{recipe.source}</div>
            <h1 className="font-display text-3xl md:text-4xl mt-1">{recipe.name}</h1>
          </div>
          <FavoriteHeart id={recipe.id} size="w-7 h-7"/>
        </div>
        <div className="flex flex-wrap gap-2 mt-3">
          <Badge tone="brand"><Icon name="clock" cls="w-3 h-3"/>{(recipe.prep_min||0)+(recipe.cook_min||0)} min</Badge>
          {recipe.servings && <Badge tone="stone">{recipe.servings} servings</Badge>}
          {recipe.macros?.calories && <Badge tone="leaf">{recipe.macros.calories} cal</Badge>}
          {recipe.macros?.protein && <Badge tone="stone">{recipe.macros.protein}g protein</Badge>}
          {match > 0 && <Badge tone={match>60?'leaf':'warn'}>{match}% pantry</Badge>}
          {cookedCount > 0 && <Badge tone="leaf">cooked {cookedCount}×{daysSinceCook!==null ? ` · ${daysSinceCook}d ago` : ''}</Badge>}
          {avgRating > 0 && <Badge tone="warn">{'★'.repeat(Math.round(avgRating))} {avgRating.toFixed(1)}</Badge>}
          {recipe._custom && <Badge tone="brand">Your recipe</Badge>}
          {(recipe.tags||[]).slice(0,5).map(t => <Badge key={t} tone="stone">{t}</Badge>)}
        </div>
      </div>

      <div className="flex gap-2 flex-wrap">
        <Button onClick={()=>go('cook', recipe.id)}><Icon name="play" cls="w-4 h-4"/>Start cooking</Button>
        <Button variant="outline" onClick={scheduleForToday}>Add to today</Button>
        {missingIngredients.length > 0 && <Button variant="leaf" onClick={addMissingToShopping}><Icon name="cart" cls="w-4 h-4"/>Add {missingIngredients.length} to shop</Button>}
      </div>

      {/* Your notes — freeform, persisted per recipe. "We double the garlic" etc. */}
      <Card className="bg-amber-50/30 border-amber-200">
        <label className="text-xs text-amber-800 uppercase tracking-wide font-semibold flex items-center gap-1">
          ✏️ Your notes
        </label>
        <textarea
          value={note}
          onChange={e => saveNote(e.target.value)}
          placeholder="e.g. We double the garlic, kids love it, use chicken thighs instead…"
          rows={2}
          className="w-full mt-2 px-3 py-2 bg-white border border-amber-200 rounded-lg text-sm focus:ring-2 focus:ring-amber-400 focus:outline-none"
          style={{minHeight:'52px'}}
        />
      </Card>

      <Card>
        <div className="flex items-center justify-between mb-3">
          <h3 className="font-display text-xl">Ingredients</h3>
          <div className="text-xs text-stone-500">{canonicalIngredients.filter(c=>c.inPantry).length}/{canonicalIngredients.length} in pantry</div>
        </div>
        <div className="space-y-1 mb-3">
          {canonicalIngredients.map(c => (
            <div key={c.id} className="flex items-center gap-2 text-sm py-1">
              {c.inPantry ? <Icon name="check" cls="w-4 h-4 text-leaf-600"/> : <div className="w-4 h-4 rounded-full border border-stone-300"/>}
              <span className={c.inPantry?'text-stone-700':'text-stone-500'}>{c.name}</span>
              {!c.inPantry && <Badge tone="warn">need</Badge>}
            </div>
          ))}
        </div>
        <details className="text-sm text-stone-600">
          <summary className="font-medium text-stone-700 hover:text-stone-900">Show verbatim ingredient list from cookbook ({recipe.ingredients?.length||0})</summary>
          <ul className="list-disc pl-5 space-y-1 mt-2 text-stone-600">
            {recipe.ingredients?.map((line,i) => <li key={i}>{line}</li>)}
          </ul>
        </details>
      </Card>

      <Card>
        <h3 className="font-display text-xl mb-3">Steps</h3>
        <ol className="space-y-3">
          {((window.KA_stepsFor && window.KA_stepsFor(recipe)) || recipe.steps || []).map((step,i) => (
            <li key={i} className="flex gap-3">
              <div className="w-7 h-7 rounded-full bg-brand-500 text-white flex items-center justify-center text-sm font-medium shrink-0">{i+1}</div>
              <div className="text-sm text-stone-700 pt-0.5">{step}</div>
            </li>
          ))}
        </ol>
      </Card>
    </div>
  );
}

function RecipePreviewModal({recipe, onClose}) {
  const { data, state, setKey, go, notify } = useApp();
  const [scaledServings, setScaledServings] = React.useState(recipe?.servings || 4);
  const [generatingDetails, setGeneratingDetails] = React.useState(false);
  const [generatedSteps, setGeneratedSteps] = React.useState(null);
  if (!recipe) return null;
  const match = Math.round(pantryMatchScore(recipe, state.pantry)*100);
  const scaleFactor = scaledServings / (recipe.servings || 1);
  const pantryById = Object.fromEntries(state.pantry.map(p => [p.ingredient_id, p]));
  const canonicalIngredients = (recipe.canonical_ingredients||[]).map(cid => {
    const ing = data.ingredients.find(i => i.id === cid);
    return { id: cid, name: ing?.name || cid, inPantry: !!pantryById[cid] };
  });
  const missing = canonicalIngredients.filter(c => !c.inPantry);

  // v16: Recognize Claude-generated recipes — they have no canonical_ingredients but DO have
  // `ingredients` entries with a `notes` field of "buy ($X)" or "from pantry".
  const isClaudeRecipe = (recipe.source === 'Claude') || (canonicalIngredients.length === 0 && (recipe.ingredients||[]).length > 0);
  const claudeIngredients = isClaudeRecipe
    ? (recipe.ingredients||[]).map((line, i) => ({
        key: 'claude-' + i,
        name: (typeof line === 'string' ? line : (line.name || '')),
        qty: typeof line === 'object' ? (line.qty || '') : '',
        notes: typeof line === 'object' ? (line.notes || '') : '',
        inPantry: typeof line === 'object' && /from pantry/i.test(line.notes || ''),
      }))
    : [];
  const claudeMissing = claudeIngredients.filter(c => !c.inPantry);

  // v16: Auto-generate full steps if recipe only has the placeholder
  React.useEffect(() => {
    if (!isClaudeRecipe) return;
    const steps = window.KA_stepsFor ? window.KA_stepsFor(recipe) : (recipe.steps || []);
    const isPlaceholder = steps.length <= 1 && steps[0] && /generated by claude/i.test(steps[0]);
    if (!isPlaceholder) return;
    if (generatedSteps || generatingDetails) return;
    setGeneratingDetails(true);
    (async () => {
      try {
        const ingList = claudeIngredients.map(c =>
          (c.qty ? c.qty + ' ' : '') + c.name + (c.notes ? ' [' + c.notes + ']' : '')
        ).join('; ');
        const prompt = `Write proper step-by-step cooking instructions for "${recipe.name}". The cook makes ${recipe.servings || 2} servings.

INGREDIENTS AVAILABLE:
${ingList}

EQUIPMENT (only use what's listed): ${(recipe.equipment_used||[]).join(', ') || 'oven, stovetop, microwave'}

Return ONLY JSON, no markdown:
{"steps": ["step 1...", "step 2...", "..."]}

5-9 logical steps, each <200 chars, imperative voice ("Heat oil", not "You should heat"). Include cook times, temperatures, and brief technique notes. Drop fluff.`;
        const raw = await window.KA_claude({
          task: 'recipe-step-cleanup',
          messages: [{ role: 'user', content: prompt }],
        });
        const m = raw.match(/\{[\s\S]*\}/);
        if (!m) throw new Error('no JSON');
        const parsed = JSON.parse(m[0]);
        if (parsed.steps && parsed.steps.length) {
          setGeneratedSteps(parsed.steps);
          if (window.KA_saveCleanedSteps) window.KA_saveCleanedSteps(recipe.id, parsed.steps);
        }
      } catch (e) {
        console.warn('auto-gen steps failed:', e.message);
      } finally {
        setGeneratingDetails(false);
      }
    })();
  }, [recipe.id, isClaudeRecipe]);

  // Lock body scroll while modal is open
  React.useEffect(() => {
    const orig = document.body.style.overflow;
    document.body.style.overflow = 'hidden';
    const onKey = (e) => { if (e.key === 'Escape') onClose(); };
    window.addEventListener('keydown', onKey);
    return () => { document.body.style.overflow = orig; window.removeEventListener('keydown', onKey); };
  }, [onClose]);

  const todayKey = new Date().toISOString().slice(0,10);
  const scheduleForToday = () => {
    const day = state.plan[todayKey] || {};
    const slot = (recipe.meal_types||['dinner'])[0] || 'dinner';
    setKey('plan', { ...state.plan, [todayKey]: { ...day, [slot]: recipe.id } });
    notify(`Scheduled for ${slot} today`, 'success');
    onClose();
  };
  const addMissingToShopping = () => {
    const extras = [...state.shoppingExtras];
    if (isClaudeRecipe) {
      claudeMissing.forEach(m => {
        const fakeId = 'claude_ing_' + m.name.toLowerCase().replace(/[^\w]+/g,'_');
        if (!extras.find(e => e.ingredient_id === fakeId)) {
          extras.push({
            id: crypto.randomUUID(),
            ingredient_id: fakeId,
            name: m.name,
            qty: 1,
            source_recipe: recipe.id,
            est_cost: (() => { const m2 = (m.notes||'').match(/\$([0-9.]+)/); return m2 ? parseFloat(m2[1]) : 0; })(),
          });
        }
      });
      setKey('shoppingExtras', extras);
      notify(`Added ${claudeMissing.length} items to your shopping list`, 'success');
    } else {
      missing.forEach(m => {
        if (!extras.find(e => e.ingredient_id === m.id)) {
          extras.push({ id: crypto.randomUUID(), ingredient_id: m.id, qty: 1, source_recipe: recipe.id });
        }
      });
      setKey('shoppingExtras', extras);
      notify(`Added ${missing.length} items to your shopping list`, 'success');
    }
  };
  const openCookMode = () => { onClose(); go('cook', recipe.id); };

  const m = recipe.macros || {};
  const totalMin = (recipe.prep_min||0)+(recipe.cook_min||0);
  const heroEmoji = recipe.tags?.includes('asian') ? '🍜' : recipe.tags?.includes('mexican') ? '🌮' : recipe.tags?.includes('italian') ? '🍝' : recipe.tags?.includes('mediterranean') ? '🥙' : recipe.tags?.includes('indian') ? '🍛' : '🍽️';

  return (
    <div className="fixed inset-0 z-40 bg-black/50 flex items-center justify-center p-0 md:p-4 fade-in" onClick={onClose}>
      <div
        className="bg-white w-full md:max-w-2xl md:rounded-2xl rounded-t-2xl shadow-2xl flex flex-col overflow-hidden"
        style={{ maxHeight: '92vh', height: 'auto' }}
        onClick={e => e.stopPropagation()}>

        {/* Hero / header */}
        <div className="relative">
          <div className="h-32 md:h-40 bg-gradient-to-br from-brand-100 to-brand-50 flex items-center justify-center text-6xl md:text-7xl">
            {heroEmoji}
          </div>
          <button onClick={onClose}
            aria-label="Close"
            className="absolute top-3 right-3 w-9 h-9 rounded-full bg-white/95 border border-stone-200 shadow-md flex items-center justify-center hover:bg-stone-100">
            <Icon name="x" cls="w-4 h-4 text-stone-700"/>
          </button>
        </div>

        {/* Scrollable content */}
        <div className="overflow-y-auto flex-1 px-4 md:px-6 py-4 space-y-5">
          <div>
            <div className="text-[11px] uppercase tracking-wider text-brand-700 font-semibold">{recipe.source}</div>
            <h2 className="font-display text-2xl md:text-3xl mt-0.5 leading-tight">{recipe.name}</h2>
            <div className="flex flex-wrap gap-1.5 mt-2">
              <Badge tone="brand"><Icon name="clock" cls="w-3 h-3"/>{totalMin} min</Badge>
              {recipe.servings && <Badge tone="stone">{recipe.servings} servings</Badge>}
              {match > 0 && <Badge tone={match>60?'leaf':'warn'}>{match}% pantry</Badge>}
              {(recipe.tags||[]).slice(0,4).map(t => <Badge key={t} tone="stone">{t}</Badge>)}
            </div>
          </div>

          {/* Macros card (per serving — scaled values shown if user adjusted) */}
          {(m.calories || m.protein || m.carbs || m.fat) && (
            <div>
              <div className="text-xs text-stone-500 uppercase tracking-wide mb-1.5">Macros (per serving)</div>
              <div className="grid grid-cols-2 sm:grid-cols-4 gap-2">
                {m.calories != null && (
                  <div className="bg-brand-50 rounded-xl p-3 text-center">
                    <div className="text-xs text-stone-500 uppercase tracking-wide">Calories</div>
                    <div className="font-display text-xl text-brand-700">{m.calories}</div>
                  </div>
                )}
                {m.protein != null && (
                  <div className="bg-leaf-500/10 rounded-xl p-3 text-center">
                    <div className="text-xs text-stone-500 uppercase tracking-wide">Protein</div>
                    <div className="font-display text-xl text-leaf-700">{m.protein}g</div>
                  </div>
                )}
                {m.carbs != null && (
                  <div className="bg-amber-50 rounded-xl p-3 text-center">
                    <div className="text-xs text-stone-500 uppercase tracking-wide">Carbs</div>
                    <div className="font-display text-xl text-amber-700">{m.carbs}g</div>
                  </div>
                )}
                {m.fat != null && (
                  <div className="bg-stone-100 rounded-xl p-3 text-center">
                    <div className="text-xs text-stone-500 uppercase tracking-wide">Fat</div>
                    <div className="font-display text-xl text-stone-700">{m.fat}g</div>
                  </div>
                )}
              </div>
              {scaleFactor !== 1 && (m.calories || m.protein) && (
                <div className="text-[11px] text-stone-500 mt-1.5">
                  Total for {scaledServings} servings: {m.calories ? `${Math.round(m.calories * scaledServings)} cal` : ''}{m.calories && m.protein ? ' · ' : ''}{m.protein ? `${Math.round(m.protein * scaledServings)}g protein` : ''}
                </div>
              )}
            </div>
          )}

          {/* Servings scaler */}
          <div className="bg-white border border-stone-200 rounded-xl p-3">
            <div className="flex items-center justify-between mb-2">
              <div className="text-xs text-stone-500 uppercase tracking-wide">Scale to</div>
              <div className="font-display text-lg">{scaledServings} servings</div>
            </div>
            <input type="range" min={1} max={Math.max(12, (recipe.servings||4)*3)} step={1} value={scaledServings}
              onChange={e => setScaledServings(parseInt(e.target.value)||1)}
              className="w-full accent-brand-500"/>
            <div className="flex justify-between text-[11px] text-stone-500 mt-1">
              <span>1</span>
              <span>Recipe default: {recipe.servings || 4}</span>
              <span>{Math.max(12, (recipe.servings||4)*3)}</span>
            </div>
            <div className="text-xs text-stone-600 mt-1">Ingredients &amp; macros below auto-scale by {scaleFactor.toFixed(2)}×.</div>
          </div>

          {/* Time breakdown */}
          {(recipe.prep_min || recipe.cook_min) && (
            <div className="flex gap-3 text-sm">
              {recipe.prep_min ? <div><span className="text-stone-500">Prep · </span><span className="font-medium">{recipe.prep_min} min</span></div> : null}
              {recipe.cook_min ? <div><span className="text-stone-500">Cook · </span><span className="font-medium">{recipe.cook_min} min</span></div> : null}
            </div>
          )}

          {/* Ingredients */}
          <div>
            <div className="flex items-center justify-between mb-2">
              <h3 className="font-display text-lg">Ingredients</h3>
              <div className="text-xs text-stone-500">
                {isClaudeRecipe
                  ? `${claudeIngredients.filter(c=>c.inPantry).length}/${claudeIngredients.length} from pantry`
                  : `${canonicalIngredients.filter(c=>c.inPantry).length}/${canonicalIngredients.length} in pantry`}
              </div>
            </div>
            <div className="space-y-1">
              {isClaudeRecipe ? (
                claudeIngredients.length === 0 ? (
                  <div className="text-sm text-stone-500 italic">No ingredient data for this Claude recipe.</div>
                ) : (
                  claudeIngredients.map(c => (
                    <div key={c.key} className="flex items-center gap-2 text-sm py-1">
                      {c.inPantry
                        ? <Icon name="check" cls="w-4 h-4 text-leaf-600"/>
                        : <div className="w-4 h-4 rounded-full border border-stone-300"/>}
                      <span className={c.inPantry?'text-stone-700':'text-stone-500'}>
                        {c.qty ? <span className="font-medium mr-1">{c.qty}</span> : null}
                        {c.name}
                      </span>
                      {c.inPantry
                        ? <Badge tone="leaf">pantry</Badge>
                        : <Badge tone="warn">{c.notes && c.notes.startsWith('buy') ? c.notes : 'need'}</Badge>}
                    </div>
                  ))
                )
              ) : (
                <>
                  {canonicalIngredients.map(c => (
                    <div key={c.id} className="flex items-center gap-2 text-sm py-1">
                      {c.inPantry
                        ? <Icon name="check" cls="w-4 h-4 text-leaf-600"/>
                        : <div className="w-4 h-4 rounded-full border border-stone-300"/>}
                      <span className={c.inPantry?'text-stone-700':'text-stone-500'}>{c.name}</span>
                      {!c.inPantry && <Badge tone="warn">need</Badge>}
                    </div>
                  ))}
                  {canonicalIngredients.length === 0 && (
                    <div className="text-sm text-stone-500 italic">Cookbook list — no canonical match data.</div>
                  )}
                </>
              )}
            </div>
            {recipe.ingredients?.length > 0 && (
              <details className="text-sm text-stone-600 mt-2" open={scaleFactor !== 1}>
                <summary className="font-medium text-stone-700 cursor-pointer hover:text-stone-900">
                  Cookbook ingredient list ({recipe.ingredients.length}){scaleFactor !== 1 ? ` — scaled ${scaleFactor.toFixed(2)}×` : ''}
                </summary>
                <ul className="list-disc pl-5 space-y-1 mt-2 text-stone-600">
                  {recipe.ingredients.map((line,i) => {
                    const text = typeof line === 'string' ? line : (line.qty ? line.qty + ' ' : '') + (line.name || '') + (line.notes ? ' — ' + line.notes : '');
                    if (scaleFactor === 1) return <li key={i}>{text}</li>;
                    // Try to scale leading numbers (e.g. "2 cups flour" → "3 cups flour")
                    const scaled = text.replace(/^(\d+(?:\.\d+)?(?:\s*\/\s*\d+)?|\d+\s+\d+\/\d+)/, (n) => {
                      let val = parseFloat(n);
                      if (n.includes('/')) {
                        const parts = n.split(/\s+/);
                        let total = 0;
                        for (const p of parts) {
                          if (p.includes('/')) { const [a,b] = p.split('/').map(parseFloat); total += a/b; }
                          else total += parseFloat(p);
                        }
                        val = total;
                      }
                      const scaled = val * scaleFactor;
                      const rounded = scaled < 1 ? scaled.toFixed(2) : scaled.toFixed(scaled % 1 === 0 ? 0 : 1);
                      return rounded;
                    });
                    return <li key={i}>{scaled}</li>;
                  })}
                </ul>
              </details>
            )}
          </div>

          {generatingDetails && (
            <div className="bg-brand-50/60 border border-brand-200 rounded-lg p-3 text-sm text-brand-800 flex items-center gap-2">
              <span className="animate-spin">⚙️</span>
              <span>Claude is writing the cooking steps — this takes ~3-5 sec…</span>
            </div>
          )}

          {/* Steps */}
          {(() => {
            const cleanedSteps = (window.KA_stepsFor && window.KA_stepsFor(recipe)) || recipe.steps || [];
            const usingOverride = window.KA_getCleanedSteps && window.KA_getCleanedSteps(recipe);
            if (!cleanedSteps.length) return null;
            return (
              <div>
                <div className="flex items-baseline justify-between mb-2">
                  <h3 className="font-display text-lg">Steps</h3>
                  <button
                    onClick={async () => {
                      try {
                        const newSteps = await window.KA_cleanupRecipeSteps(recipe);
                        window.KA_saveCleanedSteps(recipe.id, newSteps);
                        notify('Steps reformatted by Claude — close & re-open to see.', 'success');
                      } catch (e) { notify('Cleanup failed: ' + e.message, 'error'); }
                    }}
                    className="text-[11px] text-brand-600 hover:underline"
                    title="Ask Claude to clean up these steps">
                    {usingOverride ? '✓ cleaned by Claude — reformat again' : '✨ Reformat steps with Claude'}
                  </button>
                </div>
                <ol className="space-y-3">
                  {cleanedSteps.map((step,i) => (
                    <li key={i} className="flex gap-3">
                      <div className="w-7 h-7 rounded-full bg-brand-500 text-white flex items-center justify-center text-sm font-medium shrink-0">{i+1}</div>
                      <div className="text-sm text-stone-700 pt-0.5 leading-relaxed">{step}</div>
                    </li>
                  ))}
                </ol>
              </div>
            );
          })()}

          {/* Notes */}
          {recipe.notes && (
            <div className="bg-stone-50 rounded-xl p-3 text-sm text-stone-700">
              <div className="font-medium text-stone-800 mb-1">Notes</div>
              {recipe.notes}
            </div>
          )}
        </div>

        {/* Sticky bottom action bar */}
        <div className="border-t border-stone-200 bg-white px-4 md:px-6 py-3 flex flex-wrap gap-2 sticky bottom-0">
          <Button onClick={openCookMode}><Icon name="play" cls="w-4 h-4"/>Cook now</Button>
          <Button variant="outline" onClick={scheduleForToday}>Add to today</Button>
          {(isClaudeRecipe ? claudeMissing.length : missing.length) > 0 && (
            <Button variant="leaf" onClick={addMissingToShopping}>
              <Icon name="cart" cls="w-4 h-4"/>+{isClaudeRecipe ? claudeMissing.length : missing.length} to shop
            </Button>
          )}
          <Button variant="ghost" onClick={() => snapshotRecipe(recipe, scaledServings, scaleFactor)}>📸 Save image</Button>
        </div>
      </div>
    </div>
  );
}

async function snapshotRecipe(recipe, scaledServings, scaleFactor) {
  // Lazy-load html2canvas if not present
  const ensureH2C = () => new Promise((resolve, reject) => {
    if (window.html2canvas) return resolve(window.html2canvas);
    const s = document.createElement('script');
    s.src = 'https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js';
    s.onload = () => resolve(window.html2canvas);
    s.onerror = () => reject(new Error('html2canvas CDN load failed'));
    document.head.appendChild(s);
  });

  // Build a clean shareable card off-screen
  const card = document.createElement('div');
  card.style.cssText = 'position:fixed;left:-9999px;top:0;width:600px;background:#fbf7f3;padding:32px;font-family:Georgia,serif;color:#3d2b1f;border-radius:24px;border:6px solid #c96b4a;';
  const m = recipe.macros || {};
  const total = (recipe.prep_min||0)+(recipe.cook_min||0);
  card.innerHTML = `
    <div style="text-align:center;margin-bottom:18px;">
      <div style="font-size:0.7rem;color:#c96b4a;text-transform:uppercase;letter-spacing:0.1em;font-weight:700;font-family:Arial,sans-serif;">${recipe.source || 'Kitchen Agent'}</div>
      <h1 style="font-size:1.9rem;margin:6px 0 0;color:#3d2b1f;">${recipe.name}</h1>
      <div style="font-family:Arial,sans-serif;font-size:0.85rem;color:#78716c;margin-top:10px;">
        ${total ? `⏱️ ${total} min` : ''}${recipe.servings ? ` · 🍽️ ${scaledServings} servings` : ''}${m.calories ? ` · 🔥 ${m.calories} cal` : ''}${m.protein ? ` · 💪 ${m.protein}g protein` : ''}
      </div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;font-family:Arial,sans-serif;font-size:0.85rem;">
      <div>
        <div style="font-weight:700;color:#c96b4a;text-transform:uppercase;letter-spacing:0.05em;font-size:0.7rem;margin-bottom:8px;border-bottom:2px solid #c96b4a;padding-bottom:4px;">Ingredients</div>
        <ul style="margin:0;padding-left:18px;color:#3d2b1f;">
          ${(recipe.ingredients||[]).slice(0,12).map(line => {
            let text = typeof line === 'string' ? line : ((line.qty ? line.qty + ' ' : '') + (line.name || ''));
            if (scaleFactor !== 1) {
              text = text.replace(/^(\d+(?:\.\d+)?)/, n => (parseFloat(n) * scaleFactor).toFixed(1).replace(/\.0$/,''));
            }
            return `<li style="margin-bottom:4px;">${text}</li>`;
          }).join('')}
          ${(recipe.ingredients||[]).length > 12 ? `<li style="color:#a8a29e;">+${recipe.ingredients.length-12} more</li>` : ''}
        </ul>
      </div>
      <div>
        <div style="font-weight:700;color:#c96b4a;text-transform:uppercase;letter-spacing:0.05em;font-size:0.7rem;margin-bottom:8px;border-bottom:2px solid #c96b4a;padding-bottom:4px;">Steps</div>
        <ol style="margin:0;padding-left:20px;color:#3d2b1f;">
          ${((window.KA_stepsFor && window.KA_stepsFor(recipe)) || recipe.steps || []).slice(0,8).map(s => `<li style="margin-bottom:6px;">${s.length > 110 ? s.slice(0,110)+'…' : s}</li>`).join('')}
          ${(((window.KA_stepsFor && window.KA_stepsFor(recipe)) || recipe.steps || []).length) > 8 ? `<li style="color:#a8a29e;">+${(((window.KA_stepsFor && window.KA_stepsFor(recipe)) || recipe.steps || []).length)-8} more steps</li>` : ''}
        </ol>
      </div>
    </div>
    <div style="margin-top:20px;padding-top:14px;border-top:1px dashed #d6d3d1;text-align:center;font-family:Arial,sans-serif;font-size:0.7rem;color:#a8a29e;">
      Saved from Kitchen Agent · ${new Date().toLocaleDateString()}
    </div>
  `;
  document.body.appendChild(card);

  try {
    const h2c = await ensureH2C();
    const canvas = await h2c(card, { backgroundColor: '#fbf7f3', scale: 2 });
    const dataUrl = canvas.toDataURL('image/png');
    const a = document.createElement('a');
    a.href = dataUrl;
    a.download = (recipe.name || 'recipe').replace(/[^\w]+/g, '_') + '.png';
    a.click();
  } catch (e) {
    alert('Snapshot failed: ' + e.message);
  } finally {
    card.remove();
  }
}

K.RecipePreviewModal = RecipePreviewModal;
K.RecipeLibrary = RecipeLibrary;
K.RecipeDetail = RecipeDetail;
</script>

<!-- =============== COOK MODE =============== -->
<script type="text/babel" data-type="module">
const { useState, useEffect, useRef } = React;
const K = window.__KA;
const { Icon, Card, Section, Button, Badge, useApp } = K;

// ─── Helpers for live recipe scaling + step-text timer detection ────────
// Detects "for 15 min" / "5 minutes" / "1 hour 20 min" → returns total minutes.
function detectStepTimerMinutes(stepText){
  if (!stepText) return null;
  const t = stepText.toLowerCase();
  // hours + minutes combo
  const hm = t.match(/(\d+)\s*(?:h|hour|hours|hr|hrs)\s*(?:and\s*)?(\d+)?\s*(?:m|min|mins|minute|minutes)?/);
  if (hm) {
    const h = parseInt(hm[1]||'0'), m = parseInt(hm[2]||'0');
    if (h > 0) return h*60 + m;
  }
  // plain minutes — prefer "for X min" phrasing for precision
  const m = t.match(/(?:for|about|simmer|bake|cook|roast|boil|fry|saute|sauté|chill|rest|sit|wait|stir|reduce|microwave)[^.\d]{0,40}(\d{1,3})\s*(?:m|min|mins|minute|minutes)\b/);
  if (m) return parseInt(m[1]);
  const m2 = t.match(/(\d{1,3})\s*(?:minute|minutes|mins|min)\b/);
  if (m2) return parseInt(m2[1]);
  return null;
}
// Live-scale ingredient line by a ratio. Replaces leading numeric expressions
// (1, 1/2, 1 1/2, 2.5) with the scaled amount, formatted nicely.
function scaleIngredient(line, ratio){
  if (!line || ratio === 1) return line;
  const mixed = line.match(/^(\d+)\s+(\d+)\/(\d+)\s*/); // "1 1/2 cups..."
  const frac  = line.match(/^(\d+)\/(\d+)\s*/);          // "1/2 cup..."
  const dec   = line.match(/^(\d+(?:\.\d+)?)\s*/);       // "1.5 cups..." or "2 cups..."
  let original = 0, rest = line;
  if (mixed) { original = parseInt(mixed[1]) + parseInt(mixed[2])/parseInt(mixed[3]); rest = line.slice(mixed[0].length); }
  else if (frac) { original = parseInt(frac[1])/parseInt(frac[2]); rest = line.slice(frac[0].length); }
  else if (dec) { original = parseFloat(dec[1]); rest = line.slice(dec[0].length); }
  else return line;
  const scaled = original * ratio;
  // Pretty-format fractions for common ratios
  const pretty = (n) => {
    if (n >= 10) return String(Math.round(n));
    const whole = Math.floor(n);
    const frac = n - whole;
    const sixteenths = Math.round(frac * 16);
    if (sixteenths === 0) return String(whole);
    const map = {2:'⅛',4:'¼',6:'⅜',8:'½',10:'⅝',12:'¾',14:'⅞'};
    const sym = map[sixteenths];
    if (sym) return whole > 0 ? `${whole}${sym}` : sym;
    // fall back: 1 decimal
    return n.toFixed(1).replace(/\.0$/,'');
  };
  return pretty(scaled) + (rest.startsWith(' ') ? '' : ' ') + rest;
}

function CookMode({id}){
  const { data, state, setKey, go, notify } = useApp();
  const recipe = data.recipes.find(r => r.id === id);
  const [stepIdx, setStepIdx] = useState(0);
  const [done, setDone] = useState({});
  const [timers, setTimers] = useState({});
  const [voiceOn, setVoiceOn] = useState(false);
  const [voiceStatus, setVoiceStatus] = useState('');
  const [showFinish, setShowFinish] = useState(false);
  const [finishData, setFinishData] = useState({ servings_made: 0, rating: 0, leftovers_kept: 0, photo: null, est_cost: 0, freezer_packs: 0, freezer_label: '' });
  const [subOpen, setSubOpen] = useState(false);
  const [subResult, setSubResult] = useState(null);
  const [servings, setServings] = useState(() => recipe?.servings || 2);
  const [bigText, setBigText] = useState(false);
  const [showIngredients, setShowIngredients] = useState(false);
  const tick = useRef(null);
  const recogRef = useRef(null);
  const wakeLockRef = useRef(null);

  const steps = (recipe && window.KA_stepsFor) ? window.KA_stepsFor(recipe) : (recipe?.steps || []);
  const stepRef = useRef(stepIdx);
  useEffect(() => { stepRef.current = stepIdx; }, [stepIdx]);

  // ─── SCREEN WAKE LOCK ─────────────────────────────────────────────────
  // Keep the screen on the whole time the user is cooking. Re-acquire after tab refocus.
  useEffect(() => {
    let active = true;
    const acquire = async () => {
      try {
        if ('wakeLock' in navigator) {
          wakeLockRef.current = await navigator.wakeLock.request('screen');
          wakeLockRef.current.addEventListener?.('release', () => { wakeLockRef.current = null; });
        }
      } catch {} // user can deny; not fatal
    };
    acquire();
    const onVis = () => { if (document.visibilityState === 'visible' && active && !wakeLockRef.current) acquire(); };
    document.addEventListener('visibilitychange', onVis);
    return () => {
      active = false;
      document.removeEventListener('visibilitychange', onVis);
      try { wakeLockRef.current && wakeLockRef.current.release(); } catch {}
      wakeLockRef.current = null;
    };
  }, []);

  // Live-scaled ingredients (read-only display in Cook Mode).
  const scaleRatio = servings / (recipe?.servings || 1);
  const scaledIngredients = (recipe?.ingredients || []).map(line => scaleIngredient(line, scaleRatio));

  // Tick down timers
  useEffect(()=>{
    tick.current = setInterval(()=>{
      setTimers(t => {
        const next = {};
        Object.entries(t).forEach(([k, v]) => {
          if (v.running && v.remaining > 0) next[k] = {...v, remaining: v.remaining - 1};
          else if (v.running && v.remaining <= 0) {
            next[k] = {...v, running: false, doneFlag: true};
            try { speakText("Timer finished"); } catch(e){}
          }
          else next[k] = v;
        });
        return next;
      });
    }, 1000);
    return () => clearInterval(tick.current);
  }, []);

  // Voice helpers
  const speakText = (text) => {
    try {
      if (!('speechSynthesis' in window)) return;
      const u = new SpeechSynthesisUtterance(text);
      u.rate = 1.0; u.pitch = 1.0;
      window.speechSynthesis.cancel();
      window.speechSynthesis.speak(u);
    } catch(e){}
  };

  const toggleVoice = () => {
    const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SR) {
      notify('Voice control not supported in this browser', 'error');
      return;
    }
    if (voiceOn) {
      try { recogRef.current && recogRef.current.stop(); } catch(e){}
      recogRef.current = null;
      setVoiceOn(false);
      setVoiceStatus('');
      return;
    }
    const rec = new SR();
    rec.continuous = true;
    rec.interimResults = false;
    rec.lang = (navigator.language || 'en-US');
    rec.onresult = (event) => {
      const last = event.results[event.results.length - 1];
      if (!last.isFinal) return;
      const text = (last[0]?.transcript || '').toLowerCase().trim();
      setVoiceStatus(`heard: "${text}"`);
      if (/\b(next|continue|done|finished)\b/.test(text))            handleNext();
      else if (/\b(back|previous|repeat|again)\b/.test(text))         { speakText(stepsRefStep()); }
      else if (/\b(go back|previous step)\b/.test(text))              setStepIdx(i => Math.max(0, i-1));
      else if (/\bread\b|\bwhat'?s next\b|\bwhat now\b/.test(text)) speakText(stepsRefStep());
      else if (/\bset (?:a )?(?:timer for )?(\d+)\s*(minute|min)/.test(text)) {
        const m = parseInt(text.match(/(\d+)\s*(minute|min)/)[1]);
        setTimer(m);
        speakText(`Timer set for ${m} minute${m===1?'':'s'}`);
      }
      else if (/\bcancel timer|stop timer/.test(text)) {
        setTimers(t => { const n = {...t}; delete n[stepRef.current]; return n; });
      }
      else if (/\bfinish|all done|complete/.test(text) && stepRef.current === steps.length - 1) {
        openFinishScreen();
      }
    };
    rec.onerror = (e) => { setVoiceStatus('voice error: ' + e.error); };
    rec.onend = () => {
      // auto-restart if user hasn't toggled off
      if (recogRef.current) { try { rec.start(); } catch(e){} }
    };
    try {
      rec.start();
      recogRef.current = rec;
      setVoiceOn(true);
      setVoiceStatus('listening… say "next", "back", "set a 5 minute timer"');
      speakText(`Cooking ${recipe.name}. Step 1: ${steps[0]||''}`);
    } catch (e) {
      notify('Mic permission needed: ' + e.message, 'error');
    }
  };

  const stepsRefStep = () => steps[stepRef.current] || '';

  // Cleanup voice on unmount
  useEffect(() => () => {
    try { recogRef.current && recogRef.current.stop(); } catch(e){}
    recogRef.current = null;
    try { window.speechSynthesis && window.speechSynthesis.cancel(); } catch(e){}
  }, []);

  if (!recipe) return <div>Recipe not found.</div>;

  const step = steps[stepIdx];
  const setTimer = (mins) => {
    setTimers(t => ({ ...t, [stepRef.current]: {remaining: mins*60, running: true, total: mins*60} }));
  };
  const toggleTimer = () => {
    setTimers(t => ({ ...t, [stepIdx]: {...t[stepIdx], running: !t[stepIdx].running}}));
  };
  const handleNext = () => {
    if (stepRef.current < steps.length - 1) {
      const newIdx = stepRef.current + 1;
      setDone(d => ({...d, [stepRef.current]: true}));
      setStepIdx(newIdx);
      stepRef.current = newIdx;
      speakText(`Step ${newIdx+1}: ${steps[newIdx]||''}`);
    } else {
      openFinishScreen();
    }
  };
  const fmt = (sec) => {
    const m = Math.floor(sec/60), ss = sec%60;
    return `${m}:${String(ss).padStart(2,'0')}`;
  };

  const openFinishScreen = () => {
    setFinishData(d => ({ ...d, servings_made: recipe.servings || 2, est_cost: recipe.estimated_cost || 0 }));
    setShowFinish(true);
    try { recogRef.current && recogRef.current.stop(); } catch(e){}
    speakText("All done! Tap to save your meal.");
  };

  // Substitution helper — Claude micro-call
  const fetchSubstitution = async (ingredient) => {
    setSubOpen(true);
    setSubResult({ loading: true, ingredient });
    try {
      const raw = await window.KA_claude({
        task: 'substitution',
        messages: [{ role: 'user', content: `I'm cooking "${recipe.name}" and I'm out of ${ingredient}. Suggest 2-3 substitutes that work in this recipe context. Keep it short. Format:\n- Substitute 1: ratio + brief note\n- Substitute 2: ratio + brief note\n(Plain text, no markdown)` }]
      });
      setSubResult({ loading: false, ingredient, suggestion: raw });
    } catch (e) {
      setSubResult({ loading: false, ingredient, error: e.message });
    }
  };

  const submitFinish = () => {
    // 1) Auto-deduct ingredients from pantry by amount used
    //    (recipe-level subtraction: each canonical ingredient used → qty -1, scaled by servings ratio)
    const ratio = (finishData.servings_made || recipe.servings || 1) / (recipe.servings || 1);
    const newPantry = state.pantry.map(p => {
      if ((recipe.canonical_ingredients||[]).includes(p.ingredient_id) && (p.location||'pantry') !== 'non_food') {
        return {...p, qty: Math.max(0, p.qty - Math.max(1, Math.round(1 * ratio)))};
      }
      return p;
    }).filter(p => p.qty > 0);
    setKey('pantry', newPantry);

    // 2) Append to cookHistory
    const entry = {
      id: crypto.randomUUID(),
      recipe_id: recipe.id,
      recipe_name: recipe.name,
      date: new Date().toISOString(),
      rating: finishData.rating,
      photo_data_url: finishData.photo,
      servings_made: finishData.servings_made,
      leftovers_kept: finishData.leftovers_kept,
      est_cost: finishData.est_cost || 0,
    };
    setKey('cookHistory', [...(state.cookHistory||[]), entry]);

    // 3) If leftovers, push to leftovers store
    if (finishData.leftovers_kept > 0) {
      const eatBy = new Date(); eatBy.setDate(eatBy.getDate() + 4);
      setKey('leftovers', [...(state.leftovers||[]), {
        id: crypto.randomUUID(),
        recipe_id: recipe.id,
        name: recipe.name,
        servings: finishData.leftovers_kept,
        created_at: new Date().toISOString(),
        eat_by: eatBy.toISOString(),
        status: 'fresh',
      }]);
    }

    // 3b) v10: freezer packs — single-serve protein portions for future meals
    if (finishData.freezer_packs > 0) {
      const label = finishData.freezer_label?.trim() || (recipe.name + ' protein');
      const exp = new Date(); exp.setDate(exp.getDate() + 90);
      const newPantryItems = [];
      for (let i = 0; i < finishData.freezer_packs; i++) {
        newPantryItems.push({
          id: crypto.randomUUID(),
          ingredient_id: 'freezer_' + (recipe.id || 'pack') + '_' + Date.now() + '_' + i,
          name: label + ' (pack ' + (i+1) + ')',
          qty: 1,
          unit: 'serving',
          expires_at: exp.toISOString(),
          added_at: new Date().toISOString(),
          location: 'freezer',
          is_staple: false,
          restock_threshold: null,
          is_non_food: false,
          // v10 freezer-meal metadata
          source_recipe_id: recipe.id,
          freezer_meal_label: label,
          frozen_for_recipe: recipe.name,
          freezer_pack: true,
        });
      }
      setKey('pantry', [...newPantry, ...newPantryItems]);
    }

    // 4) Update cookedMarks (legacy support)
    setKey('cookedMarks', {...state.cookedMarks, [recipe.id]: (state.cookedMarks[recipe.id]||0)+1, _last: recipe.id, _lastAt: Date.now()});

    notify(`${recipe.name} saved! Pantry, history, and leftovers updated.`, 'success');
    go('dashboard');
  };

  const t = timers[stepIdx];
  const progressPct = steps.length ? Math.round(((Object.keys(done).filter(k => done[k]).length) / steps.length) * 100) : 0;

  // ------ FINISH SCREEN ------
  if (showFinish) {
    return (
      <div className="space-y-5 fade-in max-w-2xl">
        <div className="text-center py-6">
          <div className="text-6xl mb-2">🎉</div>
          <h1 className="font-display text-3xl">Nice work!</h1>
          <p className="text-stone-500 mt-1">Quick log so we can update your pantry, history, and leftovers.</p>
        </div>

        {/* Quick save — uses defaults: recipe servings, no rating, no leftovers, no photo */}
        <Card className="bg-leaf-500/10 border-leaf-500/30">
          <div className="flex items-center gap-3">
            <div className="text-2xl">⚡</div>
            <div className="flex-1">
              <div className="font-medium">Just made it?</div>
              <div className="text-xs text-stone-600">One tap saves with sensible defaults — you can edit details below if you want.</div>
            </div>
            <Button variant="leaf" onClick={submitFinish}>
              <Icon name="check" cls="w-4 h-4"/>Quick save
            </Button>
          </div>
        </Card>

        <Card>
          <label className="text-xs text-stone-500 uppercase tracking-wide">How many servings did you make?</label>
          <Input type="number" min="1" value={finishData.servings_made}
            onChange={e => setFinishData(d => ({...d, servings_made: Math.max(1, Number(e.target.value)||1)}))}
            className="mt-1"/>
          <div className="text-[11px] text-stone-500 mt-1">Recipe default: {recipe.servings || 2}. Pantry deduction scales with this.</div>
        </Card>

        <Card>
          <label className="text-xs text-stone-500 uppercase tracking-wide">Rate this recipe</label>
          <div className="flex gap-2 mt-2">
            {[1,2,3,4,5].map(n => (
              <button key={n} onClick={() => setFinishData(d => ({...d, rating: n}))}
                className={'text-3xl transition ' + (finishData.rating >= n ? 'opacity-100' : 'opacity-30 hover:opacity-60')}>
                ⭐
              </button>
            ))}
            {finishData.rating > 0 && <span className="self-center text-sm text-stone-500 ml-2">{finishData.rating}/5</span>}
          </div>
        </Card>

        <Card>
          <label className="text-xs text-stone-500 uppercase tracking-wide">Leftovers (servings to save)</label>
          <Input type="number" min="0" max={finishData.servings_made}
            value={finishData.leftovers_kept}
            onChange={e => setFinishData(d => ({...d, leftovers_kept: Math.max(0, Math.min(d.servings_made, Number(e.target.value)||0))}))}
            className="mt-1"/>
          <div className="text-[11px] text-stone-500 mt-1">Saved with a 4-day eat-by reminder. View on the Leftovers page.</div>
        </Card>

        <Card>
          <label className="text-xs text-stone-500 uppercase tracking-wide">Freeze single-serve protein packs (optional)</label>
          <div className="flex gap-2 mt-1">
            <Input type="number" min="0" value={finishData.freezer_packs}
              onChange={e => setFinishData(d => ({...d, freezer_packs: Math.max(0, Number(e.target.value)||0)}))}
              className="w-24"/>
            <Input value={finishData.freezer_label}
              onChange={e => setFinishData(d => ({...d, freezer_label: e.target.value}))}
              placeholder={'e.g. "' + (recipe.name || '') + ' protein"'}
              className="flex-1"/>
          </div>
          <div className="text-[11px] text-stone-500 mt-1">
            Saved to freezer with a 90-day life. When you plan a meal that uses it, Kitchen Agent reminds you to thaw it the night before.
          </div>
        </Card>

        <Card>
          <label className="text-xs text-stone-500 uppercase tracking-wide">Snap a photo (optional)</label>
          <input type="file" accept="image/*" capture="environment"
            onChange={e => {
              const f = e.target.files?.[0]; if (!f) return;
              const reader = new FileReader();
              reader.onload = ev => setFinishData(d => ({...d, photo: ev.target.result}));
              reader.readAsDataURL(f);
            }}
            className="mt-1 block w-full text-sm"/>
          {finishData.photo && (
            <div className="mt-2"><img src={finishData.photo} alt="meal" className="max-h-40 rounded-lg"/></div>
          )}
        </Card>

        <div className="flex gap-2">
          <Button variant="outline" onClick={() => setShowFinish(false)}>Back to steps</Button>
          <Button variant="leaf" onClick={submitFinish}><Icon name="check" cls="w-4 h-4"/>Save & finish</Button>
        </div>
      </div>
    );
  }

  // ------ MAIN COOK FLASHCARD UI ------
  return (
    <div className="space-y-4 fade-in max-w-3xl pb-12">
      <div className="flex items-center justify-between">
        <button onClick={()=>go('recipes')} className="text-sm text-stone-500 hover:text-brand-600 flex items-center gap-1">
          <Icon name="chevleft" cls="w-4 h-4"/>Back
        </button>
        <button onClick={toggleVoice}
          className={'flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs border transition ' +
            (voiceOn ? 'bg-red-500 text-white border-red-500 animate-pulse' : 'bg-white border-stone-300 text-stone-600 hover:border-brand-500')}>
          <svg viewBox="0 0 24 24" className="w-3.5 h-3.5" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
            <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/>
          </svg>
          {voiceOn ? 'Stop voice' : 'Voice control'}
        </button>
      </div>

      <div>
        <div className="text-xs uppercase tracking-wider text-brand-700 font-semibold">Cook mode</div>
        <h1 className="font-display text-2xl md:text-3xl mt-1">{recipe.name}</h1>
        {voiceOn && voiceStatus && (
          <div className="text-xs text-stone-500 italic mt-1">{voiceStatus}</div>
        )}
      </div>

      {/* Kitchen controls — servings slider, big text toggle, ingredients sheet */}
      <div className="bg-white rounded-xl border border-stone-200 p-3 space-y-3">
        <div>
          <div className="flex items-center justify-between text-sm">
            <span className="text-stone-600">Cooking for</span>
            <span className="font-medium tabular-nums">{servings} serving{servings===1?'':'s'} <span className="text-stone-400">(×{scaleRatio.toFixed(2).replace(/\.?0+$/,'')})</span></span>
          </div>
          <input type="range" min="1" max="12" value={servings}
            onChange={e => setServings(Number(e.target.value))}
            className="w-full mt-1 accent-brand-500"/>
          {Math.abs(scaleRatio - 1) > 0.01 && (
            <div className="text-[11px] text-amber-700 mt-1">
              ⚠ Ingredients scaled. Cook times may need adjustment for larger batches — check for doneness.
            </div>
          )}
        </div>
        <div className="flex gap-2 flex-wrap">
          <button onClick={() => setShowIngredients(true)}
            className="flex-1 min-w-[140px] px-3 py-2.5 rounded-lg bg-stone-100 text-stone-700 text-sm font-medium hover:bg-stone-200 active:bg-stone-300 min-h-[44px]">
            📋 Show ingredients ({scaledIngredients.length})
          </button>
          <button onClick={() => setBigText(b => !b)}
            className={'px-4 py-2.5 rounded-lg text-sm font-medium min-h-[44px] '+(bigText?'bg-brand-500 text-white':'bg-stone-100 text-stone-700 hover:bg-stone-200')}>
            {bigText ? 'A Small' : 'A Big'}
          </button>
        </div>
      </div>

      {/* Ingredients bottom sheet (with live-scaled amounts) */}
      {showIngredients && (
        <div className="fixed inset-0 bg-black/50 z-40 flex md:items-center md:justify-center md:p-4 items-end justify-stretch" onClick={()=>setShowIngredients(false)}>
          <div className="bg-white w-full md:max-w-md md:rounded-2xl rounded-t-2xl max-h-[80vh] flex flex-col shadow-2xl fade-in"
            style={{paddingBottom:'env(safe-area-inset-bottom)'}} onClick={e=>e.stopPropagation()}>
            <div className="md:hidden w-12 h-1.5 rounded-full bg-stone-300 mx-auto my-2.5"/>
            <div className="px-4 pt-2 pb-3 border-b border-stone-200 flex items-center justify-between">
              <div>
                <h3 className="font-display text-lg">Ingredients</h3>
                <div className="text-xs text-stone-500">Scaled for {servings} serving{servings===1?'':'s'}</div>
              </div>
              <button onClick={()=>setShowIngredients(false)} aria-label="close" className="w-10 h-10 rounded-full text-stone-500 hover:bg-stone-100 flex items-center justify-center">
                <Icon name="x" cls="w-5 h-5"/>
              </button>
            </div>
            <ul className="flex-1 overflow-y-auto p-4 space-y-2 text-base">
              {scaledIngredients.map((line, i) => (
                <li key={i} className="flex gap-2 items-start">
                  <span className="text-leaf-600 mt-0.5">•</span>
                  <span>{line}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      )}

      {/* Step progress */}
      <div className="flex gap-1">
        {steps.map((_,i) => (
          <div key={i} className={'flex-1 h-1.5 rounded-full transition '+(i<stepIdx?'bg-leaf-500':i===stepIdx?'bg-brand-500':'bg-stone-200')}/>
        ))}
      </div>

      {/* Flashcard step */}
      <div className="rounded-2xl shadow-lg border border-brand-200 bg-gradient-to-br from-brand-50 to-white p-6 md:p-10 min-h-[260px] flex flex-col justify-between">
        <div>
          <div className="flex items-baseline justify-between">
            <div className="text-xs uppercase tracking-wider text-stone-500">Step {stepIdx+1} of {steps.length}</div>
            <button onClick={() => speakText(step)} title="Read aloud" className="text-stone-500 hover:text-brand-600 text-xs flex items-center gap-1">
              🔊 read aloud
            </button>
          </div>
          <div className={'leading-relaxed mt-3 font-light ' + (bigText ? 'text-3xl md:text-4xl' : 'text-2xl md:text-3xl')}>{step}</div>
          {/* Auto-detected timer suggestion from step text — one tap to start */}
          {(() => {
            const autoMin = detectStepTimerMinutes(step);
            if (!autoMin || t) return null;
            return (
              <button onClick={() => { setTimer(autoMin); if (navigator.vibrate) navigator.vibrate(20); }}
                className="mt-4 inline-flex items-center gap-2 px-4 py-3 bg-brand-500 text-white rounded-lg text-base font-medium hover:bg-brand-600 active:bg-brand-700 min-h-[48px] shadow">
                ⏱ Start {autoMin}-minute timer
              </button>
            );
          })()}
        </div>

        {/* Timer UI */}
        <div className="mt-6 pt-4 border-t border-stone-200">
          {t ? (
            <div className="flex items-center gap-3 flex-wrap">
              <div className={'font-display tabular-nums ' + (bigText ? 'text-5xl' : 'text-3xl')}>{fmt(t.remaining)}</div>
              <Button variant="outline" onClick={toggleTimer}><Icon name={t.running?'pause':'play'} cls="w-4 h-4"/>{t.running?'Pause':'Resume'}</Button>
              <Button variant="ghost" onClick={()=>setTimers(({[stepIdx]:_,...rest})=>rest)}>Clear</Button>
              {t.doneFlag && <Badge tone="leaf">Done!</Badge>}
            </div>
          ) : (
            <div className="flex gap-2 flex-wrap items-center">
              <div className="text-xs text-stone-500 mr-1">Timer:</div>
              {[1,3,5,10,15,20,30].map(m => (
                <button key={m} onClick={()=>setTimer(m)}
                  className="px-3 py-2 bg-white border border-stone-300 rounded-lg text-sm font-medium hover:border-brand-500 hover:bg-brand-50 min-h-[40px]">{m}m</button>
              ))}
            </div>
          )}
        </div>
      </div>

      {/* Card flip nav */}
      <div className="flex items-center justify-between gap-2">
        <Button variant="outline" onClick={()=>setStepIdx(Math.max(0,stepIdx-1))} disabled={stepIdx===0}>
          <Icon name="chevleft" cls="w-4 h-4"/>Previous
        </Button>
        <div className="text-xs text-stone-500">{progressPct}% done</div>
        {stepIdx < steps.length-1 ? (
          <Button onClick={handleNext}>Next step<Icon name="chev" cls="w-4 h-4"/></Button>
        ) : (
          <Button variant="leaf" onClick={openFinishScreen}><Icon name="check" cls="w-4 h-4"/>Finish</Button>
        )}
      </div>

      {/* Substitution panel */}
      <Card className="bg-amber-50/40">
        <div className="flex items-center justify-between gap-2 flex-wrap">
          <div className="text-sm">Out of an ingredient? Tap one for a fast Claude substitution:</div>
          <div className="flex gap-1.5 flex-wrap">
            {(recipe.canonical_ingredients||[]).slice(0,6).map(cid => {
              const ing = data.ingredients.find(x => x.id === cid);
              return (
                <button key={cid} onClick={() => fetchSubstitution(ing?.name || cid)}
                  className="px-2 py-1 bg-white border border-amber-300 rounded-full text-xs text-amber-800 hover:bg-amber-100">
                  {ing?.name || cid}
                </button>
              );
            })}
          </div>
        </div>
      </Card>

      {subOpen && subResult && (
        <div className="fixed inset-0 bg-black/40 z-30 flex items-center justify-center p-4" onClick={()=>setSubOpen(false)}>
          <div className="bg-white rounded-xl max-w-md w-full p-5" onClick={e=>e.stopPropagation()}>
            <div className="flex items-center justify-between mb-3">
              <h3 className="font-display text-lg">Substitutes for {subResult.ingredient}</h3>
              <button onClick={()=>setSubOpen(false)}><Icon name="x" cls="w-5 h-5 text-stone-500"/></button>
            </div>
            {subResult.loading && <div className="text-sm text-stone-500">⏳ Asking Claude…</div>}
            {subResult.error && <div className="text-sm text-red-700">Error: {subResult.error}</div>}
            {subResult.suggestion && <div className="text-sm text-stone-700 whitespace-pre-line">{subResult.suggestion}</div>}
          </div>
        </div>
      )}

      {/* All steps as flashcard pile */}
      <Card>
        <h3 className="text-sm font-medium text-stone-600 mb-2">All steps (tap to jump)</h3>
        <ol className="space-y-1.5 text-sm">
          {steps.map((s,i)=>(
            <li key={i}
              onClick={()=>setStepIdx(i)}
              className={'flex gap-2 cursor-pointer rounded px-2 py-1.5 transition ' +
                (i===stepIdx ? 'bg-brand-100 text-brand-800 font-medium' : done[i] ? 'text-stone-400 line-through' : 'text-stone-600 hover:bg-stone-50')}>
              <span className="w-5 shrink-0">{i+1}.</span>
              <span className="line-clamp-2">{s}</span>
            </li>
          ))}
        </ol>
      </Card>
    </div>
  );
}

K.CookMode = CookMode;
</script>

<!-- =============== SHOPPING LIST =============== -->
<script type="text/babel" data-type="module">
const { useState, useRef, useMemo, useEffect } = React;
const K = window.__KA;
const { Icon, Card, Section, Button, Badge, Chip, Input, useApp, fmt$, dateKey, days,
  pantryMap, pantryHas, optimizeCart, effectivePrice, lookupPrice, Instacart, Walmart, Pricing } = K;

/* ─────────────────────────────────────────────────────────────────────────
   PRICE EDIT SHEET — tap any price → open this to correct it.
   Saves with source='user_corrected'. The shopping list re-renders on close.
   ───────────────────────────────────────────────────────────────────────── */
function PriceEditSheet({ ingredient, stores, defaultStoreId, basePrices, onClose, onSaved }){
  const initial = (storeId) => {
    const eff = Pricing.effectivePack(ingredient.ingredient_id, storeId, basePrices, ingredient.unit);
    return eff || { pack_size: 1, pack_unit: ingredient.unit || 'each', pack_price: 0, uses_per_pack: 1, sale_pack_price: null };
  };
  const [storeId, setStoreId] = useState(defaultStoreId || (stores[0] && stores[0].id));
  const [form, setForm] = useState(() => initial(storeId));
  React.useEffect(() => { setForm(initial(storeId)); }, [storeId]);

  const save = () => {
    Pricing.set(ingredient.ingredient_id, storeId, {
      pack_size: Number(form.pack_size) || 1,
      pack_unit: form.pack_unit || 'each',
      pack_price: Number(form.pack_price) || 0,
      uses_per_pack: Math.max(1, Number(form.uses_per_pack) || 1),
      sale_pack_price: form.sale_pack_price === '' || form.sale_pack_price == null ? null : Number(form.sale_pack_price),
    }, 'user_corrected');
    onSaved && onSaved();
    onClose();
  };

  const remove = () => {
    Pricing.clear(ingredient.ingredient_id, storeId);
    onSaved && onSaved();
    onClose();
  };

  const sourceLabel = (s) => ({
    user_corrected: 'You set this',
    claude_refresh: 'Claude refresh',
    receipt_learned: 'From your receipt',
    bundle_estimate: 'Default estimate',
  })[s] || s;

  return (
    <div className="fixed inset-0 bg-black/50 z-40 flex md:items-center md:justify-center md:p-4 items-end justify-stretch" onClick={onClose}>
      <div className="bg-white w-full md:max-w-md md:rounded-2xl rounded-t-2xl flex flex-col shadow-2xl fade-in"
        style={{paddingBottom:'env(safe-area-inset-bottom)'}} onClick={e=>e.stopPropagation()}>
        <div className="md:hidden w-12 h-1.5 rounded-full bg-stone-300 mx-auto my-2.5"/>
        <div className="px-4 pt-2 pb-3 border-b border-stone-200 flex items-center justify-between">
          <div>
            <h3 className="font-display text-lg">{ingredient.name}</h3>
            <div className="text-xs text-stone-500">{sourceLabel(form.source)}</div>
          </div>
          <button onClick={onClose} aria-label="close" className="w-10 h-10 rounded-full text-stone-500 hover:bg-stone-100 flex items-center justify-center">
            <Icon name="x" cls="w-5 h-5"/>
          </button>
        </div>
        <div className="p-4 space-y-3">
          <div>
            <label className="text-xs text-stone-500 uppercase tracking-wide">Store</label>
            <select value={storeId} onChange={e=>setStoreId(e.target.value)} className="w-full px-3 py-3 border border-stone-300 rounded-lg text-base mt-1 min-h-[48px]">
              {stores.map(s => <option key={s.id} value={s.id}>{s.logo || ''} {s.chain}</option>)}
            </select>
          </div>
          <div className="grid grid-cols-3 gap-2">
            <div>
              <label className="text-xs text-stone-500">Pack size</label>
              <Input type="number" min="0" step="0.1" inputMode="decimal" value={form.pack_size} onChange={e=>setForm({...form, pack_size: e.target.value})} className="mt-1"/>
            </div>
            <div>
              <label className="text-xs text-stone-500">Unit</label>
              <select value={form.pack_unit} onChange={e=>setForm({...form, pack_unit: e.target.value})} className="w-full px-2 py-3 border border-stone-300 rounded-lg text-base mt-1 min-h-[48px]">
                {['each','oz','fl oz','lb','gal','pack','bottle','box','can','jar','bag','bunch','dozen'].map(u => <option key={u}>{u}</option>)}
              </select>
            </div>
            <div>
              <label className="text-xs text-stone-500">Pack price ($)</label>
              <Input type="number" min="0" step="0.01" inputMode="decimal" value={form.pack_price} onChange={e=>setForm({...form, pack_price: e.target.value})} className="mt-1"/>
            </div>
          </div>
          <div className="grid grid-cols-2 gap-2">
            <div>
              <label className="text-xs text-stone-500">Uses per pack</label>
              <Input type="number" min="1" inputMode="numeric" value={form.uses_per_pack} onChange={e=>setForm({...form, uses_per_pack: e.target.value})} className="mt-1"/>
              <div className="text-[10px] text-stone-400 mt-1">e.g. 1 bottle sesame oil → ~16 recipe uses</div>
            </div>
            <div>
              <label className="text-xs text-stone-500">Sale price ($, optional)</label>
              <Input type="number" min="0" step="0.01" inputMode="decimal" value={form.sale_pack_price || ''} onChange={e=>setForm({...form, sale_pack_price: e.target.value})} className="mt-1" placeholder="—"/>
            </div>
          </div>
          <div className="text-xs text-stone-500 bg-stone-50 p-2 rounded">
            Per-use cost: <strong>${((Number(form.sale_pack_price)||Number(form.pack_price)||0) / Math.max(1, Number(form.uses_per_pack)||1)).toFixed(2)}</strong>
            {form.as_of && <span> · updated {form.as_of}</span>}
          </div>
          <div className="flex gap-2 pt-2">
            {form._override && <Button variant="outline" onClick={remove} className="px-3">Reset</Button>}
            <Button variant="outline" onClick={onClose} className="flex-1 justify-center">Cancel</Button>
            <Button onClick={save} className="flex-1 justify-center">Save</Button>
          </div>
        </div>
      </div>
    </div>
  );
}

// Small helper: best pack-aware price record for a cart item.
//   Returns { pack, store, perUse, packsToBuy, total } or null
function bestPackFor(cartItem, stores, basePrices, preferredStoreIds) {
  let best = null;
  // Prefer the user's preferred stores; fall back to any store
  const pool = preferredStoreIds?.length
    ? stores.filter(s => preferredStoreIds.includes(s.id)).concat(stores.filter(s => !preferredStoreIds.includes(s.id)))
    : stores;
  for (const s of pool) {
    const pack = Pricing.effectivePack(cartItem.ingredient_id, s.id, basePrices, cartItem.unit);
    if (!pack || !pack.pack_price) continue;
    const perUse = (pack.sale_pack_price != null ? pack.sale_pack_price : pack.pack_price) / Math.max(1, pack.uses_per_pack);
    if (!best || perUse < best.perUse) {
      const buy = Pricing.packsToBuy(cartItem.qty || 1, pack);
      best = { pack, store: s, perUse, packsToBuy: buy.packs, total: buy.total, leftoverUses: buy.leftover_uses };
    }
  }
  return best;
}

function ShoppingList(){
  const { data, state, setKey, go, notify } = useApp();
  const { recipes, ingredients, prices, stores } = data;
  const [mode, setMode] = useState('split'); // 'split' | 'single'
  const [busyStore, setBusyStore] = useState(null);
  const [showExport, setShowExport] = useState(false);
  const [groupByAisle, setGroupByAisle] = useState(state.profile.default_aisle_grouping !== false);
  const [haveFilter, setHaveFilter] = useState('all'); // 'all' | 'need' | 'have'
  const [editingPriceFor, setEditingPriceFor] = useState(null); // cartItem being edited
  const [priceRefreshTick, setPriceRefreshTick] = useState(0); // bump to force re-render after edits
  const [livePrices, setLivePrices] = useState(() => {
    try {
      const cached = JSON.parse(localStorage.getItem('kitchenAgent:v2:livePrices') || '{}');
      const cutoff = Date.now() - 6*60*60*1000;
      const fresh = {};
      Object.entries(cached).forEach(([k,v]) => { if (v && v.ts && v.ts > cutoff) fresh[k] = v; });
      return fresh;
    } catch { return {}; }
  });
  const [showLiveModal, setShowLiveModal] = useState(false);
  const [liveProgress, setLiveProgress] = useState({ done: 0, total: 0, current: '', cancelled: false });
  const liveCancelRef = useRef(false);

  // Build cart: items from planned recipes NOT in pantry + user extras
  const ingById = useMemo(() => Object.fromEntries(ingredients.map(i => [i.id, i])), [ingredients]);
  const recipesById = useMemo(() => Object.fromEntries(recipes.map(r => [r.id, r])), [recipes]);
  const pantryIds = useMemo(() => new Set(state.pantry.filter(p => p.qty > 0).map(p => p.ingredient_id)), [state.pantry]);

  // Detect meal-prep lunch: if lunch recipe id is identical across >=3 days, scale its ingredients
  const mealPrepInfo = useMemo(() => {
    const lunchCounts = {};
    Object.values(state.plan || {}).forEach(day => {
      if (day?.lunch) lunchCounts[day.lunch] = (lunchCounts[day.lunch]||0)+1;
    });
    const entry = Object.entries(lunchCounts).sort((a,b)=>b[1]-a[1])[0];
    if (!entry || entry[1] < 3) return null;
    const [recipeId, count] = entry;
    const r = recipesById[recipeId];
    if (!r) return null;
    const servings = r.servings || 1;
    return { recipeId, name: r.name, count, servings, multiplier: Math.max(1, Math.ceil(count / servings)) };
  }, [state.plan, recipesById]);

  const cart = useMemo(() => {
    const bucket = {}; // ingredient_id -> qty
    const sources = {}; // ingredient_id -> Set of recipe names
    // New plan shape: { date: { breakfast:id, lunch:id, dinner:id, snack:id } }
    Object.values(state.plan || {}).forEach(day => {
      Object.entries(day || {}).forEach(([slot, rid]) => {
        const r = recipesById[rid];
        if (!r) return;
        // Meal-prep multiplier applies only to lunches that match the detected repeat
        const mult = (slot === 'lunch' && mealPrepInfo && rid === mealPrepInfo.recipeId)
          ? mealPrepInfo.multiplier : 1;
        (r.canonical_ingredients || []).forEach(cid => {
          if (pantryIds.has(cid)) return;
          bucket[cid] = (bucket[cid] || 0) + mult;
          if (!sources[cid]) sources[cid] = new Set();
          sources[cid].add(r.name + (mult>1?` ×${mult}`:''));
        });
      });
    });
    // From extras
    state.shoppingExtras.forEach(x => {
      bucket[x.ingredient_id] = (bucket[x.ingredient_id] || 0) + (x.qty || 1);
      if (x.source_recipe) {
        const r = recipesById[x.source_recipe];
        if (r) {
          if (!sources[x.ingredient_id]) sources[x.ingredient_id] = new Set();
          sources[x.ingredient_id].add(r.name);
        }
      }
    });
    // v16: heuristic aisle/category for Claude-generated items (no canonical match)
    const guessCategory = (name) => {
      const n = (name || '').toLowerCase();
      if (/\b(chicken|beef|pork|turkey|bacon|sausage|ham|steak|ground|fish|salmon|shrimp|tuna|tofu)\b/.test(n)) return 'protein';
      if (/\b(milk|cheese|yogurt|cream|butter|sour|cottage)\b/.test(n)) return 'dairy';
      if (/\b(egg|eggs)\b/.test(n)) return 'dairy';
      if (/\b(apple|banana|berry|berries|melon|grape|orange|lemon|lime|peach|pear|plum)\b/.test(n)) return 'produce';
      if (/\b(onion|garlic|tomato|potato|carrot|celery|pepper|cucumber|lettuce|spinach|broccoli|cauliflower|zucchini|squash|mushroom|avocado|cilantro|parsley|basil|ginger)\b/.test(n)) return 'produce';
      if (/\b(bread|rice|pasta|flour|cereal|tortilla|oats|quinoa|noodle|spaghetti)\b/.test(n)) return 'grain';
      if (/\b(oil|vinegar|sauce|salsa|ketchup|mayo|mustard|soy|sriracha|honey|syrup|broth|stock)\b/.test(n)) return 'condiment';
      if (/\b(salt|pepper|paprika|cumin|oregano|basil|powder|spice|seasoning|garlic powder|onion powder)\b/.test(n)) return 'spice';
      if (/\b(beans|chickpeas|lentil|peas|corn|tomato sauce|paste|coconut milk)\b/.test(n)) return 'canned';
      if (/\b(frozen|ice cream|popsicle)\b/.test(n)) return 'frozen';
      if (/\b(soda|juice|water|coffee|tea|beer|wine)\b/.test(n)) return 'beverage';
      return 'other';
    };
    const items = Object.entries(bucket).map(([ingredient_id, qty]) => {
      // Look up extras entry to get its display name + cost for Claude items
      const extra = state.shoppingExtras.find(x => x.ingredient_id === ingredient_id);
      const canonical = ingById[ingredient_id];
      const name = canonical?.name || extra?.name || ingredient_id.replace(/^claude_ing_/,'').replace(/_+$/,'').replace(/_/g,' ').replace(/\b\w/g,ch=>ch.toUpperCase());
      const cat = canonical?.category || guessCategory(name);
      return {
        ingredient_id, qty,
        name,
        emoji: canonical?.emoji || (cat === 'protein' ? '🍗' : cat === 'produce' ? '🥬' : cat === 'dairy' ? '🥛' : cat === 'grain' ? '🍚' : cat === 'condiment' ? '🫙' : cat === 'spice' ? '🧂' : cat === 'canned' ? '🥫' : cat === 'frozen' ? '🧊' : cat === 'beverage' ? '🥤' : '🛒'),
        unit: canonical?.default_unit || 'each',
        sources: Array.from(sources[ingredient_id] || []),
        category: cat,
        est_cost: extra?.est_cost || 0,
        isClaudeItem: !canonical,
      };
    });
    return items;
  }, [state.plan, state.shoppingExtras, recipesById, pantryIds, ingById, mealPrepInfo]);

  // Total meals planned
  const mealsPlanned = useMemo(() => {
    let n = 0;
    Object.values(state.plan || {}).forEach(d => { n += Object.keys(d||{}).length; });
    return n;
  }, [state.plan]);

  const shopMethod = state.profile.shop_method || 'pickup';

  // v12: Merge seeded estimates with live prices (live wins per ingredient+store).
  // priceRefreshTick is a dep so the memo re-runs after the user edits a price,
  // forcing every bestPackFor() call below to pick up the new Pricing override.
  // eslint-disable-next-line react-hooks/exhaustive-deps
  const mergedPrices = useMemo(() => {
    void priceRefreshTick; // touch it so it's a real dep
    if (!livePrices || !Object.keys(livePrices).length) return prices;
    const merged = JSON.parse(JSON.stringify(prices || {}));
    Object.entries(livePrices).forEach(([ingId, entry]) => {
      const arr = entry?.results || [];
      arr.forEach(r => {
        if (!r || !r.store || typeof r.price !== 'number') return;
        if (!merged[ingId]) merged[ingId] = {};
        merged[ingId][r.store] = {
          ingredient_id: ingId,
          store_id: r.store,
          price: r.price,
          sale_price: r.on_sale ? r.price : null,
          _live: true,
          _source: r.source,
          _label: r.label,
          _url: r.url,
          _ts: entry.ts,
        };
      });
    });
    return merged;
  }, [prices, livePrices, priceRefreshTick]);

  const opt = useMemo(() => optimizeCart(cart.map(c => ({ingredient_id: c.ingredient_id, qty: c.qty})), stores, mergedPrices, { method: shopMethod }), [cart, stores, mergedPrices, shopMethod]);

  const updateQty = (id, delta) => {
    const extras = [...state.shoppingExtras];
    const idx = extras.findIndex(e => e.ingredient_id === id);
    if (idx >= 0) {
      extras[idx] = {...extras[idx], qty: Math.max(0, (extras[idx].qty||1) + delta)};
      if (extras[idx].qty === 0) extras.splice(idx, 1);
      setKey('shoppingExtras', extras);
    } else {
      // Item is from plan; add an override extra to modify qty
      extras.push({ id: crypto.randomUUID(), ingredient_id: id, qty: Math.max(1, 1+delta), source_recipe: null });
      setKey('shoppingExtras', extras);
    }
  };

  const removeItem = (id) => {
    // Remove from extras; if from plan, add a "zero" marker is tricky — for MVP just notify
    const extras = state.shoppingExtras.filter(e => e.ingredient_id !== id);
    setKey('shoppingExtras', extras);
    notify('Removed from shopping list', 'success');
  };

  const clearAll = () => {
    if (!confirm('Clear all extras from shopping list?')) return;
    setKey('shoppingExtras', []);
  };

  const openInInstacart = async (retailer_key) => {
    setBusyStore('instacart:'+retailer_key);
    try {
      // Build ingredients payload
      const ings = cart.map(c => ({ name: c.name, display: `${c.qty} ${c.unit} ${c.name}` }));
      const res = await Instacart.createRecipeLink({
        title: `Kitchen Agent · ${cart.length} items`,
        ingredients: ings,
        retailer_key,
      });
      if (res.fallback) {
        notify(`Opening Instacart search (no API key — add one in Settings for rich recipe links)`, 'info');
      }
      window.open(res.url, '_blank');
      // Record as an order
      saveOrder('instacart:'+retailer_key, cart, opt.singleStoreTotals[storeIdFor(retailer_key)] || opt.splitTotal);
    } catch (e) {
      notify('Couldn\'t open Instacart link: '+e.message, 'error');
    } finally {
      setBusyStore(null);
    }
  };

  const openInWalmart = () => {
    setBusyStore('walmart');
    try {
      const url = Walmart.cartUrl(cart.map(c => ({ name: c.name, qty: c.qty })));
      window.open(url, '_blank');
      saveOrder('walmart', cart, opt.singleStoreTotals['walmart'] || 0);
    } finally {
      setBusyStore(null);
    }
  };

  // Subset variants for split mode
  const openInWalmartSubset = (items, storeId, total) => {
    setBusyStore('walmart');
    try {
      const url = Walmart.cartUrl(items.map(c => ({ name: c.name, qty: c.qty })));
      window.open(url, '_blank');
      saveOrder(storeId, items, total);
    } finally {
      setBusyStore(null);
    }
  };

  const openInInstacartSubset = async (retailer_key, items, storeId, total) => {
    setBusyStore('instacart:'+retailer_key);
    try {
      const ings = items.map(c => ({ name: c.name, display: `${c.qty} ${c.unit} ${c.name}` }));
      const res = await Instacart.createRecipeLink({
        title: `Kitchen Agent · ${items.length} items (best at ${retailer_key})`,
        ingredients: ings,
        retailer_key,
      });
      if (res.fallback) notify(`Opening Instacart search for ${retailer_key} (add an API key in Settings for persistent links)`, 'info');
      window.open(res.url, '_blank');
      saveOrder(storeId, items, total);
    } catch (e) {
      notify('Couldn\'t open Instacart link: '+e.message, 'error');
    } finally {
      setBusyStore(null);
    }
  };

  const storeIdFor = (retailer) => ({ aldi:'aldi', sprouts:'sprouts', publix:'instacart_publix', kroger:'instacart_kroger' }[retailer] || retailer);

  const saveOrder = (storeId, items, total) => {
    const order = {
      id: crypto.randomUUID(),
      store_id: storeId.replace('instacart:',''),
      items: items.map(i => ({ name: i.name, qty: i.qty, ingredient_id: i.ingredient_id })),
      total: Number(total.toFixed(2)),
      status: 'scheduled',
      created_at: new Date().toISOString(),
      scheduled_at: new Date(Date.now() + 4*3600*1000).toISOString(),
      fulfillment: storeId === 'walmart' ? 'pickup' : 'delivery',
    };
    setKey('orders', [...state.orders, order]);
    // v10: also append to purchaseHistory so the smart usage learner can detect restock cadence
    setKey('purchaseHistory', [...(state.purchaseHistory||[]), {
      id: order.id,
      date: order.created_at,
      store: storeId,
      method: order.fulfillment,
      total_cost: order.total,
      items: items.map(i => ({ name: i.name, qty: i.qty, cost: 0 })),
    }]);
    notify('Order saved. Track status in Orders.', 'success');
  };

  // v12: live-price refresh — iterate cart, call /.netlify/functions/prices per item
  const startLivePriceRefresh = async () => {
    liveCancelRef.current = false;
    const cutoff = Date.now() - 6*60*60*1000;
    const queue = cart.filter(c => !livePrices[c.ingredient_id] || livePrices[c.ingredient_id].ts < cutoff);
    if (!queue.length) {
      notify('All prices are fresh (cached < 6h ago). Nothing to refresh.', 'info');
      return;
    }
    setShowLiveModal(true);
    setLiveProgress({ done: 0, total: queue.length, current: queue[0]?.name || '', cancelled: false });
    const updated = { ...livePrices };
    for (let i = 0; i < queue.length; i++) {
      if (liveCancelRef.current) break;
      const item = queue[i];
      setLiveProgress({ done: i, total: queue.length, current: item.name, cancelled: false });
      try {
        const res = await fetch('/.netlify/functions/prices', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            ingredient: item.name,
            stores: ['kroger','walmart','serpapi','browserless','apify'],
            zip: state.profile.zip || undefined,
          }),
        });
        const data = await res.json();
        updated[item.ingredient_id] = { ts: Date.now(), results: data.results || [], configured: data.configured };
      } catch (e) {
        updated[item.ingredient_id] = { ts: Date.now(), results: [], error: e.message };
      }
    }
    setLivePrices(updated);
    try { localStorage.setItem('kitchenAgent:v2:livePrices', JSON.stringify(updated)); } catch {}
    setLiveProgress({ done: queue.length, total: queue.length, current: '', cancelled: liveCancelRef.current });
    const hits = Object.values(updated).filter(e => (e.results||[]).length).length;
    notify(`Live prices: ${hits} of ${cart.length} items with real-time data`, hits ? 'success' : 'info');
    setTimeout(() => setShowLiveModal(false), 800);
  };

    if (cart.length === 0) {
    return (
      <div className="space-y-6 fade-in">
        <div>
          <h1 className="font-display text-3xl md:text-4xl">Shopping list</h1>
          <p className="text-stone-600 mt-2">Nothing to buy yet.</p>
        </div>
        <Card className="text-center py-10">
          <div className="text-5xl mb-3">🛒</div>
          <h3 className="font-display text-xl mb-2">Your list is empty</h3>
          <p className="text-sm text-stone-600 mb-4 max-w-md mx-auto">Plan some meals or add items from a recipe. Missing ingredients will show up here automatically.</p>
          <div className="flex gap-2 justify-center flex-wrap">
            <Button onClick={()=>go('plan')}><Icon name="calendar" cls="w-4 h-4"/>Plan the week</Button>
            <Button variant="outline" onClick={()=>go('recipes')}>Browse recipes</Button>
          </div>
        </Card>
      </div>
    );
  }

  const sortedStores = stores.slice().sort((a,b) => (opt.singleStoreTotals[a.id]||0) - (opt.singleStoreTotals[b.id]||0));
  const bestStore = stores.find(s => s.id === opt.bestSingleStore);

  return (
    <div className="space-y-6 fade-in">
      <div className="flex items-end justify-between gap-3 flex-wrap">
        <div>
          <h1 className="font-display text-3xl md:text-4xl">Shopping list</h1>
          <p className="text-sm text-stone-600 mt-1">
            {cart.length} items · from {mealsPlanned} planned meals
            {mealPrepInfo && <span className="text-leaf-700"> · meal-prep lunch ×{mealPrepInfo.count} ({mealPrepInfo.multiplier}× qty)</span>}
          </p>
        </div>
        <div className="flex gap-2 flex-wrap">
          <Button variant="leaf" onClick={() => startLivePriceRefresh()}>
            <Icon name="refresh" cls="w-4 h-4"/>Refresh live prices
          </Button>
          <Button variant="outline" onClick={() => setShowExport(true)}>
            <Icon name="upload" cls="w-4 h-4"/>Export
          </Button>
          <Button variant="outline" onClick={() => window.print()} title="Print this shopping list">
            🖨 Print
          </Button>
          <Button variant="ghost" onClick={() => setGroupByAisle(!groupByAisle)}>
            {groupByAisle ? '☷ List view' : '⇲ Group by aisle'}
          </Button>
          <Button variant="ghost" onClick={clearAll}>Clear extras</Button>
          <Button variant="primary" onClick={()=>openInInstacart('aldi')}>
            <Icon name="cart" cls="w-4 h-4"/>Add to Aldi Cart
          </Button>
          <Button variant="outline" onClick={()=>window.open('https://www.instacart.com/store/aldi/storefront','_blank')}>
            View Cart →
          </Button>
        </div>
      </div>

      {/* Price accuracy disclosure */}
      <details className="bg-stone-50 border border-stone-200 rounded-xl p-4 text-sm">
        <summary className="cursor-pointer font-medium flex items-center gap-2">
          <Icon name="info" cls="w-4 h-4 text-stone-500"/>
          How accurate are these prices?
        </summary>
        <div className="mt-3 space-y-2 text-stone-600">
          <p><strong>Honest answer:</strong> these prices are <em>estimates</em>, not live store quotes. Real-time pricing from Walmart, Aldi, Sprouts, Publix and Kroger requires B2B partnership agreements we don't have yet.</p>
          <p>We seed 108 common ingredients at typical 2025 US supermarket baselines (e.g. chicken breast $4.29/lb, olive oil $0.55/oz) and apply per-chain multipliers based on public price comparisons:</p>
          <ul className="pl-5 list-disc text-xs">
            <li><strong>Walmart</strong> 0.92× baseline (consistently cheapest nationally)</li>
            <li><strong>Aldi</strong> 0.82× (private-label focus)</li>
            <li><strong>Sprouts</strong> 1.08× (natural/organic premium)</li>
            <li><strong>Kroger via Instacart</strong> 1.15× (Instacart markup)</li>
            <li><strong>Publix via Instacart</strong> 1.25× (Publix baseline + Instacart markup)</li>
          </ul>
          <p>A deterministic 20% of items show a "sale" price (hash-based on ingredient+store so it's stable per session). Package sizes are normalized to the canonical unit (lb, oz, each, etc.) — we don't currently surface individual package SKUs or brands.</p>
          <p className="text-xs text-stone-500">When you click "Open in Walmart" / "Open in Instacart", the real retailer shows live pricing at checkout — that's your ground truth. We use the estimates to rank stores and suggest splits.</p>
        </div>
      </details>

      <LivePriceBadge/>

      {/* v16: have/need filter + aisle preview */}
      <div className="flex items-center gap-2 flex-wrap">
        <span className="text-xs text-stone-500">Show:</span>
        {[['all','All'],['need','Need to buy'],['have','Already have']].map(([id,label]) => (
          <Chip key={id} active={haveFilter===id} onClick={()=>setHaveFilter(id)}>{label}</Chip>
        ))}
      </div>

      {/* v10: Method-aware indicator + quick switch */}
      <div className="flex items-center gap-2 flex-wrap">
        <span className="text-xs text-stone-500">Optimizing for:</span>
        {[['pickup','🏬 Pickup'],['delivery','🚚 Delivery']].map(([m,label]) => (
          <Chip key={m} active={shopMethod === m} onClick={() => setKey('profile', { ...state.profile, shop_method: m })}>{label}</Chip>
        ))}
        <span className="text-[11px] text-stone-400">
          ({stores.filter(s => shopMethod === 'pickup' ? s.pickup_supported !== false : s.delivery_supported !== false).length} of {stores.length} stores match)
        </span>
      </div>

      {/* Price summary */}
      <div className="grid grid-cols-1 md:grid-cols-3 gap-3">
        <Card className={mode==='split'?'ring-2 ring-brand-500':''}>
          <button className="w-full text-left" onClick={()=>setMode('split')}>
            <div className="text-xs text-stone-500 uppercase tracking-wide">Split across stores</div>
            <div className="font-display text-3xl mt-1">{fmt$(opt.splitTotal)}</div>
            <div className="text-xs text-leaf-700 mt-1">Cheapest possible</div>
          </button>
        </Card>
        <Card className={mode==='single'?'ring-2 ring-brand-500':''}>
          <button className="w-full text-left" onClick={()=>setMode('single')}>
            <div className="text-xs text-stone-500 uppercase tracking-wide">Single store (best: {bestStore?.chain})</div>
            <div className="font-display text-3xl mt-1">{fmt$(opt.singleStoreTotals[opt.bestSingleStore])}</div>
            <div className="text-xs text-stone-500 mt-1">+ {fmt$(opt.singleStoreTotals[opt.bestSingleStore] - opt.splitTotal)} over split</div>
          </button>
        </Card>
        <Card>
          <div className="text-xs text-stone-500 uppercase tracking-wide">Save by splitting</div>
          <div className="font-display text-3xl mt-1 text-leaf-600">{fmt$(Math.abs(opt.savings))}</div>
          <div className="text-xs text-stone-500 mt-1">vs. single-store</div>
        </Card>
      </div>

      {/* Items table */}
      {(() => {
        // Apply have/need filter using alias-aware pantry matching
        const matchers = data.matchers || {};
        const livePantry = state.pantry.filter(p => p.qty > 0);
        const inPantry = (item) => {
          if (pantryIds.has(item.ingredient_id)) return true;
          return pantryHas(item.ingredient_id || item.name, livePantry, matchers);
        };
        const visible = cart.filter(c => {
          if (haveFilter === 'all') return true;
          if (haveFilter === 'have') return inPantry(c);
          return !inPantry(c);
        });
        if (groupByAisle) {
          const groups = {};
          visible.forEach(c => { (groups[c.category] = groups[c.category] || []).push(c); });
          const order = ['produce','protein','dairy','grain','canned','frozen','condiment','spice','beverage','other'];
          const ordered = order.filter(k => groups[k]).concat(Object.keys(groups).filter(k => !order.includes(k)));
          return ordered.map(cat => (
            <Card key={cat} className="mb-2">
              <div className="text-xs uppercase tracking-wider text-stone-500 font-semibold mb-2 flex items-center justify-between">
                <span>{cat.charAt(0).toUpperCase()+cat.slice(1)} aisle</span>
                <span className="text-stone-400">{groups[cat].length} items</span>
              </div>
              {groups[cat].map(c => {
                const preferred = state.profile.preferred_stores || [];
                const best = bestPackFor(c, stores, mergedPrices, preferred);
                return (
                <div key={c.ingredient_id} className="flex items-center gap-3 py-3 border-b border-stone-100 last:border-0">
                  <span className="text-2xl shrink-0">{c.emoji}</span>
                  <div className="flex-1 min-w-0">
                    <div className="font-medium text-sm truncate">
                      {c.name}
                      {inPantry(c) && <span className="ml-1.5 text-[10px] px-1.5 py-0.5 bg-leaf-100 text-leaf-700 rounded-full">have</span>}
                    </div>
                    {/* Pack-aware price line + tap-to-edit affordance */}
                    {best ? (
                      <button onClick={()=>setEditingPriceFor(c)}
                        className="text-[11px] text-left text-stone-600 mt-0.5 hover:text-brand-700 underline decoration-dotted decoration-stone-300 underline-offset-2">
                        {best.packsToBuy} × {best.pack.pack_size} {best.pack.pack_unit} {best.pack.pack_price ? `· $${best.total.toFixed(2)}` : ''}
                        {best.pack.uses_per_pack > 1 && c.qty < best.pack.uses_per_pack ? ` · covers ${best.pack.uses_per_pack} uses` : ''}
                        <span className="text-stone-400"> @ {best.store.chain.split(' ')[0]}</span>
                        {best.pack.source === 'bundle_estimate' && <span className="text-amber-600 ml-1">estimate</span>}
                        {best.pack.source === 'user_corrected'   && <span className="text-leaf-600 ml-1">✓</span>}
                      </button>
                    ) : (
                      <button onClick={()=>setEditingPriceFor(c)} className="text-[11px] text-stone-400 mt-0.5 hover:text-brand-600 underline decoration-dotted">+ set price</button>
                    )}
                    {c.sources.length > 0 && (
                      <div className="text-[11px] text-stone-500 mt-0.5 truncate">
                        for {c.sources.length === 1 ? c.sources[0] : `${c.sources.length} recipes: ${c.sources.slice(0,2).join(', ')}${c.sources.length>2?` +${c.sources.length-2}`:''}`}
                      </div>
                    )}
                  </div>
                  <div className="flex items-center gap-1 shrink-0">
                    <button onClick={()=>updateQty(c.ingredient_id, -1)} aria-label="decrease" className="w-9 h-9 rounded-lg border border-stone-300 hover:bg-stone-100 active:bg-stone-200 flex items-center justify-center"><Icon name="minus" cls="w-4 h-4"/></button>
                    <div className="w-7 text-center text-sm font-medium tabular-nums">{c.qty}</div>
                    <button onClick={()=>updateQty(c.ingredient_id, +1)} aria-label="increase" className="w-9 h-9 rounded-lg border border-stone-300 hover:bg-stone-100 active:bg-stone-200 flex items-center justify-center"><Icon name="plus" cls="w-4 h-4"/></button>
                    <button onClick={()=>removeItem(c.ingredient_id)} aria-label="remove" className="w-9 h-9 ml-1 text-stone-400 hover:text-red-500 active:bg-stone-100 rounded-lg flex items-center justify-center"><Icon name="trash" cls="w-4 h-4"/></button>
                  </div>
                </div>
                );
              })}
            </Card>
          ));
        }
        return null;
      })()}

      {!groupByAisle && (
      <Card>
        <div className="grid grid-cols-12 gap-2 text-xs uppercase tracking-wide text-stone-500 pb-2 border-b border-stone-200 hidden md:grid">
          <div className="col-span-4">Item</div>
          <div className="col-span-2 text-right">Qty</div>
          {stores.map(s => <div key={s.id} className="col-span-1 text-center text-[10px]">{s.chain.split(' ')[0]}</div>)}
          <div className="col-span-1 text-center">Best</div>
        </div>
        {(() => {
          const matchers = data.matchers || {};
          const livePantry = state.pantry.filter(p => p.qty > 0);
          const inPantry = (item) => {
            if (pantryIds.has(item.ingredient_id)) return true;
            return pantryHas(item.ingredient_id || item.name, livePantry, matchers);
          };
          return cart.filter(c => {
            if (haveFilter === 'all') return true;
            if (haveFilter === 'have') return inPantry(c);
            return !inPantry(c);
          });
        })().map(c => {
          const best = opt.perItemBest[c.ingredient_id];
          const bestStore = best ? stores.find(s => s.id === best.store_id) : null;
          return (
            <div key={c.ingredient_id} className="grid grid-cols-12 gap-2 py-3 border-b border-stone-100 items-center">
              <div className="col-span-12 md:col-span-4 flex items-center gap-2">
                <span className="text-lg">{c.emoji}</span>
                <div>
                  <div className="font-medium">{c.name}</div>
                  {c.sources.length > 0 && <div className="text-xs text-stone-500 line-clamp-1">for {c.sources.slice(0,2).join(', ')}{c.sources.length>2?` +${c.sources.length-2}`:''}</div>}
                </div>
              </div>
              <div className="col-span-4 md:col-span-2 flex items-center md:justify-end gap-1">
                <button onClick={()=>updateQty(c.ingredient_id, -1)} className="w-7 h-7 rounded border border-stone-300 hover:bg-stone-100"><Icon name="minus" cls="w-3 h-3 mx-auto"/></button>
                <div className="w-8 text-center text-sm">{c.qty}</div>
                <button onClick={()=>updateQty(c.ingredient_id, +1)} className="w-7 h-7 rounded border border-stone-300 hover:bg-stone-100"><Icon name="plus" cls="w-3 h-3 mx-auto"/></button>
                <button onClick={()=>removeItem(c.ingredient_id)} className="w-7 h-7 ml-1 rounded text-stone-400 hover:text-red-500"><Icon name="trash" cls="w-3.5 h-3.5 mx-auto"/></button>
              </div>
              {stores.map(s => {
                const rec = lookupPrice(c.ingredient_id, s.id, mergedPrices);
                const eff = effectivePrice(rec);
                const isBest = best && best.store_id === s.id;
                return (
                  <div key={s.id} className={'col-span-2 md:col-span-1 text-center text-xs '+(isBest?'font-bold text-leaf-700':'text-stone-500')}>
                    {eff != null ? (
                      <div>
                        {rec.sale_price ? <span className="line-through text-stone-400 mr-0.5">{fmt$(rec.price)}</span> : ''}
                        {fmt$(eff)}
                        {rec._live && <span className="ml-1 text-[8px] text-red-600 align-top">●LIVE</span>}
                      </div>
                    ) : <span className="text-stone-300">—</span>}
                  </div>
                );
              })}
              <div className="col-span-2 md:col-span-1 text-center text-xs">
                {best ? <Badge tone="leaf">{bestStore?.chain.split(' ')[0]} {fmt$(best.line)}</Badge> : <span className="text-stone-300">—</span>}
              </div>
            </div>
          );
        })}
      </Card>
      )}

      {/* ============ CHECKOUT ============ */}
      {mode === 'single' ? (
        <Section title={`Order everything from ${bestStore?.chain}`}>
          <CheckoutStoreCard
            store={bestStore}
            items={cart}
            total={opt.singleStoreTotals[bestStore?.id] || 0}
            busyStore={busyStore}
            onWalmart={openInWalmart}
            onInstacart={(rk)=>openInInstacart(rk)}
            isBest
          />
          {/* Also show alternatives */}
          <div className="mt-3 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
            {sortedStores.filter(s => s.id !== bestStore?.id).map(s => (
              <CheckoutStoreCard
                key={s.id}
                store={s}
                items={cart}
                total={opt.singleStoreTotals[s.id] || 0}
                busyStore={busyStore}
                onWalmart={openInWalmart}
                onInstacart={(rk)=>openInInstacart(rk)}
              />
            ))}
          </div>
        </Section>
      ) : (
        <Section title="Split across stores — grab the cheapest at each"
          action={<Badge tone="leaf">save {fmt$(Math.abs(opt.savings))}</Badge>}>
          <Card className="bg-leaf-500/5 border-leaf-500/30 mb-3">
            <div className="flex items-start gap-3 text-sm">
              <Icon name="info" cls="w-5 h-5 text-leaf-600 shrink-0 mt-0.5"/>
              <div>
                <strong>Multi-store split:</strong> Your {cart.length} items are split across the stores where each one is cheapest. Clicking a store below opens that store's cart pre-filled with <em>only the items it's cheapest for</em>. You'll place one order per store — typically 2–3 stores for the best savings.
              </div>
            </div>
          </Card>
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
            {sortedStores.map(s => {
              // Items where this store is the per-item winner
              const itemsForStore = cart.filter(c => opt.perItemBest[c.ingredient_id]?.store_id === s.id);
              if (itemsForStore.length === 0) return null;
              const storeTotal = itemsForStore.reduce((sum, c) => sum + (opt.perItemBest[c.ingredient_id]?.line || 0), 0);
              return (
                <CheckoutStoreCard
                  key={s.id}
                  store={s}
                  items={itemsForStore}
                  total={storeTotal}
                  busyStore={busyStore}
                  onWalmart={()=>openInWalmartSubset(itemsForStore, s.id, storeTotal)}
                  onInstacart={(rk)=>openInInstacartSubset(rk, itemsForStore, s.id, storeTotal)}
                  splitMode
                />
              );
            })}
          </div>
        </Section>
      )}

      <Card className="bg-brand-50/40">
        <div className="flex items-start gap-3">
          <Icon name="info" cls="w-5 h-5 text-brand-600 shrink-0 mt-0.5"/>
          <div className="text-sm">
            <strong>How checkout works:</strong> Walmart opens a <em>pre-filled</em> cart on walmart.com ready for pickup scheduling. Instacart links open a pre-built shopping page with your items — you pick your retailer (Aldi / Sprouts / Publix / Kroger) and pickup/delivery time at their checkout. Add an Instacart API key in <button className="underline text-brand-600" onClick={()=>go('settings')}>Settings</button> for persistent recipe URLs that stay live for 30 days.
          </div>
        </div>
      </Card>

      {showExport && <ShoppingExportModal cart={cart} stores={stores} prices={mergedPrices} opt={opt} mode={mode} onClose={() => setShowExport(false)}/>}
      {showLiveModal && <LivePriceModal progress={liveProgress} onCancel={() => { liveCancelRef.current = true; }}/>}
      {editingPriceFor && (
        <PriceEditSheet
          ingredient={editingPriceFor}
          stores={stores}
          defaultStoreId={
            (bestPackFor(editingPriceFor, stores, mergedPrices, state.profile.preferred_stores || [])?.store?.id)
            || (state.profile.preferred_stores && state.profile.preferred_stores[0])
            || stores[0]?.id
          }
          basePrices={mergedPrices}
          onClose={() => setEditingPriceFor(null)}
          onSaved={() => { setPriceRefreshTick(t=>t+1); notify('Price saved', 'success'); }}
        />
      )}
    </div>
  );
}

function LivePriceModal({ progress, onCancel }) {
  const pct = progress.total ? Math.round(progress.done / progress.total * 100) : 0;
  return (
    <div className="fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4">
      <div className="bg-white rounded-2xl max-w-md w-full p-6 shadow-2xl">
        <div className="text-center mb-4">
          <div className="text-4xl mb-2">{progress.done < progress.total ? '🔍' : '✓'}</div>
          <h3 className="font-display text-xl">
            {progress.done < progress.total ? 'Checking live prices' : 'Almost finished'}
          </h3>
          <p className="text-sm text-stone-500 mt-1">
            {progress.done < progress.total
              ? 'Looking up "' + progress.current + '"…'
              : progress.cancelled ? 'Cancelled — partial results saved.' : 'Done! Refreshing your list with real prices.'}
          </p>
        </div>
        <div className="text-xs text-stone-500 text-center mb-2">
          Item {Math.min(progress.done + 1, progress.total)} of {progress.total}
        </div>
        <div className="h-3 bg-stone-100 rounded-full overflow-hidden mb-4">
          <div className="h-full bg-gradient-to-r from-brand-500 to-leaf-500 transition-all duration-300"
            style={{ width: pct + '%' }}/>
        </div>
        {progress.done < progress.total && (
          <button onClick={onCancel} className="w-full text-xs text-stone-500 hover:text-red-600">
            Cancel and keep what we have so far
          </button>
        )}
        <p className="text-[11px] text-stone-400 mt-3 text-center">
          Prices are cached for 6 hours so repeat refreshes don't waste API calls.
        </p>
      </div>
    </div>
  );
}

function ShoppingExportModal({ cart, stores, prices, opt, mode, onClose }) {
  const text = React.useMemo(() => {
    const lines = [];
    lines.push('KITCHEN AGENT — Shopping list');
    lines.push('Generated: ' + new Date().toLocaleString());
    lines.push('Items: ' + cart.length);
    const total = mode === 'split' ? opt.splitTotal : (opt.singleStoreTotals[opt.bestSingleStore] || 0);
    lines.push('Total: $' + total.toFixed(2) + '  (' + (mode === 'split' ? 'split across stores' : 'single store') + ')');
    lines.push('');
    if (mode === 'split') {
      const byStore = {};
      cart.forEach(c => {
        const best = opt.perItemBest[c.ingredient_id];
        if (!best) return;
        if (!byStore[best.store_id]) byStore[best.store_id] = [];
        byStore[best.store_id].push({ ...c, line: best.line });
      });
      Object.entries(byStore).forEach(([sid, items]) => {
        const store = stores.find(s => s.id === sid);
        const subtotal = items.reduce((a,i) => a + (i.line||0), 0);
        lines.push('=== ' + (store?.chain || sid).toUpperCase() + '  $' + subtotal.toFixed(2) + ' ===');
        items.forEach(i => {
          const qty = String(i.qty).padEnd(4);
          const name = (i.name || '').padEnd(28);
          lines.push('  [ ] ' + qty + ' ' + name + ' $' + (i.line||0).toFixed(2));
        });
        lines.push('');
      });
    } else {
      const store = stores.find(s => s.id === opt.bestSingleStore);
      lines.push('=== ' + (store?.chain || '').toUpperCase() + ' ===');
      cart.forEach(c => {
        const rec = prices.find(p => p.ingredient_id === c.ingredient_id && p.store_id === opt.bestSingleStore);
        const eff = rec ? (rec.sale_price ?? rec.price) : null;
        const line = eff ? eff * c.qty : 0;
        const qty = String(c.qty).padEnd(4);
        const name = (c.name || '').padEnd(28);
        lines.push('  [ ] ' + qty + ' ' + name + ' $' + line.toFixed(2));
      });
    }
    return lines.join('\n');
  }, [cart, stores, prices, opt, mode]);

  const copyText = () => {
    navigator.clipboard.writeText(text).then(() => {
      const t = document.createElement('div');
      t.textContent = '✓ Copied to clipboard';
      t.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:10001;background:#16a34a;color:#fff;padding:10px 18px;border-radius:99px;font-size:0.9rem;';
      document.body.appendChild(t);
      setTimeout(() => t.remove(), 2000);
    });
  };
  const printIt = () => {
    const w = window.open('', '_blank');
    if (!w) { alert('Pop-up blocked. Please allow pop-ups.'); return; }
    w.document.write('<pre style="font-family:monospace;font-size:13px;line-height:1.5;white-space:pre-wrap;padding:24px;">' + text.replace(/</g,'&lt;') + '</pre>');
    w.document.close();
    w.print();
  };

  return (
    <div className="fixed inset-0 bg-black/50 z-40 flex items-center justify-center p-4" onClick={onClose}>
      <div className="bg-white rounded-2xl max-w-xl w-full max-h-[80vh] flex flex-col" onClick={e => e.stopPropagation()}>
        <div className="p-4 border-b border-stone-200 flex items-center justify-between">
          <h3 className="font-display text-xl">Print / Export shopping list</h3>
          <button onClick={onClose}><Icon name="x" cls="w-5 h-5 text-stone-500"/></button>
        </div>
        <div className="flex-1 overflow-y-auto p-4">
          <pre className="font-mono text-xs bg-stone-50 border border-stone-200 rounded-lg p-3 whitespace-pre-wrap leading-relaxed">{text}</pre>
        </div>
        <div className="p-4 border-t border-stone-200 flex gap-2 flex-wrap">
          <Button onClick={copyText}>📋 Copy</Button>
          <Button variant="outline" onClick={printIt}>🖨️ Print</Button>
          <a href={'data:text/plain;charset=utf-8,' + encodeURIComponent(text)}
            download={'shopping-list-' + new Date().toISOString().slice(0,10) + '.txt'}>
            <Button variant="outline">⬇ Download .txt</Button>
          </a>
        </div>
      </div>
    </div>
  );
}

/* ========== Helper: CheckoutStoreCard ========== */
function CheckoutStoreCard({store, items, total, busyStore, onWalmart, onInstacart, isBest, splitMode}){
  if (!store) return null;
  const retailerMap = { aldi:'aldi', sprouts:'sprouts', instacart_publix:'publix', instacart_kroger:'kroger' };
  const retailerKey = retailerMap[store.id] || store.id.replace('instacart_','');
  const isWalmart = store.adapter === 'walmart_deeplink';
  const isBusy = isWalmart ? busyStore==='walmart' : busyStore==='instacart:'+retailerKey;
  return (
    <Card className={isBest?'ring-1 ring-leaf-500':''}>
      <div className="flex items-start justify-between">
        <div className="flex items-center gap-2">
          <div className="text-2xl">{store.logo}</div>
          <div>
            <div className="font-medium">{store.chain}</div>
            <div className="text-xs text-stone-500">{isWalmart?'Pickup via walmart.com':'Pickup/Delivery via Instacart'}</div>
          </div>
        </div>
        {isBest && <Badge tone="leaf">cheapest</Badge>}
        {splitMode && !isBest && <Badge tone="brand">{items.length} items</Badge>}
      </div>
      <div className="font-display text-2xl mt-3">{fmt$(total)}</div>
      <div className="text-xs text-stone-500">{items.length} items{splitMode?' (cheapest here)':''}</div>
      {isWalmart ? (
        <Button className="mt-3 w-full justify-center" onClick={onWalmart}>
          <Icon name="link" cls="w-4 h-4"/>{isBusy?'Opening…':'Open filled cart on Walmart'}
        </Button>
      ) : (
        <Button className="mt-3 w-full justify-center" variant={isBest?'primary':'outline'} onClick={()=>onInstacart(retailerKey)}>
          <Icon name="link" cls="w-4 h-4"/>{isBusy?'Opening…':'Open filled cart in Instacart'}
        </Button>
      )}
      <details className="mt-2 text-xs text-stone-500">
        <summary className="cursor-pointer hover:text-brand-600">See {items.length} items</summary>
        <ul className="mt-2 space-y-0.5 pl-3">
          {items.map(it => <li key={it.ingredient_id}>• {it.qty} × {it.name}</li>)}
        </ul>
      </details>
    </Card>
  );
}

function LivePriceBadge() {
  const [status, setStatus] = React.useState(null);
  React.useEffect(() => {
    fetch('/.netlify/functions/prices', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ingredient: 'salt' }),
    }).then(r => r.json()).then(d => setStatus(d.configured || {})).catch(() => setStatus({}));
  }, []);
  if (!status) return null;
  const live = Object.entries(status).filter(([_,v]) => v).map(([k]) => k);
  if (!live.length) return (
    <div className="text-[11px] text-stone-500 bg-stone-50 border border-stone-200 rounded-lg p-3">
      💡 <strong>Prices below are seeded estimates.</strong> For real-time data, add ONE of these env vars in Netlify:
      <ul className="list-disc pl-5 mt-1 space-y-0.5">
        <li><code className="bg-white px-1 rounded">KROGER_CLIENT_ID</code> + <code className="bg-white px-1 rounded">KROGER_CLIENT_SECRET</code> + <code className="bg-white px-1 rounded">KROGER_LOCATION_ID</code> — free, Kroger only</li>
        <li><code className="bg-white px-1 rounded">SERPAPI_KEY</code> — paid, multi-retailer (~$50/mo)</li>
        <li><code className="bg-white px-1 rounded">BROWSERLESS_API_KEY</code> — renders real Chrome (~$50/mo)</li>
        <li><code className="bg-white px-1 rounded">APIFY_API_TOKEN</code> — pay-per-result (~$0.01/item)</li>
      </ul>
    </div>
  );
  return (
    <div className="flex items-center gap-2 flex-wrap">
      <Badge tone="leaf">✓ Live prices via {live.join(', ')}</Badge>
      <span className="text-[11px] text-stone-500">Tap "Refresh live prices" to scrape real data for every cart item.</span>
    </div>
  );
}

K.ShoppingList = ShoppingList;
</script>

<!-- =============== SCHEDULE PICKUP =============== -->
<script type="text/babel" data-type="module">
const { useState, useEffect, useMemo, useRef } = React;
const K = window.__KA;
const { Icon, Card, Section, Button, Badge, Input, useApp, fmt$, optimizeCart, Routing } = K;

function SchedulePickup(){
  const { data, state, setKey, go, notify } = useApp();
  const { stores, prices } = data;
  const mapDiv = useRef(null);
  const mapRef = useRef(null);
  const layerRef = useRef(null);
  const [scoring, setScoring] = useState(false);
  const [results, setResults] = useState([]); // [{store, detour_min, ...}]
  const [progress, setProgress] = useState('');
  const [selectedStore, setSelectedStore] = useState(null);
  const [pickupTime, setPickupTime] = useState('18:00');

  // Build cart once for potential total calculation
  const cartMini = useMemo(() => {
    const bucket = {};
    state.shoppingExtras.forEach(x => {
      bucket[x.ingredient_id] = (bucket[x.ingredient_id] || 0) + (x.qty || 1);
    });
    return Object.entries(bucket).map(([ingredient_id, qty]) => ({ ingredient_id, qty }));
  }, [state.shoppingExtras]);

  const opt = useMemo(() => optimizeCart(cartMini, stores, prices), [cartMini, stores, prices]);

  // Initialize map
  useEffect(() => {
    if (!mapDiv.current || !window.L) return;
    if (mapRef.current) return;
    // Default center on user's zip (Tampa, FL) — will recenter on geocode
    const map = window.L.map(mapDiv.current).setView([27.9506, -82.4572], 11);
    window.L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap',
      maxZoom: 19,
    }).addTo(map);
    mapRef.current = map;
    layerRef.current = window.L.layerGroup().addTo(map);
  }, []);

  const drawRoute = (result) => {
    if (!layerRef.current || !window.L || !result) return;
    layerRef.current.clearLayers();
    const { homeGeo, workGeo, viaStore, store } = result;
    if (workGeo) window.L.marker([workGeo.lat, workGeo.lng]).bindTooltip('Work').addTo(layerRef.current);
    if (store._geo) window.L.marker([store._geo.lat, store._geo.lng]).bindTooltip(store.chain).addTo(layerRef.current);
    if (homeGeo) window.L.marker([homeGeo.lat, homeGeo.lng]).bindTooltip('Home').addTo(layerRef.current);
    if (viaStore?.geometry) {
      const coords = viaStore.geometry.coordinates.map(([lng,lat]) => [lat, lng]);
      const line = window.L.polyline(coords, { color:'#ea580c', weight:4, opacity:0.8 }).addTo(layerRef.current);
      mapRef.current.fitBounds(line.getBounds().pad(0.1));
    }
  };

  const computeRoutes = async () => {
    setScoring(true);
    setProgress('Geocoding work address...');
    setResults([]);
    try {
      const workGeo = await Routing.geocode(state.profile.work_addr);
      if (!workGeo) { notify('Couldn\'t geocode work address', 'error'); setScoring(false); return; }
      setProgress('Geocoding home...');
      const homeGeo = await Routing.geocode(state.profile.home_addr);
      if (!homeGeo) { notify('Couldn\'t geocode home address', 'error'); setScoring(false); return; }

      // Geocode each store: <chain> near <zip>
      const withGeo = [];
      for (let i=0; i<stores.length; i++) {
        const s = stores[i];
        setProgress(`Locating ${s.chain} (${i+1}/${stores.length})...`);
        const q = `${s.chain.replace(' (via Instacart)','')} near ${state.profile.zip}`;
        const g = await Routing.geocode(q);
        if (g) withGeo.push({...s, _geo: g});
      }
      setProgress('Computing detours...');
      const scored = await Routing.scoreStores(state.profile.home_addr, state.profile.work_addr, withGeo);
      if (!scored) { notify('Routing failed (OSRM unavailable)', 'error'); setScoring(false); return; }
      setResults(scored);
      setSelectedStore(scored[0]);
      drawRoute(scored[0]);
      setProgress('');
    } catch (e) {
      notify('Routing error: '+e.message, 'error');
    } finally {
      setScoring(false);
    }
  };

  const selectStore = (r) => {
    setSelectedStore(r);
    drawRoute(r);
  };

  const schedulePickup = () => {
    if (!selectedStore) return;
    const [hh, mm] = pickupTime.split(':').map(Number);
    const when = new Date(); when.setHours(hh, mm, 0, 0);
    if (when < new Date()) when.setDate(when.getDate()+1); // tomorrow if in past

    const total = opt.singleStoreTotals[selectedStore.store.id] || opt.splitTotal;
    const order = {
      id: crypto.randomUUID(),
      store_id: selectedStore.store.id,
      items: [],
      total: Number((total||0).toFixed(2)),
      status: 'scheduled',
      created_at: new Date().toISOString(),
      scheduled_at: when.toISOString(),
      fulfillment: 'pickup',
      route: {
        work: selectedStore.workGeo.display,
        store: selectedStore.store._geo?.display,
        home: selectedStore.homeGeo.display,
        detour_min: Math.round(selectedStore.detour_min),
      }
    };
    setKey('orders', [...state.orders, order]);
    notify(`Pickup scheduled at ${selectedStore.store.chain} for ${pickupTime}`, 'success');
    go('orders');
  };

  return (
    <div className="space-y-6 fade-in">
      <div className="flex items-end justify-between flex-wrap gap-2">
        <div>
          <h1 className="font-display text-3xl md:text-4xl">Schedule pickup</h1>
          <p className="text-sm text-stone-600 mt-1">On your way home from work — picking up is 10–30 min of detour.</p>
        </div>
        <Button variant="outline" onClick={()=>go('shop')}><Icon name="chevleft" cls="w-4 h-4"/>Back to shopping</Button>
      </div>

      {/* Profile summary */}
      <Card>
        <div className="grid grid-cols-1 md:grid-cols-3 gap-3 text-sm">
          <div>
            <div className="text-xs text-stone-500 uppercase tracking-wide">Work</div>
            <div className="mt-1">{state.profile.work_addr}</div>
          </div>
          <div>
            <div className="text-xs text-stone-500 uppercase tracking-wide">Home</div>
            <div className="mt-1">{state.profile.home_addr}</div>
          </div>
          <div>
            <div className="text-xs text-stone-500 uppercase tracking-wide">Leave work at</div>
            <div className="mt-1">{state.profile.commute_end}</div>
          </div>
        </div>
        <div className="mt-3 flex gap-2">
          <Button onClick={computeRoutes} disabled={scoring}>
            <Icon name={scoring?'refresh':'route'} cls={'w-4 h-4 '+(scoring?'animate-spin':'')}/>
            {scoring ? 'Computing...' : 'Find best route'}
          </Button>
          <Button variant="outline" onClick={()=>go('settings')}>Edit addresses</Button>
        </div>
        {progress && <div className="text-xs text-stone-500 mt-2">{progress}</div>}
      </Card>

      {/* Map */}
      <Card className="p-0 overflow-hidden">
        <div ref={mapDiv} style={{height: 380, width:'100%', background:'#f5f1ea'}}></div>
        {results.length === 0 && !scoring && (
          <div className="absolute inset-0 flex items-center justify-center text-stone-500 pointer-events-none">
            <div className="text-center">
              <div className="text-4xl mb-2">🗺️</div>
              <div className="text-sm">Click "Find best route" to compute detours</div>
            </div>
          </div>
        )}
      </Card>

      {/* Store picker */}
      {results.length > 0 && (
        <Section title="Best stores by detour">
          <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
            {results.filter(r => r.store.pickup_supported !== false).map(r => {
              const total = opt.singleStoreTotals[r.store.id];
              const active = selectedStore?.store.id === r.store.id;
              return (
                <button key={r.store.id} onClick={()=>selectStore(r)} className={'text-left bg-white border rounded-xl p-4 transition '+(active?'border-brand-500 ring-2 ring-brand-500':'border-stone-200 hover:border-stone-400')}>
                  <div className="flex items-start justify-between">
                    <div className="flex items-center gap-2">
                      <div className="text-2xl">{r.store.logo}</div>
                      <div>
                        <div className="font-medium">{r.store.chain}</div>
                        <div className="text-xs text-stone-500">{r.store._geo?.display?.split(',').slice(0,2).join(', ')}</div>
                      </div>
                    </div>
                    {active && <Badge tone="brand">selected</Badge>}
                  </div>
                  <div className="flex items-center gap-4 mt-3 text-sm">
                    <div>
                      <div className="text-xs text-stone-500">Detour</div>
                      <div className="font-display text-lg">+{Math.round(r.detour_min)} min</div>
                    </div>
                    <div>
                      <div className="text-xs text-stone-500">Cart total</div>
                      <div className="font-display text-lg">{total ? fmt$(total) : '—'}</div>
                    </div>
                    <div>
                      <div className="text-xs text-stone-500">Distance via store</div>
                      <div className="font-display text-lg">{(r.viaStore.distance_m/1609).toFixed(1)} mi</div>
                    </div>
                  </div>
                </button>
              );
            })}
          </div>
        </Section>
      )}

      {/* Schedule */}
      {selectedStore && (
        <Card>
          <h3 className="font-display text-xl mb-3">Confirm pickup</h3>
          <div className="grid grid-cols-1 md:grid-cols-2 gap-3 items-end">
            <div>
              <label className="text-xs text-stone-500 uppercase tracking-wide">Pickup time</label>
              <Input type="time" value={pickupTime} onChange={e=>setPickupTime(e.target.value)} className="mt-1"/>
              <div className="text-xs text-stone-500 mt-1">Commute ends {state.profile.commute_end}. Add {Math.round(selectedStore.detour_min)} min for the detour.</div>
            </div>
            <Button variant="leaf" onClick={schedulePickup}><Icon name="check" cls="w-4 h-4"/>Schedule at {selectedStore.store.chain}</Button>
          </div>
        </Card>
      )}
    </div>
  );
}

K.SchedulePickup = SchedulePickup;
</script>

<!-- =============== PANTRY =============== -->
<script type="text/babel" data-type="module">
const { useState, useEffect, useMemo, useRef } = React;
const K = window.__KA;
const { Icon, Card, Section, Button, Badge, Chip, Input, HintBubble, useApp, expirationTone, Claude } = K;

/* ─────────────────────────────────────────────────────────────────────────
   VOICE-TO-PANTRY — speak natural language, Claude parses to pantry deltas.
   "I just used two eggs and half a gallon of milk" → updates pantry.
   ───────────────────────────────────────────────────────────────────────── */
function VoicePantrySheet({ onClose, onApply, pantryItems, ingredients }){
  const { notify } = useApp();
  const [phase, setPhase] = useState('idle'); // idle | listening | thinking | review | error
  const [heard, setHeard] = useState('');
  const [actions, setActions] = useState([]);
  const [err, setErr] = useState('');
  const recRef = useRef(null);
  const supported = typeof window !== 'undefined' && (window.SpeechRecognition || window.webkitSpeechRecognition);
  const hasClaude = Claude.isEnabled();

  const stop = () => {
    try { recRef.current && recRef.current.stop(); } catch {}
    recRef.current = null;
  };

  const start = () => {
    if (!supported) { setErr("Voice isn't supported in this browser. Try Chrome or Safari."); setPhase('error'); return; }
    if (!hasClaude) { setErr('Add an Anthropic API key in Settings to enable voice parsing.'); setPhase('error'); return; }
    const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    const rec = new SR();
    rec.continuous = false; rec.interimResults = true; rec.lang = 'en-US';
    let finalText = '';
    rec.onresult = (e) => {
      let interim = '';
      for (let i = e.resultIndex; i < e.results.length; i++) {
        const t = e.results[i][0].transcript;
        if (e.results[i].isFinal) finalText += t; else interim += t;
      }
      setHeard((finalText + ' ' + interim).trim());
    };
    rec.onerror = (e) => { setErr('Mic error: ' + e.error); setPhase('error'); };
    rec.onend = async () => {
      if (!finalText.trim()) { setPhase('idle'); return; }
      setPhase('thinking');
      try {
        const res = await Claude.parsePantryUpdate(finalText, { pantryItems, canonicalIngredients: ingredients });
        setActions(res.actions || []);
        setPhase('review');
      } catch (e) { setErr('Parse failed: ' + e.message); setPhase('error'); }
    };
    try { rec.start(); setPhase('listening'); setHeard(''); recRef.current = rec; }
    catch (e) { setErr('Mic permission needed: ' + e.message); setPhase('error'); }
  };

  useEffect(() => () => stop(), []);

  const apply = () => {
    onApply(actions);
    onClose();
  };

  return (
    <div className="fixed inset-0 bg-black/50 z-40 flex md:items-center md:justify-center md:p-4 items-end justify-stretch" onClick={onClose}>
      <div className="bg-white w-full md:max-w-md md:rounded-2xl rounded-t-2xl flex flex-col shadow-2xl fade-in"
        style={{paddingBottom:'env(safe-area-inset-bottom)'}} onClick={e=>e.stopPropagation()}>
        <div className="md:hidden w-12 h-1.5 rounded-full bg-stone-300 mx-auto my-2.5"/>
        <div className="px-4 pt-2 pb-3 border-b border-stone-200 flex items-center justify-between">
          <h3 className="font-display text-lg">Quick voice update</h3>
          <button onClick={onClose} aria-label="close" className="w-10 h-10 rounded-full text-stone-500 hover:bg-stone-100 flex items-center justify-center">
            <Icon name="x" cls="w-5 h-5"/>
          </button>
        </div>
        <div className="p-4">
          {phase === 'idle' && (
            <div className="text-center py-6">
              <button onClick={start} disabled={!supported || !hasClaude}
                className="w-28 h-28 rounded-full bg-brand-500 text-white text-5xl mx-auto flex items-center justify-center hover:bg-brand-600 active:bg-brand-700 shadow-lg disabled:opacity-40">🎤</button>
              <p className="text-sm text-stone-600 mt-4 px-4">
                Tap and say things like: <em>"I just used two eggs and a cup of milk"</em>, <em>"Add a dozen apples to the fridge"</em>, or <em>"Used up the rice"</em>.
              </p>
              {!supported && <p className="text-xs text-amber-700 mt-3">Voice not supported in this browser.</p>}
              {supported && !hasClaude && <p className="text-xs text-amber-700 mt-3">Add an Anthropic API key in Settings first.</p>}
            </div>
          )}
          {phase === 'listening' && (
            <div className="text-center py-6">
              <div className="w-28 h-28 rounded-full bg-red-500 text-white text-5xl mx-auto flex items-center justify-center animate-pulse shadow-lg">🎤</div>
              <div className="text-sm text-stone-700 mt-4">Listening…</div>
              <div className="text-xs text-stone-500 mt-1 italic min-h-[20px]">{heard || '(speak now)'}</div>
              <Button variant="outline" onClick={stop} className="mt-4">Done speaking</Button>
            </div>
          )}
          {phase === 'thinking' && (
            <div className="text-center py-8 text-stone-500">
              <Icon name="refresh" cls="w-7 h-7 mx-auto animate-spin text-brand-500 mb-2"/>
              <div className="text-sm">Claude is parsing what you said…</div>
              <div className="text-xs italic mt-1">"{heard}"</div>
            </div>
          )}
          {phase === 'review' && (
            <div className="space-y-3">
              <div className="text-xs text-stone-500">Heard: <em>"{heard}"</em></div>
              {actions.length === 0 ? (
                <div className="text-sm text-amber-700 bg-amber-50 p-3 rounded-lg">Nothing was parsed. Try again with clearer item names.</div>
              ) : (
                <>
                  <div className="text-sm font-medium">Will apply these {actions.length} change{actions.length===1?'':'s'}:</div>
                  <div className="space-y-1.5">
                    {actions.map((a, i) => (
                      <div key={i} className="flex items-center gap-2 p-2 bg-stone-50 rounded-lg border border-stone-200">
                        <span className={'text-lg font-medium ' + (a.delta < 0 ? 'text-red-600' : 'text-leaf-600')}>
                          {a.delta > 0 ? '+' : ''}{a.delta}
                        </span>
                        <div className="flex-1">
                          <div className="text-sm font-medium">{a.name}</div>
                          <div className="text-xs text-stone-500">{a.unit || ''} {a.location ? `· ${a.location}` : ''}</div>
                        </div>
                      </div>
                    ))}
                  </div>
                  <div className="flex gap-2 pt-2">
                    <Button variant="outline" onClick={() => { setActions([]); setPhase('idle'); setHeard(''); }} className="flex-1 justify-center">Redo</Button>
                    <Button onClick={apply} className="flex-1 justify-center">Apply</Button>
                  </div>
                </>
              )}
            </div>
          )}
          {phase === 'error' && (
            <div className="space-y-3">
              <div className="text-sm text-red-700 bg-red-50 p-3 rounded-lg">{err}</div>
              <Button variant="outline" onClick={() => { setErr(''); setPhase('idle'); }} className="w-full justify-center">Try again</Button>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}

function Pantry(){
  const { data, state, setKey, go, notify } = useApp();
  const { ingredients } = data;
  const ingById = useMemo(() => Object.fromEntries(ingredients.map(i => [i.id, i])), [ingredients]);
  const [showVoice, setShowVoice] = useState(false);
  const [sort, setSort] = useState('expires');
  const [q, setQ] = useState('');
  const [location, setLocation] = useState('all'); // all | pantry | fridge | freezer | non_food
  const [showStaplesOnly, setShowStaplesOnly] = useState(false);
  const [showAdd, setShowAdd] = useState(false);
  const [addSearch, setAddSearch] = useState('');
  const [addQty, setAddQty] = useState(1);
  const [addExp, setAddExp] = useState(14);
  const [addLocation, setAddLocation] = useState('pantry');
  const [addIsNonFood, setAddIsNonFood] = useState(false);
  const [editItemId, setEditItemId] = useState(null); // for restock threshold editor (mobile bottom sheet)
  const [batchQueue, setBatchQueue] = useState([]); // items added in current sheet session — for batch confirmation
  const [lastDeleted, setLastDeleted] = useState(null); // for undo

  const filtered = useMemo(() => {
    let list = state.pantry.slice();
    if (q) list = list.filter(p => p.name.toLowerCase().includes(q.toLowerCase()));
    if (location !== 'all') {
      list = list.filter(p => (p.location || 'pantry') === location);
    } else {
      // "all" excludes non_food unless that tab is selected, to keep food/household separate
      list = list.filter(p => (p.location || 'pantry') !== 'non_food');
    }
    if (showStaplesOnly) list = list.filter(p => p.is_staple);
    const score = (p) => {
      if (sort === 'expires') return new Date(p.expires_at) - Date.now();
      if (sort === 'name') return p.name.toLowerCase();
      if (sort === 'category') return ingById[p.ingredient_id]?.category || 'zzz';
      return 0;
    };
    list.sort((a,b) => {
      const sa = score(a), sb = score(b);
      return sa < sb ? -1 : sa > sb ? 1 : 0;
    });
    return list;
  }, [state.pantry, sort, q, ingById, location, showStaplesOnly]);

  // Low-stock alerts: any item below its restock_threshold (set by user, default null = no alert)
  const lowStock = useMemo(() => {
    return state.pantry.filter(p => typeof p.restock_threshold === 'number' && p.qty <= p.restock_threshold);
  }, [state.pantry]);

  const grouped = useMemo(() => {
    if (sort !== 'category') return null;
    const g = {};
    filtered.forEach(p => {
      const cat = ingById[p.ingredient_id]?.category || 'other';
      if (!g[cat]) g[cat] = [];
      g[cat].push(p);
    });
    return g;
  }, [filtered, sort, ingById]);

  const updateQty = (id, delta) => {
    const next = state.pantry.map(p => p.id === id ? {...p, qty: Math.max(0, p.qty + delta)} : p).filter(p => p.qty > 0);
    setKey('pantry', next);
  };
  const removeItem = (id) => {
    const victim = state.pantry.find(p => p.id === id);
    if (!victim) return;
    setKey('pantry', state.pantry.filter(p => p.id !== id));
    setLastDeleted(victim);
    notify(`Removed ${victim.name} · tap to undo`, 'info');
    setTimeout(() => setLastDeleted(d => d && d.id === victim.id ? null : d), 6000);
  };
  const undoDelete = () => {
    if (!lastDeleted) return;
    setKey('pantry', [...state.pantry, lastDeleted]);
    notify(`Restored ${lastDeleted.name}`, 'success');
    setLastDeleted(null);
  };
  // addItem — stays open for batch entry. Queue tracks what was added in this session.
  const addItem = (ingredient_id) => {
    const ing = ingById[ingredient_id];
    if (!ing) return;
    const existing = state.pantry.find(p => p.ingredient_id === ingredient_id && (p.location||'pantry') === addLocation);
    let queueItem;
    if (existing) {
      setKey('pantry', state.pantry.map(p => p.id === existing.id ? {...p, qty: p.qty + addQty} : p));
      queueItem = { id: existing.id, name: ing.name, qty: addQty, unit: ing.default_unit, merged: true };
    } else {
      const fresh = {
        id: crypto.randomUUID(),
        ingredient_id,
        name: ing.name,
        qty: addQty,
        unit: ing.default_unit,
        expires_at: new Date(Date.now() + addExp*86400000).toISOString(),
        added_at: new Date().toISOString(),
        location: addLocation,
        is_staple: false,
        restock_threshold: null,
        is_non_food: addIsNonFood,
      };
      setKey('pantry', [...state.pantry, fresh]);
      queueItem = { id: fresh.id, name: ing.name, qty: addQty, unit: ing.default_unit, merged: false };
    }
    setBatchQueue(q => [...q, queueItem]);
    setAddSearch(''); // ready for the next entry
    setAddQty(1);
    if (navigator.vibrate) navigator.vibrate(15);
  };

  // Add a custom (non-canonical) item — used for non-food / household items
  const addCustomItem = (name, unit) => {
    if (!name.trim()) return;
    const fresh = {
      id: crypto.randomUUID(),
      ingredient_id: 'custom_' + name.toLowerCase().replace(/[^\w]+/g,'_'),
      name: name.trim(),
      qty: addQty,
      unit: unit || 'unit',
      expires_at: new Date(Date.now() + (addLocation === 'non_food' ? 365 : addExp)*86400000).toISOString(),
      added_at: new Date().toISOString(),
      location: addLocation,
      is_staple: false,
      restock_threshold: null,
      is_non_food: addIsNonFood || addLocation === 'non_food',
    };
    setKey('pantry', [...state.pantry, fresh]);
    setBatchQueue(q => [...q, { id: fresh.id, name: fresh.name, qty: addQty, unit: fresh.unit, merged: false }]);
    setAddSearch(''); setAddQty(1);
    if (navigator.vibrate) navigator.vibrate(15);
  };

  const closeAddSheet = () => {
    if (batchQueue.length > 0) {
      notify(`Added ${batchQueue.length} ${batchQueue.length===1?'item':'items'} to ${addLocation==='non_food'?'household':addLocation}`, 'success');
    }
    setShowAdd(false); setAddSearch(''); setAddQty(1); setBatchQueue([]);
  };

  // "Quick add" chips — the 8 most-recently-added items from pantry history
  const recentItems = useMemo(() => {
    const seen = new Set();
    const sorted = state.pantry.slice().sort((a,b)=> new Date(b.added_at||0) - new Date(a.added_at||0));
    const out = [];
    for (const p of sorted) {
      const key = p.ingredient_id || p.name;
      if (seen.has(key)) continue;
      seen.add(key);
      out.push(p);
      if (out.length >= 8) break;
    }
    return out;
  }, [state.pantry]);

  const quickReAdd = (p) => {
    // Re-add at qty=1 using the source item's ingredient_id if canonical, else by name.
    if (p.ingredient_id && ingById[p.ingredient_id]) {
      const prevQty = addQty;
      setAddQty(1);
      addItem(p.ingredient_id);
      setAddQty(prevQty);
    } else {
      addCustomItem(p.name, p.unit);
    }
  };

  // Apply a list of voice-parsed pantry deltas. Matches by name (case-insensitive),
  // creates new items if the user added something we don't have.
  const applyVoiceActions = (actions) => {
    let pantry = state.pantry.slice();
    let added = 0, updated = 0, removed = 0;
    for (const a of actions) {
      if (!a.name || typeof a.delta !== 'number') continue;
      const nameLower = a.name.toLowerCase().trim();
      const idx = pantry.findIndex(p => p.name.toLowerCase().trim() === nameLower);
      if (idx >= 0) {
        const newQty = pantry[idx].qty + a.delta;
        if (newQty <= 0) { pantry = pantry.filter((_, i) => i !== idx); removed++; }
        else { pantry = pantry.map((p, i) => i === idx ? {...p, qty: newQty} : p); updated++; }
      } else if (a.delta > 0) {
        // Brand-new item, only if it's a positive delta (don't create deletions).
        const ing = ingredients.find(i => i.name.toLowerCase() === nameLower);
        pantry.push({
          id: crypto.randomUUID(),
          ingredient_id: ing?.id || ('custom_' + nameLower.replace(/[^\w]+/g,'_')),
          name: ing?.name || a.name,
          qty: a.delta,
          unit: a.unit || ing?.default_unit || 'each',
          expires_at: new Date(Date.now() + 14*86400000).toISOString(),
          added_at: new Date().toISOString(),
          location: a.location || 'pantry',
          is_staple: false,
          restock_threshold: null,
          is_non_food: a.location === 'non_food',
        });
        added++;
      }
    }
    setKey('pantry', pantry);
    notify(`Voice update: ${added} added, ${updated} adjusted${removed?', '+removed+' removed':''}`, 'success');
  };

  const setRestockThreshold = (id, threshold) => {
    setKey('pantry', state.pantry.map(p => p.id === id ? {...p, restock_threshold: threshold} : p));
  };
  const toggleStaple = (id) => {
    setKey('pantry', state.pantry.map(p => p.id === id ? {...p, is_staple: !p.is_staple} : p));
  };
  const setLocationOf = (id, loc) => {
    setKey('pantry', state.pantry.map(p => p.id === id ? {...p, location: loc} : p));
  };

  const candidateIngredients = useMemo(() => {
    if (!addSearch) return ingredients.slice(0, 30);
    return ingredients.filter(i => i.name.toLowerCase().includes(addSearch.toLowerCase())).slice(0, 50);
  }, [ingredients, addSearch]);

  const expiring = filtered.filter(p => expirationTone(p.expires_at) === 'warn' || expirationTone(p.expires_at) === 'red');

  const renderItem = (p) => {
    const tone = expirationTone(p.expires_at);
    const daysLeft = Math.round((new Date(p.expires_at) - Date.now()) / 86400000);
    const ing = ingById[p.ingredient_id];
    const lowStock = typeof p.restock_threshold === 'number' && p.qty <= p.restock_threshold;
    const locEmoji = { pantry: '🥫', fridge: '❄️', freezer: '🧊', non_food: '🧴' }[p.location || 'pantry'] || '📦';
    return (
      <div key={p.id} className="flex items-center gap-3 py-3 border-b border-stone-100 last:border-b-0">
        <div className="text-2xl w-10 text-center shrink-0" title={(p.location||'pantry')}>{ing?.emoji || locEmoji}</div>
        <div className="flex-1 min-w-0">
          <div className="font-medium truncate flex items-center gap-2">
            <span className="truncate">{p.name}</span>
            {p.is_staple && <span title="Staple — auto-restocked" className="text-[10px] px-1.5 py-0.5 bg-blue-100 text-blue-800 rounded-full font-semibold shrink-0">⭐</span>}
            {lowStock && <span title="Below restock threshold" className="text-[10px] px-1.5 py-0.5 bg-red-100 text-red-700 rounded-full font-semibold shrink-0">low</span>}
          </div>
          <div className="text-xs text-stone-500 flex flex-wrap gap-x-2">
            <span>{p.qty} {p.unit}</span>
            {!p.is_non_food && (daysLeft >= 0 ? <span>· {daysLeft}d left</span> : <span className="text-red-700">· expired {Math.abs(daysLeft)}d</span>)}
          </div>
        </div>
        {!p.is_non_food && <Badge tone={tone}>{daysLeft >= 0 ? `${daysLeft}d` : 'old'}</Badge>}
        {/* Bigger touch targets — 36px buttons, easier to thumb-tap */}
        <div className="flex items-center gap-1 shrink-0">
          <button onClick={()=>updateQty(p.id, -1)} aria-label="decrease quantity"
            className="w-9 h-9 rounded-lg border border-stone-300 hover:bg-stone-100 active:bg-stone-200 flex items-center justify-center">
            <Icon name="minus" cls="w-4 h-4"/>
          </button>
          <div className="w-7 text-center text-sm font-medium tabular-nums">{p.qty}</div>
          <button onClick={()=>updateQty(p.id, +1)} aria-label="increase quantity"
            className="w-9 h-9 rounded-lg border border-stone-300 hover:bg-stone-100 active:bg-stone-200 flex items-center justify-center">
            <Icon name="plus" cls="w-4 h-4"/>
          </button>
          <button onClick={()=>setEditItemId(p.id)} aria-label="more options" title="Options"
            className="w-9 h-9 ml-1 text-stone-400 hover:text-stone-700 active:bg-stone-100 rounded-lg flex items-center justify-center">
            <svg viewBox="0 0 24 24" className="w-4 h-4" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
              <circle cx="5" cy="12" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="19" cy="12" r="1.6"/>
            </svg>
          </button>
        </div>
      </div>
    );
  };

  return (
    <div className="space-y-5 fade-in">
      <div>
        <h1 className="font-display text-3xl md:text-4xl">Pantry</h1>
        <p className="text-sm text-stone-600 mt-1">{state.pantry.length} items · {expiring.length} need attention</p>
      </div>

      {Claude.isEnabled() && (
        <HintBubble id="pantry-voice" placement="bottom" className="max-w-sm">
          🎤 Tap the mic to update your pantry by voice. Say <em>"I used two eggs"</em> or <em>"add a dozen apples"</em>.
        </HintBubble>
      )}
      {/* Action row — chunky buttons on mobile, inline on desktop */}
      <div className="grid grid-cols-4 md:flex md:justify-end gap-2">
        <Button variant="outline" onClick={()=>setShowVoice(true)} className="justify-center px-2 md:px-4" title="Quick voice update">
          🎤<span className="hidden md:inline ml-1">Voice</span>
        </Button>
        <Button variant="outline" onClick={()=>go('scanItem')} className="justify-center px-2 md:px-4">
          <Icon name="scan" cls="w-4 h-4"/><span className="hidden sm:inline">Barcode</span>
        </Button>
        <Button variant="outline" onClick={()=>go('scanReceipt')} className="justify-center px-2 md:px-4">
          <Icon name="receipt" cls="w-4 h-4"/><span className="hidden sm:inline">Receipt</span>
        </Button>
        <Button onClick={()=>setShowAdd(true)} className="justify-center px-2 md:px-4">
          <Icon name="plus" cls="w-4 h-4"/>Add
        </Button>
      </div>

      {/* Location tabs — horizontal scroll with snap on mobile */}
      <div className="ka-no-scrollbar flex gap-1.5 overflow-x-auto pb-2 -mx-4 px-4 snap-x snap-mandatory">
        {[
          ['all','All food','🍽️'],
          ['pantry','Pantry','🥫'],
          ['fridge','Fridge','❄️'],
          ['freezer','Freezer','🧊'],
          ['non_food','Household','🧴'],
        ].map(([id,label,emoji]) => {
          const count = state.pantry.filter(p => id === 'all' ? (p.location||'pantry') !== 'non_food' : (p.location||'pantry') === id).length;
          return (
            <button key={id} onClick={() => setLocation(id)}
              className={'snap-start whitespace-nowrap px-3.5 py-2 rounded-full text-sm transition border min-h-[40px] ' +
                (location === id ? 'bg-brand-500 text-white border-brand-500 shadow-sm' : 'bg-white text-stone-600 border-stone-200 hover:bg-stone-50 active:bg-stone-100')}>
              <span className="mr-1">{emoji}</span>{label} <span className="ml-1 text-xs opacity-75">({count})</span>
            </button>
          );
        })}
      </div>

      <div className="space-y-2">
        <Input placeholder="Search pantry…" value={q} onChange={e=>setQ(e.target.value)} className="w-full md:max-w-xs"/>
        <div className="ka-no-scrollbar flex gap-2 overflow-x-auto -mx-4 px-4 md:mx-0 md:px-0 pb-1">
          <Chip active={sort==='expires'}    onClick={()=>setSort('expires')}>By expiration</Chip>
          <Chip active={sort==='category'}   onClick={()=>setSort('category')}>By category</Chip>
          <Chip active={sort==='name'}       onClick={()=>setSort('name')}>A–Z</Chip>
          <Chip active={showStaplesOnly}     onClick={()=>setShowStaplesOnly(!showStaplesOnly)}>⭐ Staples only</Chip>
        </div>
      </div>

      {expiring.length > 0 && location !== 'non_food' && (
        <Card className="border-amber-200 bg-amber-50/50">
          <div className="flex items-start gap-3">
            <Icon name="alert" cls="w-5 h-5 text-amber-600 shrink-0 mt-0.5"/>
            <div className="text-sm">
              <strong>{expiring.length} {expiring.length===1?'item needs':'items need'} using up soon.</strong> Open the Recipes tab — recipes using these will rank higher.
            </div>
          </div>
        </Card>
      )}

      {lowStock.length > 0 && (
        <Card className="border-red-200 bg-red-50/50">
          <div className="flex items-start gap-3">
            <Icon name="alert" cls="w-5 h-5 text-red-600 shrink-0 mt-0.5"/>
            <div className="text-sm">
              <strong>{lowStock.length} {lowStock.length===1?'item is':'items are'} below restock threshold:</strong>{' '}
              <span className="text-stone-700">{lowStock.slice(0,5).map(p => p.name).join(', ')}{lowStock.length > 5 ? `, +${lowStock.length-5} more` : ''}</span>
            </div>
          </div>
        </Card>
      )}

      {grouped ? (
        Object.entries(grouped).map(([cat, items]) => (
          <Section key={cat} title={cat.charAt(0).toUpperCase()+cat.slice(1)}>
            <Card>{items.map(renderItem)}</Card>
          </Section>
        ))
      ) : (
        <Card>
          {filtered.length === 0 ? <div className="text-center text-stone-500 py-8">No items match.</div> : filtered.map(renderItem)}
        </Card>
      )}

      {showVoice && (
        <VoicePantrySheet
          onClose={()=>setShowVoice(false)}
          onApply={applyVoiceActions}
          pantryItems={state.pantry}
          ingredients={ingredients}
        />
      )}

      {/* Floating undo pill — appears for 6s after a delete */}
      {lastDeleted && (
        <button onClick={undoDelete}
          className="md:hidden fixed left-1/2 -translate-x-1/2 bottom-24 z-30 bg-stone-900 text-white px-5 py-3 rounded-full shadow-2xl flex items-center gap-2 text-sm fade-in"
          style={{paddingBottom:'max(0.75rem, env(safe-area-inset-bottom))'}}>
          <svg viewBox="0 0 24 24" className="w-4 h-4" fill="none" stroke="currentColor" strokeWidth="2"><path d="M9 14l-4-4 4-4M5 10h11a4 4 0 010 8h-1"/></svg>
          Undo · restore {lastDeleted.name}
        </button>
      )}
      {lastDeleted && (
        <button onClick={undoDelete}
          className="hidden md:flex fixed right-6 bottom-6 z-30 bg-stone-900 text-white px-5 py-3 rounded-full shadow-2xl items-center gap-2 text-sm fade-in">
          ↶ Undo · restore {lastDeleted.name}
        </button>
      )}

      {/* ─────────────────  ADD ITEM BOTTOM SHEET  ──────────────────
          Slides up from bottom on mobile; centered card on desktop.
          Stays open after each add so you can batch-enter a whole grocery run. */}
      {showAdd && (
        <div className="fixed inset-0 bg-black/50 z-40 flex md:items-center md:justify-center md:p-4 items-end justify-stretch" onClick={closeAddSheet}>
          <div
            className="bg-white w-full md:max-w-lg md:rounded-2xl rounded-t-2xl max-h-[92vh] md:max-h-[85vh] flex flex-col shadow-2xl fade-in"
            style={{paddingBottom:'env(safe-area-inset-bottom)'}}
            onClick={e=>e.stopPropagation()}>
            {/* Grab handle on mobile */}
            <div className="md:hidden w-12 h-1.5 rounded-full bg-stone-300 mx-auto my-2.5"/>
            <div className="px-4 pt-2 pb-3 border-b border-stone-200">
              <div className="flex items-center justify-between mb-3">
                <h3 className="font-display text-xl">Add to {addLocation === 'non_food' ? 'household' : addLocation}</h3>
                <button onClick={closeAddSheet} aria-label="close" className="w-10 h-10 rounded-full text-stone-500 hover:bg-stone-100 active:bg-stone-200 flex items-center justify-center">
                  <Icon name="x" cls="w-5 h-5"/>
                </button>
              </div>

              {/* Where it goes */}
              <div className="flex gap-1.5 flex-wrap mb-3">
                {[['pantry','🥫 Pantry'],['fridge','❄️ Fridge'],['freezer','🧊 Freezer'],['non_food','🧴 Household']].map(([id,label]) => (
                  <Chip key={id} active={addLocation===id} onClick={()=>{ setAddLocation(id); setAddIsNonFood(id==='non_food'); }}>{label}</Chip>
                ))}
              </div>

              {/* Default qty + expiry — collapsed by default to keep the sheet short */}
              <details className="mb-3">
                <summary className="text-xs text-stone-500 cursor-pointer py-1 select-none">
                  Defaults: qty <strong>{addQty}</strong>, expires in <strong>{addExp}d</strong> &nbsp;<span className="text-brand-600 underline">change</span>
                </summary>
                <div className="grid grid-cols-2 gap-2 mt-2">
                  <div>
                    <label className="text-xs text-stone-500">Quantity</label>
                    <div className="flex items-center gap-1 mt-1">
                      <button onClick={()=>setAddQty(q=>Math.max(1,q-1))} className="w-11 h-11 rounded-lg border border-stone-300 text-lg active:bg-stone-100">−</button>
                      <Input type="number" value={addQty} min="1" inputMode="numeric" onChange={e=>setAddQty(Number(e.target.value)||1)} className="text-center"/>
                      <button onClick={()=>setAddQty(q=>q+1)} className="w-11 h-11 rounded-lg border border-stone-300 text-lg active:bg-stone-100">+</button>
                    </div>
                  </div>
                  <div>
                    <label className="text-xs text-stone-500">{addLocation==='non_food' ? 'Days till empty' : 'Expires in (days)'}</label>
                    <Input type="number" value={addExp} min="1" inputMode="numeric" onChange={e=>setAddExp(Number(e.target.value)||14)} className="mt-1"/>
                  </div>
                </div>
              </details>

              <Input
                placeholder={addLocation==='non_food' ? 'Item name (e.g. toilet paper, dish soap)' : 'Search 250+ ingredients…'}
                value={addSearch}
                onChange={e=>setAddSearch(e.target.value)}
                onKeyDown={e => {
                  if (e.key === 'Enter') {
                    if (addLocation === 'non_food' && addSearch.trim()) addCustomItem(addSearch.trim(), 'unit');
                    else if (candidateIngredients[0]) addItem(candidateIngredients[0].id);
                  }
                }}
                autoFocus
              />
              {addLocation === 'non_food' && addSearch.trim() && (
                <button onClick={() => addCustomItem(addSearch.trim(), 'unit')}
                  className="w-full mt-2 px-3 py-3 bg-brand-500 text-white rounded-lg text-sm font-medium hover:bg-brand-600 active:bg-brand-700 min-h-[44px]">
                  + Add "{addSearch.trim()}" to household
                </button>
              )}

              {/* Recent items — one-tap re-add */}
              {!addSearch && recentItems.length > 0 && addLocation !== 'non_food' && (
                <div className="mt-3">
                  <div className="text-[11px] text-stone-500 uppercase tracking-wide mb-1.5">Recent</div>
                  <div className="flex gap-1.5 flex-wrap">
                    {recentItems.map(p => {
                      const ing = ingById[p.ingredient_id];
                      return (
                        <button key={p.id} onClick={()=>quickReAdd(p)}
                          className="px-3 py-2 rounded-full text-sm bg-stone-100 hover:bg-stone-200 active:bg-stone-300 text-stone-700 min-h-[36px]">
                          {ing?.emoji || '📦'} {p.name}
                        </button>
                      );
                    })}
                  </div>
                </div>
              )}
            </div>

            {/* Search results */}
            <div className="flex-1 overflow-y-auto p-2">
              {addLocation !== 'non_food' && candidateIngredients.map(i => (
                <button key={i.id} onClick={()=>addItem(i.id)}
                  className="w-full text-left p-3 rounded-lg hover:bg-stone-50 active:bg-stone-100 flex items-center gap-3 min-h-[56px]">
                  <span className="text-2xl shrink-0">{i.emoji}</span>
                  <div className="flex-1 min-w-0">
                    <div className="text-sm font-medium truncate">{i.name}</div>
                    <div className="text-xs text-stone-500">{i.category} · {i.default_unit}</div>
                  </div>
                  <div className="w-10 h-10 rounded-full bg-brand-50 text-brand-600 flex items-center justify-center shrink-0">
                    <Icon name="plus" cls="w-5 h-5"/>
                  </div>
                </button>
              ))}
              {addLocation === 'non_food' && !addSearch && (
                <div className="p-4 text-xs text-stone-500">
                  Type a name above. Common household items: toilet paper, paper towels, dish soap, laundry detergent, toothbrushes, air filters, batteries, light bulbs.
                </div>
              )}
              {addLocation !== 'non_food' && candidateIngredients.length === 0 && (
                <div className="p-4 text-sm text-stone-500 text-center">
                  No matches for "{addSearch}".
                  <button onClick={()=>{ setAddLocation('non_food'); setAddIsNonFood(true); }} className="block mx-auto mt-2 text-brand-600 underline">Add it as a household item instead</button>
                </div>
              )}
            </div>

            {/* Sticky footer — batch counter + done */}
            <div className="border-t border-stone-200 px-4 py-3 bg-white sticky bottom-0">
              {batchQueue.length > 0 ? (
                <div className="flex items-center gap-3">
                  <div className="flex-1 text-sm">
                    <div className="font-medium text-leaf-700">✓ {batchQueue.length} added this session</div>
                    <div className="text-xs text-stone-500 truncate">
                      {batchQueue.slice(-3).map(b => b.name).join(' · ')}
                      {batchQueue.length > 3 && ` (+${batchQueue.length-3} more)`}
                    </div>
                  </div>
                  <Button onClick={closeAddSheet} className="shrink-0">Done</Button>
                </div>
              ) : (
                <div className="text-xs text-stone-500 text-center">
                  Tap items to add them. The sheet stays open so you can add multiple in a row.
                </div>
              )}
            </div>
          </div>
        </div>
      )}

      {/* ─────────────────  EDIT ITEM BOTTOM SHEET  ────────────────── */}
      {editItemId && (() => {
        const p = state.pantry.find(x => x.id === editItemId);
        if (!p) return null;
        return (
          <div className="fixed inset-0 bg-black/50 z-40 flex md:items-center md:justify-center md:p-4 items-end justify-stretch" onClick={()=>setEditItemId(null)}>
            <div
              className="bg-white w-full md:max-w-md md:rounded-2xl rounded-t-2xl flex flex-col shadow-2xl fade-in"
              style={{paddingBottom:'env(safe-area-inset-bottom)'}}
              onClick={e=>e.stopPropagation()}>
              <div className="md:hidden w-12 h-1.5 rounded-full bg-stone-300 mx-auto my-2.5"/>
              <div className="px-4 pb-4 pt-2">
                <div className="flex items-center justify-between mb-3">
                  <div>
                    <h3 className="font-display text-lg">{p.name}</h3>
                    <div className="text-xs text-stone-500">{p.qty} {p.unit} · {p.location||'pantry'}</div>
                  </div>
                  <button onClick={()=>setEditItemId(null)} aria-label="close" className="w-10 h-10 rounded-full text-stone-500 hover:bg-stone-100 flex items-center justify-center">
                    <Icon name="x" cls="w-5 h-5"/>
                  </button>
                </div>
                <div className="space-y-3">
                  <label className="flex items-center gap-3 py-2 cursor-pointer">
                    <input type="checkbox" checked={!!p.is_staple} onChange={()=>toggleStaple(p.id)} className="w-5 h-5 accent-brand-500"/>
                    <div>
                      <div className="text-sm font-medium">Mark as staple</div>
                      <div className="text-xs text-stone-500">Auto-added back to your shopping list when you run out.</div>
                    </div>
                  </label>
                  <div>
                    <label className="text-xs text-stone-500 uppercase tracking-wide">Restock when at or below</label>
                    <Input type="number" min="0" value={p.restock_threshold ?? ''} placeholder="off — never alert"
                      inputMode="numeric"
                      onChange={e => setRestockThreshold(p.id, e.target.value === '' ? null : Number(e.target.value))}
                      className="mt-1"/>
                  </div>
                  <div>
                    <label className="text-xs text-stone-500 uppercase tracking-wide">Storage</label>
                    <div className="grid grid-cols-2 gap-2 mt-1">
                      {[['pantry','🥫 Pantry'],['fridge','❄️ Fridge'],['freezer','🧊 Freezer'],['non_food','🧴 Household']].map(([id,label]) => (
                        <button key={id} onClick={()=>setLocationOf(p.id, id)}
                          className={'px-3 py-3 rounded-lg text-sm border min-h-[48px] '+((p.location||'pantry')===id ? 'bg-brand-500 text-white border-brand-500' : 'bg-white border-stone-300 text-stone-700')}>{label}</button>
                      ))}
                    </div>
                  </div>
                  <div className="pt-2 border-t border-stone-100 flex gap-2">
                    <Button variant="danger" onClick={()=>{ removeItem(p.id); setEditItemId(null); }} className="flex-1 justify-center">
                      <Icon name="trash" cls="w-4 h-4"/>Remove
                    </Button>
                    <Button onClick={()=>setEditItemId(null)} className="flex-1 justify-center">Done</Button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        );
      })()}
    </div>
  );
}

function PantryEmailGate() {
  const [email, setEmail] = React.useState(() => {
    try { return localStorage.getItem('kitchenAgent:v2:userEmail') || ''; } catch { return ''; }
  });
  const [input, setInput] = React.useState('');
  const [error, setError] = React.useState('');

  if (email) return <Pantry/>;

  const submit = () => {
    const trimmed = input.trim().toLowerCase();
    const valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(trimmed);
    if (!valid) { setError('Please enter a valid email address'); return; }
    try {
      localStorage.setItem('kitchenAgent:v2:userEmail', trimmed);
    } catch {}
    setEmail(trimmed);
  };

  return (
    <div className="space-y-6 fade-in max-w-md mx-auto">
      <div>
        <h1 className="font-display text-3xl md:text-4xl">Pantry</h1>
        <p className="text-sm text-stone-600 mt-1">Track what's in your kitchen.</p>
      </div>
      <Card className="space-y-4">
        <div className="flex items-center gap-3">
          <div className="w-12 h-12 rounded-full bg-brand-50 text-brand-600 flex items-center justify-center text-2xl">🔒</div>
          <div>
            <div className="font-medium">Sign in to use the pantry</div>
            <div className="text-xs text-stone-500">Your pantry, scans, and meal history get tied to your email so they sync across devices.</div>
          </div>
        </div>
        <div>
          <label className="text-xs text-stone-500 uppercase tracking-wide">Email address</label>
          <Input
            type="email"
            placeholder="you@example.com"
            value={input}
            onChange={e => { setInput(e.target.value); setError(''); }}
            onKeyDown={e => { if (e.key === 'Enter') submit(); }}
            autoFocus
          />
          {error && <div className="text-xs text-red-600 mt-1">{error}</div>}
        </div>
        <Button onClick={submit} className="w-full">
          <Icon name="check" cls="w-4 h-4"/>Continue
        </Button>
        <p className="text-[11px] text-stone-400 text-center">
          We use this only to identify your pantry data. No marketing, no spam.
        </p>
      </Card>
    </div>
  );
}

K.Pantry = PantryEmailGate;
</script>

<!-- =============== SCAN ITEM (BARCODE + PHOTO) =============== -->
<script type="text/babel" data-type="module">
const { useState, useEffect, useRef } = React;
const K = window.__KA;
const { Icon, Card, Section, Button, Badge, Input, useApp, OpenFoodFacts, OCR, Claude } = K;
const BarcodeMap = window.__KA.BarcodeMap;

// ── Cross-browser barcode helper ─────────────────────────────────────────
// Strategy: prefer native BarcodeDetector (Chrome/Edge — fast, low CPU);
// fall back to ZXing-js (iOS Safari, Firefox, anything else).
const BarcodeEngine = {
  // 'native' | 'zxing' | null
  pick(){
    if (typeof window === 'undefined') return null;
    if ('BarcodeDetector' in window) return 'native';
    if (window.ZXingBrowser || window.ZXing) return 'zxing';
    return null;
  },
  async scanFromVideo(video, onCode, onError){
    const kind = this.pick();
    if (!kind) { onError(new Error('No barcode engine available')); return () => {}; }
    if (kind === 'native') {
      const detector = new window.BarcodeDetector({ formats: ['ean_13','ean_8','upc_a','upc_e','code_128','code_39','itf','codabar'] });
      let stopped = false;
      const loop = async () => {
        if (stopped) return;
        try {
          const codes = await detector.detect(video);
          if (codes.length) onCode(codes[0].rawValue);
        } catch {}
        setTimeout(loop, 250);
      };
      loop();
      return () => { stopped = true; };
    }
    // ZXing path — its BrowserMultiFormatReader handles the read loop for us.
    const Z = window.ZXingBrowser || window.ZXing;
    const reader = new Z.BrowserMultiFormatReader();
    let controls = null;
    try {
      controls = await reader.decodeFromVideoElement(video, (result, err) => {
        if (result) onCode(result.getText());
        // ignore err — ZXing fires NotFoundException constantly while searching
      });
    } catch (e) { onError(e); }
    return () => { try { controls && controls.stop(); } catch {} };
  },
  async scanFromImage(file){
    const kind = this.pick();
    if (kind === 'native') {
      const bitmap = await createImageBitmap(file);
      const detector = new window.BarcodeDetector({ formats: ['ean_13','ean_8','upc_a','upc_e','code_128','code_39','itf','codabar'] });
      const codes = await detector.detect(bitmap);
      return codes[0]?.rawValue || null;
    }
    if (kind === 'zxing') {
      const Z = window.ZXingBrowser || window.ZXing;
      const reader = new Z.BrowserMultiFormatReader();
      const url = URL.createObjectURL(file);
      try {
        const result = await reader.decodeFromImageUrl(url);
        return result?.getText() || null;
      } finally { URL.revokeObjectURL(url); }
    }
    throw new Error('No barcode engine available');
  },
};

function ScanItem(){
  const { data, state, setKey, go, notify } = useApp();
  const { ingredients } = data;
  const [mode, setMode] = useState('barcode'); // 'barcode' | 'photo'
  const [barcode, setBarcode] = useState('');
  const [lookingUp, setLookingUp] = useState(false);
  const [product, setProduct] = useState(null);
  const [notFound, setNotFound] = useState(false);
  const [matchedIngId, setMatchedIngId] = useState('');
  const [qty, setQty] = useState(1);
  const [expDays, setExpDays] = useState(14);
  const [videoActive, setVideoActive] = useState(false);
  const [cameraStarting, setCameraStarting] = useState(false);
  const [torchOn, setTorchOn] = useState(false);
  const [engine] = useState(() => BarcodeEngine.pick());
  const [scannedCount, setScannedCount] = useState(0); // for batch-scan feedback
  const videoRef = useRef(null);
  const streamRef = useRef(null);
  const scanStopRef = useRef(null);
  const fileInputRef = useRef(null);
  const photoInputRef = useRef(null);

  // Photo-of-item mode state
  const [photoUrl, setPhotoUrl] = useState(null);
  const [photoOCR, setPhotoOCR] = useState('');
  const [photoBusy, setPhotoBusy] = useState(false);
  const [photoProgress, setPhotoProgress] = useState(0);
  const [photoStage, setPhotoStage] = useState(''); // 'claude' | 'ocr'
  const [photoName, setPhotoName] = useState('');
  const [photoBrand, setPhotoBrand] = useState('');
  const [photoCategory, setPhotoCategory] = useState('');
  const [photoConfidence, setPhotoConfidence] = useState('');
  const [photoIsNonFood, setPhotoIsNonFood] = useState(false);
  const [photoMatches, setPhotoMatches] = useState([]);

  const doLookup = async (code) => {
    setLookingUp(true); setNotFound(false); setProduct(null);
    try {
      // 1. Check local learned barcode map first — instant hit if we've scanned this before
      const learned = BarcodeMap.get(code);
      if (learned) {
        setProduct({
          name: learned.name,
          brand: learned.brand || (learned.is_non_food ? 'household item' : ''),
          qty: learned.last_unit || '',
          barcode: code,
          image_url: learned.image_url || null,
          _learned: true,
          _isNonFood: !!learned.is_non_food,
          _location: learned.location || (learned.is_non_food ? 'non_food' : 'pantry'),
        });
        setMatchedIngId(learned.ingredient_id || '');
        setQty(learned.default_qty || 1);
        setLookingUp(false);
        return;
      }

      // 2. Try Open Food Facts (food items)
      const p = await OpenFoodFacts.lookup(code);
      if (p && p.found) {
        setProduct(p);
        const name = (p.name || '').toLowerCase();
        const matched = ingredients.find(i => name.includes(i.name.toLowerCase()));
        setMatchedIngId(matched?.id || '');
      } else {
        // 3. Fallback: surface inline manual entry. Pre-populate as non-food guess.
        setNotFound(true);
      }
    } catch (e) {
      notify('Lookup failed: '+e.message, 'error');
    } finally {
      setLookingUp(false);
    }
  };

  const startCamera = async () => {
    if (!engine) {
      notify("Camera scanning isn't available in this browser. Upload an image or type the barcode below.", 'error');
      return;
    }
    setCameraStarting(true);
    try {
      const stream = await navigator.mediaDevices.getUserMedia({
        video: {
          facingMode: { ideal: 'environment' },
          width:  { ideal: 1280 },
          height: { ideal: 720 },
        },
        audio: false,
      });
      streamRef.current = stream;
      videoRef.current.srcObject = stream;
      // iOS Safari needs these explicit attributes & a triggered play()
      videoRef.current.setAttribute('playsinline', 'true');
      videoRef.current.setAttribute('muted', 'true');
      await videoRef.current.play().catch(()=>{});
      setVideoActive(true);
      setCameraStarting(false);
      scanStopRef.current = await BarcodeEngine.scanFromVideo(
        videoRef.current,
        (code) => {
          // Light haptic on phones that support it — feels great when a scan lands.
          if (navigator.vibrate) navigator.vibrate(40);
          stopCamera();
          setBarcode(code);
          doLookup(code);
        },
        (err) => notify('Scanner: '+err.message, 'error'),
      );
    } catch (e) {
      setCameraStarting(false);
      const msg = e.name === 'NotAllowedError'
        ? 'Camera access denied. Enable camera for this site in your browser settings.'
        : 'Camera error: '+e.message;
      notify(msg, 'error');
    }
  };

  const stopCamera = () => {
    try { scanStopRef.current && scanStopRef.current(); } catch {}
    scanStopRef.current = null;
    if (streamRef.current) streamRef.current.getTracks().forEach(t => t.stop());
    streamRef.current = null;
    setVideoActive(false);
    setTorchOn(false);
  };

  const toggleTorch = async () => {
    const track = streamRef.current?.getVideoTracks?.()[0];
    if (!track) return;
    const caps = track.getCapabilities?.() || {};
    if (!caps.torch) { notify('Torch not supported on this camera', 'info'); return; }
    try {
      await track.applyConstraints({ advanced: [{ torch: !torchOn }] });
      setTorchOn(t => !t);
    } catch (e) { notify('Torch toggle failed: '+e.message, 'error'); }
  };

  useEffect(() => () => stopCamera(), []);

  // BARCODE — upload an image file and detect barcode from it
  const handleBarcodeImageUpload = async (e) => {
    const file = e.target.files?.[0];
    if (!file) return;
    if (!engine) {
      notify("Your browser can't decode barcodes from images. Type the digits manually below.", 'error');
      return;
    }
    try {
      const code = await BarcodeEngine.scanFromImage(file);
      if (code) {
        setBarcode(code);
        doLookup(code);
      } else {
        notify('No barcode found. Make sure the whole barcode is in the photo and in focus.', 'info');
      }
    } catch (err) {
      notify('Image decode failed: '+err.message, 'error');
    } finally {
      e.target.value = ''; // allow re-upload same file
    }
  };

  // PHOTO-OF-ITEM — try Claude vision first (if key set), fall back to OCR.
  const handlePhotoUpload = async (e) => {
    const file = e.target.files?.[0];
    if (!file) return;
    const url = URL.createObjectURL(file);
    setPhotoUrl(url);
    setPhotoBusy(true); setPhotoProgress(0);
    setPhotoOCR(''); setPhotoName(''); setPhotoBrand(''); setPhotoCategory('');
    setPhotoConfidence(''); setPhotoIsNonFood(false); setPhotoMatches([]);

    try {
      if (Claude.isEnabled()) {
        setPhotoStage('claude');
        const result = await Claude.identifyItem(file, { canonicalIngredients: ingredients });
        setPhotoName(result.name || '');
        setPhotoBrand(result.brand || '');
        setPhotoCategory(result.category || '');
        setPhotoConfidence(result.confidence || 'medium');
        setPhotoIsNonFood(result.is_food === false || result.category === 'household');
        if (typeof result.default_expiry_days === 'number' && result.default_expiry_days > 0) {
          setExpDays(result.default_expiry_days);
        }
        // Try to match to a canonical ingredient by exact name first, then includes.
        const nameLower = (result.name || '').toLowerCase().trim();
        let matched = ingredients.find(i => i.name.toLowerCase() === nameLower);
        if (!matched) matched = ingredients.find(i => nameLower && (nameLower.includes(i.name.toLowerCase()) || i.name.toLowerCase().includes(nameLower)));
        if (matched) {
          setMatchedIngId(matched.id);
          setPhotoMatches([matched, ...ingredients.filter(i => i.id !== matched.id && i.category === matched.category).slice(0, 5)]);
        }
        if (navigator.vibrate) navigator.vibrate(20);
      } else {
        // OCR fallback
        setPhotoStage('ocr');
        const res = await OCR.recognize(file, (m) => {
          if (m?.status === 'recognizing text') setPhotoProgress(Math.round((m.progress||0)*100));
        });
        const text = res?.text || '';
        setPhotoOCR(text);
        const lines = text.split('\n').map(l => l.trim()).filter(l => l.length >= 3 && /[A-Za-z]{3,}/.test(l));
        const sorted = lines.slice().sort((a,b) => b.replace(/[^A-Za-z]/g,'').length - a.replace(/[^A-Za-z]/g,'').length);
        const guess = (sorted[0] || lines[0] || '').replace(/[^A-Za-z0-9\s\-]/g,'').trim();
        setPhotoName(guess);
        const hay = text.toLowerCase();
        const matches = ingredients.filter(i => hay.includes(i.name.toLowerCase())).slice(0, 6);
        setPhotoMatches(matches);
        if (matches.length) setMatchedIngId(matches[0].id);
      }
    } catch (err) {
      notify((photoStage==='claude' ? 'Claude vision: ' : 'OCR: ')+err.message, 'error');
    } finally {
      setPhotoBusy(false); setPhotoStage('');
    }
  };

  const resetPhoto = () => {
    setPhotoUrl(null); setPhotoOCR(''); setPhotoName(''); setPhotoBrand('');
    setPhotoCategory(''); setPhotoConfidence(''); setPhotoMatches([]);
    setMatchedIngId(''); setQty(1); setPhotoIsNonFood(false);
  };

  const addPhotoToPantry = () => {
    const ing = ingredients.find(i => i.id === matchedIngId);
    const name = ing?.name || photoName || 'Scanned item';
    const unit = ing?.default_unit || 'each';
    const newItem = {
      id: crypto.randomUUID(),
      ingredient_id: matchedIngId || ('custom_' + name.toLowerCase().replace(/[^\w]+/g,'_')),
      name,
      qty,
      unit,
      expires_at: new Date(Date.now() + expDays*86400000).toISOString(),
      added_at: new Date().toISOString(),
      source: Claude.isEnabled() ? 'claude_vision' : 'photo_ocr',
      raw_name: photoName,
      brand: photoBrand || undefined,
      location: photoIsNonFood ? 'non_food' : 'pantry',
      is_non_food: !!photoIsNonFood,
    };
    setKey('pantry', [...state.pantry, newItem]);
    notify(`Added ${name} to ${photoIsNonFood?'household':'pantry'}`, 'success');
    resetPhoto();
  };

  const saveBarcodeFallback = (form) => {
    const newItem = {
      id: crypto.randomUUID(),
      ingredient_id: 'custom_' + form.name.toLowerCase().replace(/[^\w]+/g,'_'),
      name: form.name,
      qty: form.qty,
      unit: form.unit,
      expires_at: new Date(Date.now() + form.exp_days * 86400000).toISOString(),
      added_at: new Date().toISOString(),
      barcode: form.barcode,
      location: form.location,
      is_non_food: form.is_non_food,
      is_staple: false,
      restock_threshold: form.restock_threshold,
    };
    setKey('pantry', [...state.pantry, newItem]);
    // Remember this barcode for instant future scans
    BarcodeMap.set(form.barcode, {
      name: form.name,
      ingredient_id: newItem.ingredient_id,
      is_non_food: form.is_non_food,
      location: form.location,
      default_qty: form.qty,
      last_unit: form.unit,
      category: form.is_non_food ? 'household' : 'food',
    });
    notify(`Saved ${form.name} & remembered this barcode`, 'success');
    setBarcode(''); setNotFound(false); setProduct(null);
  };

  const addToPantry = () => {
    const ing = ingredients.find(i => i.id === matchedIngId);
    const name = ing?.name || product?.name || 'Unknown';
    const newItem = {
      id: crypto.randomUUID(),
      ingredient_id: matchedIngId || ('custom_' + name.toLowerCase().replace(/[^\w]+/g,'_')),
      name,
      qty,
      unit: ing?.default_unit || 'unit',
      expires_at: new Date(Date.now() + expDays * 86400000).toISOString(),
      added_at: new Date().toISOString(),
      barcode: product?.barcode || barcode,
      location: product?._location || 'pantry',
      is_non_food: !!product?._isNonFood,
      is_staple: false,
      restock_threshold: null,
    };
    setKey('pantry', [...state.pantry, newItem]);
    // "I just bought this" — if the item was on the current shopping list, offer to remove it
    const nameLower = name.toLowerCase().trim();
    const onShoppingList = (state.shoppingExtras || []).find(x =>
      (x.ingredient_id && x.ingredient_id === newItem.ingredient_id) ||
      (x.name && x.name.toLowerCase().trim() === nameLower)
    );
    if (onShoppingList && window.confirm(`"${name}" is on your shopping list. Mark it as bought and remove?`)) {
      setKey('shoppingExtras', state.shoppingExtras.filter(x => x.id !== onShoppingList.id));
    }
    if (product?.barcode) {
      BarcodeMap.set(product.barcode, {
        name,
        ingredient_id: newItem.ingredient_id,
        is_non_food: newItem.is_non_food,
        location: newItem.location,
        default_qty: qty,
        last_unit: newItem.unit,
        image_url: product.image_url || null,
        brand: product.brand || '',
        category: newItem.is_non_food ? 'household' : 'food',
      });
    }
    notify(`Added ${qty} ${name} to pantry`, 'success');
    setBarcode(''); setProduct(null); setMatchedIngId(''); setQty(1);
  };

  return (
    <div className="space-y-6 fade-in max-w-2xl">
      <div>
        <h1 className="font-display text-3xl md:text-4xl">Scan an item</h1>
        <p className="text-sm text-stone-600 mt-1">
          {mode==='barcode'
            ? 'Point your camera at any barcode — works on iPhone Safari, Android Chrome, desktop.'
            : (Claude.isEnabled()
                ? 'Snap a photo of anything — bottle, produce, package. Claude vision identifies it.'
                : 'Snap a photo of a label. Add an Anthropic API key in Settings for smarter identification.')}
        </p>
      </div>

      {/* Mode toggle — chunky pill tabs that work great with a thumb */}
      <div className="grid grid-cols-2 gap-2 p-1 bg-stone-100 rounded-xl">
        <button onClick={()=>setMode('barcode')} className={'px-4 py-3 rounded-lg text-sm font-medium min-h-[48px] transition '+(mode==='barcode'?'bg-white text-brand-700 shadow-sm':'text-stone-600')}>
          <Icon name="scan" cls="w-4 h-4 inline mr-1.5 -mt-0.5"/>Barcode
        </button>
        <button onClick={()=>setMode('photo')} className={'px-4 py-3 rounded-lg text-sm font-medium min-h-[48px] transition '+(mode==='photo'?'bg-white text-brand-700 shadow-sm':'text-stone-600')}>
          <Icon name="camera" cls="w-4 h-4 inline mr-1.5 -mt-0.5"/>Photo of item
          {Claude.isEnabled() && <span className="ml-1 text-[10px] px-1.5 py-0.5 bg-brand-100 text-brand-700 rounded-full">AI</span>}
        </button>
      </div>

      {mode === 'photo' && (
        <Card>
          <h3 className="font-display text-xl mb-3">
            {Claude.isEnabled() ? 'Photo + AI identification' : 'Photo of the package'}
          </h3>
          {!photoUrl ? (
            <div className="space-y-3">
              <input type="file" accept="image/*" capture="environment" ref={photoInputRef}
                onChange={handlePhotoUpload} className="hidden"/>
              <Button onClick={()=>photoInputRef.current?.click()} className="w-full justify-center text-base py-4 min-h-[56px]">
                <Icon name="camera" cls="w-5 h-5"/>Take or choose a photo
              </Button>
              {Claude.isEnabled() ? (
                <p className="text-xs text-stone-500 text-center">
                  ✨ Claude vision identifies the item, brand, category, and typical shelf life.
                  Works on bottles, produce, household items — anywhere OCR struggles.
                </p>
              ) : (
                <p className="text-xs text-stone-500 text-center">
                  Currently using Tesseract OCR (free, runs in your browser). For better results,
                  <button onClick={()=>go('settings')} className="text-brand-600 underline mx-1">add an Anthropic API key</button>
                  to enable Claude vision.
                </p>
              )}
            </div>
          ) : (
            <div className="space-y-3">
              <div className="flex gap-3">
                <img src={photoUrl} alt="scan" className="w-32 h-32 md:w-40 md:h-40 object-contain rounded-lg bg-stone-50 border border-stone-200 shrink-0"/>
                <div className="flex-1 min-w-0">
                  {photoBusy ? (
                    <div>
                      <div className="text-sm text-stone-600 flex items-center gap-2">
                        <Icon name="refresh" cls="w-4 h-4 animate-spin"/>
                        {photoStage === 'claude' ? 'Claude is identifying the item…' : `Reading label… ${photoProgress}%`}
                      </div>
                      {photoStage === 'ocr' && (
                        <div className="h-2 bg-stone-100 rounded-full mt-2 overflow-hidden">
                          <div className="h-full bg-brand-500 transition-all" style={{width: photoProgress+'%'}}></div>
                        </div>
                      )}
                      {photoStage === 'claude' && (
                        <div className="text-xs text-stone-400 mt-2">Usually takes 2-4 seconds.</div>
                      )}
                    </div>
                  ) : (
                    <div className="space-y-2">
                      <div className="flex items-center gap-2 flex-wrap">
                        <label className="text-xs text-stone-500 uppercase tracking-wide">Identified as</label>
                        {photoConfidence && (
                          <Badge tone={photoConfidence==='high'?'leaf':photoConfidence==='low'?'warn':'stone'}>
                            {photoConfidence} confidence
                          </Badge>
                        )}
                      </div>
                      <Input value={photoName} onChange={e=>setPhotoName(e.target.value)} placeholder="Item name"/>
                      {photoBrand && <div className="text-xs text-stone-500">Brand: {photoBrand}</div>}
                      {photoCategory && <div className="text-xs text-stone-500">Category: {photoCategory}</div>}
                    </div>
                  )}
                </div>
              </div>
              {!photoBusy && photoOCR && (
                <details className="text-xs text-stone-500">
                  <summary className="cursor-pointer py-1">Raw OCR text ({photoOCR.length} chars)</summary>
                  <pre className="mt-2 p-2 bg-stone-50 rounded max-h-40 overflow-auto whitespace-pre-wrap">{photoOCR.slice(0,800)}</pre>
                </details>
              )}
              {!photoBusy && (
                <div>
                  <label className="text-xs text-stone-500 uppercase tracking-wide">Match to canonical ingredient (optional)</label>
                  <select value={matchedIngId} onChange={e=>setMatchedIngId(e.target.value)} className="w-full px-3 py-3 border border-stone-300 rounded-lg text-base mt-1 min-h-[48px]">
                    <option value="">— custom name ({photoName||'manual'}) —</option>
                    {photoMatches.length > 0 && <optgroup label="Suggested">
                      {photoMatches.map(i => <option key={i.id} value={i.id}>✨ {i.name}</option>)}
                    </optgroup>}
                    <optgroup label="All ingredients">
                      {ingredients.map(i => <option key={i.id} value={i.id}>{i.name}</option>)}
                    </optgroup>
                  </select>
                </div>
              )}
              {!photoBusy && (
                <>
                  <label className="flex items-center gap-2 text-sm py-2">
                    <input type="checkbox" checked={photoIsNonFood} onChange={e=>setPhotoIsNonFood(e.target.checked)} className="w-5 h-5 accent-brand-500"/>
                    Household / non-food item
                  </label>
                  <div className="grid grid-cols-2 gap-3">
                    <div>
                      <label className="text-xs text-stone-500 uppercase tracking-wide">Quantity</label>
                      <div className="flex items-center gap-1 mt-1">
                        <button onClick={()=>setQty(q=>Math.max(1,q-1))} className="w-11 h-11 rounded-lg border border-stone-300 text-lg active:bg-stone-100">−</button>
                        <Input type="number" value={qty} min="1" inputMode="numeric" onChange={e=>setQty(Number(e.target.value)||1)} className="text-center"/>
                        <button onClick={()=>setQty(q=>q+1)} className="w-11 h-11 rounded-lg border border-stone-300 text-lg active:bg-stone-100">+</button>
                      </div>
                    </div>
                    <div>
                      <label className="text-xs text-stone-500 uppercase tracking-wide">Expires in (days)</label>
                      <Input type="number" value={expDays} min="1" inputMode="numeric" onChange={e=>setExpDays(Number(e.target.value)||14)} className="mt-1"/>
                    </div>
                  </div>
                </>
              )}
              <div className="flex gap-2 pt-2">
                <Button onClick={addPhotoToPantry} disabled={photoBusy || (!matchedIngId && !photoName)} className="flex-1 justify-center">
                  <Icon name="plus" cls="w-4 h-4"/>Add to pantry
                </Button>
                <Button variant="outline" onClick={resetPhoto}>
                  Retry
                </Button>
              </div>
            </div>
          )}
        </Card>
      )}

      {mode === 'barcode' && (
      <Card>
        <h3 className="font-display text-xl mb-3">Point at barcode</h3>
        {!videoActive ? (
          <div className="space-y-3">
            {engine ? (
              <>
                <Button onClick={startCamera} disabled={cameraStarting} className="w-full justify-center text-base py-4 min-h-[56px]">
                  <Icon name="camera" cls="w-5 h-5"/>
                  {cameraStarting ? 'Starting camera…' : 'Use camera to scan'}
                </Button>
                <input type="file" accept="image/*" capture="environment" ref={fileInputRef}
                  onChange={handleBarcodeImageUpload} className="hidden"/>
                <Button variant="outline" onClick={()=>fileInputRef.current?.click()} className="w-full justify-center min-h-[48px]">
                  <Icon name="upload" cls="w-4 h-4"/>Upload photo of barcode
                </Button>
                <p className="text-[11px] text-center text-stone-400">
                  Scanner engine: <strong>{engine === 'native' ? 'native (fast)' : 'ZXing (universal)'}</strong>
                </p>
              </>
            ) : (
              <div className="text-sm text-amber-700 bg-amber-50 border border-amber-200 rounded-lg p-3">
                Your browser can't scan barcodes. The ZXing fallback failed to load — check your network and refresh, or just type the digits below.
              </div>
            )}
            <div className="text-xs text-center text-stone-400 py-1">— or —</div>
            <div className="flex gap-2">
              <Input placeholder="Type barcode (e.g. 0049000006346)" inputMode="numeric" value={barcode} onChange={e=>setBarcode(e.target.value)}/>
              <Button variant="outline" onClick={()=>doLookup(barcode)} disabled={!barcode || lookingUp}>
                {lookingUp ? '…' : 'Lookup'}
              </Button>
            </div>
          </div>
        ) : (
          <div className="space-y-2">
            <div className="aspect-[3/4] md:aspect-video bg-stone-900 rounded-lg overflow-hidden relative">
              <video ref={videoRef} className="w-full h-full object-cover" muted playsInline autoPlay/>
              {/* Scanning reticle — clearer than a single line */}
              <div className="absolute inset-0 pointer-events-none">
                <div className="absolute inset-x-8 top-1/4 bottom-1/4 border-2 border-brand-400/80 rounded-xl shadow-[0_0_0_9999px_rgba(0,0,0,0.45)]"></div>
                <div className="absolute inset-x-12 top-1/2 -translate-y-1/2 h-0.5 bg-brand-400 shadow-[0_0_8px_#cf8058] animate-pulse"></div>
                <div className="absolute top-3 left-0 right-0 text-center text-white text-xs font-medium drop-shadow">
                  Hold barcode in the box
                </div>
              </div>
            </div>
            <div className="flex gap-2">
              <Button variant="outline" onClick={stopCamera} className="flex-1 justify-center">Cancel</Button>
              <Button variant="outline" onClick={toggleTorch} className="px-4" title="Toggle torch">
                {torchOn ? '🔦 On' : '🔦'}
              </Button>
            </div>
          </div>
        )}
      </Card>
      )}

      {mode === 'barcode' && lookingUp && (
        <Card className="text-center py-6">
          <Icon name="refresh" cls="w-6 h-6 mx-auto animate-spin text-brand-500"/>
          <div className="text-sm text-stone-500 mt-2">Looking up {barcode}...</div>
        </Card>
      )}

      {mode === 'barcode' && notFound && (
        <NotFoundFallback
          barcode={barcode}
          onSave={(form) => saveBarcodeFallback(form)}
          onSwitchPhoto={() => setMode('photo')}
        />
      )}

      {mode === 'barcode' && product && (
        <Card>
          <div className="flex items-start gap-4">
            {product.image_url ? (
              <img src={product.image_url} alt="" className="w-24 h-24 rounded-lg object-contain bg-stone-50"/>
            ) : (
              <div className="w-24 h-24 rounded-lg bg-stone-100 flex items-center justify-center text-3xl">📦</div>
            )}
            <div className="flex-1 min-w-0">
              <div className="text-xs text-stone-500">{product.brand || '—'}</div>
              <div className="font-display text-xl">{product.name}</div>
              <div className="text-sm text-stone-500 mt-1">{product.qty || ''}</div>
              {product.nutrition_grade && <Badge tone={product.nutrition_grade==='a'||product.nutrition_grade==='b'?'leaf':product.nutrition_grade==='c'?'stone':'warn'}>Nutri-score {product.nutrition_grade.toUpperCase()}</Badge>}
              <div className="text-xs text-stone-400 mt-2">Barcode: {product.barcode}</div>
            </div>
          </div>

          <div className="mt-4 pt-4 border-t border-stone-100 grid grid-cols-1 md:grid-cols-3 gap-3">
            <div>
              <label className="text-xs text-stone-500">Link to canonical ingredient</label>
              <select value={matchedIngId} onChange={e=>setMatchedIngId(e.target.value)} className="w-full px-3 py-2 border border-stone-300 rounded-lg text-sm mt-1">
                <option value="">— custom name —</option>
                {ingredients.map(i => <option key={i.id} value={i.id}>{i.name}</option>)}
              </select>
            </div>
            <div>
              <label className="text-xs text-stone-500">Quantity</label>
              <Input type="number" value={qty} min="1" onChange={e=>setQty(Number(e.target.value)||1)} className="mt-1"/>
            </div>
            <div>
              <label className="text-xs text-stone-500">Expires in (days)</label>
              <Input type="number" value={expDays} min="1" onChange={e=>setExpDays(Number(e.target.value)||14)} className="mt-1"/>
            </div>
          </div>

          <div className="flex gap-2 mt-4">
            <Button onClick={addToPantry}><Icon name="plus" cls="w-4 h-4"/>Add to pantry</Button>
            <Button variant="outline" onClick={()=>{setProduct(null);setBarcode('');}}>Scan another</Button>
          </div>
        </Card>
      )}
    </div>
  );
}

function NotFoundFallback({ barcode, onSave, onSwitchPhoto }) {
  const [name, setName] = React.useState('');
  const [isNonFood, setIsNonFood] = React.useState(true); // OFF miss usually means non-food
  const [location, setLocation] = React.useState('non_food');
  const [qty, setQty] = React.useState(1);
  const [unit, setUnit] = React.useState('unit');
  const [restock, setRestock] = React.useState('');
  const [expDays, setExpDays] = React.useState(180);
  const [error, setError] = React.useState('');

  const submit = () => {
    if (!name.trim()) { setError('Name required'); return; }
    onSave({
      barcode,
      name: name.trim(),
      is_non_food: isNonFood,
      location: isNonFood ? 'non_food' : location,
      qty: Math.max(1, Number(qty) || 1),
      unit: unit || 'unit',
      restock_threshold: restock === '' ? null : Math.max(0, Number(restock) || 0),
      exp_days: Math.max(1, Number(expDays) || 180),
    });
  };

  return (
    <Card className="border-amber-200 bg-amber-50/30">
      <div className="flex items-start gap-3 mb-3">
        <Icon name="alert" cls="w-5 h-5 text-amber-600 mt-0.5"/>
        <div>
          <div className="font-medium">Not in food database</div>
          <div className="text-sm text-stone-600 mt-1">
            Barcode <code className="bg-white px-1 rounded">{barcode}</code> probably isn't food.
            Save it as a household item and Kitchen Agent will recognize it instantly next time you scan.
          </div>
        </div>
      </div>
      <div className="grid grid-cols-1 md:grid-cols-2 gap-3 mt-3">
        <div className="md:col-span-2">
          <label className="text-xs text-stone-500 uppercase tracking-wide">Item name</label>
          <Input value={name} onChange={e => { setName(e.target.value); setError(''); }}
            placeholder="e.g. Toilet paper, dish soap, air filter, batteries" autoFocus className="mt-1"/>
        </div>
        <div className="md:col-span-2 flex items-center gap-2">
          <input type="checkbox" id="ka-isnonfood" checked={isNonFood}
            onChange={e => { setIsNonFood(e.target.checked); if (e.target.checked) setLocation('non_food'); else setLocation('pantry'); }}
            className="w-4 h-4 accent-brand-500"/>
          <label htmlFor="ka-isnonfood" className="text-sm">This is a household / non-food item</label>
        </div>
        {!isNonFood && (
          <div>
            <label className="text-xs text-stone-500">Storage</label>
            <select value={location} onChange={e => setLocation(e.target.value)}
              className="w-full px-3 py-2 border border-stone-300 rounded-lg text-sm mt-1">
              <option value="pantry">Pantry</option>
              <option value="fridge">Fridge</option>
              <option value="freezer">Freezer</option>
            </select>
          </div>
        )}
        <div>
          <label className="text-xs text-stone-500">Quantity</label>
          <Input type="number" min="1" value={qty} onChange={e => setQty(e.target.value)} className="mt-1"/>
        </div>
        <div>
          <label className="text-xs text-stone-500">Unit</label>
          <Input value={unit} onChange={e => setUnit(e.target.value)} placeholder="unit / pack / oz" className="mt-1"/>
        </div>
        <div>
          <label className="text-xs text-stone-500">Restock when at or below (optional)</label>
          <Input type="number" min="0" value={restock} onChange={e => setRestock(e.target.value)} placeholder="off" className="mt-1"/>
        </div>
        {!isNonFood && (
          <div>
            <label className="text-xs text-stone-500">Expires in (days)</label>
            <Input type="number" min="1" value={expDays} onChange={e => setExpDays(e.target.value)} className="mt-1"/>
          </div>
        )}
      </div>
      {error && <div className="text-xs text-red-600 mt-2">{error}</div>}
      <div className="flex gap-2 mt-4">
        <Button onClick={submit}><Icon name="plus" cls="w-4 h-4"/>Add &amp; remember this barcode</Button>
        <Button variant="outline" onClick={onSwitchPhoto}>Try OCR mode</Button>
      </div>
      <p className="text-[11px] text-stone-500 mt-2">
        We&apos;ll save the barcode → item mapping locally. Future scans of this product auto-fill.
      </p>
    </Card>
  );
}

K.ScanItem = ScanItem;
</script>

<!-- =============== SCAN RECEIPT (OCR) =============== -->
<script type="text/babel" data-type="module">
const { useState, useRef } = React;
const K = window.__KA;
const { Icon, Card, Section, Button, Badge, Chip, Input, useApp, OCR, fmt$, Pricing } = K;

// Parse a Tesseract text blob into line items
function parseReceiptLines(text, ingredients){
  const lines = text.split('\n').map(l => l.trim()).filter(Boolean);
  const items = [];
  const ingByLower = {};
  ingredients.forEach(i => { ingByLower[i.name.toLowerCase()] = i; });
  // Patterns: "ITEM NAME 4.99" or "ITEM NAME  $4.99" or "ITEM NAME   4.99 F"
  const priceRe = /(\$?\s*\d+\.\d{2})\s*[A-Z]?$/;
  for (const raw of lines) {
    const m = raw.match(priceRe);
    if (!m) continue;
    const priceStr = m[1].replace(/[$\s]/g,'');
    const price = parseFloat(priceStr);
    if (isNaN(price) || price < 0.10 || price > 500) continue;
    let name = raw.slice(0, raw.length - m[0].length).trim();
    name = name.replace(/\s*\d+\s*@\s*\d+\.\d+\s*$/, ''); // strip "2 @ 1.99"
    name = name.replace(/\s{2,}/g, ' ');
    // Skip totals / subtotals / tax
    if (/^(total|subtotal|tax|change|cash|balance|tender|auth|debit|credit|savings|discount|coupon|thank|customer|purchase|store|items?\s+sold)/i.test(name)) continue;
    if (name.length < 2) continue;
    // Try to match ingredient
    let matched = null;
    const lower = name.toLowerCase();
    for (const [iname, ing] of Object.entries(ingByLower)) {
      if (lower.includes(iname)) { matched = ing; break; }
    }
    items.push({
      id: crypto.randomUUID(),
      raw_name: name,
      price,
      qty: 1,
      matched_ingredient_id: matched?.id || '',
      matched_ingredient_name: matched?.name || '',
      include: true,
    });
  }
  return items;
}

function ScanReceipt(){
  const { data, state, setKey, go, notify } = useApp();
  const { ingredients } = data;
  const [imageUrl, setImageUrl] = useState(null);
  const [working, setWorking] = useState(false);
  const [progress, setProgress] = useState({status:'idle', pct:0});
  const [rawText, setRawText] = useState('');
  const [items, setItems] = useState([]);
  const [store, setStore] = useState('walmart');
  const fileRef = useRef(null);

  const onFile = (f) => {
    if (!f) return;
    const url = URL.createObjectURL(f);
    setImageUrl(url);
    runOCR(f);
  };

  // Detect the store from the first few lines of OCR text (headers usually have the chain name).
  const detectStore = (text) => {
    const upper = (text || '').toUpperCase();
    const head = upper.split('\n').slice(0, 12).join('\n'); // most receipts have store name in first ~12 lines
    const map = [
      [/WAL[- ]?MART|WALMART/,                  'walmart'],
      [/\bALDI\b/,                              'aldi'],
      [/PUBLIX/,                                'instacart_publix'],
      [/KROGER|HARRIS\s*TEETER|FRED\s*MEYER/,   'instacart_kroger'],
      [/SPROUTS/,                               'sprouts'],
      [/TARGET/,                                'target'],
      [/TRADER\s*JOE/,                          'trader_joes'],
      [/WHOLE\s*FOODS/,                         'whole_foods'],
      [/COSTCO/,                                'costco'],
      [/SAFEWAY|ALBERTSONS/,                    'safeway'],
      [/H[- ]?E[- ]?B/,                         'heb'],
      [/MEIJER/,                                'meijer'],
    ];
    for (const [re, sid] of map) {
      if (re.test(head)) {
        // Confirm the store id exists in our data; otherwise skip.
        if (data.stores.some(s => s.id === sid)) return sid;
      }
    }
    return null;
  };

  const runOCR = async (f) => {
    setWorking(true); setItems([]); setRawText('');
    try {
      const result = await OCR.recognize(f, (m) => {
        if (m.status && m.progress !== undefined) {
          setProgress({ status: m.status, pct: Math.round(m.progress*100) });
        }
      });
      const text = result.text || '';
      setRawText(text);
      // Auto-pick the store from the receipt header if we recognize it
      const detected = detectStore(text);
      if (detected && detected !== store) {
        setStore(detected);
        const chain = data.stores.find(s => s.id === detected)?.chain || detected;
        notify(`Detected store: ${chain}`, 'info');
      }
      const parsed = parseReceiptLines(text, ingredients);
      setItems(parsed);
      if (parsed.length === 0) {
        notify('No items detected. Try a clearer photo or edit manually below.', 'info');
      } else {
        notify(`Extracted ${parsed.length} items from receipt`, 'success');
      }
    } catch (e) {
      notify('OCR error: '+e.message, 'error');
    } finally {
      setWorking(false);
      setProgress({status:'idle', pct:0});
    }
  };

  const toggleInclude = (id) => setItems(it => it.map(x => x.id===id ? {...x, include: !x.include} : x));
  const updateField = (id, field, v) => setItems(it => it.map(x => x.id===id ? {...x, [field]: v} : x));
  const removeRow = (id) => setItems(it => it.filter(x => x.id !== id));

  const saveSelected = () => {
    const selected = items.filter(i => i.include);
    if (selected.length === 0) { notify('Select at least one item', 'error'); return; }
    const newPantry = [...state.pantry];
    let pricesLearned = 0;
    selected.forEach(it => {
      const ing = ingredients.find(i => i.id === it.matched_ingredient_id);
      const name = ing?.name || it.raw_name;
      const unit = ing?.default_unit || 'each';
      newPantry.push({
        id: crypto.randomUUID(),
        ingredient_id: it.matched_ingredient_id || null,
        name,
        qty: it.qty,
        unit,
        expires_at: new Date(Date.now() + 14*86400000).toISOString(),
        added_at: new Date().toISOString(),
        source: 'receipt_scan',
        purchase_price: it.price,
      });
      // RECEIPT-LEARNED PRICING — capture pack price for canonical matches.
      // The receipt line price IS the pack price (what they paid for one shopping unit).
      // uses_per_pack defaults to whatever's already in the override (or 1) — we don't
      // know recipe-uses-per-pack from a receipt, so we keep any prior estimate.
      if (it.matched_ingredient_id && it.price > 0) {
        const prior = Pricing.get(it.matched_ingredient_id, store);
        Pricing.set(it.matched_ingredient_id, store, {
          pack_size: prior?.pack_size || 1,
          pack_unit: prior?.pack_unit || ing?.default_unit || 'each',
          pack_price: Number((it.price / Math.max(1, it.qty)).toFixed(2)),
          uses_per_pack: prior?.uses_per_pack || 1,
          sale_pack_price: null,
        }, 'receipt_learned');
        pricesLearned++;
      }
    });
    setKey('pantry', newPantry);

    // Also record the order
    const order = {
      id: crypto.randomUUID(),
      store_id: store,
      items: selected.map(i => ({ name: i.raw_name, qty: i.qty, price: i.price, ingredient_id: i.matched_ingredient_id })),
      total: Number(selected.reduce((s,i) => s + i.price*i.qty, 0).toFixed(2)),
      status: 'picked_up',
      created_at: new Date().toISOString(),
      scheduled_at: new Date().toISOString(),
      fulfillment: 'pickup',
      source: 'receipt_scan',
    };
    setKey('orders', [...state.orders, order]);
    notify(
      `Added ${selected.length} items to pantry${pricesLearned ? ` · learned ${pricesLearned} ${store} price${pricesLearned===1?'':'s'}` : ''}`,
      'success'
    );
    go('pantry');
  };

  const total = items.filter(i => i.include).reduce((s,i) => s + i.price*i.qty, 0);

  return (
    <div className="space-y-6 fade-in">
      <div>
        <h1 className="font-display text-3xl md:text-4xl">Scan receipt</h1>
        <p className="text-sm text-stone-600 mt-1">Photo → Tesseract.js OCR → parsed line items → auto-pantry.</p>
      </div>

      <Card>
        <div className="flex gap-2 flex-wrap">
          <label className="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-medium bg-brand-500 text-white hover:bg-brand-600 cursor-pointer">
            <Icon name="camera" cls="w-4 h-4"/>Take / upload photo
            <input ref={fileRef} type="file" accept="image/*" capture="environment" className="hidden" onChange={e=>onFile(e.target.files?.[0])}/>
          </label>
          <div className="flex-1 flex items-center gap-2">
            <label className="text-xs text-stone-500">From store:</label>
            <select value={store} onChange={e=>setStore(e.target.value)} className="px-3 py-2 border border-stone-300 rounded-lg text-sm">
              {data.stores.map(s => <option key={s.id} value={s.id}>{s.chain}</option>)}
            </select>
          </div>
        </div>

        {imageUrl && (
          <div className="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
            <img src={imageUrl} alt="" className="max-h-64 object-contain rounded-lg border border-stone-200 bg-stone-50"/>
            <div className="text-xs text-stone-500">
              {working ? (
                <div>
                  <div className="mb-2">Running OCR... {progress.status} {progress.pct}%</div>
                  <div className="w-full bg-stone-100 rounded-full h-2">
                    <div className="bg-brand-500 h-2 rounded-full transition-all" style={{width: `${progress.pct}%`}}></div>
                  </div>
                </div>
              ) : (
                <>Extracted {items.length} items · {fmt$(total)} total</>
              )}
            </div>
          </div>
        )}
      </Card>

      {items.length > 0 && (
        <Section title="Extracted items" action={
          <Button variant="leaf" onClick={saveSelected}><Icon name="save" cls="w-4 h-4"/>Save {items.filter(i=>i.include).length} to pantry</Button>
        }>
          <Card>
            <div className="hidden md:grid grid-cols-12 text-xs uppercase text-stone-500 pb-2 border-b border-stone-200 gap-2">
              <div className="col-span-1">Use</div>
              <div className="col-span-4">Name (raw)</div>
              <div className="col-span-3">Match</div>
              <div className="col-span-1">Qty</div>
              <div className="col-span-2">Price</div>
              <div className="col-span-1"></div>
            </div>
            {items.map(it => (
              <div key={it.id} className="grid grid-cols-12 gap-2 py-2 border-b border-stone-100 items-center">
                <div className="col-span-2 md:col-span-1"><input type="checkbox" checked={it.include} onChange={()=>toggleInclude(it.id)} className="w-4 h-4"/></div>
                <div className="col-span-10 md:col-span-4 text-sm">
                  <Input value={it.raw_name} onChange={e=>updateField(it.id,'raw_name',e.target.value)}/>
                </div>
                <div className="col-span-6 md:col-span-3">
                  <select value={it.matched_ingredient_id} onChange={e=>updateField(it.id,'matched_ingredient_id',e.target.value)} className="w-full px-2 py-1.5 text-xs border border-stone-300 rounded">
                    <option value="">— custom —</option>
                    {ingredients.map(i => <option key={i.id} value={i.id}>{i.name}</option>)}
                  </select>
                </div>
                <div className="col-span-2 md:col-span-1"><Input type="number" value={it.qty} min="1" onChange={e=>updateField(it.id,'qty',Number(e.target.value)||1)}/></div>
                <div className="col-span-3 md:col-span-2"><Input type="number" value={it.price} step="0.01" onChange={e=>updateField(it.id,'price',Number(e.target.value)||0)}/></div>
                <div className="col-span-1 text-right"><button onClick={()=>removeRow(it.id)} className="text-stone-400 hover:text-red-500"><Icon name="trash" cls="w-4 h-4"/></button></div>
              </div>
            ))}
            <div className="flex justify-between items-center pt-3 text-sm">
              <div className="text-stone-500">{items.filter(i=>i.include).length} of {items.length} selected</div>
              <div className="font-display text-xl">{fmt$(total)}</div>
            </div>
          </Card>
        </Section>
      )}

      {rawText && (
        <details className="text-sm">
          <summary className="text-stone-500 cursor-pointer hover:text-stone-700">View raw OCR text</summary>
          <pre className="mt-2 bg-stone-50 border border-stone-200 rounded p-3 text-xs whitespace-pre-wrap">{rawText}</pre>
        </details>
      )}
    </div>
  );
}

K.ScanReceipt = ScanReceipt;
</script>

