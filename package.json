<script type="text/babel" data-type="module">
const { useMemo } = React;
const K = window.__KA;
const { Icon, Card, Section, Button, Badge, useApp, fmt$ } = K;

function Orders(){
  const { state, setKey, data, go, notify } = useApp();
  const storesById = useMemo(()=>Object.fromEntries(data.stores.map(s => [s.id, s])),[data.stores]);

  const sorted = useMemo(() => {
    return state.orders.slice().sort((a,b) => new Date(b.scheduled_at||b.created_at) - new Date(a.scheduled_at||a.created_at));
  }, [state.orders]);

  const advance = (id) => {
    const flow = ['scheduled','preparing','ready','picked_up'];
    setKey('orders', state.orders.map(o => {
      if (o.id !== id) return o;
      const i = flow.indexOf(o.status);
      if (i < 0 || i >= flow.length-1) return o;
      return {...o, status: flow[i+1]};
    }));
  };
  const cancel = (id) => {
    if (!confirm('Cancel this order?')) return;
    setKey('orders', state.orders.map(o => o.id === id ? {...o, status:'cancelled'} : o));
  };
  const remove = (id) => {
    if (!confirm('Remove this order from history?')) return;
    setKey('orders', state.orders.filter(o => o.id !== id));
  };

  const statusTone = { scheduled:'brand', preparing:'warn', ready:'leaf', picked_up:'stone', cancelled:'red' };

  return (
    <div className="space-y-6 fade-in">
      <div className="flex items-end justify-between flex-wrap gap-2">
        <div>
          <h1 className="font-display text-3xl md:text-4xl">Orders</h1>
          <p className="text-sm text-stone-600 mt-1">{sorted.filter(o=>o.status!=='picked_up'&&o.status!=='cancelled').length} active · {sorted.length} total</p>
        </div>
        <Button variant="outline" onClick={()=>go('shop')}>Start a new order</Button>
      </div>

      {sorted.length === 0 ? (
        <Card className="text-center py-10">
          <div className="text-5xl mb-3">📦</div>
          <h3 className="font-display text-xl mb-2">No orders yet</h3>
          <p className="text-sm text-stone-600 mb-4">Shop for planned meals or scan a receipt to log a past order.</p>
          <div className="flex gap-2 justify-center flex-wrap">
            <Button onClick={()=>go('shop')}><Icon name="cart" cls="w-4 h-4"/>Shop</Button>
            <Button variant="outline" onClick={()=>go('scanReceipt')}><Icon name="receipt" cls="w-4 h-4"/>Log past receipt</Button>
          </div>
        </Card>
      ) : (
        <div className="space-y-3">
          {sorted.map(o => {
            const s = storesById[o.store_id];
            const when = new Date(o.scheduled_at || o.created_at);
            const isActive = o.status !== 'picked_up' && o.status !== 'cancelled';
            return (
              <Card key={o.id} className={isActive?'':'opacity-80'}>
                <div className="flex items-start gap-3 flex-wrap">
                  <div className="text-3xl">{s?.logo || '🛍️'}</div>
                  <div className="flex-1 min-w-[200px]">
                    <div className="flex items-center gap-2 flex-wrap">
                      <div className="font-medium">{s?.chain || o.store_id}</div>
                      <Badge tone={statusTone[o.status]||'stone'}>{o.status.replace('_',' ')}</Badge>
                      <Badge tone="stone">{o.fulfillment}</Badge>
                      {o.source === 'receipt_scan' && <Badge tone="stone">from receipt</Badge>}
                    </div>
                    <div className="text-xs text-stone-500 mt-1">
                      {when.toLocaleDateString()} · {when.toLocaleTimeString([],{hour:'numeric',minute:'2-digit'})}
                      {o.route?.detour_min != null && ` · +${o.route.detour_min} min detour`}
                    </div>
                    {o.items?.length > 0 && (
                      <details className="mt-2 text-sm">
                        <summary className="text-stone-600 cursor-pointer hover:text-stone-900">{o.items.length} items</summary>
                        <ul className="mt-1 pl-4 text-stone-600 list-disc text-xs">
                          {o.items.map((it,i) => <li key={i}>{it.qty||1}× {it.name}{it.price?` — ${fmt$(it.price)}`:''}</li>)}
                        </ul>
                      </details>
                    )}
                  </div>
                  <div className="text-right">
                    <div className="font-display text-xl">{fmt$(o.total)}</div>
                    <div className="flex gap-1 mt-2">
                      {isActive && <Button variant="outline" onClick={()=>advance(o.id)}>{o.status==='scheduled'?'Mark preparing':o.status==='preparing'?'Mark ready':'Mark picked up'}</Button>}
                      {isActive && <Button variant="ghost" onClick={()=>cancel(o.id)}>Cancel</Button>}
                      {!isActive && <Button variant="ghost" onClick={()=>remove(o.id)}><Icon name="trash" cls="w-4 h-4"/></Button>}
                    </div>
                  </div>
                </div>
              </Card>
            );
          })}
        </div>
      )}
    </div>
  );
}

K.Orders = Orders;
</script>

