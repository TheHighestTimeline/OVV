}
function Input(props){
  return <input {...props} className={'w-full px-3 py-2 border border-stone-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:outline-none text-sm '+(props.className||'')} />;
}
function LoadingPlaceholder(){
