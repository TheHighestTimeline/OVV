function migratePlan(raw){
  // Old shape: { '2026-04-23': 'recipeId' }
  // New shape: { '2026-04-23': { breakfast:id, lunch:id, dinner:id, snack:id } }
  if (!raw || typeof raw !== 'object') return {};
  const out = {};
  Object.entries(raw).forEach(([k,v]) => {
    if (typeof v === 'string') {
      out[k] = { dinner: v };              // legacy value went into dinner slot
    } else if (v && typeof v === 'object') {
      out[k] = { ...v };
    }
  });
  return out;
}

function initialState(data){
  const rawProfile = store.get('profile', DEFAULT_PROFILE);
  const profile = { ...DEFAULT_PROFILE, ...rawProfile };
  // Grandfather existing users — if they have any prior data, they've already
  // used the app and shouldn't see onboarding.
  if (profile.onboarded === undefined) {
    const hasData = store.get('pantry', []).length > 0
                 || Object.keys(store.get('plan', {})).length > 0
                 || store.get('orders', []).length > 0
                 || store.get('cookHistory', []).length > 0;
    profile.onboarded = hasData;
  }
  return {
    profile,
    pantry: migratePantry(store.get('pantry', seedPantry(data))),
    plan: migratePlan(store.get('plan', {})),
    orders: store.get('orders', []),
    shoppingExtras: store.get('shoppingExtras', []),
    cookedMarks: store.get('cookedMarks', {}),
    // v9: new stores
    leftovers: store.get('leftovers', []),         // [{id, recipe_id, name, servings, created_at, eat_by, status}]
    cookHistory: store.get('cookHistory', []),     // [{id, recipe_id, recipe_name, date, rating, photo_data_url, servings_made, leftovers_kept, est_cost}]
    purchaseHistory: store.get('purchaseHistory', []), // [{id, date, items:[{name,qty,cost,store,aisle}], total_cost, store, method}]
    wasteLog: store.get('wasteLog', []),           // [{id, item_name, qty, date, reason}]
  };
}

// v9: ensure pantry items have storage location + restock fields
function migratePantry(rawPantry) {
  if (!Array.isArray(rawPantry)) return [];
  return rawPantry.map(p => ({
    ...p,
    location: p.location || 'pantry',
    is_staple: p.is_staple || false,
    restock_threshold: typeof p.restock_threshold === 'number' ? p.restock_threshold : null,
    is_non_food: p.is_non_food || false,
  }));
}

function seedPantry(data){
  // Start with ~20 common items so pantry isn't empty
  const picks = ['salt','pepper','olive_oil','garlic','onion','chicken_breast','rice_white',
    'pasta_spaghetti','eggs','butter','soy_sauce','paprika','garlic_powder','honey','cumin',
    'oregano','cilantro','lemon','flour','sugar'];
  const now = Date.now();
  return picks.map(id => {
    const ing = data.ingredients.find(i => i.id===id);
    if (!ing) return null;
    const expDays = Math.floor(Math.random()*40)+10;
    return {
      id: crypto.randomUUID(),
      ingredient_id: id,
      name: ing.name,
      qty: Math.round(Math.random()*3+1),
      unit: ing.default_unit,
      expires_at: new Date(now + expDays*86400000).toISOString(),
      added_at: new Date(now - Math.random()*14*86400000).toISOString(),
    };
  }).filter(Boolean);
}

function reducer(state, action){
  switch(action.type){
    case 'SET': return { ...state, [action.key]: action.value };
    case 'RESET': return action.state;
    default: return state;
  }
}

