/* =====================================================================
   USER PICKER — first-run identity selection
   ===================================================================== */
function UserPicker({ onChosen }){
  const [users, setUsers] = useState(null);
  const [name, setName] = useState('');
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState(null);

  useEffect(() => {
    Cloud.listUsers()
      .then(u => setUsers(u))
      .catch(e => { setError(e.message); setUsers([]); });
  }, []);

  const createNew = async () => {
    if (!name.trim()) { setError('Enter a name'); return; }
    setLoading(true); setError(null);
    try {
      const id = Cloud.newUserId();
      await onChosen(id, name.trim());
    } catch (e) {
      setError(e.message);
      setLoading(false);
    }
  };

  const pickExisting = async (u) => {
    setLoading(true); setError(null);
    try { await onChosen(u.id, u.name); }
    catch (e) { setError(e.message); setLoading(false); }
  };

  return (
    <div style={{minHeight:'100vh', background:'#f9fafb', display:'flex', alignItems:'center', justifyContent:'center', padding:'1.5rem'}}>
      <div style={{background:'#fff', borderRadius:'1rem', boxShadow:'0 4px 24px rgba(0,0,0,0.08)', padding:'2rem', maxWidth:'420px', width:'100%'}}>
        <h1 style={{fontSize:'1.5rem', fontWeight:700, marginBottom:'0.25rem'}}>Welcome to Kitchen Agent</h1>
        <p style={{color:'#6b7280', fontSize:'0.9rem', marginBottom:'1.5rem'}}>Pick who you are so your pantry, plan, and recipes sync to your account.</p>

        {users === null && <div style={{color:'#6b7280'}}>Loading…</div>}

        {users && users.length > 0 && (
          <div style={{marginBottom:'1.5rem'}}>
            <div style={{fontSize:'0.85rem', fontWeight:600, color:'#374151', marginBottom:'0.5rem'}}>Existing users</div>
            <div style={{display:'flex', flexDirection:'column', gap:'0.5rem'}}>
              {users.map(u => (
                <button key={u.id} onClick={() => pickExisting(u)} disabled={loading}
                  style={{textAlign:'left', padding:'0.75rem 1rem', border:'1px solid #e5e7eb', borderRadius:'0.5rem', background:'#fff', cursor:'pointer', fontSize:'0.95rem'}}>
                  {u.name}
                </button>
              ))}
            </div>
            <div style={{margin:'1.25rem 0 0.75rem', textAlign:'center', color:'#9ca3af', fontSize:'0.8rem'}}>or create new</div>
          </div>
        )}

        {users && (
          <>
            <input
              type="text" value={name} onChange={e => setName(e.target.value)}
              placeholder="Your name (e.g. Tanner)" disabled={loading}
              onKeyDown={e => { if (e.key === 'Enter') createNew(); }}
              style={{width:'100%', padding:'0.75rem 1rem', border:'1px solid #d1d5db', borderRadius:'0.5rem', fontSize:'0.95rem', marginBottom:'0.75rem', boxSizing:'border-box'}}
            />
            <button onClick={createNew} disabled={loading || !name.trim()}
              style={{width:'100%', padding:'0.75rem', background:'#059669', color:'#fff', border:'none', borderRadius:'0.5rem', fontSize:'0.95rem', fontWeight:600, cursor: loading ? 'wait' : 'pointer', opacity: (!name.trim() || loading) ? 0.5 : 1}}>
              {loading ? 'Setting up…' : 'Continue'}
            </button>
          </>
        )}

        {error && <div style={{marginTop:'1rem', padding:'0.75rem', background:'#fef2f2', color:'#991b1b', borderRadius:'0.5rem', fontSize:'0.85rem'}}>{error}</div>}
      </div>
    </div>
  );
}

/* ─────────────────────────────────────────────────────────────────────────
   ONBOARDING WIZARD — three-step first-run flow.
   1) Welcome  2) Anthropic key (skippable)  3) Pick preferred stores.
   ───────────────────────────────────────────────────────────────────────── */
function OnboardingWizard({ onDone }){
  const { data, state } = useApp();
  const [step, setStep] = useState(0);
  const [name, setName] = useState(state.profile.name || '');
  const [apiKey, setApiKey] = useState(Claude.getKey());
  const [keyState, setKeyState] = useState({ state:'idle', msg:'' });
  const [stores, setStores] = useState(new Set(state.profile.preferred_stores || []));
  const [skipping, setSkipping] = useState(false);

  const testKey = async () => {
    if (!apiKey.trim()) return;
    Claude.setKey(apiKey);
    setKeyState({ state:'testing', msg:'Testing…' });
    try {
      const res = await fetch(Claude.ENDPOINT, {
        method:'POST',
        headers:{
          'content-type':'application/json',
          'x-api-key': apiKey,
          'anthropic-version':'2023-06-01',
          'anthropic-dangerous-direct-browser-access':'true',
        },
        body: JSON.stringify({ model: Claude.MODEL, max_tokens: 10, messages:[{ role:'user', content:'ok' }] }),
      });
      if (!res.ok) {
        const j = await res.json().catch(()=>({}));
        setKeyState({ state:'err', msg: j?.error?.message || `HTTP ${res.status}` });
        return;
      }
      setKeyState({ state:'ok', msg:'Connected ✓' });
    } catch (e) { setKeyState({ state:'err', msg: e.message }); }
  };

  const toggleStore = (id) => {
    const next = new Set(stores);
    if (next.has(id)) next.delete(id); else next.add(id);
    setStores(next);
  };

  const finish = () => {
    if (apiKey && apiKey !== Claude.getKey()) Claude.setKey(apiKey);
    onDone({ name: name || 'Cook', preferred_stores: Array.from(stores) });
  };

  const next = () => setStep(s => s + 1);
  const back = () => setStep(s => Math.max(0, s - 1));

  return (
    <div className="min-h-screen flex flex-col items-center justify-center p-6 bg-gradient-to-br from-brand-50 via-white to-leaf-500/5">
      <div className="max-w-md w-full bg-white rounded-2xl shadow-2xl p-6 md:p-8 fade-in">
        {/* Progress dots */}
        <div className="flex items-center justify-center gap-2 mb-6">
          {[0,1,2].map(i => (
            <div key={i} className={'h-2 rounded-full transition-all ' + (i === step ? 'w-8 bg-brand-500' : i < step ? 'w-2 bg-brand-300' : 'w-2 bg-stone-200')}/>
          ))}
        </div>

        {step === 0 && (
          <div className="space-y-5">
            <div className="text-center">
              <div className="text-5xl mb-3">🍳</div>
              <h1 className="font-display text-3xl">Welcome to Kitchen Agent</h1>
              <p className="text-sm text-stone-600 mt-2">Plan meals, scan groceries, track your pantry — built for daily kitchen use.</p>
            </div>
            <div>
              <label className="text-xs text-stone-500 uppercase tracking-wide">What should we call you?</label>
              <Input value={name} onChange={e=>setName(e.target.value)} placeholder="Your name" autoFocus className="mt-1"/>
            </div>
            <Button onClick={next} disabled={!name.trim()} className="w-full justify-center min-h-[48px]">Get started →</Button>
          </div>
        )}

        {step === 1 && (
          <div className="space-y-5">
            <div className="text-center">
              <div className="text-5xl mb-3">✨</div>
              <h2 className="font-display text-2xl">Unlock the AI features</h2>
              <p className="text-sm text-stone-600 mt-2">
                Add your Anthropic API key to enable voice-to-pantry, photo item identification,
                recipe import from any URL, "what can I cook?", and realistic store prices.
              </p>
            </div>
            <div>
              <label className="text-xs text-stone-500 uppercase tracking-wide">Anthropic API key</label>
              <Input type="password" value={apiKey} onChange={e => { setApiKey(e.target.value); setKeyState({state:'idle',msg:''}); }} placeholder="sk-ant-api03-…" className="mt-1"/>
              <div className="flex items-center gap-2 mt-2 flex-wrap">
                <Button variant="outline" onClick={testKey} disabled={!apiKey.trim() || keyState.state==='testing'} className="text-xs px-3">
                  {keyState.state==='testing' ? 'Testing…' : 'Test'}
                </Button>
                <a className="text-xs text-brand-600 hover:underline" href="https://console.anthropic.com/settings/keys" target="_blank">Get a key →</a>
                {keyState.state==='ok'  && <span className="text-xs text-leaf-700">✓ {keyState.msg}</span>}
                {keyState.state==='err' && <span className="text-xs text-red-600">✗ {keyState.msg}</span>}
              </div>
              <p className="text-[11px] text-stone-500 mt-3">
                Stored only in your browser. Requests go directly to Anthropic's API.
              </p>
            </div>
            <div className="flex gap-2">
              <Button variant="outline" onClick={back} className="flex-1 justify-center">Back</Button>
              <Button onClick={next} className="flex-1 justify-center">
                {apiKey.trim() ? 'Next →' : 'Skip for now →'}
              </Button>
            </div>
          </div>
        )}

        {step === 2 && (
          <div className="space-y-5">
            <div className="text-center">
              <div className="text-5xl mb-3">🛒</div>
              <h2 className="font-display text-2xl">Where do you shop?</h2>
              <p className="text-sm text-stone-600 mt-2">Pick the stores you actually use — they'll show first in routing and pricing.</p>
            </div>
            <div className="grid grid-cols-2 gap-2">
              {data.stores.map(s => (
                <button key={s.id} onClick={() => toggleStore(s.id)}
                  className={'px-3 py-3 rounded-lg text-sm border min-h-[48px] flex items-center gap-2 ' +
                    (stores.has(s.id) ? 'bg-brand-500 text-white border-brand-500' : 'bg-white text-stone-700 border-stone-300 hover:bg-stone-50')}>
                  <span className="text-lg">{s.logo}</span>
                  <span className="truncate">{s.chain}</span>
                </button>
              ))}
            </div>
            <p className="text-[11px] text-stone-500 text-center">You can change these anytime in Settings.</p>
            <div className="flex gap-2">
              <Button variant="outline" onClick={back} className="flex-1 justify-center">Back</Button>
              <Button onClick={finish} className="flex-1 justify-center min-h-[48px]">
                <Icon name="check" cls="w-4 h-4"/>Let's cook
              </Button>
            </div>
          </div>
        )}
      </div>
      <button onClick={() => onDone({ name: 'Cook', preferred_stores: [] })}
        className="mt-4 text-xs text-stone-400 hover:text-stone-600 underline">
        Skip setup
      </button>
    </div>
  );
}

function App({data: initialData}){
  // v16: keep data in state so new recipes added via KA_addRecipe (Claude plans, imports)
  // are visible immediately without a page refresh.
  const [data, setData] = useState(initialData);
  const [state, dispatch] = useReducer(reducer, null, () => initialState(initialData));
  const [view, setView] = useState(store.get('view','dashboard'));
  const [viewArg, setViewArg] = useState(null);
  const [banner, setBanner] = useState(null);

  // --- Cloud sync boot ---
  const [cloudReady, setCloudReady] = useState(false);
  const [needsUser, setNeedsUser] = useState(false);

  useEffect(() => {
    let cancelled = false;
    (async () => {
      const ok = await Cloud.init();
      if (cancelled) return;
      if (!ok) {
        // Airtable disabled (no env vars or offline) — proceed local-only.
        setCloudReady(true);
        return;
      }
      // Need a user identity before we can pull/push.
      if (!Cloud.getUserId()) {
        setNeedsUser(true);
        return; // wait for user to pick/create identity
      }
      try {
        await Cloud.ensureUser(Cloud.getUserName());
        await Cloud.pullAll();
        // Reload state from (possibly updated) localStorage
        dispatch({ type: 'RESET', state: initialState(data) });
      } catch (e) {
        console.warn('[Cloud] boot pull failed:', e.message);
      }
      setCloudReady(true);
    })();
    return () => { cancelled = true; };
  }, []);

  // After user picks identity, finish boot
  const onUserChosen = async (userId, userName) => {
    Cloud.setUser(userId, userName);
    setNeedsUser(false);
    try {
      await Cloud.ensureUser(userName);
      await Cloud.pullAll();
      dispatch({ type: 'RESET', state: initialState(data) });
    } catch (e) {
      console.warn('[Cloud] post-pick pull failed:', e.message);
    }
    setCloudReady(true);
  };

  // --- localStorage writes (existing) + cloud push (new) ---
  // Bridge: vanilla-JS Claude modal can write to localStorage and dispatch this event
  // to make React reload state (used for ✨ Claude Plan "Add to Plan" / "Swap").
  // v16: also pulls fresh recipes from __KA_DATA so newly-added Claude recipes show up.
  useEffect(() => {
    const handler = () => {
      try {
        // Refresh data prop (new recipes are pushed onto __KA_DATA.recipes by KA_addRecipe).
        if (window.__KA_DATA) {
          setData({
            ...window.__KA_DATA,
            recipes: [...window.__KA_DATA.recipes],
          });
        }
        dispatch({ type: 'RESET', state: initialState(data) });
      } catch(e) { console.warn(e); }
    };
    window.addEventListener('kitchenagent:reload', handler);
    return () => window.removeEventListener('kitchenagent:reload', handler);
  }, [data]);

  // Fire daily-batched notifications for expiring items + leftovers on boot
  useEffect(() => { try { Notifs.checkAndFire(state); } catch {} }, []); // eslint-disable-line react-hooks/exhaustive-deps

  useEffect(()=> { store.set('profile', state.profile); if (cloudReady) Cloud.pushKey('profile', state.profile); }, [state.profile, cloudReady]);
  useEffect(()=> { store.set('pantry',  state.pantry);  if (cloudReady) Cloud.pushKey('pantry',  state.pantry);  }, [state.pantry, cloudReady]);
  useEffect(()=> { store.set('plan',    state.plan);    if (cloudReady) Cloud.pushKey('plan',    state.plan);    }, [state.plan, cloudReady]);
  useEffect(()=> { store.set('orders',  state.orders);  if (cloudReady) Cloud.pushKey('orders',  state.orders);  }, [state.orders, cloudReady]);
  useEffect(()=> store.set('shoppingExtras', state.shoppingExtras), [state.shoppingExtras]);
  useEffect(()=> { store.set('cookedMarks',  state.cookedMarks); if (cloudReady) Cloud.pushKey('cookedMarks', state.cookedMarks); }, [state.cookedMarks, cloudReady]);
  // v9 stores
  useEffect(()=> { store.set('leftovers',       state.leftovers       || []); if (cloudReady) Cloud.pushKey('leftovers',       state.leftovers       || []); }, [state.leftovers, cloudReady]);
  useEffect(()=> { store.set('cookHistory',     state.cookHistory     || []); if (cloudReady) Cloud.pushKey('cookHistory',     state.cookHistory     || []); }, [state.cookHistory, cloudReady]);
  useEffect(()=> { store.set('purchaseHistory', state.purchaseHistory || []); if (cloudReady) Cloud.pushKey('purchaseHistory', state.purchaseHistory || []); }, [state.purchaseHistory, cloudReady]);
  useEffect(()=> { store.set('wasteLog',        state.wasteLog        || []); if (cloudReady) Cloud.pushKey('wasteLog',        state.wasteLog        || []); }, [state.wasteLog, cloudReady]);
  useEffect(()=> store.set('view', view), [view]);

  const setKey = (key, value) => dispatch({type:'SET',key,value});
  const go = (v, arg=null) => { setView(v); setViewArg(arg); window.scrollTo(0,0); };
  const notify = (msg, tone='info') => {
    setBanner({msg, tone, ts: Date.now()});
    setTimeout(() => setBanner(b => b && b.ts === Date.now() ? null : b), 4000);
  };

  const api = { state, setKey, go, view, viewArg, dispatch, notify, data };

  if (needsUser) {
    return <UserPicker onChosen={onUserChosen} />;
  }

  // First-run onboarding gate — until the user is marked as onboarded.
  const showOnboarding = !state.profile.onboarded;
  if (showOnboarding) {
    return (
      <AppCtx.Provider value={api}>
        <OnboardingWizard onDone={(updates) => {
          dispatch({ type:'SET', key:'profile', value: { ...state.profile, ...updates, onboarded: true } });
        }}/>
      </AppCtx.Provider>
    );
  }

  return (
    <AppCtx.Provider value={api}>
      <Shell banner={banner}>
        {(() => {
          const K = window.__KA;
          switch(view){
            case 'dashboard':    return K.Dashboard ? <K.Dashboard/> : <LoadingPlaceholder/>;
            case 'plan':         return K.MealPlan ? <K.MealPlan/> : <LoadingPlaceholder/>;
            case 'recipes':      return K.RecipeLibrary ? <K.RecipeLibrary/> : <LoadingPlaceholder/>;
            case 'recipe':       return K.RecipeDetail ? <K.RecipeDetail id={viewArg}/> : <LoadingPlaceholder/>;
            case 'cook':         return K.CookMode ? <K.CookMode id={viewArg}/> : <LoadingPlaceholder/>;
            case 'shop':         return K.ShoppingList ? <K.ShoppingList/> : <LoadingPlaceholder/>;
            case 'pickup':       return K.SchedulePickup ? <K.SchedulePickup/> : <LoadingPlaceholder/>;
            case 'pantry':       return K.Pantry ? <K.Pantry/> : <LoadingPlaceholder/>;
            case 'scanItem':     return K.ScanItem ? <K.ScanItem/> : <LoadingPlaceholder/>;
            case 'scanReceipt':  return K.ScanReceipt ? <K.ScanReceipt/> : <LoadingPlaceholder/>;
            case 'orders':       return K.Orders ? <K.Orders/> : <LoadingPlaceholder/>;
            case 'leftovers':    return K.Leftovers ? <K.Leftovers/> : <LoadingPlaceholder/>;
            case 'reminders':    return K.Reminders ? <K.Reminders/> : <LoadingPlaceholder/>;
            case 'cookhistory':  return K.CookHistory ? <K.CookHistory/> : <LoadingPlaceholder/>;
            case 'settings':     return K.Settings ? <K.Settings/> : <LoadingPlaceholder/>;
            default: return <LoadingPlaceholder/>;
          }
        })()}
      </Shell>
    </AppCtx.Provider>
  );
}

/* ─────────────────────────────────────────────────────────────────────────
   GLOBAL SEARCH — Cmd-K (or click search icon) → overlay across recipes,
   pantry, and shopping list. Tap a result to jump.
   ───────────────────────────────────────────────────────────────────────── */
function GlobalSearch({ open, onClose }){
  const { data, state, go } = useApp();
  const [q, setQ] = useState('');
  const inputRef = useRef(null);

  useEffect(() => {
    if (open) setTimeout(() => inputRef.current?.focus(), 50);
    if (!open) setQ('');
  }, [open]);

  const results = useMemo(() => {
    if (!q.trim()) return { recipes: [], pantry: [], shopping: [] };
    const qLower = q.toLowerCase();
    const score = (s) => {
      const sl = (s||'').toLowerCase();
      if (sl === qLower) return 100;
      if (sl.startsWith(qLower)) return 50;
      if (sl.includes(qLower)) return 25;
      return 0;
    };
    const recipes = (data.recipes||[])
      .map(r => ({ ...r, _score: score(r.name) }))
      .filter(r => r._score > 0)
      .sort((a,b)=>b._score-a._score).slice(0, 6);
    const pantry = (state.pantry||[])
      .map(p => ({ ...p, _score: score(p.name) }))
      .filter(p => p._score > 0)
      .sort((a,b)=>b._score-a._score).slice(0, 6);
    const shopping = (state.shoppingExtras||[])
      .map(s => ({ ...s, _score: score(s.name||s.ingredient_id) }))
      .filter(s => s._score > 0)
      .sort((a,b)=>b._score-a._score).slice(0, 4);
    return { recipes, pantry, shopping };
  }, [q, data.recipes, state.pantry, state.shoppingExtras]);

  if (!open) return null;
  return (
    <div className="fixed inset-0 bg-black/50 z-50 flex items-start justify-center pt-[10vh] px-3" onClick={onClose}>
      <div className="bg-white rounded-2xl w-full max-w-xl shadow-2xl fade-in overflow-hidden" onClick={e=>e.stopPropagation()}>
        <div className="flex items-center gap-2 border-b border-stone-200 px-4 py-3">
          <span className="text-stone-400 text-lg">🔍</span>
          <input ref={inputRef} value={q} onChange={e=>setQ(e.target.value)}
            placeholder="Search recipes, pantry, shopping list…"
            className="flex-1 bg-transparent outline-none text-base"/>
          <kbd className="hidden md:inline text-[10px] text-stone-400 border border-stone-200 rounded px-1.5 py-0.5">esc</kbd>
        </div>
        <div className="max-h-[60vh] overflow-y-auto">
          {!q && (
            <div className="p-6 text-center text-sm text-stone-500">
              Type to search across recipes, pantry, and shopping list.
              <div className="mt-2 text-xs text-stone-400">
                <kbd className="border border-stone-200 rounded px-1.5 py-0.5">⌘K</kbd> or <kbd className="border border-stone-200 rounded px-1.5 py-0.5">/</kbd> from anywhere
              </div>
            </div>
          )}
          {q && results.recipes.length === 0 && results.pantry.length === 0 && results.shopping.length === 0 && (
            <div className="p-6 text-center text-sm text-stone-500">No matches for "{q}".</div>
          )}
          {results.recipes.length > 0 && (
            <div className="p-2">
              <div className="text-[10px] uppercase tracking-wider text-stone-500 px-2 py-1 font-semibold">Recipes</div>
              {results.recipes.map(r => (
                <button key={r.id} onClick={() => { onClose(); go('recipe', r.id); }}
                  className="w-full text-left px-3 py-2.5 rounded-lg hover:bg-stone-50 active:bg-stone-100 flex items-center gap-3">
                  <span className="text-xl">🍽️</span>
                  <div className="flex-1 min-w-0">
                    <div className="text-sm font-medium truncate">{r.name}</div>
                    <div className="text-xs text-stone-500 truncate">{r.source}</div>
                  </div>
                </button>
              ))}
            </div>
          )}
          {results.pantry.length > 0 && (
            <div className="p-2 border-t border-stone-100">
              <div className="text-[10px] uppercase tracking-wider text-stone-500 px-2 py-1 font-semibold">Pantry</div>
              {results.pantry.map(p => (
                <button key={p.id} onClick={() => { onClose(); go('pantry'); }}
                  className="w-full text-left px-3 py-2.5 rounded-lg hover:bg-stone-50 active:bg-stone-100 flex items-center gap-3">
                  <span className="text-xl">🥫</span>
                  <div className="flex-1 min-w-0">
                    <div className="text-sm font-medium truncate">{p.name}</div>
                    <div className="text-xs text-stone-500">{p.qty} {p.unit} · {p.location||'pantry'}</div>
                  </div>
                </button>
              ))}
            </div>
          )}
          {results.shopping.length > 0 && (
            <div className="p-2 border-t border-stone-100">
              <div className="text-[10px] uppercase tracking-wider text-stone-500 px-2 py-1 font-semibold">Shopping list</div>
              {results.shopping.map(s => (
                <button key={s.id} onClick={() => { onClose(); go('shop'); }}
                  className="w-full text-left px-3 py-2.5 rounded-lg hover:bg-stone-50 active:bg-stone-100 flex items-center gap-3">
                  <span className="text-xl">🛒</span>
                  <div className="flex-1 min-w-0">
                    <div className="text-sm font-medium truncate">{s.name || s.ingredient_id}</div>
                    <div className="text-xs text-stone-500">qty {s.qty}</div>
                  </div>
                </button>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  );
}

/* =====================================================================
   SHELL + NAV
   ===================================================================== */
function Shell({children, banner}){
  const { view, go } = useApp();
  const [searchOpen, setSearchOpen] = React.useState(false);

  // Keyboard shortcut — Cmd-K / Ctrl-K / "/" anywhere not inside an input
  React.useEffect(() => {
    const onKey = (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        setSearchOpen(true);
      } else if (e.key === '/' && !['INPUT','TEXTAREA','SELECT'].includes(document.activeElement?.tagName)) {
        e.preventDefault();
        setSearchOpen(true);
      } else if (e.key === 'Escape' && searchOpen) {
        setSearchOpen(false);
      }
    };
    window.addEventListener('keydown', onKey);
    return () => window.removeEventListener('keydown', onKey);
  }, [searchOpen]);

  const nav = [
    { id:'dashboard',  label:'Today',      icon:'home' },
    { id:'plan',       label:'Plan',       icon:'calendar' },
    { id:'recipes',    label:'Recipes',    icon:'book' },
    { id:'shop',       label:'Shop',       icon:'cart' },
    { id:'pantry',     label:'Pantry',     icon:'pantry' },
    { id:'leftovers',  label:'Leftovers',  icon:'pkg' },
    { id:'reminders',  label:'Reminders',  icon:'alert' },
    { id:'orders',     label:'Orders',     icon:'pkg' },
    { id:'cookhistory',label:'History',    icon:'clock' },
    { id:'settings',   label:'Profile',    icon:'user' },
  ];
  const active = {
    dashboard:'dashboard', plan:'plan', recipes:'recipes', recipe:'recipes', cook:'recipes',
    shop:'shop', pickup:'shop', orders:'orders', pantry:'pantry',
    scanItem:'pantry', scanReceipt:'pantry', settings:'settings',
    leftovers:'leftovers', cookhistory:'cookhistory', reminders:'reminders',
  }[view] || view;
  return (
    <div className="min-h-screen flex flex-col md:flex-row">
      <aside className="hidden md:flex md:w-60 lg:w-64 shrink-0 flex-col border-r border-stone-200 bg-white/60 backdrop-blur sticky top-0 h-screen">
        <div className="p-5 flex items-center gap-2">
          <div className="w-9 h-9 rounded-lg bg-brand-500 text-white flex items-center justify-center font-display text-lg">K</div>
          <div className="flex-1">
            <div className="font-display text-lg leading-5">Kitchen Agent</div>
            <div className="text-[11px] text-stone-500">plan · shop · cook</div>
          </div>
        </div>
        <div className="px-4 pb-3">
          <button onClick={() => setSearchOpen(true)}
            className="w-full flex items-center gap-2 px-3 py-2 bg-stone-100 hover:bg-stone-200 text-stone-600 rounded-lg text-sm">
            <span>🔍</span>
            <span className="flex-1 text-left">Search…</span>
            <kbd className="text-[10px] border border-stone-300 rounded px-1.5 py-0.5">⌘K</kbd>
          </button>
        </div>
        <nav className="px-2 pb-4 flex-1 space-y-1">
          {nav.map(n=>(
            <button key={n.id} onClick={()=>go(n.id)}
              className={'w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm '+
                (active===n.id?'bg-brand-500 text-white shadow-sm':'text-stone-700 hover:bg-stone-100')}>
              <Icon name={n.icon} cls="w-5 h-5"/><span>{n.label}</span>
            </button>
          ))}
        </nav>
        <div className="p-3 text-xs text-stone-400 border-t border-stone-200">
          Phase 1 · connected via Instacart + Open Food Facts
        </div>
      </aside>

      <main className="flex-1 flex flex-col">
        {banner && (
          <div className={'px-4 py-2 text-sm fade-in '+(
            banner.tone==='error' ? 'bg-red-50 text-red-800 border-b border-red-200' :
            banner.tone==='success' ? 'bg-leaf-500/10 text-leaf-700 border-b border-leaf-500/20' :
            'bg-brand-50 text-brand-800 border-b border-brand-200')}>{banner.msg}</div>
        )}
        {window.__KA?.ReminderBanner && <window.__KA.ReminderBanner/>}
        <div className="ka-content flex-1 max-w-6xl w-full mx-auto px-4 md:px-8 py-6 pb-24 md:pb-8">
          {children}
        </div>
        {/* Mobile bottom nav — 5 primary tabs + "More" sheet for the rest */}
        <MobileBottomNav nav={nav} active={active} go={go}/>
      </main>
      <GlobalSearch open={searchOpen} onClose={() => setSearchOpen(false)}/>
    </div>
  );
}

function MobileBottomNav({ nav, active, go }){
  const [moreOpen, setMoreOpen] = React.useState(false);
  const { state } = useApp();
  // Primary 4 always visible: Today, Plan, Recipes, Pantry — then a "More" tab
  const primaryIds = ['dashboard','plan','recipes','pantry'];
  const primary = primaryIds.map(id => nav.find(n => n.id === id)).filter(Boolean);
  const more = nav.filter(n => !primaryIds.includes(n.id));
  const moreActive = more.some(n => n.id === active);
  // Reminder badge — anything expiring within 3 days OR a leftover within its eat-by date
  const reminderCount = React.useMemo(() => {
    const now = Date.now(), day = 86400000;
    let n = 0;
    (state.pantry || []).forEach(p => {
      if (!p || (p.location||'pantry') === 'non_food') return;
      const diff = (new Date(p.expires_at).getTime() - now) / day;
      if (diff >= 0 && diff <= 3) n++;
    });
    (state.leftovers || []).forEach(l => {
      if (l.status !== 'fresh') return;
      const diff = (new Date(l.eat_by).getTime() - now) / day;
      if (diff >= 0 && diff <= 1) n++;
    });
    return n;
  }, [state.pantry, state.leftovers]);
  return (
    <>
      <nav className="ka-bottom-nav md:hidden fixed bottom-0 inset-x-0 bg-white border-t border-stone-200 flex items-stretch z-20">
        {primary.map(n => (
          <button key={n.id} onClick={() => go(n.id)}
            className={'flex-1 flex flex-col items-center justify-center gap-1 py-2.5 text-[10px] ' +
              (active === n.id ? 'text-brand-600' : 'text-stone-500')}>
            <Icon name={n.icon} cls="w-5 h-5"/><span>{n.label}</span>
          </button>
        ))}
        <button onClick={() => setMoreOpen(true)}
          className={'relative flex-1 flex flex-col items-center justify-center gap-1 py-2.5 text-[10px] ' +
            (moreActive ? 'text-brand-600' : 'text-stone-500')}>
          <div className="relative">
            <svg viewBox="0 0 24 24" className="w-5 h-5" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
              <circle cx="5" cy="12" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="19" cy="12" r="1.6"/>
            </svg>
            {reminderCount > 0 && (
              <span className="absolute -top-1.5 -right-2 min-w-[18px] h-[18px] px-1 rounded-full bg-red-500 text-white text-[10px] font-bold flex items-center justify-center leading-none">
                {reminderCount > 9 ? '9+' : reminderCount}
              </span>
            )}
          </div>
          <span>More</span>
        </button>
      </nav>
      {moreOpen && (
        <div className="md:hidden fixed inset-0 z-30 bg-black/40" onClick={() => setMoreOpen(false)}>
          <div className="absolute left-0 right-0 bottom-0 bg-white rounded-t-2xl pt-3 pb-[calc(1rem+env(safe-area-inset-bottom))] shadow-2xl"
               onClick={e => e.stopPropagation()}>
            <div className="w-12 h-1.5 rounded-full bg-stone-300 mx-auto mb-3"/>
            <div className="px-2 pb-1 grid grid-cols-1 divide-y divide-stone-100">
              {more.map(n => (
                <button key={n.id}
                  onClick={() => { setMoreOpen(false); go(n.id); }}
                  className={'flex items-center gap-3 px-4 py-3.5 text-left ' +
                    (active === n.id ? 'text-brand-600 font-semibold' : 'text-stone-700')}>
                  <Icon name={n.icon} cls="w-5 h-5"/>
                  <span className="text-base">{n.label}</span>
                </button>
              ))}
              <button onClick={() => setMoreOpen(false)}
                className="flex items-center justify-center gap-2 px-4 py-3 text-stone-500 text-sm mt-2">
                Cancel
              </button>
            </div>
          </div>
        </div>
      )}
    </>
  );
}

/* ─────────────────────────────────────────────────────────────────────────
   HINT BUBBLE — one-time tooltip pointing at a new feature.
   Pass `id` to track dismissal in localStorage (so it shows only once).
   Pass `placement` 'top'|'bottom'|'right'|'left' for the arrow direction.
   ───────────────────────────────────────────────────────────────────────── */
const Hints = {
  KEY: 'kitchenAgent:v2:dismissedHints',
  isDismissed(id){
    try { return (JSON.parse(localStorage.getItem(this.KEY)||'[]')).includes(id); }
    catch { return false; }
  },
  dismiss(id){
    try {
      const arr = JSON.parse(localStorage.getItem(this.KEY)||'[]');
      if (!arr.includes(id)) { arr.push(id); localStorage.setItem(this.KEY, JSON.stringify(arr)); }
    } catch {}
  },
  reset(){ try { localStorage.removeItem(this.KEY); } catch {} },
};
function HintBubble({id, placement='bottom', children, className=''}){
  const [shown, setShown] = React.useState(() => !Hints.isDismissed(id));
  if (!shown) return null;
  const arrow = {
    top:    'after:content-[""] after:absolute after:top-full after:left-6 after:border-8 after:border-transparent after:border-t-brand-600',
    bottom: 'after:content-[""] after:absolute after:bottom-full after:left-6 after:border-8 after:border-transparent after:border-b-brand-600',
    left:   'after:content-[""] after:absolute after:left-full after:top-3 after:border-8 after:border-transparent after:border-l-brand-600',
    right:  'after:content-[""] after:absolute after:right-full after:top-3 after:border-8 after:border-transparent after:border-r-brand-600',
  }[placement];
  return (
    <div className={'relative z-20 bg-brand-600 text-white text-xs rounded-xl px-3 py-2.5 shadow-xl max-w-[260px] fade-in '+arrow+' '+className}>
      <div className="pr-5">{children}</div>
      <button onClick={()=>{ Hints.dismiss(id); setShown(false); }}
        aria-label="dismiss" className="absolute top-1.5 right-1.5 w-6 h-6 rounded-full text-white/80 hover:bg-white/10 flex items-center justify-center text-base leading-none">×</button>
    </div>
  );
}

function Card({children, className='', onClick, ...rest}){
  return <div onClick={onClick} className={'bg-white border border-stone-200 rounded-xl p-4 md:p-5 '+className} {...rest}>{children}</div>;
}
function Section({title, action, children, className=''}){
  return (<section className={'space-y-3 '+className}>
    <div className="flex items-end justify-between gap-3"><h2 className="font-display text-xl md:text-2xl">{title}</h2>{action}</div>
    {children}</section>);
}
function Button({children, onClick, variant='primary', className='', ...rest}){
  const base = 'inline-flex items-center gap-2 px-4 py-3 rounded-lg text-sm font-medium transition min-h-[44px]';
  const styles = {
