<script type="text/babel" data-type="module">
const { useState } = React;
const K = window.__KA;
const { Icon, Card, Section, Button, Badge, Chip, Input, useApp, Instacart, Walmart, OpenFoodFacts, Routing, Claude, Pricing, StorageHealth, Notifs } = K;

function RecipeStepCleanup({ data, notify }) {
  const allRecipes = data.recipes;
  const [progress, setProgress] = React.useState({ done: 0, total: 0, current: '', running: false, cancelled: false });
  const cancelRef = React.useRef(false);
  const [cleanedCount, setCleanedCount] = React.useState(() => {
    try {
      const m = JSON.parse(localStorage.getItem('kitchenAgent:v2:recipeStepOverrides') || '{}');
      return Object.keys(m).length;
    } catch { return 0; }
  });

  const refreshCount = () => {
    try {
      const m = JSON.parse(localStorage.getItem('kitchenAgent:v2:recipeStepOverrides') || '{}');
      setCleanedCount(Object.keys(m).length);
    } catch {}
  };

  const startCleanup = async (onlyDirty) => {
    cancelRef.current = false;
    const overrides = (() => {
      try { return JSON.parse(localStorage.getItem('kitchenAgent:v2:recipeStepOverrides') || '{}'); }
      catch { return {}; }
    })();
    // Heuristic: a recipe "needs cleanup" if any single step is >300 chars or fewer than 3 steps total but a long combined length.
    const needsCleanup = (r) => {
      const steps = r.steps || [];
      if (!steps.length) return false;
      const longest = Math.max(...steps.map(s => (s || '').length));
      const combined = steps.join(' ').length;
      return longest > 300 || (steps.length < 4 && combined > 400);
    };
    const queue = allRecipes.filter(r => {
      if (overrides[r.id]) return false; // already cleaned
      return onlyDirty ? needsCleanup(r) : true;
    });
    if (!queue.length) {
      notify(onlyDirty ? 'No recipes look mangled — nothing to clean.' : 'All recipes already cleaned.', 'info');
      return;
    }
    setProgress({ done: 0, total: queue.length, current: queue[0]?.name || '', running: true, cancelled: false });
    let failures = 0;
    for (let i = 0; i < queue.length; i++) {
      if (cancelRef.current) break;
      const r = queue[i];
      setProgress({ done: i, total: queue.length, current: r.name, running: true, cancelled: false });
      try {
        const newSteps = await window.KA_cleanupRecipeSteps(r);
        window.KA_saveCleanedSteps(r.id, newSteps);
      } catch (e) {
        console.warn('cleanup failed for', r.id, e.message);
        failures++;
      }
    }
    setProgress(p => ({ ...p, done: queue.length, running: false, cancelled: cancelRef.current }));
    refreshCount();
    notify(`Cleanup ${cancelRef.current ? 'cancelled' : 'finished'}: ${queue.length - failures} cleaned${failures ? ', ' + failures + ' failed' : ''}.`, failures > 0 && !cancelRef.current ? 'info' : 'success');
  };

  const undoAll = () => {
    if (!confirm('Remove all Claude-cleaned step overrides? Original recipe steps will return.')) return;
    window.KA_clearCleanedSteps();
    setCleanedCount(0);
    notify('All step overrides cleared.', 'success');
  };

  return (
    <div className="space-y-3">
      <div className="text-sm">
        <strong>{cleanedCount}</strong> of <strong>{allRecipes.length}</strong> recipes have Claude-cleaned steps so far.
      </div>
      <p className="text-xs text-stone-600">
        Many imported recipes have mangled step text — run-on sentences, embedded "serving suggestion" headers,
        or OCR fragments. This sends each recipe's existing steps to Claude Sonnet to be rewritten as proper,
        sequential cooking instructions. The result is saved per-recipe in your browser; original data is untouched.
      </p>
      <div className="text-[11px] text-stone-500">
        Sonnet takes ~3-5 sec per recipe. For {allRecipes.length} recipes, plan on ~{Math.ceil(allRecipes.length * 4 / 60)} minutes total.
        You can cancel anytime — progress is saved as it goes.
      </div>

      <div className="flex gap-2 flex-wrap">
        <Button variant="leaf" onClick={() => startCleanup(true)} disabled={progress.running}>
          ✨ Clean only mangled recipes
        </Button>
        <Button variant="outline" onClick={() => startCleanup(false)} disabled={progress.running}>
          🔄 Clean ALL {allRecipes.length} recipes
        </Button>
        {cleanedCount > 0 && (
          <Button variant="ghost" onClick={undoAll} disabled={progress.running}>
            Undo all cleanups
          </Button>
        )}
      </div>

      {progress.running && (
        <div className="mt-3 p-3 rounded-lg border border-brand-200 bg-brand-50">
          <div className="flex items-center justify-between mb-1">
            <div className="text-sm">
              <span className="font-medium">Cleaning "{progress.current}"</span>
              <span className="text-stone-500 ml-2">{progress.done + 1} of {progress.total}</span>
            </div>
            <button onClick={() => { cancelRef.current = true; }}
              className="text-xs text-red-600 hover:underline">Cancel</button>
          </div>
          <div className="h-2 bg-white rounded-full overflow-hidden">
            <div className="h-full bg-gradient-to-r from-brand-500 to-leaf-500 transition-all"
              style={{ width: (progress.total ? (progress.done / progress.total * 100) : 0) + '%' }}/>
          </div>
          <div className="text-[11px] text-stone-500 mt-2">
            Estimated time remaining: ~{Math.ceil((progress.total - progress.done) * 4 / 60)} min
          </div>
        </div>
      )}

      {!progress.running && progress.total > 0 && (
        <div className="mt-2 p-2 rounded-lg bg-leaf-500/10 border border-leaf-500/30 text-sm text-leaf-800">
          ✓ Cleanup {progress.cancelled ? 'cancelled' : 'finished'} · {progress.done} of {progress.total} processed.
        </div>
      )}
    </div>
  );
}

function HouseholdSyncStatus({ partnerEmail, onSync }) {
  const ns = window.Cloud?.getSharedNamespace?.();
  const myEmail = (typeof localStorage !== 'undefined' ? localStorage.getItem('kitchenAgent:v2:userEmail') : '') || '';
  if (!partnerEmail) return (
    <div className="text-xs text-stone-500">
      <span className="inline-block px-2 py-0.5 bg-stone-100 rounded-full mr-1">Solo</span>
      Add a partner email above + Save to start sharing your pantry &amp; plan.
    </div>
  );
  if (!myEmail) return (
    <div className="text-xs text-amber-700">
      Open Pantry once and enter your email — that's how the app identifies you for sharing.
    </div>
  );
  return (
    <div className="text-xs">
      <span className={'inline-block px-2 py-0.5 rounded-full mr-2 ' + (ns ? 'bg-leaf-100 text-leaf-800' : 'bg-stone-100 text-stone-600')}>
        {ns ? '✓ Linked' : 'Not linked yet'}
      </span>
      {ns
        ? <span className="text-stone-600">Pantry, plan, leftovers, &amp; shopping list sync between {myEmail} and {partnerEmail}.</span>
        : <span className="text-stone-600">Save settings, then ask {partnerEmail} to add you back as their partner email and enter the pantry email gate.</span>}
      <Button variant="ghost" onClick={onSync} className="mt-2">
        <Icon name="refresh" cls="w-3.5 h-3.5"/>Pull from cloud
      </Button>
    </div>
  );
}

function HouseholdEditor({ members, onChange }) {
  const [draft, setDraft] = React.useState({ name: '', age_group: 'adult', dislikes: '', allergies: '' });
  const add = () => {
    if (!draft.name.trim()) return;
    const m = {
      id: crypto.randomUUID(),
      name: draft.name.trim(),
      age_group: draft.age_group,
      dislikes: draft.dislikes.split(',').map(x => x.trim()).filter(Boolean),
      allergies: draft.allergies.split(',').map(x => x.trim()).filter(Boolean),
    };
    onChange([...(members||[]), m]);
    setDraft({ name: '', age_group: 'adult', dislikes: '', allergies: '' });
  };
  const remove = (id) => onChange(members.filter(m => m.id !== id));
  return (
    <div className="space-y-3">
      {(members||[]).length === 0 && <div className="text-sm text-stone-500 italic">No members yet. Add yourself or family below — Claude will respect each person's dislikes &amp; allergies.</div>}
      {(members||[]).map(m => (
        <div key={m.id} className="flex items-start gap-3 p-3 bg-stone-50 rounded-lg">
          <div className="text-2xl">{m.age_group === 'kid' ? '🧒' : m.age_group === 'teen' ? '🧑' : '👤'}</div>
          <div className="flex-1 min-w-0">
            <div className="font-medium">{m.name} <span className="text-xs text-stone-500 font-normal">({m.age_group})</span></div>
            {m.allergies?.length > 0 && <div className="text-xs text-red-700 mt-0.5">Allergies: {m.allergies.join(', ')}</div>}
            {m.dislikes?.length > 0 && <div className="text-xs text-amber-700 mt-0.5">Dislikes: {m.dislikes.join(', ')}</div>}
          </div>
          <button onClick={() => remove(m.id)} className="text-stone-400 hover:text-red-600">
            <Icon name="trash" cls="w-4 h-4"/>
          </button>
        </div>
      ))}
      <div className="border-t border-stone-200 pt-3">
        <div className="text-xs text-stone-500 uppercase tracking-wide mb-2">Add member</div>
        <div className="grid grid-cols-2 gap-2">
          <Input placeholder="Name" value={draft.name} onChange={e => setDraft({...draft, name: e.target.value})}/>
          <select value={draft.age_group} onChange={e => setDraft({...draft, age_group: e.target.value})}
            className="px-3 py-2 border border-stone-300 rounded-lg text-sm bg-white">
            <option value="adult">Adult</option>
            <option value="teen">Teen</option>
            <option value="kid">Kid</option>
          </select>
          <Input placeholder="Dislikes (comma-separated)" value={draft.dislikes} onChange={e => setDraft({...draft, dislikes: e.target.value})} className="col-span-2"/>
          <Input placeholder="Allergies (comma-separated)" value={draft.allergies} onChange={e => setDraft({...draft, allergies: e.target.value})} className="col-span-2"/>
        </div>
        <Button onClick={add} className="mt-2" disabled={!draft.name.trim()}>
          <Icon name="plus" cls="w-4 h-4"/>Add member
        </Button>
      </div>
    </div>
  );
}

// Theme helper used by Settings and the boot.
const Theme = {
  KEY: 'kitchenAgent:v2:theme',
  get(){ try { return localStorage.getItem(this.KEY) || 'system'; } catch { return 'system'; } },
  set(mode){
    try { localStorage.setItem(this.KEY, mode); } catch {}
    const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
    const isDark = mode === 'dark' || (mode === 'system' && prefersDark);
    document.documentElement.classList.toggle('dark', isDark);
  },
};

function Settings(){
  const { state, setKey, data, notify, go } = useApp();
  const [form, setForm] = useState(state.profile);
  const [theme, setTheme] = useState(() => Theme.get());
  const [instKey, setInstKey] = useState(Instacart.getKey());
  const [wmKey, setWmKey] = useState(Walmart.getKey());
  const [claudeKey, setClaudeKey] = useState(Claude.getKey());
  const [claudeTest, setClaudeTest] = useState({ state:'idle', msg:'' }); // idle | testing | ok | err
  const [priceRefresh, setPriceRefresh] = useState({ state:'idle', msg:'', updated: 0 });
  const overrideCount = (() => {
    try { return Object.values(JSON.parse(localStorage.getItem(Pricing.KEY) || '{}')).reduce((n,o)=>n+Object.keys(o||{}).length,0); }
    catch { return 0; }
  })();

  const save = () => {
    setKey('profile', form);
    Instacart.setKey(instKey);
    Walmart.setKey(wmKey);
    Claude.setKey(claudeKey);
    notify('Settings saved', 'success');
  };

  // Refresh pack prices for every ingredient at the user's preferred stores.
  const refreshPricesNow = async () => {
    if (!Claude.isEnabled()) {
      notify('Add an Anthropic API key first', 'error');
      return;
    }
    const prefIds = new Set((form.preferred_stores || []).length ? form.preferred_stores : data.stores.map(s=>s.id));
    const targetStores = data.stores.filter(s => prefIds.has(s.id));
    if (!targetStores.length) {
      setPriceRefresh({ state:'err', msg:'No preferred stores selected.', updated: 0 });
      return;
    }
    setPriceRefresh({ state:'busy', msg:`Asking Claude for ${data.ingredients.length} × ${targetStores.length} prices…`, updated: 0 });
    try {
      const region = form.zip ? ('US ZIP ' + form.zip) : 'United States';
      const { results } = await Claude.refreshPrices({
        ingredients: data.ingredients,
        stores: targetStores,
        region,
      });
      const n = Pricing.setMany(results || [], 'claude_refresh');
      setPriceRefresh({ state:'ok', msg:`Updated ${n} prices. They\'ll appear in your shopping list immediately.`, updated: n });
      notify(`Prices refreshed (${n} updated)`, 'success');
    } catch (e) {
      setPriceRefresh({ state:'err', msg: e.message, updated: 0 });
    }
  };
  const wipeOverrides = () => {
    if (!confirm('Reset all your price corrections and refreshed prices back to the bundled estimates?')) return;
    Pricing.clearAll();
    setPriceRefresh({ state:'idle', msg:'', updated: 0 });
    notify('Price overrides cleared', 'success');
  };

  const testClaudeKey = async () => {
    Claude.setKey(claudeKey); // persist so the test uses what's in the field right now
    setClaudeTest({ state:'testing', msg:'Calling Claude…' });
    try {
      // Tiny no-image call just to confirm the key + network works.
      const res = await fetch(Claude.ENDPOINT, {
        method:'POST',
        headers:{
          'content-type':'application/json',
          'x-api-key': claudeKey,
          'anthropic-version':'2023-06-01',
          'anthropic-dangerous-direct-browser-access':'true',
        },
        body: JSON.stringify({
          model: Claude.MODEL,
          max_tokens: 10,
          messages:[{ role:'user', content:'Reply with the single word: ok' }]
        }),
      });
      const json = await res.json().catch(()=>({}));
      if (!res.ok) {
        const msg = json?.error?.message || `HTTP ${res.status}`;
        setClaudeTest({ state:'err', msg });
        return;
      }
      setClaudeTest({ state:'ok', msg:'Connected. Photo identification is ready.' });
    } catch (e) {
      setClaudeTest({ state:'err', msg: e.message });
    }
  };

  const toggleStore = (sid) => {
    const cur = new Set(form.preferred_stores || []);
    if (cur.has(sid)) cur.delete(sid); else cur.add(sid);
    setForm({...form, preferred_stores: Array.from(cur)});
  };

  const resetDemoData = () => {
    if (!confirm('Reset ALL data (pantry, plan, orders, settings)? This cannot be undone.')) return;
    try {
      Object.keys(localStorage).filter(k => k.startsWith('kitchenAgent:v2:')).forEach(k => localStorage.removeItem(k));
      notify('Reset complete. Reloading...', 'success');
      setTimeout(() => location.reload(), 600);
    } catch(e) { notify('Reset failed: '+e.message, 'error'); }
  };
  const clearCaches = () => {
    try {
      localStorage.removeItem('kitchenAgent:v2:off:cache');
      localStorage.removeItem('kitchenAgent:v2:routing:cache');
      notify('Caches cleared (Open Food Facts + Routing)', 'success');
    } catch(e){ notify('Clear failed: '+e.message, 'error'); }
  };

  const [tab, setTab] = useState(() => { try { return localStorage.getItem('kitchenAgent:v2:settingsTab') || 'profile'; } catch { return 'profile'; } });
  const switchTab = (t) => { setTab(t); try { localStorage.setItem('kitchenAgent:v2:settingsTab', t); } catch {} };
  const TABS = [
    ['profile',    '👤 Profile'],
    ['diet',       '🥗 Diet & kitchen'],
    ['shop',       '🛒 Shopping'],
    ['api',        '🔌 API & prices'],
    ['appearance', '🎨 Appearance'],
    ['data',       '💾 Data'],
  ];

  return (
    <div className="space-y-6 fade-in max-w-3xl">
      <div>
        <h1 className="font-display text-3xl md:text-4xl">Settings</h1>
        <p className="text-sm text-stone-600 mt-1">Your profile and store connections.</p>
      </div>

      {/* Tab bar — horizontal scroll on mobile */}
      <div className="ka-no-scrollbar flex gap-1.5 overflow-x-auto pb-2 -mx-4 px-4 md:mx-0 md:px-0 snap-x">
        {TABS.map(([id, label]) => (
          <button key={id} onClick={() => switchTab(id)}
            className={'snap-start whitespace-nowrap px-4 py-2.5 rounded-full text-sm font-medium border min-h-[44px] ' +
              (tab === id ? 'bg-brand-500 text-white border-brand-500 shadow-sm' : 'bg-white text-stone-700 border-stone-300 hover:bg-stone-50')}>
            {label}
          </button>
        ))}
      </div>

      {tab === 'profile' && (<>
      <Section title="Profile">
        <Card>
          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
