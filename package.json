/* =====================================================================
   PRICE ENGINE
   ===================================================================== */
function lookupPrice(ingredient_id, store_id, prices){
  if (prices?.[ingredient_id]?.[store_id]) return prices[ingredient_id][store_id];
  if (ingredient_id && ingredient_id.startsWith('claude_ing_')) {
    const stripped = ingredient_id.replace(/^claude_ing_/, '').replace(/_+$/, '');
    const parts = stripped.split('_').filter(Boolean);
    for (let len = parts.length; len >= 1; len--) {
      for (let start = 0; start <= parts.length - len; start++) {
        const c = parts.slice(start, start + len).join('_');
        if (prices?.[c]?.[store_id]) return prices[c][store_id];
        const cs = c.endsWith('s') ? c.slice(0,-1) : null;
        if (cs && prices?.[cs]?.[store_id]) return prices[cs][store_id];
      }
    }
  }
  return null;
}
function effectivePrice(record){ if (!record) return null; return record.sale_price ?? record.price; }

function optimizeCart(cart, stores, prices, opts){
  // cart: [{ingredient_id, qty}]
  // opts: { method: 'pickup'|'delivery' } — filter to stores supporting this method
  // Returns:
  //   perItemBest: { ingredient_id: {store_id, price_record} }
  //   singleStoreTotals: { store_id: total }
  //   bestSingleStore: store_id
  //   splitTotal: number  (sum of per-item cheapest)
  //   savings: splitTotal vs single-store
  let activeStores = stores;
  if (opts && opts.method) {
    if (opts.method === 'pickup') activeStores = stores.filter(s => s.pickup_supported !== false);
    else if (opts.method === 'delivery') activeStores = stores.filter(s => s.delivery_supported !== false);
  }
  if (!activeStores.length) activeStores = stores; // safety
  const perItemBest = {};
  const singleStoreTotals = {};
  activeStores.forEach(s => singleStoreTotals[s.id] = 0);
  cart.forEach(item => {
    let best = null;
    activeStores.forEach(s => {
      const rec = lookupPrice(item.ingredient_id, s.id, prices);
      const eff = effectivePrice(rec);
      if (eff == null) return;
      const line = eff * item.qty;
      singleStoreTotals[s.id] += line;
      if (!best || eff < effectivePrice(best.rec)) best = { store_id: s.id, rec, line };
    });
    if (best) perItemBest[item.ingredient_id] = best;
  });
  const splitTotal = Object.values(perItemBest).reduce((s,b)=>s+b.line,0);
  let bestSingleStore = null;
  Object.entries(singleStoreTotals).forEach(([sid,total]) => {
    if (bestSingleStore==null || total < singleStoreTotals[bestSingleStore]) bestSingleStore = sid;
  });
  return {
    perItemBest,
    singleStoreTotals,
    bestSingleStore,
    splitTotal,
    savings: bestSingleStore ? singleStoreTotals[bestSingleStore] - splitTotal : 0,
  };
}

/* =====================================================================
   PANTRY UTILITIES
   ===================================================================== */
function pantryMap(pantry){
  const m = {};
  pantry.forEach(p => {
    m[p.ingredient_id] = (m[p.ingredient_id] || 0) + p.qty;
  });
  return m;
}

// ── Stronger "do I have this ingredient?" check ─────────────────────────
// Beyond exact ingredient_id match, this normalizes both names and uses
// matchers aliases (already in __KA_DATA.matchers) to catch cases like
// "yellow onion" ↔ "onion", "fresh tomato" ↔ "tomato", etc.
function normalizeIngName(s){
  if (!s) return '';
  return String(s).toLowerCase()
    .replace(/\(.*?\)/g, ' ')               // strip "(small bottle)"
    .replace(/\b(fresh|dried|raw|whole|chopped|sliced|minced|diced|grated|shredded|frozen|canned|organic|small|large|medium|extra|virgin)\b/g, ' ')
    .replace(/\b(yellow|red|green|white|brown|black|sweet|baby)\b/g, ' ')
    .replace(/\b(cup|cups|oz|tbsp|tsp|lb|lbs|pound|pounds|each|pack|bunch|clove|cloves)\b/g, ' ')
    .replace(/[^a-z\s]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim()
    .replace(/s$/,'');                       // crude singularize
}
// ── Unit conversion (rough but useful) ──────────────────────────────────
// Returns the qty in `to` units, or null if not convertible.
const UNIT_BASE = {
  // mass → g
  g:1, gram:1, grams:1,
  kg:1000, kilogram:1000, kilograms:1000,
  oz:28.35, ounce:28.35, ounces:28.35,
  lb:453.6, lbs:453.6, pound:453.6, pounds:453.6,
  // volume → ml
  ml:1, milliliter:1, milliliters:1,
  l:1000, liter:1000, liters:1000, litre:1000, litres:1000,
  tsp:4.93, teaspoon:4.93, teaspoons:4.93,
  tbsp:14.79, tablespoon:14.79, tablespoons:14.79,
  cup:236.6, cups:236.6,
  'fl oz':29.57, 'fluid ounce':29.57, 'fluid ounces':29.57,
  pint:473, pints:473, pt:473,
  quart:946, quarts:946, qt:946,
  gallon:3785, gallons:3785, gal:3785,
};
function unitsCompatible(a, b) {
  const sa = (a||'').toLowerCase().trim(), sb = (b||'').toLowerCase().trim();
  if (sa === sb) return true;
  if (!UNIT_BASE[sa] || !UNIT_BASE[sb]) return false;
  // Both mass OR both volume — heuristic: same magnitude bucket
  const massSet = new Set(['g','gram','grams','kg','kilogram','kilograms','oz','ounce','ounces','lb','lbs','pound','pounds']);
  if (massSet.has(sa) && massSet.has(sb)) return true;
  if (!massSet.has(sa) && !massSet.has(sb)) return true;
  return false;
}
function convertQty(qty, fromUnit, toUnit) {
  if (!qty || !fromUnit || !toUnit) return null;
  if (!unitsCompatible(fromUnit, toUnit)) return null;
  const sa = fromUnit.toLowerCase().trim(), sb = toUnit.toLowerCase().trim();
  if (sa === sb) return qty;
  const a = UNIT_BASE[sa], b = UNIT_BASE[sb];
  if (!a || !b) return null;
  return qty * (a / b);
}
// Parse "1 cup", "1/2 cup", "2 tbsp", "1 lb", "3" from a recipe ingredient line.
function parseIngredientQty(line) {
  if (!line) return null;
  const m = String(line).match(/^\s*(\d+(?:\s+\d+\/\d+)?|\d+\/\d+|\d*\.?\d+)\s*([a-zA-Z]+(?:\s+oz)?)?/);
  if (!m) return null;
  let qty;
  if (/\//.test(m[1]) && /\s/.test(m[1])) {
    const [whole, frac] = m[1].split(/\s+/);
    const [n,d] = frac.split('/').map(Number);
    qty = Number(whole) + n/d;
  } else if (/\//.test(m[1])) {
    const [n,d] = m[1].split('/').map(Number);
    qty = n/d;
  } else {
    qty = parseFloat(m[1]);
  }
  const unit = (m[2] || '').toLowerCase().replace(/s$/,'');
  return { qty, unit };
}

function pantryHas(ing_or_name, pantryItems, matchers){
  if (!pantryItems || !pantryItems.length) return false;
  // 1) Canonical id direct match
  if (typeof ing_or_name === 'string' && pantryItems.some(p => p.ingredient_id === ing_or_name && p.qty > 0)) return true;
  const name = typeof ing_or_name === 'string'
    ? (matchers && matchers[ing_or_name] ? matchers[ing_or_name][0] : ing_or_name)
    : (ing_or_name?.name || '');
  const nameN = normalizeIngName(name);
  if (!nameN) return false;
  // 2) Build the set of equivalent strings we'd accept
  const aliases = new Set([nameN]);
  if (matchers) {
    for (const [cid, list] of Object.entries(matchers)) {
      if (list.some(a => normalizeIngName(a) === nameN) || (typeof ing_or_name === 'string' && cid === ing_or_name)) {
        list.forEach(a => aliases.add(normalizeIngName(a)));
      }
    }
  }
  // 3) Check pantry names against any alias
  for (const p of pantryItems) {
    if (p.qty <= 0) continue;
    const pn = normalizeIngName(p.name);
    if (!pn) continue;
    for (const a of aliases) {
      if (a === pn || pn.includes(a) || a.includes(pn)) return true;
    }
  }
  return false;
}
function pantryMatchScore(recipe, pantry){
  const needed = recipe.canonical_ingredients || [];
  if (!needed.length) return 0;
  const have = pantryMap(pantry);
  const matches = needed.filter(id => have[id] > 0).length;
  return matches / needed.length;
}
function expirationTone(expires_at){
  const days = (new Date(expires_at) - Date.now()) / 86400000;
  if (days < 0) return 'red';
  if (days < 3) return 'warn';
  if (days < 7) return 'brand';
  return 'leaf';
}

/* =====================================================================
   PLANNER v3 — fills 4 slots per day (B/L/D/Snack) honoring preferences
   Inputs:
     options.slots            = MEAL_SLOTS to fill (default all)
     options.proteinFilter    = ['chicken','beef', ...] (empty = any)
     options.preferencesText  = free-form "I want X" text
     options.excludeIds       = recipe ids to avoid (previous picks)
     options.mealPrepLunch    = boolean; pick ONE lunch x7 with scaled qtys
     options.mealPrepCount    = how many lunch servings to produce (default 7)
   Returns:
     plan: { '2026-04-23': { breakfast:id, lunch:id, dinner:id, snack:id } }
     meta: { mealPrep: { recipeId, multiplier } | null, picks: [ids] }
   ===================================================================== */
function scoreRecipe(r, ctx){
  const { pantry, usedCuisines, recentIds, prefTokens, proteinFilter } = ctx;
  let score = 0;
  score += pantryMatchScore(r, pantry) * 3;
  if ((r.tags||[]).some(t => !usedCuisines.slice(-3).includes(t))) score += 1;
  if ((r.prep_min + r.cook_min) > 60) score -= 1;
  if (recentIds.includes(r.id)) score -= 10;
  if (proteinFilter && proteinFilter.length){
    const proteins = r.proteins || [];
    if (proteins.some(p => proteinFilter.includes(p))) score += 2.5;
    else score -= 1.5;
  }
  if (prefTokens && prefTokens.length){
    const hay = (r.name + ' ' + (r.tags||[]).join(' ') + ' ' + (r.canonical_ingredients||[]).join(' ')).toLowerCase();
    let hits = 0;
    prefTokens.forEach(tok => { if (hay.includes(tok)) hits++; });
    if (hits) score += Math.min(hits, 3) * 1.5;
  }
  score += Math.random()*0.3;
  return score;
}

function pickRecipeForSlot(recipes, slot, ctx){
  // Filter to eligible recipes for this slot
  const candidates = recipes.filter(r => {
    if (!r.ingredients || r.ingredients.length === 0) return false;
    const meals = r.meal_types || ['dinner','lunch'];
    if (!meals.includes(slot)) return false;
    if (ctx.excludeIds && ctx.excludeIds.has(r.id)) return false;
    return true;
  });
  if (candidates.length === 0) return null;
  const scored = candidates.map(r => ({ r, s: scoreRecipe(r, ctx) }));
  scored.sort((a,b) => b.s - a.s);
  // Top-3 weighted random pick for variety
  const top = scored.slice(0, Math.min(5, scored.length));
  const w = top.map((_,i) => Math.max(1, top.length - i));
  const sum = w.reduce((a,b)=>a+b,0);
  let r = Math.random()*sum;
  for (let i=0;i<top.length;i++){ r -= w[i]; if (r<=0) return top[i].r; }
  return top[0].r;
}

function autoPlan(recipes, pantry, profile, startDate, numDays=7, options={}){
  const slots = options.slots || (profile?.meal_slots) || MEAL_SLOTS;
  const proteinFilter = options.proteinFilter || profile?.protein_picks || [];
  const preferencesText = (options.preferencesText ?? profile?.preferences_text ?? '').toString().toLowerCase().trim();
  const prefTokens = preferencesText
    .replace(/[^a-z0-9\s]/g,' ')
    .split(/\s+/)
    .filter(w => w.length >= 3 && !['the','and','for','with','want','like','some','more','need','please'].includes(w));
  const excludeIds = new Set(options.excludeIds || []);
  const mealPrepLunch = options.mealPrepLunch ?? profile?.meal_prep_lunch ?? false;
  const mealPrepCount = options.mealPrepCount ?? profile?.meal_prep_lunch_count ?? numDays;

  const plan = {};
  const usedCuisines = [];
  const recentIds = [];
  const picks = [];
  let mealPrepMeta = null;

  // If meal prep lunch is on, pick one lunch recipe first and reuse
  let mealPrepLunchRecipe = null;
  if (mealPrepLunch && slots.includes('lunch')){
    const ctx = { pantry, usedCuisines, recentIds, prefTokens, proteinFilter, excludeIds };
    mealPrepLunchRecipe = pickRecipeForSlot(recipes, 'lunch', ctx);
    if (mealPrepLunchRecipe) {
      const servings = mealPrepLunchRecipe.servings || 1;
      mealPrepMeta = {
        recipeId: mealPrepLunchRecipe.id,
        name: mealPrepLunchRecipe.name,
        servings,
        count: mealPrepCount,
        // scaling: assume each lunch = 1 serving; multiplier = count / servings
        multiplier: Math.max(1, Math.ceil(mealPrepCount / servings)),
      };
    }
  }

  for (let i=0; i<numDays; i++){
    const d = new Date(startDate); d.setDate(d.getDate()+i);
    const key = dateKey(d);
    const dayPlan = {};
    for (const slot of slots){
      if (slot === 'lunch' && mealPrepLunchRecipe){
        dayPlan.lunch = mealPrepLunchRecipe.id;
        continue;
      }
      const ctx = { pantry, usedCuisines, recentIds, prefTokens, proteinFilter, excludeIds };
      const pick = pickRecipeForSlot(recipes, slot, ctx);
      if (pick){
        dayPlan[slot] = pick.id;
        usedCuisines.push(...(pick.tags||[]));
        recentIds.push(pick.id);
        excludeIds.add(pick.id);   // within-run variety (don't repeat across week)
        picks.push(pick.id);
        if (recentIds.length > 14) recentIds.shift();
      }
    }
    plan[key] = dayPlan;
  }
  return { plan, meta: { mealPrep: mealPrepMeta, picks } };
}

/* =====================================================================
   COMPONENTS — continued in next script block
   ===================================================================== */
window.__KA = { AppCtx, useApp, Icon, Card, Section, Button, Badge, Chip, Input, HintBubble, Hints,
  slug, fmt$, today, dateKey, days, dayLabel, dayShort, useLocalState,
  lookupPrice, effectivePrice, optimizeCart, pantryMap, pantryMatchScore, pantryHas, normalizeIngName, convertQty, parseIngredientQty, expirationTone, autoPlan,
  Instacart, Walmart, OpenFoodFacts, OCR, Claude, Pricing, StorageHealth, Notifs, Routing, DEFAULT_PROFILE, App, BarcodeMap,
  MEAL_SLOTS, MEAL_SLOT_EMOJI, MEAL_SLOT_LABEL
};
</script>

<script type="text/babel" data-type="module">
