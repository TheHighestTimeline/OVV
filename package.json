   ===================================================================== */
const slug = s => String(s||'').toLowerCase().replace(/[^\w]+/g,'-').replace(/^-|-$/g,'');
const fmt$ = n => n==null ? '—' : `$${Number(n).toFixed(2)}`;
const today = () => new Date().toISOString().slice(0,10);
const dateKey = d => d.toISOString().slice(0,10);
const days = n => {
  const out = []; const d = new Date(); d.setHours(0,0,0,0);
  for (let i=0;i<n;i++){ const c = new Date(d); c.setDate(c.getDate()+i); out.push(c); }
  return out;
};
const dayLabel = d => d.toLocaleDateString('en-US',{weekday:'short'});
const dayShort  = d => d.toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'});

function useLocalState(key, initial){
  const [v, setV] = useState(() => store.get(key, initial));
  useEffect(() => { store.set(key, v); }, [v]);
  return [v, setV];
}

