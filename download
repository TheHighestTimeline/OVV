      <tr><td>Mode 1 — Early Entry</td><td>${pLabels[pi]}</td><td>${d.mode1.trades}</td>
          <td class="${d.mode1.winRate>=70?'green':'gold'}">${d.mode1.winRate}%</td>
          <td>$${d.mode1.startBank}</td><td>$${d.mode1.endBank.toFixed(2)}</td>
          <td class="green">${fmt$(d.mode1.pnl)}</td><td class="green">${fmtPct(d.mode1.roi)}</td></tr>
      <tr><td>Mode 2 — Distance Play</td><td>${pLabels[pi]}</td><td>${d.mode2.trades}</td>
          <td class="green">${d.mode2.winRate}%</td>
          <td>$${d.mode2.startBank}</td><td>$${d.mode2.endBank.toFixed(2)}</td>
          <td class="green">${fmt$(d.mode2.pnl)}</td><td class="green">${fmtPct(d.mode2.roi)}</td></tr>
      <tr><td style="color:var(--muted)">Mode 3 (paper)</td><td>${pLabels[pi]}</td><td>${d.mode3.trades}</td>
          <td class="${d.mode3.winRate>=30?'gold':'red'}">${d.mode3.winRate}%</td>
          <td>—</td><td>—</td>
          <td class="${d.mode3.paperPnl>=0?'green':'red'}">${fmt$(d.mode3.paperPnl)} paper</td><td>—</td></tr>
    `;
  }
  document.getElementById('compare-tbody').innerHTML=rows;

  // Equity compare chart
  equityCompChart=destroyChart(equityCompChart);
  const h1=pd.mode1.bankrollHistory, h2=pd.mode2.bankrollHistory;
  const len=Math.max(h1.length,h2.length);
  const labels=Array.from({length:len},(_,i)=>i);
  equityCompChart=new Chart(document.getElementById('equity-compare-chart'),{
    type:'line',
    data:{
      labels,
      datasets:[
        {label:'Mode 1 Bankroll',data:h1.map(p=>p.v||p),borderColor:col('blue',1),backgroundColor:col('blue',0.05),fill:true,tension:0.3,pointRadius:0,borderWidth:2},
        {label:'Mode 2 Bankroll',data:h2.map(p=>p.v||p),borderColor:col('green',1),backgroundColor:col('green',0.05),fill:true,tension:0.3,pointRadius:0,borderWidth:2},
      ]
    },
    options:{responsive:true,interaction:{mode:'index',intersect:false},
      scales:{
        x:{display:false},
        y:{ticks:{callback:v=>'$'+v.toLocaleString()},grid:{color:'rgba(48,54,61,0.5)'}},
      },
      plugins:{legend:{position:'top'},tooltip:{callbacks:{label:ctx=>`${ctx.dataset.label}: $${ctx.parsed.y.toLocaleString()}`}}}
    }
  });

  // Win rate chart
  winrateChart=destroyChart(winrateChart);
  winrateChart=new Chart(document.getElementById('winrate-chart'),{
    type:'bar',
    data:{
      labels:['Mode 1','Mode 2','Mode 3'],
      datasets:[
        {label:'90d',data:[RAW.days90.mode1.winRate,RAW.days90.mode2.winRate,RAW.days90.mode3.winRate],backgroundColor:col('blue',0.7)},
        {label:'30d',data:[RAW.days30.mode1.winRate,RAW.days30.mode2.winRate,RAW.days30.mode3.winRate],backgroundColor:col('green',0.7)},
        {label:'10d',data:[RAW.days10.mode1.winRate,RAW.days10.mode2.winRate,RAW.days10.mode3.winRate],backgroundColor:col('gold',0.7)},
      ]
    },
    options:{responsive:true,scales:{y:{min:0,max:100,ticks:{callback:v=>v+'%'},grid:{color:'rgba(48,54,61,0.5)'}},x:{grid:{display:false}}},plugins:{legend:{position:'top'}}}
  });

  // Trades chart
  tradesChart=destroyChart(tradesChart);
  tradesChart=new Chart(document.getElementById('trades-chart'),{
    type:'bar',
    data:{
      labels:['Mode 1','Mode 2','Mode 3'],
      datasets:[
        {label:'90d',data:[RAW.days90.mode1.trades,RAW.days90.mode2.trades,RAW.days90.mode3.trades],backgroundColor:col('blue',0.7)},
        {label:'30d',data:[RAW.days30.mode1.trades,RAW.days30.mode2.trades,RAW.days30.mode3.trades],backgroundColor:col('green',0.7)},
        {label:'10d',data:[RAW.days10.mode1.trades,RAW.days10.mode2.trades,RAW.days10.mode3.trades],backgroundColor:col('gold',0.7)},
      ]
    },
    options:{responsive:true,scales:{y:{grid:{color:'rgba(48,54,61,0.5)'}},x:{grid:{display:false}}},plugins:{legend:{position:'top'}}}
  });
}

// ══════════════════════════════ MODE 1 ═══════════════════════════════════════
function renderMode1(){
  const pd=RAW[m1Period];
  const m=pd.mode1;

  // Cards
  document.getElementById('m1-cards').innerHTML=`
    <div class="card"><div class="card-label">Win Rate</div><div class="card-value green">${m.winRate}%</div><div class="card-sub">${m.wins}W / ${m.losses}L</div></div>
    <div class="card"><div class="card-label">Total Trades</div><div class="card-value blue">${m.trades}</div><div class="card-sub">${m.skipped} skipped</div></div>
    <div class="card"><div class="card-label">Start → End</div><div class="card-value">$${m.endBank.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2})}</div><div class="card-sub">from $${m.startBank}</div></div>
    <div class="card"><div class="card-label">Net P&L</div><div class="card-value ${m.pnl>=0?'green':'red'}">${fmt$(m.pnl)}</div><div class="card-sub">ROI ${fmtPct(m.roi)}</div></div>
  `;

  // Equity chart
  m1equityChart=destroyChart(m1equityChart);
  const hist=m.bankrollHistory;
  m1equityChart=new Chart(document.getElementById('m1-equity-chart'),{
    type:'line',
    data:{
      labels:hist.map((_,i)=>i),
      datasets:[{
        label:'Bankroll',data:hist.map(p=>p.v||p),
        borderColor:col('blue',1),backgroundColor:col('blue',0.08),
        fill:true,tension:0.3,pointRadius:0,borderWidth:2
      }]
    },
    options:{responsive:true,interaction:{mode:'index',intersect:false},
      scales:{x:{display:false},y:{ticks:{callback:v=>'$'+v.toLocaleString()},grid:{color:'rgba(48,54,61,0.5)'}}},
      plugins:{tooltip:{callbacks:{label:ctx=>'Bankroll: $'+ctx.parsed.y.toLocaleString()}}}
    }
  });

  // P&L distribution per trade
  m1pnlChart=destroyChart(m1pnlChart);
  const trades=m.allTrades||[];
  m1pnlChart=new Chart(document.getElementById('m1-pnl-chart'),{
    type:'bar',
    data:{
      labels:trades.map((_,i)=>i+1),
      datasets:[{
        label:'P&L per trade',
        data:trades.map(t=>t.pnl),
        backgroundColor:trades.map(t=>t.won?col('green',0.7):col('red',0.7)),
        borderWidth:0,
      }]
    },
    options:{responsive:true,scales:{
      x:{display:false},
      y:{ticks:{callback:v=>(v>=0?'+':'')+v.toFixed(2)},grid:{color:'rgba(48,54,61,0.5)'}}
    },plugins:{legend:{display:false}}}
  });

  // Confidence buckets
  m1confChart=destroyChart(m1confChart);
  const buckets={'70-74':{w:0,l:0},'75-79':{w:0,l:0},'80-84':{w:0,l:0},'85-89':{w:0,l:0},'90+':{w:0,l:0}};
  trades.forEach(t=>{
    const c=t.conf;
    const k=c>=90?'90+':c>=85?'85-89':c>=80?'80-84':c>=75?'75-79':'70-74';
    if(t.won)buckets[k].w++;else buckets[k].l++;
  });
  const bKeys=Object.keys(buckets);
  m1confChart=new Chart(document.getElementById('m1-conf-chart'),{
    type:'bar',
    data:{
      labels:bKeys,
      datasets:[
        {label:'Wins',data:bKeys.map(k=>buckets[k].w),backgroundColor:col('green',0.7),stack:'s'},
        {label:'Losses',data:bKeys.map(k=>buckets[k].l),backgroundColor:col('red',0.7),stack:'s'},
      ]
    },
    options:{responsive:true,scales:{x:{stacked:true,grid:{display:false}},y:{stacked:true,grid:{color:'rgba(48,54,61,0.5)'}}},plugins:{legend:{position:'top'}}}
  });

  // Trade table
  const recent=trades.slice(-50).reverse();
  document.getElementById('m1-trade-table').innerHTML=recent.map((t,i)=>`
    <tr class="${t.won?'win-row':'loss-row'}">
      <td>${trades.length-i}</td>
      <td>${t.date}</td>
      <td><span class="pill pill-${t.side.toLowerCase()}">${t.side}</span></td>
      <td>${t.conf}%</td>
      <td>$${t.strike.toLocaleString()}</td>
      <td>$${t.btcEntry.toLocaleString()}</td>
      <td>$${t.settle.toLocaleString()}</td>
      <td>$${t.cost.toFixed(2)}</td>
      <td class="${t.pnl>=0?'green':'red'}">${fmt$(t.pnl)}</td>
      <td>$${t.bank.toFixed(2)}</td>
      <td><span class="pill ${t.won?'pill-win':'pill-loss'}">${t.won?'WIN':'LOSS'}</span></td>
    </tr>
  `).join('');
}

// ══════════════════════════════ MODE 2 ═══════════════════════════════════════
function renderMode2(){
  const pd=RAW[m2Period];
  const m=pd.mode2;

  document.getElementById('m2-cards').innerHTML=`
    <div class="card"><div class="card-label">Win Rate</div><div class="card-value green">${m.winRate}%</div><div class="card-sub">${m.wins}W / ${m.losses}L</div></div>
    <div class="card"><div class="card-label">Total Trades</div><div class="card-value blue">${m.trades}</div><div class="card-sub">${m.skipped} skipped</div></div>
    <div class="card"><div class="card-label">End Bankroll</div><div class="card-value green">$${m.endBank.toLocaleString(undefined,{minimumFractionDigits:2})}</div><div class="card-sub">from $${m.startBank}</div></div>
    <div class="card"><div class="card-label">Net P&L</div><div class="card-value green">${fmt$(m.pnl)}</div><div class="card-sub">ROI ${fmtPct(m.roi)}</div></div>
    <div class="card"><div class="card-label">Avg Win</div><div class="card-value blue">${(()=>{const ws=(m.allTrades||[]).filter(t=>t.won);return ws.length?'$'+(ws.reduce((s,t)=>s+t.pnl,0)/ws.length).toFixed(2):'—';})()}</div><div class="card-sub">per winning trade</div></div>
    <div class="card"><div class="card-label">Avg Loss</div><div class="card-value red">${(()=>{const ls=(m.allTrades||[]).filter(t=>!t.won);return ls.length?'$'+(ls.reduce((s,t)=>s+Math.abs(t.pnl),0)/ls.length).toFixed(2):'—';})()}</div><div class="card-sub">per losing trade</div></div>
  `;

  m2equityChart=destroyChart(m2equityChart);
  const hist=m.bankrollHistory;
  m2equityChart=new Chart(document.getElementById('m2-equity-chart'),{
    type:'line',
    data:{labels:hist.map((_,i)=>i),datasets:[{
      label:'Bankroll',data:hist.map(p=>p.v||p),
      borderColor:col('green',1),backgroundColor:col('green',0.08),
      fill:true,tension:0.3,pointRadius:0,borderWidth:2
    }]},
    options:{responsive:true,interaction:{mode:'index',intersect:false},
      scales:{x:{display:false},y:{ticks:{callback:v=>'$'+v.toFixed(2)},grid:{color:'rgba(48,54,61,0.5)'}}},
      plugins:{tooltip:{callbacks:{label:ctx=>'Bankroll: $'+ctx.parsed.y.toFixed(2)}}}
    }
  });

  // Distance bucket chart
  m2distChart=destroyChart(m2distChart);
  const trades=m.allTrades||[];
  const db={'200-299':{w:0,l:0},'300-399':{w:0,l:0},'400-599':{w:0,l:0},'600+':{w:0,l:0}};
  trades.forEach(t=>{
    const d=t.dist;
    const k=d>=600?'600+':d>=400?'400-599':d>=300?'300-399':'200-299';
    if(t.won)db[k].w++;else db[k].l++;
  });
  const dKeys=Object.keys(db);
  m2distChart=new Chart(document.getElementById('m2-dist-chart'),{
    type:'bar',
    data:{labels:dKeys.map(k=>k+'  (odds: '+(k==='600+'?'85¢':k==='400-599'?'78¢':'70¢')+')'),
      datasets:[
        {label:'Wins',data:dKeys.map(k=>db[k].w),backgroundColor:col('green',0.7),stack:'s'},
        {label:'Losses',data:dKeys.map(k=>db[k].l),backgroundColor:col('red',0.7),stack:'s'},
      ]
    },
    options:{responsive:true,scales:{x:{stacked:true,grid:{display:false}},y:{stacked:true,grid:{color:'rgba(48,54,61,0.5)'}}},plugins:{legend:{position:'top'}}}
  });

  // P&L per trade
  m2pnlChart2=destroyChart(m2pnlChart2);
  m2pnlChart2=new Chart(document.getElementById('m2-pnl-chart'),{
    type:'bar',
    data:{
      labels:trades.map((_,i)=>i+1),
      datasets:[{label:'P&L',data:trades.map(t=>t.pnl),backgroundColor:trades.map(t=>t.won?col('green',0.7):col('red',0.7)),borderWidth:0}]
    },
    options:{responsive:true,scales:{x:{display:false},y:{ticks:{callback:v=>(v>=0?'+':'')+v.toFixed(2)},grid:{color:'rgba(48,54,61,0.5)'}}},plugins:{legend:{display:false}}}
  });

  // Loss detail
  const losses=trades.filter(t=>!t.won);
  document.getElementById('m2-losses').innerHTML=`<h3>❌ Loss Analysis (${losses.length} losses out of ${m.trades} trades)</h3>`
    +(losses.length?losses.map(t=>`
      <div class="loss-item">
        <strong>LOSS</strong> &nbsp;${t.date} &nbsp;·&nbsp; Side: ${t.side} &nbsp;·&nbsp; Strike: $${t.strike.toLocaleString()} &nbsp;·&nbsp; BTC Entry: $${t.btcEntry.toLocaleString()} (${t.side==='YES'?'+':'-'}${t.dist})
        &nbsp;·&nbsp; Settlement: $${t.settle.toLocaleString()} &nbsp;·&nbsp; <strong style="color:var(--red)">Lost ${fmt$(t.pnl)}</strong>
        <br><span style="color:var(--muted)">What happened: BTC was $${t.dist} ${t.side==='YES'?'above':'below'} strike but reversed through it. Settlement $${t.settle.toLocaleString()} was ${t.side==='YES'?'below':'above'} strike $${t.strike.toLocaleString()}.</span>
      </div>
    `).join(''):'<div class="loss-item">No losses recorded in this period.</div>');

  // Trade table
  document.getElementById('m2-trade-table').innerHTML=trades.map((t,i)=>`
    <tr class="${t.won?'win-row':'loss-row'}">
      <td>${i+1}</td><td>${t.date}</td>
      <td><span class="pill pill-${t.side.toLowerCase()}">${t.side}</span></td>
      <td>$${t.strike.toLocaleString()}</td>
      <td>$${t.btcEntry.toLocaleString()}</td>
      <td>${t.side==='YES'?'+':'-'}${t.dist}</td>
      <td>${(t.odds*100).toFixed(0)}¢</td>
      <td>$${t.cost.toFixed(2)}</td>
      <td>$${t.settle.toLocaleString()}</td>
      <td class="${t.pnl>=0?'green':'red'}">${fmt$(t.pnl)}</td>
      <td>$${t.bank.toFixed(2)}</td>
      <td><span class="pill ${t.won?'pill-win':'pill-loss'}">${t.won?'WIN':'LOSS'}</span></td>
    </tr>
  `).join('');
}

// ══════════════════════════════ MODE 3 ═══════════════════════════════════════
function renderMode3(){
  const pd=RAW[m3Period];
  const m=pd.mode3;
  document.getElementById('m3-cards').innerHTML=`
    <div class="card"><div class="card-label">Win Rate</div><div class="card-value gold">${m.winRate}%</div><div class="card-sub">${m.wins}W / ${m.losses}L</div></div>
    <div class="card"><div class="card-label">Total Trades</div><div class="card-value blue">${m.trades}</div><div class="card-sub">$1 flat bets</div></div>
    <div class="card"><div class="card-label">Paper P&L</div><div class="card-value ${m.paperPnl>=0?'green':'red'}">${fmt$(m.paperPnl)}</div><div class="card-sub">10¢ contracts</div></div>
    <div class="card"><div class="card-label">Avg Win</div><div class="card-value green">+$9.00</div><div class="card-sub">9x return at 10¢</div></div>
  `;

  m3pnlChart=destroyChart(m3pnlChart);
  const trades=m.allTrades||[];
  let cumPnl=0;
  const cumData=trades.map(t=>{cumPnl+=t.pnl;return+cumPnl.toFixed(2);});
  m3pnlChart=new Chart(document.getElementById('m3-pnl-chart'),{
    type:'line',
    data:{labels:trades.map((_,i)=>i+1),datasets:[{
      label:'Cum P&L',data:cumData,
      borderColor:col('gold',1),backgroundColor:col('gold',0.08),
      fill:true,tension:0.3,pointRadius:0,borderWidth:2
    }]},
    options:{responsive:true,scales:{
      x:{display:false},
      y:{ticks:{callback:v=>'$'+v.toFixed(0)},grid:{color:'rgba(48,54,61,0.5)'},
        title:{display:true,text:'Cumulative P&L',color:'#8b949e'}}
    },plugins:{tooltip:{callbacks:{label:ctx=>'Cum P&L: $'+ctx.parsed.y.toFixed(2)}}}}
  });

  document.getElementById('m3-trade-table').innerHTML=trades.map((t,i)=>`
    <tr class="${t.won?'win-row':'loss-row'}">
      <td>${i+1}</td><td>${t.date}</td>
      <td><span class="pill pill-${t.side.toLowerCase()}">${t.side}</span></td>
      <td>$${t.strike.toLocaleString()}</td>
      <td>$${t.settle.toLocaleString()}</td>
      <td class="${t.pnl>=0?'green':'red'}">${fmt$(t.pnl)}</td>
      <td><span class="pill ${t.won?'pill-win':'pill-loss'}">${t.won?'WIN':'LOSS'}</span></td>
    </tr>
  `).join('');
}

// ── Init ─────────────────────────────────────────────────────────────────────
document.getElementById('genAt').textContent = 'Generated: ' + new Date(RAW.generatedAt).toLocaleString();
renderOverview();
</script>
