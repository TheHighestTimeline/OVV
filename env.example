// Kitchen Agent — Pantry Vision Scanner (Netlify Function)
// Haiku primary → Sonnet fallback if confidence < 0.85
// Supports single and batch (up to 10) images
//
// POST {
//   images: [{ base64: "...", mimeType: "image/jpeg", index: 0 }],
//   threshold?: 0.85
// }
// Returns { results: [PantryItem, ...] }

const CORS_HEADERS = {
  'Access-Control-Allow-Origin': '*',
  'Access-Control-Allow-Headers': 'Content-Type',
  'Access-Control-Allow-Methods': 'POST, OPTIONS',
};

const HAIKU_MODEL = 'claude-3-5-haiku-20241022';
const SONNET_MODEL = 'claude-3-5-sonnet-20241022';
const DEFAULT_THRESHOLD = 0.85;
const MAX_BATCH = 10;
const ANTHROPIC_API = 'https://api.anthropic.com/v1/messages';

const VISION_PROMPT = `Analyze this grocery/pantry item image and return ONLY a JSON object. No markdown, no explanation.

Required JSON schema:
{
  "item_name": "<brand and product name, e.g. Hunts Diced Tomatoes>",
  "total_volume": "<size on label, e.g. 14.5 oz>",
  "estimated_qty_percent": <integer 0-100, 100 = sealed/full, 0 = empty>,
  "exp_date": "<YYYY-MM-DD from label, or estimated from category shelf life if not visible>",
  "confidence": <float 0.0-1.0>
}

Rules:
- confidence: 1.0 = clear label with all info. 0.5 = blurry. Below 0.7 = very uncertain.
- estimated_qty_percent: estimate based on visible fill level, transparency, or assumption for sealed items.
- exp_date: if not visible, estimate from typical shelf life (canned goods ~2 years, dry pasta ~2 years, sauces ~18 months).
- Return ONLY the JSON. No other text.`;

// ── Single image API call ────────────────────────────────────────────────────

async function callVision(base64, mimeType, model, apiKey) {
  const headers = {
    'x-api-key': apiKey,
    'anthropic-version': '2023-06-01',
    'content-type': 'application/json',
  };

  const payload = {
    model,
    max_tokens: 512,
    messages: [
      {
        role: 'user',
        content: [
          {
            type: 'image',
            source: { type: 'base64', media_type: mimeType || 'image/jpeg', data: base64 },
          },
          { type: 'text', text: VISION_PROMPT },
        ],
      },
    ],
  };

  // Retry once on 429
  for (let attempt = 0; attempt < 2; attempt++) {
    const res = await fetch(ANTHROPIC_API, {
      method: 'POST',
      headers,
      body: JSON.stringify(payload),
    });

    if (res.status === 429 && attempt === 0) {
      await new Promise((r) => setTimeout(r, 2000));
      continue;
    }

    if (!res.ok) {
      throw new Error(`Anthropic API ${res.status}: ${await res.text()}`);
    }

    const data = await res.json();
    let text = data.content?.[0]?.text?.trim() || '{}';

    // Strip accidental markdown fences
    if (text.startsWith('```')) {
      text = text.replace(/^```json?\n?/, '').replace(/\n?```$/, '').trim();
    }

    return JSON.parse(text);
  }

  throw new Error('Max retries exceeded');
}

// ── Per-image pipeline: Haiku → optional Sonnet fallback ────────────────────

async function processOne(image, threshold, apiKey) {
  const { base64, mimeType, index } = image;
  let fallbackUsed = false;
  let lowConfidence = false;

  try {
    const haikuResult = await callVision(base64, mimeType, HAIKU_MODEL, apiKey);
    const confidence = parseFloat(haikuResult.confidence || 0);

    if (confidence < threshold) {
      // Try Sonnet
      try {
        const sonnetResult = await callVision(base64, mimeType, SONNET_MODEL, apiKey);
        const sonnetConf = parseFloat(sonnetResult.confidence || 0);
        if (sonnetConf >= threshold) {
          return {
            ...sonnetResult,
            index,
            fallback_used: true,
            low_confidence: false,
            model_used: SONNET_MODEL,
          };
        } else {
          lowConfidence = true;
        }
      } catch {
        lowConfidence = true;
      }
    }

    return {
      ...haikuResult,
      index,
      fallback_used: false,
      low_confidence: lowConfidence,
      model_used: HAIKU_MODEL,
    };
  } catch (e) {
    return {
      index,
      item_name: 'Unknown',
      total_volume: 'Unknown',
      estimated_qty_percent: 0,
      exp_date: 'Unknown',
      confidence: 0,
      fallback_used: false,
      low_confidence: true,
      model_used: HAIKU_MODEL,
      error: e.message,
    };
  }
}

// ── Handler ──────────────────────────────────────────────────────────────────

exports.handler = async (event) => {
  if (event.httpMethod === 'OPTIONS') {
    return { statusCode: 200, headers: CORS_HEADERS, body: '' };
  }

  const headers = { ...CORS_HEADERS, 'Content-Type': 'application/json' };

  if (event.httpMethod !== 'POST') {
    return { statusCode: 405, headers, body: JSON.stringify({ error: 'Method Not Allowed' }) };
  }

  let body;
  try {
    body = JSON.parse(event.body || '{}');
  } catch {
    return { statusCode: 400, headers, body: JSON.stringify({ error: 'Invalid JSON' }) };
  }

  const apiKey = process.env.ANTHROPIC_API_KEY;
  if (!apiKey) {
    return { statusCode: 500, headers, body: JSON.stringify({ error: 'ANTHROPIC_API_KEY not set' }) };
  }

  const { images, threshold = DEFAULT_THRESHOLD } = body;

  if (!images || !Array.isArray(images) || images.length === 0) {
    return { statusCode: 400, headers, body: JSON.stringify({ error: 'images array required' }) };
  }

  const batch = images.slice(0, MAX_BATCH).map((img, i) => ({ ...img, index: img.index ?? i }));

  try {
    // Process all images in parallel
    const results = await Promise.all(
      batch.map((img) => processOne(img, threshold, apiKey))
    );

    // Sort by original index
    results.sort((a, b) => a.index - b.index);

    return {
      statusCode: 200,
      headers,
      body: JSON.stringify({ results, count: results.length }),
    };
  } catch (e) {
    return {
      statusCode: 500,
      headers,
      body: JSON.stringify({ error: e.message }),
    };
  }
};
